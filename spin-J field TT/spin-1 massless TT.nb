       RowBox[{"LorentzIndex", "[", "nu", "]"}]}], "]"}], "*", 
     RowBox[{"Pair", "[", 
      RowBox[{
       RowBox[{"Momentum", "[", "q", "]"}], ",", 
       RowBox[{"Momentum", "[", "q", "]"}]}], "]"}]}]}]}], " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalPi]tens", " ", "=", " ", 
    RowBox[{
     RowBox[{"2", "*", 
      RowBox[{"\[Pi]tens", "[", 
       RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "*", 
      RowBox[{"\[Pi]tens", "[", 
       RowBox[{"\[Rho]", ",", "\[Sigma]"}], "]"}]}], " ", "-", " ", 
     RowBox[{"3", "*", 
      RowBox[{"\[Pi]tens", "[", 
       RowBox[{"\[Mu]", ",", "\[Rho]"}], "]"}], "*", 
      RowBox[{"\[Pi]tens", "[", 
       RowBox[{"\[Nu]", ",", "\[Sigma]"}], "]"}]}], " ", "-", " ", 
     RowBox[{"3", "*", 
      RowBox[{"\[Pi]tens", "[", 
       RowBox[{"\[Mu]", ",", "\[Sigma]"}], "]"}], "*", 
      RowBox[{"\[Pi]tens", "[", 
       RowBox[{"\[Nu]", ",", "\[Rho]"}], "]"}]}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
