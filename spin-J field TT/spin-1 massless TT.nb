Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Pi]tens", "[", 
    RowBox[{"mu_", ",", "nu_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"Pair", "[", 
      RowBox[{
       RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
       RowBox[{"Momentum", "[", "q", "]"}]}], "]"}], "*", 
     RowBox[{"Pair", "[", 
      RowBox[{
       RowBox[{"LorentzIndex", "[", "nu", "]"}], ",", 
       RowBox[{"Momentum", "[", "q", "]"}]}], "]"}]}], "-", " ", 
    RowBox[{
     RowBox[{"Pair", "[", 
      RowBox[{
