   " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"NoPolesPart", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"serieResult", " ", "-", " ", 
       RowBox[{
        FractionBox["1", 
         RowBox[{"64", " ", 
          SuperscriptBox["\[Pi]", "2"], " ", "\[Epsilon]"}]], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", "x"}], ")"}], " ", "x", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "+", "x"}], ")"}], " ", "x", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"Pair", "[", 
               RowBox[{
                RowBox[{"LorentzIndex", "[", "\[Mu]", "]"}], ",", 
                RowBox[{"Momentum", "[", "q", "]"}]}], "]"}], " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"8", " ", 
                 RowBox[{"Pair", "[", 
                  RowBox[{
                   RowBox[{"LorentzIndex", "[", "\[Nu]", "]"}], ",", 
                   RowBox[{"Momentum", "[", "q", "]"}]}], "]"}], " ", 
                 RowBox[{"Pair", "[", 
                  RowBox[{
                   RowBox[{"LorentzIndex", "[", "\[Rho]", "]"}], ",", 
                   RowBox[{"Momentum", "[", "q", "]"}]}], "]"}], " ", 
                 RowBox[{"Pair", "[", 
                  RowBox[{
                   RowBox[{"LorentzIndex", "[", "\[Sigma]", "]"}], ",", 
                   RowBox[{"Momentum", "[", "q", "]"}]}], "]"}]}], "-", 
                RowBox[{"2", " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"Pair", "[", 
                    RowBox[{
                    RowBox[{"LorentzIndex", "[", "\[Nu]", "]"}], ",", 
                    RowBox[{"LorentzIndex", "[", "\[Sigma]", "]"}]}], "]"}], " ", 
                    RowBox[{"Pair", "[", 
                    RowBox[{
                    RowBox[{"LorentzIndex", "[", "\[Rho]", "]"}], ",", 
                    RowBox[{"Momentum", "[", "q", "]"}]}], "]"}]}], "+", 
                   RowBox[{
                    RowBox[{"Pair", "[", 
                    RowBox[{
                    RowBox[{"LorentzIndex", "[", "\[Nu]", "]"}], ",", 
                    RowBox[{"LorentzIndex", "[", "\[Rho]", "]"}]}], "]"}], " ", 
                    RowBox[{"Pair", "[", 
                    RowBox[{
                    RowBox[{"LorentzIndex", "[", "\[Sigma]", "]"}], ",", 
                    RowBox[{"Momentum", "[", "q", "]"}]}], "]"}]}]}], ")"}], " ", 
