Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"subLog", " ", "=", " ", 
   RowBox[{
    RowBox[{"FinalResult", "/.", " ", 
     RowBox[{
      RowBox[{"Log", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", "x"}], ")"}], " ", "x", " ", 
        RowBox[{"SP", "[", 
         RowBox[{"q", ",", "q"}], "]"}]}], "]"}], "->", 
      RowBox[{"Log", "[", "z", "]"}]}]}], " ", "//", " ", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"divLog", " ", "=", " ", 
   RowBox[{
    RowBox[{"subLog", "/", 
     RowBox[{"Log", "[", "z", "]"}]}], " ", "//", " ", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"limLog", " ", "=", " ", 
   RowBox[{"Limit", "[", 
    RowBox[{
     RowBox[{"Limit", "[", 
      RowBox[{"divLog", ",", 
       RowBox[{"{", 
        RowBox[{"z", "->", "\[Infinity]"}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Epsilon]", "->", "0"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"resfin", " ", "=", " ", 
    RowBox[{"\[Pi]", "*", "limLog"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalPi]tensor", " ", "=", " ", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{"resfin", ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "1"}], "}"}]}], "]"}], "//", 
    "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalPi]Tensor2", " ", "=", " ", 
    RowBox[{"Collect2", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[CapitalPi]tensor", "/.", " ", 
         RowBox[{
          RowBox[{"SP", "[", 
           RowBox[{"q", ",", "q"}], "]"}], "->", 
          RowBox[{"Pair", "[", 
           RowBox[{
            RowBox[{"Momentum", "[", "q", "]"}], ",", 
            RowBox[{"Momentum", "[", "q", "]"}]}], "]"}]}]}], ")"}], "//", 
       "Simplify"}], ",", "MT", ",", "FV"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<\\n (should be zero): \>\"", ",", 
   RowBox[{
    RowBox[{"\[CapitalPi]Tensor", " ", "-", " ", 
     RowBox[{"2", "*", "\[CapitalPi]Tensor2"}]}], " ", "//", "Simplify"}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.980090843290531*^9, 3.9800909705313225`*^9}, {
