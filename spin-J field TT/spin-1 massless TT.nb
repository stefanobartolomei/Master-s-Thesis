Cell[CellGroupData[{

Cell[TextData[{
 "Check for gauge field that equals to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             SuperscriptBox[
              StyleBox["T", "TI"], "\[Mu]\[Nu]"], 
             RowBox[{"(", 
               StyleBox["q", "TI"], ")"}], 
             SuperscriptBox[
              StyleBox["T", "TI"], "\[Rho]\[Sigma]"], 
             RowBox[{"(", 
               StyleBox["q", "TI"], ")"}]}], "\[RightAngleBracket]"}], 
         "\[LongEqual]", 
         FractionBox[
          SubscriptBox[
           StyleBox["c", "TI"], 
           StyleBox["J", "TI"]], 
          RowBox[{"7680", 
            SuperscriptBox["\[Pi]", "2"]}]], 
         SuperscriptBox["\[CapitalPi]", "\[Mu]\[Nu]\[Rho]\[Sigma]"], 
         RowBox[{"(", 
           StyleBox["q", "TI"], ")"}], "Im", 
         RowBox[{"[", 
           RowBox[{"log", "(", 
             RowBox[{"-", 
               SuperscriptBox[
                StyleBox["q", "TI"], "2"]}], ")"}], "]"}]}], TraditionalForm],
      "errors" -> {}, "input" -> 
     "\\langle T^{\\mu \\nu}(q) T^{\\rho \\sigma}(q)\\rangle \
=\\frac{c_J}{7680 \\pi^2} \\Pi^{\\mu \\nu \\rho \\sigma}(q) \
\\text{Im}[\\log(-q^2)]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e93c51d2-6b9c-7442-afe9-841b7210c4cc"]
}], "Chapter",
 CellChangeTimes->{{3.978359739332329*^9, 3.978359778951891*^9}, {
