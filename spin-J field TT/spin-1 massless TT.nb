Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"consider", " ", "the", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["O", "TI"], "(", 
