Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubscriptBox[
         StyleBox["I", "TI"], "4"], "\[LongEqual]", 
        SubsuperscriptBox["\[Integral]", "0", "1"], 
        StyleBox["d", "TI"], 
        StyleBox["x", "TI"], 
        FractionBox[
         RowBox[{
           SuperscriptBox[
            RowBox[{"(", "-1", ")"}], 
            StyleBox["n", "TI"]], 
           StyleBox["i", "TI"]}], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"4", "\[Pi]"}], ")"}], 
          RowBox[{
            StyleBox["d", "TI"], "/", "2"}]]], 
        FractionBox[
         RowBox[{"\[CapitalGamma]", "(", 
           RowBox[{
             StyleBox["n", "TI"], "-", 
             FractionBox[
              StyleBox["d", "TI"], "2"], "-", "2"}], ")"}], 
         RowBox[{"\[CapitalGamma]", "(", 
           StyleBox["n", "TI"], ")"}]], 
        SuperscriptBox["\[CapitalDelta]", 
         RowBox[{
           FractionBox[
            StyleBox["d", "TI"], "2"], "+", "2", "-", 
           StyleBox["n", "TI"]}]], 
        FractionBox["1", "4"], 
        SuperscriptBox[
         StyleBox["S", "TI"], "\[Mu]\[Nu]\[Rho]\[Sigma]"]}], TraditionalForm],
     "errors" -> {}, "input" -> 
    "I_4 = \\int^1_0 dx \\frac{(-1)^n i}{(4\\pi)^{d/2}} \\frac{\\Gamma(n - \
\\frac{d}{2} -2)}{\\Gamma(n)} \\Delta^{\\frac{d}{2} + 2 - n} \
\\frac{1}{4}S^{\\mu \\nu \\rho \\sigma}", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"e96db49c-276b-7b42-b397-5c9afd4594dd"]], \
"Subtitle",
