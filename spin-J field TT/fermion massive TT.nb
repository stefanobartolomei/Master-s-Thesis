Cell[BoxData[
 RowBox[{
  RowBox[{"I4", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"-", "1"}], ")"}], "^", "n"}], " ", 
    RowBox[{"Simplify", "[", 
     RowBox[{"Normal", "[", 
      RowBox[{"Series", "[", 
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{"Gamma", "[", 
           RowBox[{"n", "-", 
            FractionBox["d", "2"], "-", " ", "2"}], "]"}], 
          RowBox[{"Gamma", "[", "n", "]"}]], " ", 
         FractionBox[
          RowBox[{"\[CapitalDelta]", "^", 
           RowBox[{"(", 
            RowBox[{
             FractionBox["d", "2"], "+", "2", "-", "n"}], ")"}]}], 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"4", "\[Pi]"}], ")"}], "^", 
           RowBox[{"(", 
            RowBox[{"d", "/", "2"}], ")"}]}]]}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Epsilon]", ",", "0", ",", "0"}], "}"}]}], "]"}], "]"}], 
     "]"}]}]}], ";"}]], "Input",
