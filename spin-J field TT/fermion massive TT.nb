          RowBox[{
           RowBox[{"Momentum", "[", "q", "]"}], ",", 
           RowBox[{"Momentum", "[", "q", "]"}]}], "]"}]}]}], "]"}], "->", 
      RowBox[{"Log", "[", "z", "]"}]}]}], " ", "//", " ", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"divLog", " ", "=", " ", 
   RowBox[{
