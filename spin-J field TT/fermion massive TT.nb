       RowBox[{
        RowBox[{
         RowBox[{"-", "4"}], " ", 
         SuperscriptBox["M", "2"]}], "+", 
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"Momentum", "[", "q", "]"}], ",", 
          RowBox[{"Momentum", "[", "q", "]"}]}], "]"}], " "}], 
       RowBox[{"Pair", "[", 
