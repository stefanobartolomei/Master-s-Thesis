Cell[CellGroupData[{

Cell["Template: correlation modeled by the size of the bubbles", "Chapter",
 CellChangeTimes->{{3.9821483781011467`*^9, 3.982148403693825*^9}, {
  3.9821524299894505`*^9, 
  3.982152432764742*^9}},ExpressionUUID->"ba41e02f-1e5a-164f-8adc-\
94b4c3c5b67c"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["g", "TI"], 
          StyleBox["n", "TI"]], 
         RowBox[{"(", "\[Tau]", ")"}], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"[", 
            RowBox[{"4", 
              SuperscriptBox["\[Beta]", "2"], "\[Tau]", 
              RowBox[{"(", 
                RowBox[{
                  FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
            "]"}], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]], "\[Theta]", 
         RowBox[{"(", "\[Tau]", ")"}], "\[Theta]", 
         RowBox[{"(", 
           RowBox[{
             FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "g_n(\\tau) = \\Big[4\\beta^2 \\tau \\Big(\\frac{1}{\\beta} - \
\\tau\\Big)\\Big]^{n-1} \\theta(\\tau) \\theta(\\frac{1}{\\beta} - \\tau)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "830ff396-0251-7f43-bd12-e96499f311a1"],
 " ,\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["R", "TI"], 
         RowBox[{"(", "\[Tau]", ")"}], "\[LongEqual]", 
         StyleBox["v", "TI"], "\[Tau]"}], TraditionalForm], "errors" -> {}, 
     "input" -> "R(\\tau) = v\\tau", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "975f14f4-d5ee-6042-93e0-837fff71246e"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["g", "TI"], 
          StyleBox["n", "TI"]], 
         RowBox[{"(", "\[Tau]", ")"}], 
         SuperscriptBox[
          StyleBox["R", "TI"], 
          RowBox[{"3", "/", "2"}]], 
         RowBox[{"(", "\[Tau]", ")"}], 
         SqrtBox[
          FractionBox[
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["R", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "3"], ")"}], "2"]}], 
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["R", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "2"], ")"}], "2"], "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["R", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "3"], ")"}], "6"]}]]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "f(\\tau,q) = g_n(\\tau) R^{3/2}(\\tau)\\sqrt{\\frac{1 + \\qty(\\frac{q \
R(\\tau)}{3})^2}{1 + \\qty(\\frac{q R(\\tau)}{2})^2 + \\qty(\\frac{q \
R(\\tau)}{3})^6}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9f3e3eb3-7bac-0846-be65-fafc18c90f0a"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["q", "TI"], ",", "\[Tau]", ",", 
             SuperscriptBox["\[Tau]", "\[Prime]"]}], ")"}], "\[LongEqual]", 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], 
         SuperscriptBox[
          StyleBox["f", "TI"], "*"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox["\[Tau]", "\[Prime]"], ",", 
             StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "\\Delta(q,\\tau,\\tau') = f(\\tau,q) f^*(\\tau',q)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "db8b82ab-9f7e-7a4a-be4d-faffb1d56b85"]
}], "Subtitle",
 CellChangeTimes->{{3.9821480284432774`*^9, 3.982148109156109*^9}, {
  3.9821481775169754`*^9, 3.9821482229266453`*^9}, {3.9821483442190266`*^9, 
