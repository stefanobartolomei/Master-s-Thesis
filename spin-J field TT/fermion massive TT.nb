86f19cfd1626"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"S", "[", 
    RowBox[{"mu_", ",", "nu_", ",", "rho_", ",", "sigma_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"MT", "[", 
      RowBox[{"mu", ",", "nu"}], "]"}], "*", 
     RowBox[{"MT", "[", 
      RowBox[{"rho", ",", "sigma"}], "]"}]}], " ", "+", " ", 
    RowBox[{
     RowBox[{"MT", "[", 
      RowBox[{"mu", ",", "rho"}], "]"}], "*", 
     RowBox[{"MT", "[", 
      RowBox[{"nu", ",", "sigma"}], "]"}]}], " ", "+", " ", 
    RowBox[{
     RowBox[{"MT", "[", 
      RowBox[{"mu", ",", "sigma"}], "]"}], "*", 
     RowBox[{"MT", "[", 
      RowBox[{"nu", ",", "rho"}], "]"}]}]}]}], ";"}]], "Input",
