          RowBox[{"q", ",", "q"}], "]"}], "]"}], "->", "X"}]}], " ", "//", 
      "Simplify"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"when", " ", 
      TemplateBox[<|"boxes" -> FormBox[
          RowBox[{"log", "(", 
