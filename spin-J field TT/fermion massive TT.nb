Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"gn", "[", 
    RowBox[{"tau_", ",", "n_"}], "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"4", "*", 
           SuperscriptBox["beta", "2"], " ", "tau", " ", "*", 
           RowBox[{"(", 
            RowBox[{
             FractionBox["1", "beta"], "-", "tau"}], ")"}]}], ")"}], 
         RowBox[{"n", "-", "1"}]], ",", 
        RowBox[{"0", "<", "tau", "<", 
         RowBox[{"1", "/", "beta"}]}]}], "}"}], "}"}], ",", "0"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"R", "[", "tau_", "]"}], " ", ":=", " ", 
   RowBox[{"v", "*", "tau"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"tau_", ",", "q_", ",", "n_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"gn", "[", 
     RowBox[{"tau", ",", "n"}], "]"}], "*", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"R", "[", "tau", "]"}], ")"}], 
     FractionBox["3", "2"]], " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", "tau", "]"}]}], "3"], ")"}], "2"]}], 
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", "tau", "]"}]}], "2"], ")"}], "2"], " ", "+", 
       SuperscriptBox[
        RowBox[{"(", 
