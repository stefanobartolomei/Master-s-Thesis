   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Look", " ", "at", " ", "the", " ", "expression", " ", "and", " ", 
      "extract", " ", "by", " ", "hand", " ", "the", " ", "imaginary", " ", 
      "part"}], ",", " ", 
     RowBox[{
