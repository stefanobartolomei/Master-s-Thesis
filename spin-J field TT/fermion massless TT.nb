                RowBox[{"LorentzIndex", "[", "\[Mu]", "]"}], ",", 
                RowBox[{"LorentzIndex", "[", "\[Nu]", "]"}]}], "]"}], " ", 
              RowBox[{"Pair", "[", 
               RowBox[{
                RowBox[{"LorentzIndex", "[", "\[Rho]", "]"}], ",", 
