Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "transverse", " ", "traceless", " ", 
    "projector"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"qdir", " ", "=", " ", 
     RowBox[{"q3D", "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"q3D", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "^", "2"}], " ", ",", " ", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}], "]"}]}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PTT2D", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"KroneckerDelta", "[", 
         RowBox[{"i", ",", "j"}], "]"}], "-", 
        RowBox[{
         RowBox[{"qdir", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", 
         RowBox[{"qdir", "[", 
          RowBox[{"[", "j", "]"}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "3"}], "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PTT4D", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         FractionBox["1", "2"], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"PTT2D", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "k"}], "]"}], "]"}], "*", 
            RowBox[{"PTT2D", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "r"}], "]"}], "]"}]}], "+", 
           RowBox[{
            RowBox[{"PTT2D", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "r"}], "]"}], "]"}], "*", 
            RowBox[{"PTT2D", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "k"}], "]"}], "]"}]}]}], ")"}]}], "-", 
        RowBox[{
         FractionBox["1", "2"], 
         RowBox[{"PTT2D", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "j"}], "]"}], "]"}], "*", 
         RowBox[{"PTT2D", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "r"}], "]"}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "3"}], "}"}], ",", 
