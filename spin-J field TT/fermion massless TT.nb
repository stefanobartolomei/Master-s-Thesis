Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"spatial", " ", "metric", " ", "and", " ", "vector"}], " ", "*)"}],
   "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Eta]3D", "=", 
