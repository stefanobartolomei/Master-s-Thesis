Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"subLog", " ", "=", " ", 
   RowBox[{
    RowBox[{"FinalResult", "/.", " ", 
     RowBox[{
      RowBox[{"Log", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", "x"}], ")"}], " ", "x", " ", 
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"Momentum", "[", "q", "]"}], ",", 
          RowBox[{"Momentum", "[", "q", "]"}]}], "]"}]}], "]"}], "->", 
      RowBox[{"Log", "[", "z", "]"}]}]}], " ", "//", " ", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"divLog", " ", "=", " ", 
   RowBox[{
    RowBox[{"subLog", "/", 
     RowBox[{"Log", "[", "z", "]"}]}], " ", "//", " ", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"limLog", " ", "=", " ", 
   RowBox[{"Limit", "[", 
    RowBox[{
     RowBox[{"Limit", "[", 
      RowBox[{"divLog", ",", 
       RowBox[{"{", 
        RowBox[{"z", "->", "\[Infinity]"}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Epsilon]", "->", "0"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"resfin", " ", "=", " ", 
    RowBox[{"\[Pi]", "*", "limLog"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"IMTensor", " ", "=", " ", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{"resfin", ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "1"}], "}"}]}], "]"}], "//", 
    "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"IMTensornew", " ", "=", " ", 
    RowBox[{"Collect2", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Contract", "[", "IMTensor", "]"}], "//", "Simplify"}], ",", 
      "MT", ",", "FV"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"check", " ", "of", " ", "the", " ", "two", " ", "ways"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<\\n (should be zero): \>\"", ",", 
   RowBox[{"Collect2", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"\[CapitalPi]Tensor", "-", "IMTensornew"}], " ", "//", 
      "Simplify"}], ",", "MT", ",", "FV"}], "]"}]}], "]"}]}], "Input",
