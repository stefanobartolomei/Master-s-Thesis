Cell[CellGroupData[{

Cell[TextData[{
 "Transverse, Traceless Projectors (and symmetric in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["i", "TI"], "\[LeftRightArrow]", 
         StyleBox["j", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "i\\leftrightarrow j", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0bb12431-d1d7-eb42-8e4e-37e38747d2fc"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["k", "TI"], "\[LeftRightArrow]", 
          StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
      "k \\leftrightarrow r", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "e2ab2e67-e77f-434b-b91e-8a2e0d286751"],
 ")\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]", 
         SubscriptBox["\[Delta]", 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "-", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["q", "TI"], "^"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["q", "TI"], "^"], 
          StyleBox["j", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "P_{ij} = \\delta_{ij} - \\hat{q}_i \\hat{q}_j", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c6309071-2371-784c-8533-8c1f909268a2"],
 "     in 2D\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"], 
            StyleBox["k", "TI"], 
            StyleBox["r", "TI"]}]], "\[LongEqual]", 
         FractionBox["1", "2"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["k", "TI"]}]], 
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["r", "TI"]}]], "+", 
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["r", "TI"]}]], 
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["k", "TI"]}]]}], ")"}], "-", 
         FractionBox["1", "2"], 
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], 
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["r", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "P_{ijkr} = \\frac{1}{2}\\qty(P_{ik}P_{jr} + P_{ir}P_{jk}) -\\frac{1}{2} \
P_{ij}P_{kr}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e19673f4-a57b-9e4d-bc86-9853edef7c17"],
 "  in 4D"
