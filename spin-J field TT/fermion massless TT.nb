Cell[BoxData[{
 RowBox[{
  RowBox[{"subLog", " ", "=", " ", 
   RowBox[{
    RowBox[{"FinalResult", "/.", " ", 
     RowBox[{
      RowBox[{"Log", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", "x"}], ")"}], " ", "x", " ", 
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"Momentum", "[", "q", "]"}], ",", 
          RowBox[{"Momentum", "[", "q", "]"}]}], "]"}]}], "]"}], "->", 
      RowBox[{"Log", "[", "z", "]"}]}]}], " ", "//", " ", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"divLog", " ", "=", " ", 
   RowBox[{
    RowBox[{"subLog", "/", 
     RowBox[{"Log", "[", "z", "]"}]}], " ", "//", " ", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"limLog", " ", "=", " ", 
   RowBox[{"Limit", "[", 
    RowBox[{
     RowBox[{"Limit", "[", 
      RowBox[{"divLog", ",", 
       RowBox[{"{", 
        RowBox[{"z", "->", "\[Infinity]"}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Epsilon]", "->", "0"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"resfin", " ", "=", " ", 
   RowBox[{"\[Pi]", "*", "limLog"}]}], ";"}]}], "Input",
