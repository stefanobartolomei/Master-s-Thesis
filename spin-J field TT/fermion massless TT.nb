          SuperscriptBox["\[Pi]", "2"], " ", "\[Epsilon]"}]], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", "x"}], ")"}], " ", "x", " ", 
        RowBox[{"(", 
         RowBox[{
