   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Rule", " ", "to", " ", "pass", " ", "from", " ", "FeynCalc", " ", 
     "expression", " ", "to", " ", "Table"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Rule3DFeynToTable", "=", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"LorentzIndex", "[", "a_", "]"}], ",", 
          RowBox[{"LorentzIndex", "[", "b_", "]"}]}], "]"}], ":>", 
        RowBox[{"\[Eta]3D", "[", 
         RowBox[{"[", 
          RowBox[{"a", ",", "b"}], "]"}], "]"}]}], ",", "\[IndentingNewLine]",
        "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"LorentzIndex", "[", "a_", "]"}], ",", 
          RowBox[{"Momentum", "[", "q", "]"}]}], "]"}], ":>", 
        RowBox[{"q3D", "[", 
         RowBox[{"[", "a", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"ExplicitLorentzIndex", "[", "a_", "]"}], ",", 
          RowBox[{"Momentum", "[", "q", "]"}]}], "]"}], ":>", 
        RowBox[{"q3D", "[", 
         RowBox[{"[", "a", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"Momentum", "[", "q", "]"}], ",", 
          RowBox[{"Momentum", "[", "q", "]"}]}], "]"}], ":>", 
        RowBox[{
         RowBox[{"q0", "^", "2"}], " ", "-", " ", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"q3D", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "^", "2"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}]}]}], 
      "\[IndentingNewLine]", "}"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Rulefinal", " ", "=", 
