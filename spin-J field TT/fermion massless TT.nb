Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Pi]tens", "[", 
     RowBox[{"mu_", ",", "nu_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"Pair", "[", 
       RowBox[{
        RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
        RowBox[{"Momentum", "[", "q", "]"}]}], "]"}], "*", 
      RowBox[{"Pair", "[", 
       RowBox[{
        RowBox[{"LorentzIndex", "[", "nu", "]"}], ",", 
        RowBox[{"Momentum", "[", "q", "]"}]}], "]"}]}], "-", " ", 
     RowBox[{
      RowBox[{"Pair", "[", 
       RowBox[{
        RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
        RowBox[{"LorentzIndex", "[", "nu", "]"}]}], "]"}], "*", 
      RowBox[{"Pair", "[", 
       RowBox[{
        RowBox[{"Momentum", "[", "q", "]"}], ",", 
        RowBox[{"Momentum", "[", "q", "]"}]}], "]"}]}]}]}], " ", ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalPi]tens", " ", "=", " ", 
    RowBox[{
     RowBox[{"2", "*", 
      RowBox[{"\[Pi]tens", "[", 
       RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "*", 
      RowBox[{"\[Pi]tens", "[", 
       RowBox[{"\[Rho]", ",", "\[Sigma]"}], "]"}]}], " ", "-", " ", 
     RowBox[{"3", "*", 
      RowBox[{"\[Pi]tens", "[", 
       RowBox[{"\[Mu]", ",", "\[Rho]"}], "]"}], "*", 
      RowBox[{"\[Pi]tens", "[", 
       RowBox[{"\[Nu]", ",", "\[Sigma]"}], "]"}]}], " ", "-", " ", 
     RowBox[{"3", "*", 
      RowBox[{"\[Pi]tens", "[", 
       RowBox[{"\[Mu]", ",", "\[Sigma]"}], "]"}], "*", 
      RowBox[{"\[Pi]tens", "[", 
       RowBox[{"\[Nu]", ",", "\[Rho]"}], "]"}]}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Result\[CapitalPi]", " ", "=", " ", 
   RowBox[{
    FractionBox["4", 
     RowBox[{"7680", " ", 
      RowBox[{"\[Pi]", "^", "2"}]}]], "\[CapitalPi]tens", "*", "\[Pi]"}]}], 
  ";"}]}], "Input",
