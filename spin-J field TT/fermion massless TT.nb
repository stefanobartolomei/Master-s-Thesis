            ")"}], " ", 
           SuperscriptBox[
            RowBox[{"Pair", "[", 
             RowBox[{
              RowBox[{"Momentum", "[", "q", "]"}], ",", 
              RowBox[{"Momentum", "[", "q", "]"}]}], "]"}], "2"]}], "+", 
          RowBox[{"2", " ", 
           RowBox[{"Pair", "[", 
            RowBox[{
             RowBox[{"Momentum", "[", "q", "]"}], ",", 
             RowBox[{"Momentum", "[", "q", "]"}]}], "]"}], " ", 
