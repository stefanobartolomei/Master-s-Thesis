                RowBox[{"LorentzIndex", "[", "\[Sigma]", "]"}]}], "]"}], " ", 
              RowBox[{"Pair", "[", 
               RowBox[{
                RowBox[{"Momentum", "[", "q", "]"}], ",", 
                RowBox[{"Momentum", "[", "q", "]"}]}], "]"}]}], "+", 
             RowBox[{"4", " ", 
              SuperscriptBox["x", "2"], " ", 
