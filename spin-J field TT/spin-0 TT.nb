 RowBox[{
  RowBox[{
   RowBox[{"TracelessCheck", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Sum", "[", 
