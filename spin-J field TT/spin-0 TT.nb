Cell[CellGroupData[{

Cell[TextData[{
 "Transverse, Traceless Projectors (and symmetric in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["i", "TI"], "\[LeftRightArrow]", 
         StyleBox["j", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "i\\leftrightarrow j", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cbc82e89-cebe-c94b-b149-d5d21bca89fb"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["k", "TI"], "\[LeftRightArrow]", 
          StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
      "k \\leftrightarrow r", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "c10afd3a-fd14-1d4c-a774-b853ef61e27f"],
 ")\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]", 
         SubscriptBox["\[Delta]", 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "-", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["q", "TI"], "^"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["q", "TI"], "^"], 
          StyleBox["j", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "P_{ij} = \\delta_{ij} - \\hat{q}_i \\hat{q}_j", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f11144ea-aba9-4d48-8288-1ca2b0bd088d"],
 "     in 2D\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"], 
            StyleBox["k", "TI"], 
            StyleBox["r", "TI"]}]], "\[LongEqual]", 
         FractionBox["1", "2"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["k", "TI"]}]], 
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["r", "TI"]}]], "+", 
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["r", "TI"]}]], 
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["k", "TI"]}]]}], ")"}], "-", 
         FractionBox["1", "2"], 
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], 
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["r", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "P_{ijkr} = \\frac{1}{2}\\qty(P_{ik}P_{jr} + P_{ir}P_{jk}) -\\frac{1}{2} \
P_{ij}P_{kr}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8de80aeb-ea73-0746-8774-ab72a3296851"],
 "  in 4D"
}], "Subtitle",
 CellChangeTimes->{{3.982234120601471*^9, 3.9822341499257736`*^9}, 
