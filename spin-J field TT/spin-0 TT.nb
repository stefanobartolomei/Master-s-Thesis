            RowBox[{
             RowBox[{"\[Eta]4D", "[", 
              RowBox[{"[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "]"}], "*", 
             RowBox[{"TTtable4DMassive", "[", 
              RowBox[{"[", 
               RowBox[{
               "\[Mu]", ",", "\[Nu]", ",", "\[Rho]", ",", "\[Sigma]"}], "]"}],
               "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "1", ",", "4"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"\[Nu]", ",", "1", ",", "4"}], "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Rho]", ",", "1", ",", "4"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Sigma]", ",", "1", ",", "4"}], "}"}]}], "]"}], "/.", 
        " ", 
        RowBox[{"\[Xi]", "->", 
         RowBox[{"1", "/", "6"}]}]}], " ", ")"}], "/.", 
      RowBox[{"m", "->", "0"}]}], "//", "Simplify"}]}], ";"}], 
