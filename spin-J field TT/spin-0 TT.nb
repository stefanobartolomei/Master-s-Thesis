  "0b0e6bda-31b8-5948-a7a3-6333710d9fb6"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["h", "TI"], "\[Mu]\[Nu]"], "Im", 
         RowBox[{"[", 
           RowBox[{"\[LeftAngleBracket]", 
             RowBox[{
               SuperscriptBox[
                StyleBox["T", "TI"], "\[Mu]\[Nu]"], 
               SuperscriptBox[
                StyleBox["T", "TI"], "\[Rho]\[Sigma]"]}], 
             "\[RightAngleBracket]"}], "]"}], 
         SubscriptBox[
          StyleBox["h", "TI"], "\[Rho]\[Sigma]"], "\[Rule]", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[PartialD]", 
              StyleBox["i", "TI"]], 
             SubsuperscriptBox[
              StyleBox["W", "TI"], 
              StyleBox["j", "TI"], "T"], "-", 
             SubscriptBox["\[PartialD]", 
              StyleBox["j", "TI"]], 
             SubsuperscriptBox[
              StyleBox["W", "TI"], 
              StyleBox["i", "TI"], "T"]}], ")"}], "Im", 
         RowBox[{"[", 
           RowBox[{"\[LeftAngleBracket]", 
             RowBox[{
               SuperscriptBox[
                StyleBox["T", "TI"], 
                RowBox[{
                  StyleBox["i", "TI"], 
                  StyleBox["j", "TI"]}]], 
               SuperscriptBox[
                StyleBox["T", "TI"], 
                RowBox[{
                  StyleBox["k", "TI"], 
                  StyleBox["r", "TI"]}]]}], "\[RightAngleBracket]"}], "]"}], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[PartialD]", 
              StyleBox["k", "TI"]], 
             SubsuperscriptBox[
              StyleBox["W", "TI"], 
              StyleBox["r", "TI"], "T"], "-", 
             SubscriptBox["\[PartialD]", 
              StyleBox["r", "TI"]], 
             SubsuperscriptBox[
              StyleBox["W", "TI"], 
              StyleBox["k", "TI"], "T"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "h_{\\mu \\nu}\\text{Im}\\qty[\\langle T^{\\mu \\nu} T^{\\rho \
