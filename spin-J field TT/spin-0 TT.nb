Cell[TextData[{
 "Check for conformally coupled field that equals to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             SuperscriptBox[
              StyleBox["T", "TI"], "\[Mu]\[Nu]"], 
             RowBox[{"(", 
               StyleBox["q", "TI"], ")"}], 
             SuperscriptBox[
              StyleBox["T", "TI"], "\[Rho]\[Sigma]"], 
             RowBox[{"(", 
               StyleBox["q", "TI"], ")"}]}], "\[RightAngleBracket]"}], 
         "\[LongEqual]", 
         FractionBox[
          SubscriptBox[
           StyleBox["c", "TI"], 
           StyleBox["J", "TI"]], 
          RowBox[{"7680", 
            SuperscriptBox["\[Pi]", "2"]}]], 
         SuperscriptBox["\[CapitalPi]", "\[Mu]\[Nu]\[Rho]\[Sigma]"], 
         RowBox[{"(", 
