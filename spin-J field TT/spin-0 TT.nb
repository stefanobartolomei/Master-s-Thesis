Cell[CellGroupData[{

Cell["Second Template", "Chapter",
 CellChangeTimes->{{3.982844872099203*^9, 
  3.9828448824684124`*^9}},ExpressionUUID->"3f7f9d9a-70f7-8d4e-9677-\
6eb7d84663a3"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["g", "TI"], 
          StyleBox["n", "TI"]], 
         RowBox[{"(", "\[Tau]", ")"}], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"[", 
            RowBox[{"4", 
              SuperscriptBox["\[Beta]", "2"], "\[Tau]", 
              RowBox[{"(", 
                RowBox[{
                  FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
            "]"}], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]], "\[Theta]", 
         RowBox[{"(", "\[Tau]", ")"}], "\[Theta]", 
         RowBox[{"(", 
           RowBox[{
             FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "g_n(\\tau) = \\Big[4\\beta^2 \\tau \\Big(\\frac{1}{\\beta} - \
\\tau\\Big)\\Big]^{n-1} \\theta(\\tau) \\theta(\\frac{1}{\\beta} - \\tau)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0517e01e-54df-8046-9ed0-9cf3b40412c4"],
 " , interested in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], "\[LongEqual]", "2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "n=2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "469e5840-4840-1b47-aee2-8b2d961b1ae7"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["L", "TI"], 
         RowBox[{"(", "\[Tau]", ")"}], "\[LongEqual]", 
         FractionBox[
          StyleBox["v", "TI"], "\[Beta]"], 
         SubscriptBox[
          StyleBox["g", "TI"], "2"], 
         RowBox[{"(", "\[Tau]", ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "L(\\tau) = \\frac{v}{\\beta}g_2(\\tau)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "33cb01a9-fe9c-9d47-993b-becdc8cc5311"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], "\[LongEqual]", 
         StyleBox["L", "TI"], 
         RowBox[{"(", "\[Tau]", ")"}], 
         SqrtBox[
          FractionBox[
           RowBox[{
             StyleBox["v", "TI"], "\[Epsilon]"}], "\[Beta]"]], 
         SqrtBox[
          FractionBox[
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["L", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "3"], ")"}], "2"]}], 
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["L", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "2"], ")"}], "2"], "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["L", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "3"], ")"}], "6"]}]]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "f(\\tau,q) = L(\\tau) \\sqrt{\\frac{v\\epsilon}{\\beta}}\\sqrt{\\frac{1 \
+ \\qty(\\frac{q L(\\tau)}{3})^2}{1 + \\qty(\\frac{q L(\\tau)}{2})^2 + \\qty(\
\\frac{q L(\\tau)}{3})^6}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5c68fad8-9e0e-7446-af1d-105fee5604ab"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["q", "TI"], ",", "\[Tau]", ",", 
             SuperscriptBox["\[Tau]", "\[Prime]"]}], ")"}], "\[LongEqual]", 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], 
         SuperscriptBox[
          StyleBox["f", "TI"], "*"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox["\[Tau]", "\[Prime]"], ",", 
             StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "\\Delta(q,\\tau,\\tau') = f(\\tau,q) f^*(\\tau',q)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ac791512-1917-f546-b46f-c908db2d6419"]
}], "Subtitle",
 CellChangeTimes->{{3.9821480284432774`*^9, 3.982148109156109*^9}, {
  3.9821481775169754`*^9, 3.9821482229266453`*^9}, {3.9821483442190266`*^9, 
  3.9821483764376736`*^9}, {3.9821508718699665`*^9, 3.9821508808600235`*^9}, {
  3.982844754222252*^9, 
  3.9828447617587986`*^9}},ExpressionUUID->"aa484607-482c-cc4f-acfb-\
1ed537d94351"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"L", "[", "tau_", "]"}], " ", ":=", 
   RowBox[{
    FractionBox["v", "beta"], " ", 
    RowBox[{"g2", "[", "tau", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Epsilon]factor", " ", "=", " ", "0.4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"tau_", ",", "q_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"L", "[", "tau", "]"}], "*", 
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox[
       RowBox[{"v", "*", "\[Epsilon]factor"}], "beta"], ")"}], 
     FractionBox["1", "2"]], " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"L", "[", "tau", "]"}]}], "3"], ")"}], "2"]}], 
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"L", "[", "tau", "]"}]}], "2"], ")"}], "2"], " ", "+", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"L", "[", "tau", "]"}]}], "3"], ")"}], "6"]}]]]}]}], " ", 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9822370952469406`*^9, 3.9822371303995323`*^9}, {
  3.9822376188099556`*^9, 3.982237619200279*^9}, {3.9828447982163353`*^9, 
