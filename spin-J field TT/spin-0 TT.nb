             SuperscriptBox["x", "2"]}], "+", 
           RowBox[{
             RowBox[{"(", 
               RowBox[{
                 SuperscriptBox["y", "2"], "-", "1"}], ")"}], " ", 
             RowBox[{"(", 
               RowBox[{
                 SqrtBox["15"], "-", 
                 RowBox[{"15", " ", 
                   SqrtBox[
                    RowBox[{"1", "-", 
                    SuperscriptBox["y", "2"]}]]}]}], ")"}]}]}], 
         RowBox[{"90", " ", 
           SuperscriptBox[
            RowBox[{"(", 
              RowBox[{"1", "-", 
                SuperscriptBox["y", "2"]}], ")"}], 
            RowBox[{"3", "/", "2"}]]}]], 
        RowBox[{
          RowBox[{"0", "<", "x", "<", 
            FractionBox["1", "2"]}], "\[And]", 
          RowBox[{"0", "<", "y", "<", 
            SqrtBox[
             RowBox[{"1", "-", 
               RowBox[{"4", " ", 
                 SuperscriptBox["x", "2"]}]}]]}]}]},
       "ConditionalExpression"]}], "}"}], ",", 
    RowBox[{"{", 
