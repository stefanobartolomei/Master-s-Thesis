Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"spatial", " ", "metric", " ", "and", " ", "vector"}], " ", "*)"}],
   "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Eta]3D", "=", 
     RowBox[{"-", 
      RowBox[{"IdentityMatrix", "[", "3", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"q3D", "=", 
     RowBox[{"{", 
      RowBox[{"qx", ",", "qy", ",", "qz"}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Rule", " ", "to", " ", "pass", " ", "from", " ", "FeynCalc", " ", 
     "expression", " ", "to", " ", "Table"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Rule3DFeynToTable", "=", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"MT", "[", 
         RowBox[{"a_", ",", "b_"}], "]"}], ":>", 
        RowBox[{"\[Eta]3D", "[", 
         RowBox[{"[", 
          RowBox[{"a", ",", "b"}], "]"}], "]"}]}], ",", "\[IndentingNewLine]",
        "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"FV", "[", 
         RowBox[{"q", ",", "a_"}], "]"}], ":>", 
        RowBox[{"q3D", "[", 
         RowBox[{"[", "a", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SP", "[", 
         RowBox[{"q", ",", "q"}], "]"}], ":>", 
        RowBox[{
         RowBox[{"q0", "^", "2"}], " ", "-", " ", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"q3D", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "^", "2"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}]}]}], 
      "\[IndentingNewLine]", "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Rulefinal", " ", "=", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
         SuperscriptBox["qx", "2"], "+", 
         SuperscriptBox["qy", "2"], "+", 
         SuperscriptBox["qz", "2"]}], ":>", 
        SuperscriptBox["Q", "2"]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["qx", "2"]}], "-", 
         SuperscriptBox["qy", "2"], "-", 
         SuperscriptBox["qz", "2"]}], ":>", 
        RowBox[{"-", 
         SuperscriptBox["Q", "2"]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["qx", "2"], "+", 
           SuperscriptBox["qy", "2"], "+", 
           SuperscriptBox["qz", "2"]}], ")"}], "2"], ":>", 
        SuperscriptBox["Q", "4"]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox["qx", "2"]}], "-", 
           SuperscriptBox["qy", "2"], "-", 
           SuperscriptBox["qz", "2"]}], ")"}], "2"], ":>", 
        SuperscriptBox["Q", "4"]}]}], "\[IndentingNewLine]", " ", "}"}]}], 
    ";"}]}]}]], "Input",
