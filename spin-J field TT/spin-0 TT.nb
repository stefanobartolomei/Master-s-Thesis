Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Just", " ", "to", " ", "see"}], ",", " ", 
    RowBox[{
    "for", " ", "the", " ", "equivalence", " ", "between", " ", "the", " ", 
     "vector", " ", "and", " ", "scalar", " ", "\[CapitalSigma]"}], ",", " ", 
    RowBox[{
    "it", " ", "does", " ", "not", " ", "exist", " ", "a", " ", "fixed", " ", 
     "\[Xi]", " ", "parameter"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalDelta]fW\[CapitalSigma]", "[", 
      RowBox[{"x_", ",", "y_", ",", "\[Xi]_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"FunzWnew", "[", 
        RowBox[{"x", ",", "y"}], "]"}], "-", 
       RowBox[{"Funz\[CapitalSigma]new", "[", 
        RowBox[{"x", ",", "y", ",", "\[Xi]"}], "]"}]}], "//", "Simplify"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"\[CapitalDelta]fW\[CapitalSigma]", "[", 
         RowBox[{"x", ",", "y", ",", "\[Xi]"}], "]"}], "==", "0"}], " ", "&&", 
       RowBox[{
        RowBox[{"1", "-", 
         RowBox[{"y", "^", "2"}]}], ">=", 
        RowBox[{"4", 
         RowBox[{"x", "^", "2"}]}]}], "&&", 
       RowBox[{"y", ">", "0"}], "&&", 
       RowBox[{"x", ">", "0"}]}], ",", "\[Xi]"}], "]"}], "//", "Simplify"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"\[CapitalDelta]fW\[CapitalSigma]", "[", 
         RowBox[{"0", ",", "y", ",", "\[Xi]"}], "]"}], "==", "0"}], " ", "&&", 
       RowBox[{
        RowBox[{"1", "-", 
         RowBox[{"y", "^", "2"}]}], ">=", "0"}], "&&", 
       RowBox[{"y", ">", "0"}]}], " ", ",", "\[Xi]"}], "]"}], "//", 
    "Simplify"}]}]}]], "Input",
