Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "transverse", " ", "traceless", " ", 
    "projector"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"qdir", " ", "=", " ", 
     RowBox[{"q3D", "/", 
