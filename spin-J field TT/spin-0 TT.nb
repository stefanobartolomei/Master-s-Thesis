      RowBox[{"q_", "?", "NumericQ"}], ",", 
      RowBox[{"n_", "?", "NumericQ"}], ",", 
      RowBox[{"M_", "?", "NumericQ"}]}], "]"}], ":=", 
    RowBox[{
     FractionBox[
