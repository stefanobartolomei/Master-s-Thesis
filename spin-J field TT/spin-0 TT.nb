Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubscriptBox[
         StyleBox["N", "TI"], "dec"], "\[LongEqual]", "2", "Im", 
        SubscriptBox["\[CapitalGamma]", 
         RowBox[{"1", "PI"}]], "\[LongEqual]", 
        FractionBox[
         SubscriptBox[
          StyleBox["c", "TI"], 
          StyleBox["J", "TI"]], 
         RowBox[{"30720", "\[Pi]"}]], "\[Integral]", 
        FractionBox[
         RowBox[{
           SuperscriptBox[
            StyleBox["d", "TI"], "4"], 
           StyleBox["q", "TI"]}], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"2", "\[Pi]"}], ")"}], "4"]], "\[Theta]", 
        RowBox[{"(", 
          RowBox[{
            SuperscriptBox[
             StyleBox["q", "TI"], "2"], "-", "4", 
            SuperscriptBox[
             StyleBox["m", "TI"], "2"]}], ")"}], 
        SubscriptBox[
         StyleBox["h", "TI"], "\[Mu]\[Nu]"], 
        RowBox[{"(", 
          StyleBox["q", "TI"], ")"}], 
        SuperscriptBox["\[CapitalPi]", "\[Mu]\[Nu]\[Rho]\[Sigma]"], 
        SubscriptBox[
         StyleBox["h", "TI"], "\[Rho]\[Sigma]"], 
        RowBox[{"(", 
          RowBox[{"-", 
            StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {}, 
    "input" -> 
    "N_{\\text{dec}} = 2 \\text{Im} \\Gamma_{1\\text{PI}} = \\frac{c_J}{30720\
\\pi}\\int \\frac{d^4q}{(2\\pi)^4} \\theta(q^2 - 4m^2) h_{\\mu \\nu}(q) \
\\Pi^{\\mu \\nu \\rho \\sigma} h_{\\rho \\sigma}(-q)", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"35699260-5bd8-8d4c-9bbd-a0645ec7e4d3"]], \
