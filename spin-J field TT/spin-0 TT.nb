Cell[TextData[{
 "Vectorial perturbation ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["W", "TI"], 
        StyleBox["i", "TI"], "T"], TraditionalForm], "errors" -> {}, "input" -> 
