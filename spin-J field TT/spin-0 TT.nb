Cell[BoxData[
 RowBox[{
  RowBox[{"AbundanceSpectrum", "[", 
   RowBox[{
    RowBox[{"q0_", "?", "NumericQ"}], ",", 
    RowBox[{"M_", "?", "NumericQ"}], ",", "n_Integer"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "interpolatedDeltaH", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "Select", " ", "the", " ", "correct", " ", "template", " ", "based", " ",
       "on", " ", "n"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"interpolatedDeltaH", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"n", "==", "1"}], ",", "fast\[CapitalDelta]h1", ",", 
        "fast\[CapitalDelta]h2"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"2", "*", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{"funzh", "[", 
           RowBox[{"q0", ",", "q", ",", "M"}], "]"}], "q"], "*", 
         RowBox[{"interpolatedDeltaH", "[", 
          RowBox[{"q0", ",", "q"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"q", ",", "qMin", ",", "qMax"}], "}"}], ",", 
        RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}], ",", 
        RowBox[{"MaxRecursion", "->", "20"}]}], "]"}]}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9828417117119026`*^9, 3.9828418534003735`*^9}, {
  3.9828422962118664`*^9, 3.982842302149273*^9}, {3.9828426530723896`*^9, 
