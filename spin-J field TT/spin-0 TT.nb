              RowBox[{"i", ",", "r"}], "]"}], "]"}], "*", 
            RowBox[{"PTT2D", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "k"}], "]"}], "]"}]}]}], ")"}]}], "-", 
        RowBox[{
         FractionBox["1", "2"], 
         RowBox[{"PTT2D", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "j"}], "]"}], "]"}], "*", 
         RowBox[{"PTT2D", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "r"}], "]"}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "1", ",", "3"}], "}"}]}], "]"}]}], 
