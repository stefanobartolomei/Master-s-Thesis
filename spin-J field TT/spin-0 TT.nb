         RowBox[{"PTT2D", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "r"}], "]"}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
