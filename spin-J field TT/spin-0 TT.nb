Cell[CellGroupData[{

Cell["Template: correlation modeled by the size of the bubbles", "Chapter",
 CellChangeTimes->{{3.9821483781011467`*^9, 3.982148403693825*^9}, {
  3.9821524299894505`*^9, 
  3.982152432764742*^9}},ExpressionUUID->"47a2927c-0d21-754c-8a61-\
0230ab48960c"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["g", "TI"], 
          StyleBox["n", "TI"]], 
         RowBox[{"(", "\[Tau]", ")"}], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"[", 
            RowBox[{"4", 
              SuperscriptBox["\[Beta]", "2"], "\[Tau]", 
              RowBox[{"(", 
                RowBox[{
                  FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
            "]"}], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]], "\[Theta]", 
         RowBox[{"(", "\[Tau]", ")"}], "\[Theta]", 
         RowBox[{"(", 
           RowBox[{
             FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "g_n(\\tau) = \\Big[4\\beta^2 \\tau \\Big(\\frac{1}{\\beta} - \
\\tau\\Big)\\Big]^{n-1} \\theta(\\tau) \\theta(\\frac{1}{\\beta} - \\tau)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a85a240c-1bd7-8d4b-b517-0437d4d14091"],
 " , interested in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], "\[LongEqual]", "2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "n=2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ae14059e-5d98-514a-8de6-d05b2b1cf0c5"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["R", "TI"], 
         RowBox[{"(", "\[Tau]", ")"}], "\[LongEqual]", 
         StyleBox["v", "TI"], "\[Tau]"}], TraditionalForm], "errors" -> {}, 
     "input" -> "R(\\tau) = v\\tau", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "63fe647a-6197-9d4b-abd2-76c108869e25"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["g", "TI"], "2"], 
         RowBox[{"(", "\[Tau]", ")"}], 
         SuperscriptBox[
          StyleBox["R", "TI"], 
          RowBox[{"3", "/", "2"}]], 
         RowBox[{"(", "\[Tau]", ")"}], 
         SqrtBox[
          FractionBox[
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["R", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "3"], ")"}], "2"]}], 
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["R", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "2"], ")"}], "2"], "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["R", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "3"], ")"}], "6"]}]]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "f(\\tau,q) = g_2(\\tau) R^{3/2}(\\tau)\\sqrt{\\frac{1 + \\qty(\\frac{q \
R(\\tau)}{3})^2}{1 + \\qty(\\frac{q R(\\tau)}{2})^2 + \\qty(\\frac{q \
R(\\tau)}{3})^6}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3ce220a7-7c53-e84f-81ae-d5ad9095edaa"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["q", "TI"], ",", "\[Tau]", ",", 
             SuperscriptBox["\[Tau]", "\[Prime]"]}], ")"}], "\[LongEqual]", 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], 
         SuperscriptBox[
          StyleBox["f", "TI"], "*"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox["\[Tau]", "\[Prime]"], ",", 
             StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "\\Delta(q,\\tau,\\tau') = f(\\tau,q) f^*(\\tau',q)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7448f432-28cb-6143-882a-02c48ea1cbb3"]
}], "Subtitle",
 CellChangeTimes->{{3.9821480284432774`*^9, 3.982148109156109*^9}, {
  3.9821481775169754`*^9, 3.9821482229266453`*^9}, {3.9821483442190266`*^9, 
  3.9821483764376736`*^9}, {3.9821508718699665`*^9, 3.9821508808600235`*^9}, {
