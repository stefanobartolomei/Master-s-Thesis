Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "In", " ", "case", " ", "of", " ", "massless", " ", "scalar", " ", 
     "field"}], ",", " ", 
    RowBox[{"the", " ", "\[Xi]", " ", "value", " ", 
     RowBox[{"(", 
      RowBox[{
      "for", " ", "which", " ", "fh", " ", "and", " ", "f\[CapitalSigma]", " ",
        "are", " ", "equals"}], ")"}], " ", "is", " ", "fixed"}]}], " ", 
   "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Print", "[", "\"\<\\n ---- Solutions -----\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{"sol\[Xi]massless", " ", "=", " ", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"\[CapitalDelta]fh\[CapitalSigma]", "[", 
          RowBox[{"0", ",", "y", ",", "\[Xi]"}], "]"}], "==", "0"}], " ", "&&", 
        RowBox[{
         RowBox[{"1", "-", 
          RowBox[{"y", "^", "2"}]}], ">=", "0"}], "&&", 
        RowBox[{"y", ">", "0"}]}], " ", ",", "\[Xi]"}], "]"}], "//", 
     "Simplify"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Funz\[CapitalSigma]new\[Xi]1massless", "[", "y_", "]"}], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Funz\[CapitalSigma]new", "[", 
         RowBox[{"0", ",", "y", ",", "\[Xi]"}], "]"}], "/.", 
        RowBox[{"sol\[Xi]massless", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "//", "Simplify"}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Funz\[CapitalSigma]\[Xi]2newmassless", "[", "y_", "]"}], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Funz\[CapitalSigma]new", "[", 
         RowBox[{"0", ",", "y", ",", "\[Xi]"}], "]"}], "/.", 
        RowBox[{"sol\[Xi]massless", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "//", "Simplify"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", "Plots", " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plot\[CapitalSigma]\[Xi]1", " ", "=", " ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Funz\[CapitalSigma]new\[Xi]1massless", "[", "y", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"10", "^", 
          RowBox[{"-", "5"}]}], ",", "1"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Green"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", 
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"StringForm", "[", 
            RowBox[{"\"\<Scalar \[CapitalSigma] with `` \>\"", ",", 
             RowBox[{"sol\[Xi]massless", "[", 
              RowBox[{"[", 
               RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "]"}], ",", "14"}], 
          "]"}], "}"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"Frame", "->", "True"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plot\[CapitalSigma]\[Xi]2", " ", "=", " ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Funz\[CapitalSigma]\[Xi]2newmassless", "[", "y", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"10", "^", 
          RowBox[{"-", "5"}]}], ",", "1"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Dotted", ",", "Brown"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", 
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"StringForm", "[", 
            RowBox[{"\"\<Scalar \[CapitalSigma] with `` \>\"", ",", 
             RowBox[{"sol\[Xi]massless", "[", 
              RowBox[{"[", 
               RowBox[{"2", ",", "1"}], "]"}], "]"}]}], "]"}], ",", "14"}], 
          "]"}], "}"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"Frame", "->", "True"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plothmassless", " ", "=", " ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Funzhnew", "[", 
        RowBox[{"0", ",", "y"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"10", "^", 
          RowBox[{"-", "5"}]}], ",", "1"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Dashed", ",", "Blue"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", "\"\<Tensor\>\"", "}"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"Frame", "->", "True"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "plot\[CapitalSigma]\[Xi]1", ",", " ", "plot\[CapitalSigma]\[Xi]2", ",",
        "plothmassless"}], "}"}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{
        "StringForm", "[", "\"\<Kernel Functions in the massless limit\>\"", 
         "]"}], ",", "14"}], "]"}]}], ",", 
     RowBox[{"FrameLabel", "->", 
