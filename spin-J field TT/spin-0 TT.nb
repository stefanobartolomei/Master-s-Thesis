      RowBox[{"M_", "?", "NumericQ"}]}], "]"}], ":=", 
    RowBox[{"2", "*", 
     RowBox[{"(", 
      RowBox[{"4", 
       RowBox[{"\[Pi]", "^", "2"}]}], ")"}], "*", 
     RowBox[{"(", 
