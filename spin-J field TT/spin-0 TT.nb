          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["q", "TI"]}], 
          StyleBox["q", "TI"]], 
         SubscriptBox[
          StyleBox["f", "TI"], 
          StyleBox["h", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["q", "TI"], "0"], ",", 
             StyleBox["q", "TI"], ",", 
             StyleBox["M", "TI"]}], ")"}], 
         RowBox[{"(", 
           RowBox[{"2", 
             SuperscriptBox["\[Pi]", "2"]}], ")"}], 
         SubscriptBox["\[CapitalDelta]", 
          StyleBox["h", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["q", "TI"], "0"], ",", 
             OverscriptBox[
              StyleBox["q", "TI"], "\[RightVector]"]}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{d(na^3)}{dq_0} = 2(4\\pi^2)\\int_0^{\\sqrt{q_0^2-4M^2}} \
