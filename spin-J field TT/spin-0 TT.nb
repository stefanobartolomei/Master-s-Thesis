Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "vertex", " ", "of", " ", "the", " ", "scalar", 
    " ", "field", " ", "interacting", " ", "with", " ", "the", " ", "metric", 
    " ", "perturbation"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Vertex", "[", 
     RowBox[{"\[Omega]_", ",", "k_", ",", "mu_", ",", "nu_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", " ", 
       FractionBox["1", "2"]}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"FV", "[", 
          RowBox[{"k", ",", "mu"}], "]"}], "*", 
         RowBox[{"FV", "[", 
          RowBox[{"\[Omega]", ",", "nu"}], "]"}]}], "+", 
        RowBox[{
         RowBox[{"FV", "[", 
          RowBox[{"\[Omega]", ",", "mu"}], "]"}], "*", 
