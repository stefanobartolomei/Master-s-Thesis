              StyleBox["n", "TI"], 
              SuperscriptBox[
               StyleBox["a", "TI"], "3"]}], ")"}], 
          RowBox[{
            StyleBox["d", "TI"], 
            SubscriptBox[
             StyleBox["q", "TI"], "0"]}]], "\[LongEqual]", "2", 
         RowBox[{"(", 
           RowBox[{"4", 
             SuperscriptBox["\[Pi]", "2"]}], ")"}], 
         SubsuperscriptBox["\[Integral]", "0", 
          SqrtBox[
           RowBox[{
             SubsuperscriptBox[
              StyleBox["q", "TI"], "0", "2"], "-", "4", 
             SuperscriptBox[
              StyleBox["M", "TI"], "2"]}]]], 
