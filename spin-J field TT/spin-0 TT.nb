Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"g2", "[", "tau_", "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"4", "*", 
          SuperscriptBox["beta", "2"], " ", "tau", " ", "*", 
          RowBox[{"(", 
           RowBox[{
            FractionBox["1", "beta"], "-", "tau"}], ")"}]}], ")"}], ",", 
        RowBox[{"0", "<", "tau", "<", 
         RowBox[{"1", "/", "beta"}]}]}], "}"}], "}"}], ",", "0"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"R", "[", "tau_", "]"}], " ", ":=", " ", 
   RowBox[{"v", "*", "tau"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"tau_", ",", "q_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"g2", "[", "tau", "]"}], "*", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"R", "[", "tau", "]"}], ")"}], 
     FractionBox["3", "2"]], " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", "tau", "]"}]}], "3"], ")"}], "2"]}], 
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", "tau", "]"}]}], "2"], ")"}], "2"], " ", "+", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", "tau", "]"}]}], "3"], ")"}], "6"]}]]]}]}], " ", 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9822370952469406`*^9, 3.9822371303995323`*^9}, {
  3.9822376188099556`*^9, 3.982237619200279*^9}, {3.9828447982163353`*^9, 
  3.9828448096323643`*^9}, {3.9828450208376827`*^9, 
  3.982845024791567*^9}},ExpressionUUID->"94c2b351-8526-6d40-a0f9-\
a7932d325d60"]
