Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"H", "=", 
    RowBox[{
     RowBox[{"FunzWnew", "[", 
      RowBox[{"x", ",", "y"}], "]"}], "/.", 
     RowBox[{
      RowBox[{"y", "^", "2"}], "->", "u"}]}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Compute", " ", "the", " ", "logarithmic", " ", "derivative", " ", "with", 
    " ", "respect", " ", "to", " ", "u"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"logDeriv", "=", 
    RowBox[{"Simplify", "[", 
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"Log", "[", "H", "]"}], ",", "u"}], "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Solve", " ", "the", " ", "numerator", " ", "for", " ", "u"}], 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"numeratorEqn", "=", 
    RowBox[{
     RowBox[{"Numerator", "[", 
      RowBox[{"Together", "[", "logDeriv", "]"}], "]"}], "==", "0"}]}], ";"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Find", " ", "analytical", " ", "roots", " ", "of", " ", "the", " ", 
    "quadratic", " ", "equation"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"uSolutions", "=", 
    RowBox[{"Solve", "[", 
     RowBox[{"numeratorEqn", ",", "u"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "We", " ", "must", " ", "choose", " ", "the", " ", "negative", " ", 
     "root", " ", "to", " ", "stay", " ", "within", " ", "the", " ", 
     "physical", " ", "domain", " ", "u"}], "<=", 
    RowBox[{"1", "-", 
     RowBox[{"4", 
      RowBox[{"x", "^", "2."}]}]}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"uMaxAnalytical", "=", 
    RowBox[{"u", "/.", " ", 
     RowBox[{"uSolutions", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Negative", " ", "root"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"yMaxAnalytical", "=", 
   RowBox[{"Sqrt", "[", "uMaxAnalytical", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
    RowBox[{"\"\<y_max = q/q0 = \>\"", ",", "yMaxAnalytical"}], "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"visualizer", "=", 
   RowBox[{"Manipulate", "[", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"yLim", ",", "xM", ",", "yM", ",", "fPlot"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"yLim", "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"1", "-", 
           RowBox[{"4", "*", 
            SuperscriptBox["valX", "2"]}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"yM", "=", 
         RowBox[{"yMaxAnalytical", "/.", 
          RowBox[{"x", "->", "valX"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"xM", "=", 
         RowBox[{"FunzWnew", "[", 
          RowBox[{"valX", ",", "yM"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Plot", "[", 
         RowBox[{
          RowBox[{"FunzWnew", "[", 
           RowBox[{"valX", ",", "y"}], "]"}], ",", 
