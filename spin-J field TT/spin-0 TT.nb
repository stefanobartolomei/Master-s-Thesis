  3.9828447617587986`*^9}},ExpressionUUID->"0b22e42b-8353-eb49-80a7-\
4d7a8dc0b5c6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Given", " ", "parameter"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"beta", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"v", " ", "=", " ", "1"}], ";"}]}]}]], "Input",
