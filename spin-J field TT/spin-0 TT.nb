Cell[TextData[{
 "Check Traceless (for conformally coupled) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Eta]", "\[Mu]\[Nu]"], "Im", 
         RowBox[{"[", 
           RowBox[{"\[LeftAngleBracket]", 
             RowBox[{
               SuperscriptBox[
                StyleBox["T", "TI"], "\[Mu]\[Nu]"], 
               SuperscriptBox[
                StyleBox["T", "TI"], "\[Rho]\[Sigma]"]}], 
             "\[RightAngleBracket]"}], "]"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\eta_{\\mu \\nu} \\text{Im}[\\langle T^{\\mu \\nu}T^{\\rho \
\\sigma}\\rangle] = 0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "201d7269-f429-b845-8534-11500e269bdf"],
 " with tables"
}], "Subtitle",
