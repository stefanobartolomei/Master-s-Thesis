               SuperscriptBox[
                StyleBox["T", "TI"], 
                RowBox[{
                  StyleBox["k", "TI"], 
                  StyleBox["r", "TI"]}]]}], "\[RightAngleBracket]"}], "]"}]}],
        TraditionalForm], "errors" -> {}, "input" -> 
     "f_h(q_0,q,M) \\equiv P_{ijkr}\\text{Im}\\qty[\\langle T^{ij} \
T^{kr}\\rangle]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3184d079-fea0-4e4b-9a98-790514ec33c6"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             SubscriptBox[
              StyleBox["h", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["j", "TI"]}]], 
             RowBox[{"(", 
               RowBox[{
                 SubscriptBox[
                  StyleBox["q", "TI"], "0"], ",", 
                 OverscriptBox[
                  StyleBox["q", "TI"], "\[RightVector]"]}], ")"}], 
             SubscriptBox[
              StyleBox["h", "TI"], 
              RowBox[{
                StyleBox["r", "TI"], 
                StyleBox["k", "TI"]}]], 
             RowBox[{"(", 
               RowBox[{
                 SubsuperscriptBox[
                  StyleBox["q", "TI"], "0", "\[Prime]"], ",", 
                 SuperscriptBox[
                  OverscriptBox[
                   StyleBox["q", "TI"], "\[RightVector]"], "\[Prime]"]}], 
               ")"}]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"2", "\[Pi]"}], ")"}], "3"], 
         SuperscriptBox["\[Delta]", "3"], 
         RowBox[{"(", 
           RowBox[{
             OverscriptBox[
              StyleBox["q", "TI"], "\[RightVector]"], "+", 
             SuperscriptBox[
              OverscriptBox[
               StyleBox["q", "TI"], "\[RightVector]"], "\[Prime]"]}], ")"}], 
         FractionBox[
          RowBox[{"2", 
            SuperscriptBox["\[Pi]", "2"]}], 
          SuperscriptBox[
           StyleBox["q", "TI"], "3"]], 
         SubscriptBox["\[CapitalDelta]", 
          StyleBox["h", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["q", "TI"], "0"], ",", 
             OverscriptBox[
              StyleBox["q", "TI"], "\[RightVector]"]}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle h_{ij}(q_0, \\vec{q})h_{rk}(q_0', \\vec{q}') \\rangle = \
(2\\pi)^3 \\delta^3(\\vec{q} + \\vec{q}') \\frac{2\\pi^2}{q^3} \\Delta_h(q_0,\
\\vec{q})", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "13def954-af04-f143-bc08-f2d3180bd191"],
 "\nwe arrive at ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], "(", 
