          RowBox[{"Funz\[CapitalTheta]new", "[", 
           RowBox[{"x", ",", "y", ",", "\[Xi]value"}], "]"}], ",", 
          RowBox[{"y", "<=", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"1", "-", 
             RowBox[{"4", "*", 
              RowBox[{"x", "^", "2"}]}]}], "]"}]}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "xvalues"}], "}"}]}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"10", "^", 
        RowBox[{"-", "5"}]}], ",", "1"}], "}"}], ",", 
     RowBox[{"Evaluate", "@", 
      RowBox[{"scientificPlotOptions", "[", 
       RowBox[{"\"\<Scalar \[CapitalTheta] Kernel Function\>\"", 
        ",", "\"\<\!\(\*SubscriptBox[\(f\), \(\[CapitalTheta]\)]\)\>\""}], 
       "]"}]}]}], "]"}]}], ";"}], "\n", 
