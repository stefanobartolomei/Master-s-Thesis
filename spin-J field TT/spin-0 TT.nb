Cell[CellGroupData[{

Cell[TextData[{
 "Fourier transform\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["q", "TI"], "0"], ",", 
             StyleBox["q", "TI"]}], ")"}], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", "0", 
          RowBox[{"1", "/", "\[Beta]"}]], 
         StyleBox["d", "TI"], "\[Tau]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            StyleBox["i", "TI"], 
            SubscriptBox[
             StyleBox["q", "TI"], "0"], "\[Tau]"}]], 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "f(q_0,q) = \\int _0^{1/\\beta}d\\tau e^{-iq_0\\tau} f(\\tau,q)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "562369a6-e3c0-594f-8e05-14801ba94149"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[CapitalDelta]", 
          StyleBox["h", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["q", "TI"], ",", 
             SubscriptBox[
              StyleBox["q", "TI"], "0"]}], ")"}], "\[LongEqual]", 
         "\[Integral]", 
         StyleBox["d", "TI"], "\[Tau]", 
         StyleBox["d", "TI"], 
         SuperscriptBox["\[Tau]", "\[Prime]"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            StyleBox["i", "TI"], 
            SubscriptBox[
             StyleBox["q", "TI"], "0"], 
            RowBox[{"(", 
              RowBox[{"\[Tau]", "-", 
                SuperscriptBox["\[Tau]", "\[Prime]"]}], ")"}]}]], 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], 
         SuperscriptBox[
          StyleBox["f", "TI"], "*"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox["\[Tau]", "\[Prime]"], ",", 
             StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\Delta_h(q,q_0) = \\int d\\tau d\\tau' e^{-iq_0(\\tau - \\tau')} \
f(\\tau,q) f^*(\\tau',q)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "75a348fa-fffc-b54b-a30a-c037f26ec75e"]
}], "Subtitle",
 CellChangeTimes->{{3.982148302632866*^9, 3.9821483418615055`*^9}, {
  3.982148423795065*^9, 3.982148428935589*^9}, {3.9821485020359325`*^9, 
  3.9821485071603603`*^9}},ExpressionUUID->"74eb183d-58e0-154d-a75d-\
fd35e64c3791"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"fTdf", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}], ",", 
     RowBox[{"n_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"tau", ",", "q", ",", "n"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], "*", "q0", "*", "tau"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"tau", ",", "0", ",", 
       RowBox[{"1", "/", "beta"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fstarTdf", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}], ",", 
     RowBox[{"n_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ComplexExpand", "[", 
       RowBox[{"f", "[", 
        RowBox[{"tau", ",", "q", ",", "n"}], "]"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", "*", "q0", "*", "tau"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"tau", ",", "0", ",", 
       RowBox[{"1", "/", "beta"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalDelta]h", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}], ",", 
     RowBox[{"n_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{"fTdf", "[", 
     RowBox[{"q0", ",", "q", ",", "n"}], "]"}], "*", 
    RowBox[{"fstarTdf", "[", 
     RowBox[{"q0", ",", "q", ",", "n"}], "]"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.982147260108927*^9, 3.982147261635111*^9}, {
