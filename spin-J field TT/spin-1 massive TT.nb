Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"define", " ", "the", " ", "log", " ", "data", " ", "tail"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"logData2", "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"M\[CapitalOmega]scale", ",", 
        RowBox[{"Log", "[", "scaleData", "]"}]}], "}"}], "]"}]}], ";"}], "\n",
    "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Fit", " ", ":", " ", 
     RowBox[{"param1", " ", "+", " ", 
      RowBox[{"param2", "*", 
       RowBox[{"Log", "[", "x", "]"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"logFit2", "=", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{"logData2", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"Log", "[", "x", "]"}]}], "}"}], ",", "x"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"param1", " ", "+", " ", 
      RowBox[{"param2", "*", 
       RowBox[{"Log", "[", "x", "]"}]}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{"param1", " ", "+", " ", 
       RowBox[{"Log", "[", 
        RowBox[{"x", "^", "param2"}], "]"}]}], " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"Log", "[", 
         RowBox[{"E", "^", "param1"}], "]"}], " ", "+", " ", 
        RowBox[{"Log", "[", 
         RowBox[{"x", "^", "param2"}], "]"}]}], " ", "=", " ", 
       RowBox[{
        RowBox[{"Log", "[", 
         RowBox[{
          RowBox[{"E", "^", "param1"}], " ", 
          RowBox[{"x", "^", "param2"}]}], "]"}], " ", "=", " ", 
        RowBox[{"Log", "[", 
         RowBox[{"A", " ", 
          RowBox[{"x", "^", "b"}]}], "]"}]}]}]}]}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "parameters"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"b2", "=", 
     RowBox[{
      RowBox[{"logFit2", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"A2", "=", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"logFit2", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Power law fit: y = \>\"", ",", "A2", ",", "\"\< * x^\>\"", ",",
       "b2"}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "To", " ", "plot", " ", "it", " ", "over", " ", "your", " ", 
     RowBox[{"ListLogPlot", ":"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListLogPlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"M\[CapitalOmega]scale", ",", "scaleData"}], "}"}], "]"}], ",", 
       RowBox[{"PlotStyle", "->", "Red"}]}], "]"}], ",", 
     RowBox[{"LogPlot", "[", 
      RowBox[{
       RowBox[{"A2", "*", 
        RowBox[{"x", "^", "b2"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"Min", "[", "M\[CapitalOmega]scale", "]"}], ",", 
         RowBox[{"Max", "[", "M\[CapitalOmega]scale", "]"}]}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9897387137120113`*^9, 3.9897387725373096`*^9}, {
  3.9897388387055664`*^9, 3.9897388404941254`*^9}},
 CellLabel->
  "In[276]:=",ExpressionUUID->"05099e6e-2cfe-8a4e-9b9a-ca9394272ad7"],

