             StyleBox["q", "TI"]}], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["g", "TI"], 
          StyleBox["n", "TI"]], 
         RowBox[{"(", "\[Tau]", ")"}], 
         SuperscriptBox[
          StyleBox["R", "TI"], 
          RowBox[{"3", "/", "2"}]], 
         RowBox[{"(", "\[Tau]", ")"}], 
         SqrtBox[
          FractionBox[
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
