Cell[CellGroupData[{

Cell[TextData[{
 "Tensorial perturbation\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], "(", 
            RowBox[{
              StyleBox["n", "TI"], 
              SuperscriptBox[
               StyleBox["a", "TI"], "3"]}], ")"}], 
          RowBox[{
            StyleBox["d", "TI"], 
            SubscriptBox[
             StyleBox["q", "TI"], "0"]}]], "\[LongEqual]", "2", "\[Integral]", 
         StyleBox["d", "TI"], 
         StyleBox["q", "TI"], 
         SubscriptBox[
          StyleBox["h", "TI"], "\[Mu]\[Nu]"], "Im", 
         RowBox[{"[", 
           RowBox[{"\[LeftAngleBracket]", 
             RowBox[{
               SuperscriptBox[
                StyleBox["T", "TI"], "\[Mu]\[Nu]"], 
               SuperscriptBox[
                StyleBox["T", "TI"], "\[Rho]\[Sigma]"]}], 
             "\[RightAngleBracket]"}], "]"}], 
         SubscriptBox[
          StyleBox["h", "TI"], "\[Rho]\[Sigma]"], "\[Rule]", "2", 
         "\[Integral]", 
         StyleBox["d", "TI"], 
         StyleBox["q", "TI"], 
         SubsuperscriptBox[
          StyleBox["h", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}], "TT"], "Im", 
         RowBox[{"[", 
           RowBox[{"\[LeftAngleBracket]", 
             RowBox[{
               SuperscriptBox[
                StyleBox["T", "TI"], 
                RowBox[{
                  StyleBox["i", "TI"], 
                  StyleBox["j", "TI"]}]], 
               SuperscriptBox[
                StyleBox["T", "TI"], 
                RowBox[{
                  StyleBox["k", "TI"], 
                  StyleBox["r", "TI"]}]]}], "\[RightAngleBracket]"}], "]"}], 
         SubsuperscriptBox[
          StyleBox["h", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["r", "TI"]}], "TT"]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\frac{d (na^3)}{dq_0} = 2\\int dq h_{\\mu \
\\nu}\\text{Im}\\qty[\\langle T^{\\mu \\nu} T^{\\rho \\sigma}\\rangle] \
h_{\\rho \\sigma} \\to 2 \\int dq h^{\\text{TT}}_{ij}\\text{Im}\\qty[\\langle \
T^{ij} T^{kr}\\rangle] h^{\\text{TT}}_{kr}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0626658e-aed3-034a-a100-b75aebfa8d2b"]
}], "Chapter",
 CellChangeTimes->{{3.9822319606359863`*^9, 3.982231991108328*^9}, {
