Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
    "define", " ", "the", " ", "log", " ", "data", " ", "tail", " ", "\[IndentingNewLine]",
      "logData"}], "=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"M\[CapitalOmega]tail", ",", 
       RowBox[{"Log", "[", "tailData", "]"}]}], "}"}], "]"}]}], ";", "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Fit", " ", ":", " ", 
     RowBox[{"param1", " ", "+", " ", 
      RowBox[{"param2", "*", 
       RowBox[{"Log", "[", "x", "]"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"logFit", "=", 
    RowBox[{"LinearModelFit", "[", 
     RowBox[{"logData", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"Log", "[", "x", "]"}]}], "}"}], ",", "x"}], "]"}]}], ";", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"param1", " ", "+", " ", 
      RowBox[{"param2", "*", 
       RowBox[{"Log", "[", "x", "]"}]}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{"param1", " ", "+", " ", 
       RowBox[{"Log", "[", 
        RowBox[{"x", "^", "param2"}], "]"}]}], " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"Log", "[", 
         RowBox[{"E", "^", "param1"}], "]"}], " ", "+", " ", 
        RowBox[{"Log", "[", 
         RowBox[{"x", "^", "param2"}], "]"}]}], " ", "=", " ", 
       RowBox[{
        RowBox[{"Log", "[", 
         RowBox[{
          RowBox[{"E", "^", "param1"}], " ", 
          RowBox[{"x", "^", "param2"}]}], "]"}], " ", "=", " ", 
        RowBox[{"Log", "[", 
         RowBox[{"A", " ", 
          RowBox[{"x", "^", "b"}]}], "]"}]}]}]}]}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "parameters"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"b", "=", 
    RowBox[{
     RowBox[{"logFit", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
     RowBox[{"[", "2", "]"}], "]"}]}], ";", "\n", 
   RowBox[{"A", "=", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"logFit", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Power law fit: y = \>\"", ",", "A", ",", "\"\< * x^\>\"", ",",
      "b"}], "]"}], ";", "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "To", " ", "plot", " ", "it", " ", "over", " ", "your", " ", 
     RowBox[{"ListLogPlot", ":"}]}], "*)"}], "\[IndentingNewLine]", 
