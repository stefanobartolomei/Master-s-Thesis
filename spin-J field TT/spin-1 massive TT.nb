            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]", 
         SubscriptBox["\[Delta]", 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "-", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["q", "TI"], "^"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["q", "TI"], "^"], 
          StyleBox["j", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "P_{ij} = \\delta_{ij} - \\hat{q}_i \\hat{q}_j", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b479fd5e-deef-db45-883d-5e86bf9828bb"],
 "     in 2D\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"], 
            StyleBox["k", "TI"], 
            StyleBox["r", "TI"]}]], "\[LongEqual]", 
         FractionBox["1", "2"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["k", "TI"]}]], 
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["r", "TI"]}]], "+", 
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["r", "TI"]}]], 
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["k", "TI"]}]]}], ")"}], "-", 
         FractionBox["1", "2"], 
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], 
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["r", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "P_{ijkr} = \\frac{1}{2}\\qty(P_{ik}P_{jr} + P_{ir}P_{jk}) -\\frac{1}{2} \
P_{ij}P_{kr}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "95363f76-ed95-614a-b5ff-cce0a65787f4"],
 "  in 4D"
