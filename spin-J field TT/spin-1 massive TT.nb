Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"From", " ", "the", " ", "Kernel", " ", "factor", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SqrtBox[
           RowBox[{
             FractionBox[
              RowBox[{"4", 
                SuperscriptBox[
                 StyleBox["x", "TI"], "2"]}], 
              RowBox[{
                SuperscriptBox[
                 StyleBox["y", "TI"], "2"], "-", "1"}]], "+", "1"}]], " ", 
          "\[Rule] ", 
          FractionBox[
           RowBox[{"4", 
             SuperscriptBox[
              StyleBox["x", "TI"], "2"]}], 
           RowBox[{
             SuperscriptBox[
              StyleBox["y", "TI"], "2"], "-", "1"}]], "+", "1", 
          "\[GreaterEqual]", "0"}], TraditionalForm], "errors" -> {}, "input" -> 
      "\\sqrt{\\frac{4x^2}{y^2 - 1} +1} \\ \\to \\ \\frac{4x^2}{y^2 - 1} + \
1\\ge 0", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "\[IndentingNewLine]", "From", " ", "the", 
    " ", "condition", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubsuperscriptBox[
           StyleBox["q", "TI"], "0", "2"], "-", 
          SuperscriptBox[
           StyleBox["q", "TI"], "2"], "\[GreaterEqual]", "4", 
          SuperscriptBox[
           StyleBox["m", "TI"], "2"], " ", "\[Rule] ", "1", "-", 
          SuperscriptBox[
           StyleBox["y", "TI"], "2"], "\[GreaterEqual]", "4", 
          SuperscriptBox[
           StyleBox["x", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
      "input" -> "q_0^2-q^2 \\ge 4m^2 \\ \\to \\ 1-y^2\\ge 4x^2", "state" -> 
      "Boxes"|>,
     "TeXAssistantTemplate"]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Reduce", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{"4", 
         RowBox[{"x", "^", "2"}]}], 
        RowBox[{
         RowBox[{"y", "^", "2"}], " ", "-", " ", "1"}]], "+", "1"}], ">=", 
      "0"}], "&&", 
     RowBox[{
      RowBox[{"1", "-", 
       RowBox[{"y", "^", "2"}]}], ">=", 
      RowBox[{"4", 
       RowBox[{"x", "^", "2"}]}]}], "&&", 
     RowBox[{"x", ">", "0"}], "&&", 
