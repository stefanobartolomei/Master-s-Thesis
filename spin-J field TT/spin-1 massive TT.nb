Cell[TextData[{
 "Transverse, Traceless Projectors (and symmetric in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["i", "TI"], "\[LeftRightArrow]", 
         StyleBox["j", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "i\\leftrightarrow j", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d57c5c78-7fd2-4040-a2eb-d0e2aad29fb6"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["k", "TI"], "\[LeftRightArrow]", 
          StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
      "k \\leftrightarrow r", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "57592a6a-b0b8-6a41-a8e0-d3616739b2e8"],
 ")\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]", 
         SubscriptBox["\[Delta]", 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "-", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["q", "TI"], "^"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["q", "TI"], "^"], 
          StyleBox["j", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "P_{ij} = \\delta_{ij} - \\hat{q}_i \\hat{q}_j", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "08577095-632c-2645-a892-df377a2de281"],
 "     in 2D\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"], 
            StyleBox["k", "TI"], 
            StyleBox["r", "TI"]}]], "\[LongEqual]", 
         FractionBox["1", "2"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["k", "TI"]}]], 
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["r", "TI"]}]], "+", 
             SubscriptBox[
