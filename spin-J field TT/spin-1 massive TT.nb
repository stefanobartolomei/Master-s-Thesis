Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "massless", " ", "limit", " ", "is", " ", "the", " ", "one", " ",
     "maximum"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ListLogPlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"M\[CapitalOmega]", ",", "Nadimensional"}], "}"}], "]"}], ",", 
     RowBox[{"Joined", "->", "True"}], ",", 
     RowBox[{"InterpolationOrder", "->", "2"}]}], "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"define", " ", "the", " ", "log", " ", "data"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"logDataN", "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"M\[CapitalOmega]", "[", 
         RowBox[{"[", 
          RowBox[{"5", ";;"}], "]"}], "]"}], ",", 
        RowBox[{"Log", "[", 
         RowBox[{"Nadimensional", "[", 
          RowBox[{"[", 
           RowBox[{"5", ";;"}], "]"}], "]"}], "]"}]}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Fit", " ", ":", " ", 
     RowBox[{"param1", " ", "+", " ", 
      RowBox[{"param2", "*", 
       RowBox[{"Log", "[", "x", "]"}]}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"logFitN", "=", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{"logDataN", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"Log", "[", "x", "]"}]}], "}"}], ",", "x"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"param1", " ", "+", " ", 
      RowBox[{"param2", "*", 
       RowBox[{"Log", "[", "x", "]"}]}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{"param1", " ", "+", " ", 
       RowBox[{"Log", "[", 
        RowBox[{"x", "^", "param2"}], "]"}]}], " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"Log", "[", 
         RowBox[{"E", "^", "param1"}], "]"}], " ", "+", " ", 
        RowBox[{"Log", "[", 
         RowBox[{"x", "^", "param2"}], "]"}]}], " ", "=", " ", 
       RowBox[{
        RowBox[{"Log", "[", 
         RowBox[{
          RowBox[{"E", "^", "param1"}], " ", 
          RowBox[{"x", "^", "param2"}]}], "]"}], " ", "=", " ", 
        RowBox[{"Log", "[", 
         RowBox[{"A", " ", 
          RowBox[{"x", "^", "b"}]}], "]"}]}]}]}]}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "parameters"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bN", "=", 
     RowBox[{
      RowBox[{"logFitN", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"AN", "=", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"logFitN", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Power law fit: y = \>\"", ",", "AN", ",", "\"\< * x^\>\"", ",",
       "bN"}], "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "To", " ", "plot", " ", "it", " ", "over", " ", "your", " ", 
     RowBox[{"ListLogPlot", ":"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListLogPlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"M\[CapitalOmega]", ",", "Nadimensional"}], "}"}], "]"}], ",", 
       RowBox[{"PlotStyle", "->", "Red"}]}], "]"}], ",", 
     RowBox[{"LogPlot", "[", 
      RowBox[{
       RowBox[{"AN", "*", 
        RowBox[{"x", "^", "bN"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"Min", "[", "M\[CapitalOmega]", "]"}], ",", 
         RowBox[{"Max", "[", "M\[CapitalOmega]", "]"}]}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}]}], "]"}]}]}]], "Input",
