Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"define", " ", "the", " ", "log", " ", "data"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"logData2", "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"M\[CapitalOmega]2", "[", 
         RowBox[{"[", 
          RowBox[{"15", ";;"}], "]"}], "]"}], ",", 
        RowBox[{"Log", "[", 
         RowBox[{"Nadimensional2", "[", 
          RowBox[{"[", 
           RowBox[{"15", ";;"}], "]"}], "]"}], "]"}]}], "}"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Fit", " ", ":", " ", 
     RowBox[{"param1", " ", "+", " ", 
      RowBox[{"param2", "*", 
       RowBox[{"Log", "[", "x", "]"}]}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"logFit2", "=", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{"logData2", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"Log", "[", "x", "]"}]}], "}"}], ",", "x"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "parameters"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"b2", "=", 
     RowBox[{
      RowBox[{"logFit2", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"A2", "=", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"logFit2", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Power law fit: y = \>\"", ",", "A2", ",", "\"\< * x^\>\"", ",",
       "b2"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "To", " ", "plot", " ", "it", " ", "over", " ", "your", " ", 
     RowBox[{"ListLogPlot", ":"}]}], "*)"}], "\n", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListLogPlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"M\[CapitalOmega]2", ",", "Nadimensional2"}], "}"}], "]"}], ",", 
       RowBox[{"PlotStyle", "->", "Red"}]}], "]"}], ",", 
     RowBox[{"LogPlot", "[", 
      RowBox[{
       RowBox[{"A2", "*", 
        RowBox[{"x", "^", "b2"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"Min", "[", "M\[CapitalOmega]2", "]"}], ",", 
         RowBox[{"Max", "[", "M\[CapitalOmega]2", "]"}]}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9900687945751953`*^9, 3.990068840164049*^9}, {
   3.990068962012268*^9, 3.9900689972785015`*^9}, 3.9900690720622864`*^9, {
