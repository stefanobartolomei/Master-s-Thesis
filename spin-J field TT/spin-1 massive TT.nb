        StyleBox["d", "TI"], 
        StyleBox["x", "TI"], 
        FractionBox[
         RowBox[{
           SuperscriptBox[
            RowBox[{"(", "-1", ")"}], 
            RowBox[{
              StyleBox["n", "TI"], "+", "\[Alpha]"}]], 
