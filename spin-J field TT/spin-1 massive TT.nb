               RowBox[{"(", 
                RowBox[{
                 SuperscriptBox["Wy", "2"], "+", 
                 SuperscriptBox["Wz", "2"]}], ")"}]}]}], ")"}], "->", 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{
