Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"define", " ", "the", " ", "log", " ", "data", " ", "tail"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"logData", "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"M\[CapitalOmega]tail", ",", 
        RowBox[{"Log", "[", "tailData", "]"}]}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Fit", " ", ":", " ", 
     RowBox[{"param1", " ", "+", " ", 
      RowBox[{"param2", "*", 
       RowBox[{"Log", "[", "x", "]"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"logFit", "=", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{"logData", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"Log", "[", "x", "]"}]}], "}"}], ",", "x"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"param1", " ", "+", " ", 
      RowBox[{"param2", "*", 
       RowBox[{"Log", "[", "x", "]"}]}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{"param1", " ", "+", " ", 
       RowBox[{"Log", "[", 
        RowBox[{"x", "^", "param2"}], "]"}]}], " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"Log", "[", 
         RowBox[{"E", "^", "param1"}], "]"}], " ", "+", " ", 
        RowBox[{"Log", "[", 
         RowBox[{"x", "^", "param2"}], "]"}]}], " ", "=", " ", 
       RowBox[{
        RowBox[{"Log", "[", 
         RowBox[{
          RowBox[{"E", "^", "param1"}], " ", 
          RowBox[{"x", "^", "param2"}]}], "]"}], " ", "=", " ", 
        RowBox[{"Log", "[", 
         RowBox[{"A", " ", 
          RowBox[{"x", "^", "b"}]}], "]"}]}]}]}]}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "parameters"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"b", "=", 
     RowBox[{
      RowBox[{"logFit", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"A", "=", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"logFit", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Power law fit: y = \>\"", ",", "A", ",", "\"\< * x^\>\"", ",",
       "b"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "To", " ", "plot", " ", "it", " ", "over", " ", "your", " ", 
     RowBox[{"ListLogPlot", ":"}]}], "*)"}], "\n", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListLogPlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"M\[CapitalOmega]tail", ",", "tailData"}], "}"}], "]"}], ",", 
       RowBox[{"PlotStyle", "->", "Red"}]}], "]"}], ",", 
     RowBox[{"LogPlot", "[", 
      RowBox[{
       RowBox[{"A", "*", 
        RowBox[{"x", "^", "b"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"Min", "[", "M\[CapitalOmega]tail", "]"}], ",", 
         RowBox[{"Max", "[", "M\[CapitalOmega]tail", "]"}]}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.989725753512451*^9, 3.9897258206761627`*^9}, {
