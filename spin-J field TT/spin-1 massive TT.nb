  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["h", "TI"], 
        RowBox[{
          StyleBox["i", "TI"], 
          StyleBox["j", "TI"]}], "TT"], TraditionalForm], "errors" -> {}, 
     "input" -> "h_{ij}^{\\text{TT}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "74f6587e-58e0-a748-a127-831422cdb69b"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["h", "TI"], "\[Mu]\[Nu]"], "Im", 
         RowBox[{"[", 
           RowBox[{"\[LeftAngleBracket]", 
             RowBox[{
               SuperscriptBox[
                StyleBox["T", "TI"], "\[Mu]\[Nu]"], 
               SuperscriptBox[
                StyleBox["T", "TI"], "\[Rho]\[Sigma]"]}], 
             "\[RightAngleBracket]"}], "]"}], 
         SubscriptBox[
          StyleBox["h", "TI"], "\[Rho]\[Sigma]"], "\[Rule]", 
         SubsuperscriptBox[
          StyleBox["h", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}], "TT"], "Im", 
         RowBox[{"[", 
           RowBox[{"\[LeftAngleBracket]", 
             RowBox[{
               SuperscriptBox[
                StyleBox["T", "TI"], 
                RowBox[{
                  StyleBox["i", "TI"], 
                  StyleBox["j", "TI"]}]], 
               SuperscriptBox[
                StyleBox["T", "TI"], 
                RowBox[{
                  StyleBox["k", "TI"], 
                  StyleBox["r", "TI"]}]]}], "\[RightAngleBracket]"}], "]"}], 
         SubsuperscriptBox[
          StyleBox["h", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["r", "TI"]}], "TT"]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "h_{\\mu \\nu}\\text{Im}\\qty[\\langle T^{\\mu \\nu} T^{\\rho \
\\sigma}\\rangle] h_{\\rho \\sigma} \\to \
h^{\\text{TT}}_{ij}\\text{Im}\\qty[\\langle T^{ij} T^{kr}\\rangle] \
h^{\\text{TT}}_{kr}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bf9fe651-fc43-7543-aea9-0f5b550dc467"]
