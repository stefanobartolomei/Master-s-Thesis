   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"M", "/", "\[Beta]value"}], ",", 
       RowBox[{"\[CapitalOmega]hToday", "[", 
        RowBox[{"M", ",", 
         RowBox[{"Intq0Fast", "[", 
          RowBox[{"M", "/", "\[Beta]value"}], "]"}]}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"M", ",", "Mmin", ",", "Mmax", ",", 
       RowBox[{
        RowBox[{"(", 
