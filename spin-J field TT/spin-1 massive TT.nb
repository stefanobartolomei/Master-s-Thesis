Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Interpolated", " ", "Integrand"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Integrand", "[", 
      RowBox[{"q0_", ",", "q_", ",", "M_"}], "]"}], ":=", " ", 
     RowBox[{
      FractionBox[
       RowBox[{"funzh", "[", 
        RowBox[{"q0", ",", "q", ",", "M"}], "]"}], "q"], "*", 
      RowBox[{"\[CapitalDelta]h", "[", 
       RowBox[{"q0", ",", "q"}], "]"}], "*", 
      RowBox[{"(", 
       RowBox[{"q0", "*", 
        RowBox[{"Log", "[", "10", "]"}]}], ")"}], "*", 
      RowBox[{"(", 
       RowBox[{"q", "*", 
        RowBox[{"Log", "[", "10", "]"}]}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"integration", " ", "over", " ", 
     TemplateBox[<|"boxes" -> FormBox[
         StyleBox["q", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
       "q", "state" -> "Boxes"|>,
      "TeXAssistantTemplate"], " ", "and", " ", 
     TemplateBox[<|"boxes" -> FormBox[
         SubscriptBox[
          StyleBox["q", "TI"], "0"], TraditionalForm], "errors" -> {}, 
       "input" -> "q_0", "state" -> "Boxes"|>,
      "TeXAssistantTemplate"]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Nadim", "[", "M_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{"Integrand", "[", 
          RowBox[{
           RowBox[{"10", "^", "lq0"}], ",", 
           RowBox[{"10", "^", "lq"}], ",", "M"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"lq0", ",", 
           RowBox[{
            RowBox[{"Log10", "[", 
             RowBox[{"2", "M"}], "]"}], "+", "0.05"}], ",", "3", ",", 
           "0.05"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"lq", ",", 
           RowBox[{"-", "2"}], ",", 
           RowBox[{
            FractionBox["1", "2"], 
            RowBox[{"Log10", "[", 
             RowBox[{
              RowBox[{"10", "^", 
               RowBox[{"(", 
                RowBox[{"2", "*", "lq0"}], ")"}]}], " ", "-", " ", 
              RowBox[{"4", 
               RowBox[{"M", "^", "2"}]}]}], "]"}]}], ",", "0.05"}], "}"}]}], 
        "]"}], 
       RowBox[{
        RowBox[{"(", "0.05", ")"}], "^", "2"}]}], "//", "Quiet"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"M", " ", "should", " ", "be"}], " ", "<", " ", 
      RowBox[{
      "500", " ", "\[Beta]", " ", "to", " ", "not", " ", "exceed", " ", "3", " ",
        "in", " ", 
       TemplateBox[<|"boxes" -> FormBox[
           SubscriptBox[
            StyleBox["q", "TI"], "0"], TraditionalForm], "errors" -> {}, 
         "input" -> "q_0", "state" -> "Boxes"|>,
        "TeXAssistantTemplate"], " ", "integral"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Note", " ", "that", " ", 
      TemplateBox[<|"boxes" -> FormBox[
          RowBox[{
            FractionBox["1", "2"], 
            SubscriptBox["log", "10"], 
            RowBox[{"(", 
              RowBox[{
                SuperscriptBox["10", 
                 RowBox[{"2", 
                   StyleBox["l", "TI"], 
                   StyleBox["q", "TI"], "0"}]], "-", "4", 
                SuperscriptBox[
                 StyleBox["M", "TI"], "2"]}], ")"}]}], TraditionalForm], 
        "errors" -> {}, "input" -> 
        "\\frac{1}{2}\\log_{10}(10^{2 lq0} - 4M^2)", "state" -> "Boxes"|>,
       "TeXAssistantTemplate"], " ", "has", " ", "a", " ", "maximum", " ", 
      "value", " ", "of", " ", "3", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"for", " ", "lq0"}], " ", "=", " ", 
        RowBox[{
         RowBox[{"3", " ", "and", " ", "M"}], " ", "=", "0"}]}], ")"}]}]}], 
    "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.986121036564663*^9, 3.986121038940302*^9}, {
