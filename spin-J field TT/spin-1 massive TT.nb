 FormBox[
  InterpretationBox[
   RowBox[{"\<\"Power law fit: y = \"\>", "\[InvisibleSpace]", 
    "0.0015704446253928185`", "\[InvisibleSpace]", "\<\" * x^\"\>", "\[InvisibleSpace]",
