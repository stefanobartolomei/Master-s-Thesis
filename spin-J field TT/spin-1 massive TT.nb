   RowBox[{
    RowBox[{"logFit1", "=", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{"logData1", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"Log", "[", "x", "]"}]}], "}"}], ",", "x"}], "]"}]}], ";"}], 
