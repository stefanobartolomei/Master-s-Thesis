     RowBox[{"M_", ",", "nIntegral_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "\[Rho]Today", "}"}], ",", "\[IndentingNewLine]", 
