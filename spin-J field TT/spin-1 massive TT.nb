      RowBox[{"param1", " ", "+", " ", 
       RowBox[{"Log", "[", 
        RowBox[{"x", "^", "param2"}], "]"}]}], " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"Log", "[", 
