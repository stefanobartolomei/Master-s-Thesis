              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["r", "TI"]}]], 
             SubscriptBox[
              StyleBox["P", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["k", "TI"]}]]}], ")"}], "-", 
         FractionBox["1", "2"], 
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], 
         SubscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["r", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "P_{ijkr} = \\frac{1}{2}\\qty(P_{ik}P_{jr} + P_{ir}P_{jk}) -\\frac{1}{2} \
P_{ij}P_{kr}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0654a5e8-6292-b148-b51e-1c0b81ec22d5"],
