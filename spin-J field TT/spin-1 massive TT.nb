Cell[CellGroupData[{

Cell[TextData[{
 "Model for the Power spectrum of GW, sourced by a ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox["1", "ST"], TraditionalForm], "errors" -> {}, "input" -> 
     "1^{\\text{ST}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "251c1c17-7aa9-a441-8f52-e839d0ca7f3c"],
 " Order Phase-Transition"
}], "Title",
 CellChangeTimes->{{3.982235395021017*^9, 
  3.982235458672268*^9}},ExpressionUUID->"e1510f40-c11f-c14f-8e6b-\
1168af925531"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Standard", " ", "Cosmologies", " ", "parameters"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"T0", "=", 
     RowBox[{"2.35", "*", 
      RowBox[{"10", "^", 
       RowBox[{"-", "13"}]}]}]}], ";"}], "        ", 
   RowBox[{"(*", " ", 
    RowBox[{"CMB", " ", 
     RowBox[{"temperature", " ", "[", "GeV", "]"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"gS0", "=", "3.91"}], ";"}], "                        ", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Today", " ", "entropy", " ", "degrees", " ", "of", " ", "freedom"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"\[Rho]c0", "=", 
     RowBox[{"8.09", "*", 
      RowBox[{"10", "^", 
       RowBox[{"-", "47"}]}]}]}], ";"}], "     ", 
   RowBox[{"(*", " ", 
    RowBox[{"Today", " ", "critical", " ", 
     RowBox[{"density", "/", 
      RowBox[{"h", "^", 
       RowBox[{"2", " ", "[", 
        RowBox[{"GeV", "^", "4"}], "]"}]}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"Mpl", "=", 
     RowBox[{"2.43", "*", 
      RowBox[{"10", "^", "18"}]}]}], ";"}], "        ", 
   RowBox[{"(*", " ", 
    RowBox[{"Reduced", " ", "Planck", " ", 
     RowBox[{"mass", " ", "[", "GeV", "]"}]}], " ", "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"At", " ", "the", " ", "Phase", " ", "transition"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Tstar", "=", 
     RowBox[{"10", "^", "3"}]}], ";"}], 
   "                                      ", 
   RowBox[{"(*", " ", 
    RowBox[{"Temperature", " ", "[", "GeV", "]"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"gSstar", "=", "106.75"}], ";"}], 
   "                                ", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Degrees", " ", "of", " ", "freedom", " ", "by", " ", "Standard", " ", 
     "Model"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Hstar", "=", 
     RowBox[{
      SqrtBox[
       RowBox[{
        FractionBox[
         SuperscriptBox["\[Pi]", "2"], "90"], "*", "gSstar"}]], 
      FractionBox[
       SuperscriptBox["Tstar", "2"], "Mpl"]}]}], ";"}], "   ", 
   RowBox[{"(*", " ", 
    RowBox[{"Hubble", " ", "parameter"}], " ", "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", "Redshift", " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"RedshiftFactor", "=", 
     FractionBox[
      RowBox[{"gS0", "*", 
       SuperscriptBox["T0", "3"]}], 
      RowBox[{"gSstar", "*", 
       SuperscriptBox["Tstar", "3"]}]]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"1", "PT", " ", "parameters"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Beta]H", " ", "=", " ", "100"}], ";"}], 
   "                                    ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "We", " ", "assume", " ", "no", " ", "universe", " ", "expansion"}], ",",
      " ", 
     RowBox[{"so", " ", 
      TemplateBox[<|"boxes" -> FormBox[
          RowBox[{
            FractionBox["\[Beta]", 
             SubscriptBox[
              StyleBox["H", "TI"], "\[FivePointedStar]"]], 
            "\[GreaterGreater]", "1"}], TraditionalForm], "errors" -> {}, 
        "input" -> "\\frac{\\beta}{H_\\star} \\gg 1", "state" -> "Boxes"|>,
       "TeXAssistantTemplate"]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Beta]value", "=", 
     RowBox[{"\[Beta]H", "*", " ", "Hstar"}]}], ";"}], "               ", 
   RowBox[{"(*", " ", 
    RowBox[{"Inverse", " ", "time", " ", "duration", " ", "of", " ", "1", 
     RowBox[{"PT", " ", "[", "GeV", "]"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"velocity", " ", "=", " ", "1"}], ";"}], 
   "                           ", 
   RowBox[{"(*", " ", 
    RowBox[{"Bubble", " ", "wall", " ", "velocity", " ", 
     RowBox[{"(", 
      RowBox[{"speed", " ", "of", " ", "light"}], ")"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Alpha]heat", "=", "0.1"}], ";"}], 
   "                                ", 
   RowBox[{"(*", " ", 
    RowBox[{"Latent", " ", "heat", " ", 
     TemplateBox[<|"boxes" -> FormBox[
         FractionBox[
          SubscriptBox["\[Rho]", 
           RowBox[{
             StyleBox["v", "TI"], 
             StyleBox["a", "TI"], 
             StyleBox["c", "TI"]}]], 
          SubscriptBox["\[Rho]", 
           RowBox[{
             StyleBox["r", "TI"], 
             StyleBox["a", "TI"], 
             StyleBox["d", "TI"]}]]], TraditionalForm], "errors" -> {}, 
       "input" -> "\\frac{\\rho_{vac}}{\\rho_{rad}}", "state" -> "Boxes"|>,
      "TeXAssistantTemplate"]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"kappa", "=", "0.05"}], ";"}], "                               ", 
   RowBox[{"(*", " ", 
    RowBox[{"Efficiency", " ", "factor"}], " ", "*)"}], "\[IndentingNewLine]",
    "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Dimensional", " ", "factor"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ScaleFactorDim", "=", 
     RowBox[{
      SuperscriptBox["\[Beta]value", "3"], "*", 
      FractionBox[
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"kappa", "*", "\[Alpha]heat"}], ")"}], "2"], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", "\[Alpha]heat"}], ")"}], "2"]], "*", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["Hstar", "\[Beta]value"], ")"}], "4"], "*", 
      SuperscriptBox["velocity", "3"]}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"[", 
     RowBox[{"Gev", "^", "3"}], "]"}], "*)"}], 
   "\[IndentingNewLine]"}]}]], "Input",
