         FractionBox[
          RowBox[{"ScaleFactorDim", "*", "RedshiftFactor"}], "\[Rho]c0"], "*", 
         RowBox[{"(", 
          RowBox[{"M", "*", "nIntegral"}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", "\[Rho]Today"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
