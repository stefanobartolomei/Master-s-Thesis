              StyleBox["q", "TI"], "0"]}], ")"}], "\[LongEqual]", 
         "\[Integral]", 
         StyleBox["d", "TI"], "\[Tau]", 
         StyleBox["d", "TI"], 
         SuperscriptBox["\[Tau]", "\[Prime]"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            StyleBox["i", "TI"], 
            SubscriptBox[
             StyleBox["q", "TI"], "0"], 
            RowBox[{"(", 
              RowBox[{"\[Tau]", "-", 
                SuperscriptBox["\[Tau]", "\[Prime]"]}], ")"}]}]], 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], 
         SuperscriptBox[
          StyleBox["f", "TI"], "*"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox["\[Tau]", "\[Prime]"], ",", 
             StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\Delta_h(q,q_0) = \\int d\\tau d\\tau' e^{-iq_0(\\tau - \\tau')} \
f(\\tau,q) f^*(\\tau',q)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
