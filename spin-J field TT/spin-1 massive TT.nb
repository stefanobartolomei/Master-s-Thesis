 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "transverse", " ", "traceless", " ", 
    "projector"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
