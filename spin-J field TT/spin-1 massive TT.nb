              StyleBox["j", "TI"], "T"], "-", 
             SubscriptBox["\[PartialD]", 
              StyleBox["j", "TI"]], 
             SubsuperscriptBox[
              StyleBox["W", "TI"], 
              StyleBox["i", "TI"], "T"]}], ")"}], "Im", 
         RowBox[{"[", 
           RowBox[{"\[LeftAngleBracket]", 
             RowBox[{
               SuperscriptBox[
