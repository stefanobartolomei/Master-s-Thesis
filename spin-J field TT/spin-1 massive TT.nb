     RowBox[{"Prop", "[", 
      RowBox[{"\[Alpha]", ",", "\[Tau]", ",", 
       RowBox[{"l", " ", "+", " ", 
        RowBox[{"x", "*", "q"}], " ", "-", " ", "q"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"firstVP", " ", "=", " ", 
     RowBox[{"Contract", "[", 
