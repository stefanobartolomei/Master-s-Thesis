Cell[CellGroupData[{

Cell["Template: correlation modeled by the size of the bubbles", "Chapter",
 CellChangeTimes->{{3.9821483781011467`*^9, 3.982148403693825*^9}, {
  3.9821524299894505`*^9, 
  3.982152432764742*^9}},ExpressionUUID->"1c63803e-b328-1848-a04c-\
a31ddbd1b9f3"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["g", "TI"], 
          StyleBox["n", "TI"]], 
         RowBox[{"(", "\[Tau]", ")"}], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"[", 
            RowBox[{"4", 
              SuperscriptBox["\[Beta]", "2"], "\[Tau]", 
              RowBox[{"(", 
                RowBox[{
                  FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
            "]"}], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]], "\[Theta]", 
         RowBox[{"(", "\[Tau]", ")"}], "\[Theta]", 
         RowBox[{"(", 
           RowBox[{
             FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "g_n(\\tau) = \\Big[4\\beta^2 \\tau \\Big(\\frac{1}{\\beta} - \
\\tau\\Big)\\Big]^{n-1} \\theta(\\tau) \\theta(\\frac{1}{\\beta} - \\tau)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "04bee5ec-eb87-7045-b119-bf1f83362faf"],
 " , interested in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], "\[LongEqual]", "2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "n=2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bc85ca02-b9d7-0f49-98fa-67b07495f4e3"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["R", "TI"], 
         RowBox[{"(", "\[Tau]", ")"}], "\[LongEqual]", 
         StyleBox["v", "TI"], "\[Tau]"}], TraditionalForm], "errors" -> {}, 
     "input" -> "R(\\tau) = v\\tau", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f150a30b-3b1c-c943-a81e-9222d5dcd174"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["g", "TI"], "2"], 
         RowBox[{"(", "\[Tau]", ")"}], 
         SuperscriptBox[
          StyleBox["R", "TI"], 
          RowBox[{"3", "/", "2"}]], 
         RowBox[{"(", "\[Tau]", ")"}], 
         SqrtBox[
          FractionBox[
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["R", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "3"], ")"}], "2"]}], 
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["R", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "2"], ")"}], "2"], "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["R", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "3"], ")"}], "6"]}]]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "f(\\tau,q) = g_2(\\tau) R^{3/2}(\\tau)\\sqrt{\\frac{1 + \\qty(\\frac{q \
R(\\tau)}{3})^2}{1 + \\qty(\\frac{q R(\\tau)}{2})^2 + \\qty(\\frac{q \
R(\\tau)}{3})^6}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e1fafb5f-b930-304b-a706-33e78ad86881"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["q", "TI"], ",", "\[Tau]", ",", 
             SuperscriptBox["\[Tau]", "\[Prime]"]}], ")"}], "\[LongEqual]", 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], 
         SuperscriptBox[
          StyleBox["f", "TI"], "*"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox["\[Tau]", "\[Prime]"], ",", 
             StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "\\Delta(q,\\tau,\\tau') = f(\\tau,q) f^*(\\tau',q)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e1433ac0-6508-fc4b-82ee-e3a30b721bde"]
}], "Subtitle",
 CellChangeTimes->{{3.9821480284432774`*^9, 3.982148109156109*^9}, {
  3.9821481775169754`*^9, 3.9821482229266453`*^9}, {3.9821483442190266`*^9, 
  3.9821483764376736`*^9}, {3.9821508718699665`*^9, 3.9821508808600235`*^9}, {
  3.982844754222252*^9, 
  3.9828447617587986`*^9}},ExpressionUUID->"12e6bb19-23c1-404e-b94c-\
b4975970a56f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Model", " ", "Template"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"g2", "[", 
      RowBox[{"tau_", ",", "beta_"}], "]"}], ":=", 
     RowBox[{"4", "*", 
      SuperscriptBox["beta", "2"], " ", "tau", " ", "*", 
      RowBox[{"(", 
       RowBox[{
        FractionBox["1", "beta"], "-", "tau"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"R", "[", "tau_", "]"}], " ", ":=", " ", 
     RowBox[{"velocity", "*", "tau"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"tau_", ",", "beta_", ",", "q_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"g2", "[", 
        RowBox[{"tau", ",", "beta"}], "]"}], "*", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"R", "[", "tau", "]"}], ")"}], 
        FractionBox["3", "2"]], " ", 
       SqrtBox[
        FractionBox[
         RowBox[{"1", " ", "+", " ", 
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox[
             RowBox[{"q", "*", 
              RowBox[{"R", "[", "tau", "]"}]}], "3"], ")"}], "2"]}], 
         RowBox[{"1", " ", "+", " ", 
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox[
             RowBox[{"q", "*", 
              RowBox[{"R", "[", "tau", "]"}]}], "2"], ")"}], "2"], " ", "+", 
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox[
             RowBox[{"q", "*", 
              RowBox[{"R", "[", "tau", "]"}]}], "3"], ")"}], "6"]}]]]}], " ", 
      "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"fTDF", "[", 
      RowBox[{
       RowBox[{"q0_", "?", "NumericQ"}], ",", 
       RowBox[{"q_", "?", "NumericQ"}], ",", 
       RowBox[{"beta_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"f", "[", 
         RowBox[{"tau", ",", "beta", ",", "q"}], "]"}], "*", 
        RowBox[{"Exp", "[", 
         RowBox[{"I", "*", "q0", "*", "tau"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"tau", ",", "0", ",", 
         RowBox[{"1", "/", "beta"}]}], "}"}], ",", 
       RowBox[{"Method", "->", "\"\<LevinRule\>\""}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalDelta]h", "[", 
      RowBox[{
       RowBox[{"q0_", "?", "NumericQ"}], ",", 
       RowBox[{"q_", "?", "NumericQ"}], ",", 
       RowBox[{"beta_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{"fTDF", "[", 
        RowBox[{"q0", ",", "q", ",", "beta"}], "]"}], "]"}], "^", "2"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9822370952469406`*^9, 3.9822371303995323`*^9}, {
   3.9822376188099556`*^9, 3.982237619200279*^9}, {3.9828447982163353`*^9, 
   3.9828448096323643`*^9}, {3.9828450208376827`*^9, 3.982845024791567*^9}, {
