           SuperscriptBox["qz", "2"]}], ")"}], "2"], ":>", 
        SuperscriptBox["Q", "4"]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox["qx", "2"]}], "-", 
           SuperscriptBox["qy", "2"], "-", 
           SuperscriptBox["qz", "2"]}], ")"}], "2"], ":>", 
        SuperscriptBox["Q", "4"]}]}], "\[IndentingNewLine]", " ", "}"}]}], 
    ";"}]}]}]], "Input",
