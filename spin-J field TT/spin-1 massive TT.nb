           StyleBox["n", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
    "input" -> 
    "I_0(\\alpha) =\\int_0^1 dx \\frac{(-1)^{n+\\alpha}i}{(4\\pi)^{d/2}} \
