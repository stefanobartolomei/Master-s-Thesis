Cell[CellGroupData[{

Cell[TextData[{
 "Tensorial perturbation ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["h", "TI"], 
        RowBox[{
          StyleBox["i", "TI"], 
          StyleBox["j", "TI"]}], "TT"], TraditionalForm], "errors" -> {}, 
     "input" -> "h_{ij}^{\\text{TT}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "74f6587e-58e0-a748-a127-831422cdb69b"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["h", "TI"], "\[Mu]\[Nu]"], "Im", 
         RowBox[{"[", 
           RowBox[{"\[LeftAngleBracket]", 
             RowBox[{
               SuperscriptBox[
                StyleBox["T", "TI"], "\[Mu]\[Nu]"], 
               SuperscriptBox[
                StyleBox["T", "TI"], "\[Rho]\[Sigma]"]}], 
             "\[RightAngleBracket]"}], "]"}], 
         SubscriptBox[
          StyleBox["h", "TI"], "\[Rho]\[Sigma]"], "\[Rule]", 
         SubsuperscriptBox[
          StyleBox["h", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}], "TT"], "Im", 
         RowBox[{"[", 
           RowBox[{"\[LeftAngleBracket]", 
             RowBox[{
               SuperscriptBox[
                StyleBox["T", "TI"], 
                RowBox[{
                  StyleBox["i", "TI"], 
                  StyleBox["j", "TI"]}]], 
               SuperscriptBox[
                StyleBox["T", "TI"], 
                RowBox[{
                  StyleBox["k", "TI"], 
                  StyleBox["r", "TI"]}]]}], "\[RightAngleBracket]"}], "]"}], 
         SubsuperscriptBox[
          StyleBox["h", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["r", "TI"]}], "TT"]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "h_{\\mu \\nu}\\text{Im}\\qty[\\langle T^{\\mu \\nu} T^{\\rho \
\\sigma}\\rangle] h_{\\rho \\sigma} \\to \
h^{\\text{TT}}_{ij}\\text{Im}\\qty[\\langle T^{ij} T^{kr}\\rangle] \
h^{\\text{TT}}_{kr}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bf9fe651-fc43-7543-aea9-0f5b550dc467"]
}], "Chapter",
 CellChangeTimes->{{3.9822319606359863`*^9, 3.982231991108328*^9}, {
   3.982232145126108*^9, 3.9822321573356476`*^9}, 3.9822348639830704`*^9, {
   3.982234975158676*^9, 3.982234975710417*^9}, {3.982424852149767*^9, 
   3.982424853176914*^9}},ExpressionUUID->"09cbb22f-95b7-df42-b156-\
ce9b0f35e360"],

