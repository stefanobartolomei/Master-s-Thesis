eba132eee60f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Interpolated", " ", "Integrand"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Integrandf\[CapitalDelta]Fast", "[", 
      RowBox[{
       RowBox[{"q0_", "?", "NumericQ"}], ",", 
       RowBox[{"q_", "?", "NumericQ"}], ",", 
       RowBox[{"M_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{
      FractionBox[
       RowBox[{"funzh", "[", 
        RowBox[{"q0", ",", "q", ",", "M"}], "]"}], "q"], "*", 
      RowBox[{"Fast\[CapitalDelta]h", "[", 
       RowBox[{"q0", ",", "q"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"integration", " ", "over", " ", 
     TemplateBox[<|"boxes" -> FormBox[
         StyleBox["q", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
       "q", "state" -> "Boxes"|>,
      "TeXAssistantTemplate"]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"IntqFast", "[", 
      RowBox[{
       RowBox[{"q0_", "?", "NumericQ"}], ",", 
       RowBox[{"M_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"16", " ", 
      SuperscriptBox["\[Pi]", "4"], "  ", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{"Integrandf\[CapitalDelta]Fast", "[", 
         RowBox[{"q0", ",", "q", ",", "M"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"q", ",", 
          RowBox[{"10", "^", 
           RowBox[{"-", "4"}]}], ",", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"q0", "^", "2"}], " ", "-", " ", 
            RowBox[{"4", " ", "*", 
             RowBox[{"M", "^", "2"}]}]}], "]"}]}], "}"}], ",", 
        RowBox[{"Method", "->", "\"\<LocalAdaptive\>\""}], ",", 
        RowBox[{"PrecisionGoal", "->", "3"}], ",", 
        RowBox[{"AccuracyGoal", "->", "\[Infinity]"}], ",", 
        RowBox[{"MaxRecursion", "->", "200"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"integration", " ", "over", " ", 
     TemplateBox[<|"boxes" -> FormBox[
         SubscriptBox[
          StyleBox["q", "TI"], "0"], TraditionalForm], "errors" -> {}, 
       "input" -> "q_0", "state" -> "Boxes"|>,
      "TeXAssistantTemplate"]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Intq0Fast", "[", 
      RowBox[{"M_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{"IntqFast", "[", 
        RowBox[{"q0", ",", "M"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"q0", ",", 
         RowBox[{"2", "M"}], ",", "q0Max"}], "}"}], ",", 
       RowBox[{"Method", "->", "\"\<LocalAdaptive\>\""}], ",", 
       RowBox[{"PrecisionGoal", "->", "3"}], ",", 
       RowBox[{"AccuracyGoal", "->", "\[Infinity]"}], ",", 
       RowBox[{"MaxRecursion", "->", "200"}]}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"from", " ", "q0Max"}], "=", 
      RowBox[{"500", "\[Beta]", " ", "in", " ", "the", " ", "grid"}]}], ",", 
     " ", 
     RowBox[{
      RowBox[{
      "the", " ", "mass", " ", "should", " ", "not", " ", "exceed", " ", 
       "M"}], "<", 
      RowBox[{"250", "\[Beta]"}]}]}], " ", "*)"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.986121036564663*^9, 3.986121038940302*^9}, {
