Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"define", " ", "the", " ", "log", " ", "data"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"logData3", "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"M\[CapitalOmega]3", "[", 
         RowBox[{"[", 
          RowBox[{"15", ";;"}], "]"}], "]"}], ",", 
        RowBox[{"Log", "[", 
         RowBox[{"Nadimensional3", "[", 
          RowBox[{"[", 
           RowBox[{"15", ";;"}], "]"}], "]"}], "]"}]}], "}"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Fit", " ", ":", " ", 
     RowBox[{"param1", " ", "+", " ", 
      RowBox[{"param2", "*", 
       RowBox[{"Log", "[", "x", "]"}]}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"logFit3", "=", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{"logData3", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"Log", "[", "x", "]"}]}], "}"}], ",", "x"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "parameters"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"b3", "=", 
     RowBox[{
      RowBox[{"logFit3", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"A3", "=", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"logFit3", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"logFit3", "[", "\"\<ParameterErrors\>\"", "]"}], " ", "*)"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Power law fit: y = \>\"", ",", "A3", ",", "\"\< * x^\>\"", ",",
       "b3"}], "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "To", " ", "plot", " ", "it", " ", "over", " ", "your", " ", 
     RowBox[{"ListLogPlot", ":"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListLogPlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"M\[CapitalOmega]3", ",", "Nadimensional3"}], "}"}], "]"}], ",", 
       RowBox[{"PlotStyle", "->", "Red"}]}], "]"}], ",", 
     RowBox[{"LogPlot", "[", 
      RowBox[{
       RowBox[{"A3", "*", 
        RowBox[{"x", "^", "b3"}]}], ",", 
