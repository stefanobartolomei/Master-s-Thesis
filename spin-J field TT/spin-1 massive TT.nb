0f1955ade0e7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Working", " ", "with", " ", "adimensional", " ", "functions"}], ",",
     " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           OverscriptBox[
            StyleBox["q", "TI"], "~"], "0"], "\[LongEqual]", 
          FractionBox[
           SubscriptBox[
            StyleBox["q", "TI"], "0"], "\[Beta]"]}], TraditionalForm], 
      "errors" -> {}, "input" -> "\\tilde{q}_0 = \\frac{q_0}{\\beta}", 
      "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], ",", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          OverscriptBox[
           StyleBox["q", "TI"], "~"], "\[LongEqual]", 
          FractionBox[
           StyleBox["q", "TI"], "\[Beta]"]}], TraditionalForm], 
      "errors" -> {}, "input" -> "\\tilde{q} = \\frac{q}{\\beta}", "state" -> 
      "Boxes"|>,
     "TeXAssistantTemplate"], ",", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           OverscriptBox[
            StyleBox["L", "TI"], "~"], "\[Omega]"], "\[LongEqual]", 
          FractionBox[
           SubscriptBox[
            StyleBox["L", "TI"], "\[Omega]"], "\[Beta]"]}], TraditionalForm], 
      "errors" -> {}, "input" -> 
      "\\tilde{L}_\\omega = \\frac{L_\\omega}{\\beta}", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], "  ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Beta]Grid", " ", "=", "1.0"}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"\[Beta]grid", " ", "=", " ", 
     RowBox[{"1.", " ", "Gev"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Lw", "=", "0.05"}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"Finite", " ", "bubble", " ", "wall", " ", "thickness", " ", 
     RowBox[{"(", 
      RowBox[{
      "roughly", " ", "5", "%", " ", "of", " ", "bubble", " ", "radius"}], 
      ")"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalDelta]hADIM", "[", 
      RowBox[{
       RowBox[{"q0_", "?", "NumericQ"}], ",", 
       RowBox[{"q_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"\[CapitalDelta]h", "[", 
       RowBox[{"q0", ",", "q", ",", "\[Beta]Grid"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{"-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"q0", "*", "Lw"}], ")"}], "^", "2"}]}], "]"}]}]}], ";"}], 
   " ", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Generate", " ", "grid", " ", "data"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"q0Max", "=", "500.0"}], ";"}], " ", 
   RowBox[{"(*", " ", "cutoff", "*)"}], "\n", 
   RowBox[{
    RowBox[{"qMax", "=", "500.0"}], ";"}], " ", 
   RowBox[{"(*", " ", "cutoff", " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"qMin", " ", "=", " ", 
     RowBox[{"10", "^", 
      RowBox[{"-", "4"}]}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"initial", " ", "point"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gridData", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"ParallelTable", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"q0", ",", "q"}], "}"}], ",", 
           RowBox[{"\[CapitalDelta]hADIM", "[", 
            RowBox[{"q0", ",", "q"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"q0", ",", "qMin", ",", "q0Max", ",", "0.5"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"q", ",", "qMin", ",", "qMax", ",", "0.5"}], "}"}]}], "]"}],
        ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", "Interpolation", " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Fast\[CapitalDelta]h", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{"gridData", ",", 
       RowBox[{"InterpolationOrder", "->", "2"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Save", " ", "data"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Fast\[CapitalDelta]hFile", 
     "=", "\"\<Fast\[CapitalDelta]h_spin-1.wdx\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Saving interpolation data to: \>\"", ",", 
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"NotebookDirectory", "[", "]"}], ",", 
         "Fast\[CapitalDelta]hFile"}], "}"}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
