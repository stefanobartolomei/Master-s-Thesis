               RowBox[{"(", 
                RowBox[{
                 SuperscriptBox["Wx", "2"], "+", 
                 SuperscriptBox["Wy", "2"]}], ")"}]}], "-", 
              RowBox[{"2", " ", "qx", " ", "qz", " ", "Wx", " ", "Wz"}], "-", 
              RowBox[{"2", " ", "qy", " ", "Wy", " ", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"qx", " ", "Wx"}], "+", 
                 RowBox[{"qz", " ", "Wz"}]}], ")"}]}], "+", 
              RowBox[{
