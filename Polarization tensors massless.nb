 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Epsilon]", "\[Lambda]", "\[Mu]\[Nu]"], 
         RowBox[{"(", 
           OverscriptBox[
            StyleBox["q", "TI"], "\[RightVector]"], ")"}], "\[LongEqual]", 
         "\[CapitalLambda]", 
         RowBox[{"(", 
           RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}], 
         SubsuperscriptBox["\[Epsilon]", "\[Lambda]", "\[Mu]\[Nu]"], 
         SuperscriptBox["\[CapitalLambda]", 
          StyleBox["T", "TI"]], 
         RowBox[{"(", 
           RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\epsilon^{\\mu \\nu}_\\lambda(\\vec{q}) = \\Lambda(\\theta,\\phi) \
\\epsilon^{\\mu \\nu}_\\lambda \\Lambda^T(\\theta,\\phi)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "51518657-fa94-49d0-af90-8f0cfed1e744"],
