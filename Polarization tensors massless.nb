   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"z", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"qmu", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", "q", "}"}], ",", 
