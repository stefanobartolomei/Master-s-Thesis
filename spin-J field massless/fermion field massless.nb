Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubscriptBox[
         RowBox[{"(", 
           SubsuperscriptBox[
            StyleBox["C", "TI"], 
            RowBox[{"1", "/", "2"}], "\[PlusMinus]"], ")"}], "LH"], 
        "\[LongEqual]", 
        FractionBox["1", "2"], 
        SqrtBox[
         RowBox[{"2", 
           SuperscriptBox[
            StyleBox["k", "TI"], "0"]}]], 
        SqrtBox[
         RowBox[{"2", 
           SuperscriptBox["\[Omega]", "0"]}]], 
        SuperscriptBox[
         RowBox[{"(", 
           SubsuperscriptBox["\[Xi]", 
            OverscriptBox[
             StyleBox["k", "TI"], "\[RightVector]"], "-"], ")"}], 
         "\[Dagger]"], 
        RowBox[{"[", 
          RowBox[{
            SuperscriptBox["\[Omega]", 
             StyleBox["i", "TI"]], 
            SubsuperscriptBox["\[Epsilon]", 
             RowBox[{
               StyleBox["i", "TI"], 
               StyleBox["j", "TI"]}], "\[PlusMinus]"], 
            RowBox[{"(", 
              OverscriptBox[
               StyleBox["q", "TI"], "\[RightVector]"], ")"}], 
            SuperscriptBox["\[Sigma]", 
             StyleBox["j", "TI"]], "+", 
            FractionBox["1", "2"], 
            SuperscriptBox["\[Sigma]", 
             StyleBox["i", "TI"]], 
            SubsuperscriptBox["\[Epsilon]", 
             RowBox[{
               StyleBox["i", "TI"], 
               StyleBox["j", "TI"]}], "\[PlusMinus]"], 
            RowBox[{"(", 
              OverscriptBox[
               StyleBox["q", "TI"], "\[RightVector]"], ")"}], 
            SuperscriptBox["\[Sigma]", 
             StyleBox["j", "TI"]], 
            SubscriptBox[
             OverscriptBox["\[Sigma]", "_"], 
             StyleBox["a", "TI"]], 
            SuperscriptBox[
             StyleBox["q", "TI"], 
             StyleBox["a", "TI"]]}], "]"}], 
        SubsuperscriptBox["\[Xi]", 
         OverscriptBox["\[Omega]", "\[RightVector]"], "-"]}], 
      TraditionalForm], "errors" -> {}, "input" -> 
    "\\qty(C^\\pm_{1/2})_{\\text{LH}} = \
\\frac{1}{2}\\sqrt{2k^0}\\sqrt{2\\omega^0} \\qty(\\xi_{\\vec{k}}^-)^\\dagger \
\\qty[\\omega^i \\epsilon^\\pm_{ij}(\\vec{q}) \\sigma^j + \
\\frac{1}{2}\\sigma^i \\epsilon^\\pm_{ij}(\\vec{q}) \\sigma^j  \
\\bar{\\sigma}_a q^a]\\xi_{\\vec{\\omega}}^-", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"3476914f-c957-4b81-bfae-5c7fd575a3e7"]], \
