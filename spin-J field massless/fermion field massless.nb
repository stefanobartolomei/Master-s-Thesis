          RowBox[{"Conjugate", "[", "spinorK", "]"}], ".", "M", ".", 
          "spinor\[Omega]"}]}], ",", " ", 
        RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ResultC", " ", "=", " ", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"C", "/.", " ", "substitution\[Theta]"}], ",", " ", 
        RowBox[{"Assumptions", "->", 
