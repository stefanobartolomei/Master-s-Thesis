Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox[
         StyleBox["B", "TI"], 
         RowBox[{"1", "/", "2"}], "Left-handed"], "\[LongEqual]", 
        SubscriptBox["\[Delta]", "\[Mu]\[Nu]"], 
        FractionBox["1", "2"], 
        SqrtBox[
         RowBox[{"2", 
           SuperscriptBox[
            StyleBox["k", "TI"], "0"]}]], 
        SqrtBox[
         RowBox[{"2", 
           SuperscriptBox["\[Omega]", "0"]}]], 
        SubsuperscriptBox["\[Xi]", 
         OverscriptBox[
          StyleBox["k", "TI"], "\[RightVector]"], "-*"], 
        RowBox[{"[", 
          RowBox[{"-", 
            SuperscriptBox[
             OverscriptBox["\[Sigma]", "_"], "\[Nu]"], 
            SuperscriptBox["\[Omega]", "\[Mu]"], "+", 
            FractionBox["1", "2"], 
            RowBox[{"(", 
              RowBox[{
                SuperscriptBox[
                 OverscriptBox["\[Sigma]", "_"], "\[Mu]"], 
                SuperscriptBox[
                 StyleBox["q", "TI"], "\[Nu]"], "-", 
                SuperscriptBox[
                 OverscriptBox["\[Sigma]", "_"], "\[Mu]"], 
                SuperscriptBox["\[Sigma]", "\[Nu]"], 
                SubscriptBox[
                 OverscriptBox["\[Sigma]", "_"], 
                 StyleBox["a", "TI"]], 
                SuperscriptBox[
                 StyleBox["q", "TI"], 
                 StyleBox["a", "TI"]]}], ")"}]}], "]"}], 
        SubsuperscriptBox["\[Xi]", 
         OverscriptBox["\[Omega]", "\[RightVector]"], "-"]}], 
      TraditionalForm], "errors" -> {}, "input" -> 
    "B_{1/2}^{\\text{Left-handed}} =  \\delta_{\\mu \\nu} \
