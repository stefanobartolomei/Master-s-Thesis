Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Ccoeff", "[", 
    RowBox[{"\[Epsilon]q_", ",", "\[Epsilon]\[Omega]_", ",", "\[Epsilon]K_"}],
     "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"C", ",", "ResultC"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"C", " ", "=", " ", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\[Epsilon]\[Omega]", " ", ".", " ", "\[Epsilon]K"}], 
            ")"}], "*", 
           RowBox[{"(", 
            RowBox[{"\[Omega]", ".", "\[Epsilon]q", ".", "K"}], ")"}]}], "-", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"K", ".", "\[Epsilon]\[Omega]"}], ")"}], "*", 
           RowBox[{"(", 
            RowBox[{"\[Omega]", ".", "\[Epsilon]q", ".", "\[Epsilon]K"}], 
            ")"}]}], " ", "-", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\[Omega]", ".", "\[Epsilon]K"}], ")"}], "*", 
           RowBox[{"(", 
            RowBox[{"K", ".", "\[Epsilon]q", ".", "\[Epsilon]\[Omega]"}], 
            ")"}]}], " ", "-", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"eta", ".", "\[Omega]mu"}], ")"}], ".", "Kmu"}], ")"}], 
           "*", 
           RowBox[{"(", 
            RowBox[{
            "\[Epsilon]\[Omega]", ".", "\[Epsilon]q", ".", "\[Epsilon]K"}], 
            ")"}]}]}], ",", " ", 
         RowBox[{"Assumptions", " ", "->", " ", "assumps2"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ResultC", "=", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"C", "/.", "substitution\[Theta]2"}], ",", 
         RowBox[{"Assumptions", "->", 
          RowBox[{"\[CapitalOmega]", ">", "0"}]}]}], "]"}]}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
