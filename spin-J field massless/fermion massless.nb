             StyleBox["q", "TI"], ",", 
             SubscriptBox[
              StyleBox["q", "TI"], "0"], ",", "\[Theta]"}], ")"}], 
         "\[Congruent]", 
         FractionBox[
          OverscriptBox[
           StyleBox["k", "TI"], "~"], 
          SqrtBox[
           RowBox[{
             SuperscriptBox[
              OverscriptBox[
