Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Bcoeff", "[", 
    RowBox[{
    "spinor\[Omega]_", ",", "spinorK_", ",", "matrix1_", ",", " ", "matrix2_",
      ",", "fourmomentum_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"prodmatrix", ",", "M", ",", "B", ",", "ResultB"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"prodmatrix", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"matrix1", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ".", 
         RowBox[{"matrix2", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], " ", "-", " ", 
        RowBox[{
         RowBox[{"matrix1", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ".", 
         RowBox[{"matrix2", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "  ", "-", " ", 
        RowBox[{
         RowBox[{"matrix1", "[", 
          RowBox[{"[", "3", "]"}], "]"}], ".", 
         RowBox[{"matrix2", "[", 
          RowBox[{"[", "3", "]"}], "]"}]}], "  ", "-", " ", 
        RowBox[{
         RowBox[{"matrix1", "[", 
          RowBox[{"[", "4", "]"}], "]"}], ".", 
         RowBox[{"matrix2", "[", 
          RowBox[{"[", "4", "]"}], "]"}]}]}]}], " ", ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"M", " ", "=", " ", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"fourmomentum", ".", "matrix1"}]}], " ", "+", " ", 
        RowBox[{
         FractionBox["1", "2"], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Qmu", ".", "matrix1"}], " ", "-", " ", 
           RowBox[{"prodmatrix", ".", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"eta", ".", "Qmu"}], ")"}], ".", "matrix1"}], 
             ")"}]}]}], ")"}]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"B", " ", "=", " ", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], 
          SqrtBox[
           RowBox[{"2", 
            RowBox[{"\[Omega]mu", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}]], 
          SqrtBox[
           RowBox[{"2", 
            RowBox[{"Kmu", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}]], " ", 
          RowBox[{
           RowBox[{"Conjugate", "[", "spinorK", "]"}], ".", "M", ".", 
           "spinor\[Omega]"}]}], ",", " ", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ResultB", " ", "=", " ", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{"B", " ", "/.", " ", "substitution\[Theta]"}], ",", " ", 
         RowBox[{"Assumptions", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"k", ">", "0"}], ",", 
            RowBox[{"q", ">", "0"}], ",", 
            RowBox[{"\[CapitalOmega]", ">", "0"}]}], "}"}]}]}], "]"}]}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
