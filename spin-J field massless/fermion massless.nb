            RowBox[{"\[Epsilon]q", ".", "momentum"}], ")"}]}], " ", "+", " ", 
          RowBox[{
           FractionBox["1", "2"], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"-", 
               RowBox[{"(", 
                RowBox[{"\[Epsilon]q", ".", "vec\[Sigma]"}], ")"}]}], 
              RowBox[{"(", 
               RowBox[{"Q", ".", "Q"}], ")"}]}], " ", "+", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"\[Epsilon]q", ".", "vec\[Sigma]"}], ")"}], ".", 
              RowBox[{"(", 
               RowBox[{"Q", ".", "vec\[Sigma]"}], ")"}], ".", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"(", 
