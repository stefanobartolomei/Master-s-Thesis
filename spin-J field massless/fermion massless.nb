     SqrtBox[
      RowBox[{"2", "-", 
       FractionBox[
        RowBox[{"4", " ", "q"}], 
        RowBox[{"k", "+", "q", "+", "\[CapitalOmega]"}]]}]]}]]}],
  SequenceForm[
  "\n \!\(\*SuperscriptBox[\(C\), \(+\)]\) = ", 
