              SuperscriptBox[
               StyleBox["f", "TI"], "\[Prime]"], 
              RowBox[{"(", 
                OverscriptBox[
                 StyleBox["k", "TI"], "~"], ")"}]}]}, "Abs"]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "F_J(M,q,q_0,\\theta) \\equiv \\frac{\\tilde{k}}{ \\sqrt{ \\tilde{k}^2 + \
q^2 -2q\\tilde{k}\\cos\\theta}} \\frac{\\qty|\\mathcal{M}_J \
\\qty[M,q_0,q,\\theta]|^2}{|f'(\\tilde{k})|}", "state" -> "Boxes"|>,
