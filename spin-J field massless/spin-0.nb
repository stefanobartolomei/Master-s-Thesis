     RowBox[{
      RowBox[{"{", 
       RowBox[{"fk", ",", "ResultF"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"fk", " ", "=", 
        RowBox[{"k", " ", "+", " ", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"k", "^", "2"}], " ", "+", " ", 
           RowBox[{"q", "^", "2"}], " ", "-", " ", 
           RowBox[{"2", "q", " ", "k", " ", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "]"}], " ", "-", " ", 
         "q0"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ResultF", " ", "=", " ", 
