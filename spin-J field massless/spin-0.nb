                StyleBox["M", "TI"], ",", 
                SubscriptBox[
                 StyleBox["q", "TI"], "0"], ",", 
                StyleBox["q", "TI"], ",", "\[Theta]"}], "]"}], 
            SuperscriptBox["|", "2"]}], 
