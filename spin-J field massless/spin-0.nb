Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Definition", " ", "for", " ", "the", " ", "Matrix", " ", "operator", " ",
      "of", " ", "the", " ", "angular", " ", "momentum", " ", "in", " ", 
     "3"}], "-", 
    RowBox[{"dim", " ", "representation"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"J", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"(", GridBox[{
          {"0", "0", "0"},
          {"0", "0", 
           RowBox[{"-", "I"}]},
          {"0", "I", "0"}
         }], ")"}], ",", 
       RowBox[{"(", GridBox[{
          {"0", "0", "I"},
          {"0", "0", "0"},
          {
           RowBox[{"-", "I"}], "0", "0"}
         }], ")"}], ",", 
       RowBox[{"(", GridBox[{
          {"0", 
           RowBox[{"-", "I"}], "0"},
          {"I", "0", "0"},
          {"0", "0", "0"}
         }], ")"}]}], "}"}]}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Jz", " ", "=", " ", 
     RowBox[{"J", ".", "z"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol", " ", "=", " ", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"Eigensystem", "[", "Jz", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]PlusQ", "=", 
     RowBox[{"Normalize", "[", 
      RowBox[{"sol", "[", 
       RowBox[{"[", 
        RowBox[{"2", ",", "2"}], "]"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]MinusQ", " ", "=", 
     RowBox[{"Normalize", "[", 
      RowBox[{"sol", "[", 
       RowBox[{"[", 
