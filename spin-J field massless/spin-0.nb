Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"\\n \\!\\(\\*SubscriptBox[SuperscriptBox[\\(V\\), \\(+\\)], \
\\(\[Xi]\\)]\\) = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{"k", " ", 
     RowBox[{"(", 
      RowBox[{"k", "-", "\[CapitalOmega]"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{"k", "+", "\[CapitalOmega]"}], ")"}], " ", 
     SqrtBox[
      RowBox[{"1", "-", 
       FractionBox[
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["k", "2"], "+", 
           SuperscriptBox["q", "2"], "-", 
           SuperscriptBox["\[CapitalOmega]", "2"]}], ")"}], "2"], 
        RowBox[{"4", " ", 
         SuperscriptBox["k", "2"], " ", 
         SuperscriptBox["q", "2"]}]]}]], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "\[ImaginaryI]"}], " ", 
        RowBox[{"Cos", "[", "\[Phi]", "]"}]}], "+", 
       RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ")"}]}], 
    SqrtBox["2"]]}],
  SequenceForm[
  "\n \!\(\*SubscriptBox[SuperscriptBox[\(V\), \(+\)], \(\[Xi]\)]\) = ", 
   2^Rational[-1, 
      2] $CellContext`k ($CellContext`k - $CellContext`\[CapitalOmega]) \
($CellContext`k + $CellContext`\[CapitalOmega]) (1 + 
     Rational[-1, 
        4] $CellContext`k^(-2) $CellContext`q^(-2) ($CellContext`k^2 + \
$CellContext`q^2 - $CellContext`\[CapitalOmega]^2)^2)^Rational[1, 2] (
    Complex[0, -1] Cos[$CellContext`\[Phi]] + Sin[$CellContext`\[Phi]])],
  Editable->False]], "Print",
 CellChangeTimes->{3.9769744826730194`*^9, 3.9769752386757526`*^9, 
