Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"IntegratResult", "[", "Amplitude_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "fk", ",", " ", "F\[Xi]", ",", " ", "IntF\[Xi]", ",", 
       "\[CapitalGamma]\[Xi]"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"fk", " ", "=", 
       RowBox[{"k", " ", "+", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"k", "^", "2"}], " ", "+", " ", 
          RowBox[{"q", "^", "2"}], " ", "-", " ", 
          RowBox[{"2", "q", " ", "k", " ", 
           RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "]"}], " ", "-", " ", 
        "q0"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"F\[Xi]", " ", "=", " ", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           FractionBox["k", 
            SqrtBox[
             RowBox[{
              RowBox[{"k", "^", "2"}], " ", "+", " ", 
              RowBox[{"q", "^", "2"}], " ", "-", " ", 
              RowBox[{"2", " ", "q", " ", "k", " ", 
               RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]]], 
           FractionBox["Amplitude", 
            RowBox[{"Abs", "[", 
             RowBox[{"D", "[", 
              RowBox[{"fk", ",", "k"}], "]"}], "]"}]]}], "/.", " ", 
          RowBox[{"k", "->", 
           FractionBox[
            RowBox[{
             RowBox[{"(", 
              RowBox[{"q", "-", "q0"}], ")"}], " ", 
             RowBox[{"(", 
              RowBox[{"q", "+", "q0"}], ")"}]}], 
            RowBox[{
             RowBox[{
              RowBox[{"-", "2"}], " ", "q0"}], "+", 
             RowBox[{"2", " ", "q", " ", 
              RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]]}]}], ",", " ", 
         RowBox[{"Assumptions", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"q", ">", "0"}], ",", 
            RowBox[{"0", "<", "\[Theta]", "<", "\[Pi]"}], ",", 
            RowBox[{"q0", ">", "q"}]}], "}"}]}]}], "]"}]}], ";", 
      RowBox[{"IntF\[Xi]", "=", 
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{"F\[Xi]", " ", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Theta]", ",", "0", ",", "\[Pi]"}], "}"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"\[CapitalGamma]\[Xi]", " ", "=", " ", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], 
          FractionBox["1", 
           RowBox[{"8", " ", "\[Pi]", " "}]], "IntF\[Xi]"}], ",", " ", 
         RowBox[{"Assumptions", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"q", ">", "0"}], ",", 
            RowBox[{"q0", ">", "q"}]}], "}"}]}]}], "]"}]}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
