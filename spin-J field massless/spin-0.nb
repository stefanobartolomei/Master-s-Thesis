 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["F", "TI"], 
          StyleBox["J", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["M", "TI"], ",", 
             StyleBox["q", "TI"], ",", 
             SubscriptBox[
              StyleBox["q", "TI"], "0"], ",", "\[Theta]"}], ")"}], 
         "\[Congruent]", 
         FractionBox[
          OverscriptBox[
           StyleBox["k", "TI"], "~"], 
          SqrtBox[
           RowBox[{
             SuperscriptBox[
              OverscriptBox[
               StyleBox["k", "TI"], "~"], "2"], "+", 
             SuperscriptBox[
              StyleBox["q", "TI"], "2"], "-", "2", 
             StyleBox["q", "TI"], 
             OverscriptBox[
              StyleBox["k", "TI"], "~"], "cos", "\[Theta]"}]]], 
         FractionBox[
