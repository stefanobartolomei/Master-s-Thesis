             SubscriptBox[
              StyleBox["q", "TI"], "0"], ",", "\[Theta]"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\Gamma = \\frac{1}{16\\pi \\sqrt{q_0^2 - q^2}}\\int_0^\\pi d\\theta \\ \
