Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"For", " ", "spatial", " ", "momentum", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          OverscriptBox[
           StyleBox["q", "TI"], "\[RightVector]"], "\[LongEqual]", "|", 
          OverscriptBox[
           StyleBox["q", "TI"], "\[RightVector]"], "|", 
          OverscriptBox[
           StyleBox["z", "TI"], "^"]}], TraditionalForm], "errors" -> {}, 
      "input" -> "\\vec{q} = |\\vec{q}| \\hat{z}", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"matrixPlus", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}], "*", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "I", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"I", ",", 
          RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"matrixMinus", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}], "*", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"-", "I"}], ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "I"}], ",", 
          RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], "}"}]}]}], 
    ";"}]}]}]], "Input",
