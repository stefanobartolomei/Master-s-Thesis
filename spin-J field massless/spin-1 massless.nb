Cell[CellGroupData[{

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["C", "TI"], "1", 
          RowBox[{"+", ",", "\[MinusPlus]\[PlusMinus]"}]], "\[LongEqual]", 
         RowBox[{"(", 
           RowBox[{
             SubsuperscriptBox[
              OverscriptBox["\[Epsilon]", "\[RightVector]"], 
              OverscriptBox["\[Omega]", "\[RightVector]"], 
              RowBox[{" ", "\[MinusPlus]", "*"}]], "\[CenterDot]", 
             SubsuperscriptBox[
              OverscriptBox["\[Epsilon]", "\[RightVector]"], 
              OverscriptBox[
               StyleBox["k", "TI"], "\[RightVector]"], 
              RowBox[{" ", "\[PlusMinus]", "*"}]]}], ")"}], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              OverscriptBox["\[Omega]", "\[RightVector]"], 
              StyleBox["T", "TI"]], "\[CenterDot]", 
             SubsuperscriptBox["\[Epsilon]", "3", "\[PlusMinus]"], 
             "\[CenterDot]", 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"]}], ")"}], "-", 
         RowBox[{"(", 
           RowBox[{
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], "\[CenterDot]", 
             SubsuperscriptBox[
              OverscriptBox["\[Epsilon]", "\[RightVector]"], 
              OverscriptBox["\[Omega]", "\[RightVector]"], 
              RowBox[{" ", "\[MinusPlus]", "*"}]]}], ")"}], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              OverscriptBox["\[Omega]", "\[RightVector]"], 
              StyleBox["T", "TI"]], "\[CenterDot]", 
             SubsuperscriptBox["\[Epsilon]", "3", "\[PlusMinus]"], 
             "\[CenterDot]", 
             SubsuperscriptBox[
              OverscriptBox["\[Epsilon]", "\[RightVector]"], 
              OverscriptBox[
               StyleBox["k", "TI"], "\[RightVector]"], 
              RowBox[{" ", "\[PlusMinus]", "*"}]]}], ")"}], "-", 
         RowBox[{"(", 
           RowBox[{
             OverscriptBox["\[Omega]", "\[RightVector]"], "\[CenterDot]", 
             SubsuperscriptBox[
              OverscriptBox["\[Epsilon]", "\[RightVector]"], 
              OverscriptBox[
               StyleBox["k", "TI"], "\[RightVector]"], 
              RowBox[{" ", "\[PlusMinus]", "*"}]]}], ")"}], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              OverscriptBox[
               StyleBox["k", "TI"], "\[RightVector]"], 
              StyleBox["T", "TI"]], "\[CenterDot]", 
             SubsuperscriptBox["\[Epsilon]", "3", "\[PlusMinus]"], 
             "\[CenterDot]", 
             SubsuperscriptBox[
              OverscriptBox["\[Epsilon]", "\[RightVector]"], 
              OverscriptBox["\[Omega]", "\[RightVector]"], 
              RowBox[{" ", "\[MinusPlus]", "*"}]]}], ")"}], "-", 
         RowBox[{"(", 
           RowBox[{"\[Omega]", "\[CenterDot]", 
             StyleBox["k", "TI"]}], ")"}], 
         RowBox[{"(", 
           RowBox[{
             SubsuperscriptBox[
              OverscriptBox["\[Epsilon]", "\[RightVector]"], 
              OverscriptBox["\[Omega]", "\[RightVector]"], 
              RowBox[{" ", "\[MinusPlus]", "* ", 
                StyleBox["T", "TI"]}]], "\[CenterDot]", 
             SubsuperscriptBox["\[Epsilon]", "3", "\[PlusMinus]"], 
             "\[CenterDot]", 
             SubsuperscriptBox[
