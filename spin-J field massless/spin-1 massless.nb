Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["F", "TI"], 
          StyleBox["J", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["q", "TI"], ",", 
             SubscriptBox[
              StyleBox["q", "TI"], "0"], ",", "\[Theta]"}], ")"}], 
         "\[Congruent]", 
         FractionBox[
          OverscriptBox[
           StyleBox["k", "TI"], "~"], 
          SqrtBox[
           RowBox[{
             SuperscriptBox[
              OverscriptBox[
               StyleBox["k", "TI"], "~"], "2"], "+", 
             SuperscriptBox[
              StyleBox["q", "TI"], "2"], "-", "2", 
             StyleBox["q", "TI"], 
             OverscriptBox[
              StyleBox["k", "TI"], "~"], "cos", "\[Theta]"}]]], 
         FractionBox[
          RowBox[{"|", 
            SubscriptBox[
             StyleBox["M", "TI"], 
             StyleBox["J", "TI"]], 
            RowBox[{"[", 
              RowBox[{
                SubscriptBox[
                 StyleBox["q", "TI"], "0"], ",", 
                StyleBox["q", "TI"], ",", "\[Theta]"}], "]"}], 
            SuperscriptBox["|", "2"]}], 
          TemplateBox[{
            RowBox[{
              SuperscriptBox[
               StyleBox["f", "TI"], "\[Prime]"], 
              RowBox[{"(", 
                OverscriptBox[
                 StyleBox["k", "TI"], "~"], ")"}]}]}, "Abs"]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "F_J(q,q_0,\\theta) \\equiv \\frac{\\tilde{k}}{ \\sqrt{ \\tilde{k}^2 + \
q^2 -2q\\tilde{k}\\cos\\theta}} \\frac{\\qty|\\mathcal{M}_J \
\\qty[q_0,q,\\theta]|^2}{|f'(\\tilde{k})|}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "84fdc72e-1b6d-45ef-94d8-5039640444ab"],
