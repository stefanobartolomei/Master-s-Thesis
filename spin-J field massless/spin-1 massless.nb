         StyleBox["k", "TI"], "+", 
         SqrtBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["k", "TI"], "2"], "+", 
            SuperscriptBox[
             StyleBox["q", "TI"], "2"], "-", "2", 
            StyleBox["q", "TI"], 
            StyleBox["k", "TI"], "cos", "\[Theta]"}]], "-", 
         SubscriptBox[
          StyleBox["q", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "f(k) =k+ \\sqrt{k^2 + q^2 -2qk\\cos\\theta} - q_0", "state" -> 
