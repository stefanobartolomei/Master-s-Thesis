Cell[CellGroupData[{

Cell[TextData[{
 "Check that for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox["\[Alpha]", "sol"], " ", ", ", 
          SubscriptBox["\[Beta]", "sol"]}], TraditionalForm], "errors" -> {}, 
      "input" -> "\\alpha_{\\text{sol}} \\ , \\ \\beta_{\\text{sol}}", 
      "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "7567894a-d94d-4760-9472-eaadb205908b"],
 " the Rotation matrix is such that: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         OverscriptBox[
          StyleBox["q", "TI"], "\[RightVector]"], "|", 
         StyleBox["R", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[Alpha]", "sol"], ",", 
             SubscriptBox["\[Beta]", "sol"]}], ")"}], 
         OverscriptBox[
          StyleBox["z", "TI"], "^"], "\[LongEqual]", 
         OverscriptBox["\[Omega]", "\[RightVector]"], "+", 
         OverscriptBox[
          StyleBox["k", "TI"], "\[RightVector]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "|\\vec{q}| R(\\alpha_{\\text{sol}}, \\beta_{\\text{sol}}) \\hat{z}  = \
\\vec{\\omega} + \\vec{k}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "af6efd65-d3d4-4da3-932a-7c7084a33263"],
 " "
}], "Subsubsection",
