     RowBox[{"B1_", ",", "B2_"}], "]"}], ":=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"B1", "/", "B2"}], ",", " ", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"k", ">", "0"}], ",", 
