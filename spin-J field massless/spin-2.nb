Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubscriptBox["\[Delta]", "\[Mu]\[Nu]"], 
        SuperscriptBox[
         StyleBox["A", "TI"], "\[Mu]"], 
        SuperscriptBox[
         StyleBox["B", "TI"], "\[Nu]"], "\[LongEqual]", 
        StyleBox["A", "TI"], ".", 
        StyleBox["B", "TI"], "    ", ",    ", 
        SubscriptBox["\[Delta]", "\[Mu]\[Nu]"], 
        SuperscriptBox["\[Eta]", "\[Mu]\[Nu]"], "\[LongEqual]", "-2"}], 
      TraditionalForm], "errors" -> {}, "input" -> 
    "\\delta_{\\mu \\nu}A^\\mu B^\\nu = A.B \\qquad , \\qquad \\delta_{\\mu \
