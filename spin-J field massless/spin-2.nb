Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox["\[Epsilon]", 
         RowBox[{
           StyleBox["i", "TI"], 
           StyleBox["j", "TI"]}], "\[PlusMinus]"], 
        RowBox[{"(", 
          RowBox[{
            OverscriptBox["\[Omega]", "\[RightVector]"], "\[LongEqual]", 
            OverscriptBox[
             StyleBox["q", "TI"], "\[RightVector]"], "-", 
            OverscriptBox[
             StyleBox["k", "TI"], "\[RightVector]"], "\[LongEqual]", "|", 
            OverscriptBox["\[Omega]", "\[RightVector]"], "|", 
            StyleBox["R", "TI"], 
            RowBox[{"(", 
              RowBox[{"\[Alpha]", ",", "\[Beta]"}], ")"}], 
            OverscriptBox[
             StyleBox["z", "TI"], "^"]}], ")"}], "\[LongEqual]", 
        StyleBox["R", "TI"], 
        RowBox[{"(", 
          RowBox[{"\[Alpha]", ",", "\[Beta]"}], ")"}], 
        SubsuperscriptBox["\[Epsilon]", "3", "\[PlusMinus]"], 
        SuperscriptBox[
         RowBox[{"(", 
           RowBox[{
             StyleBox["R", "TI"], "(", 
             RowBox[{"\[Alpha]", ",", "\[Beta]"}], ")"}], ")"}], 
         StyleBox["T", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
    "\\epsilon^\\pm_{ij}\\qty(\\vec{\\omega} =  \\vec{q} - \\vec{k} = |\\vec{\
