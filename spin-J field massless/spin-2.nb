        RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]]], "]"}]}],
  SequenceForm["(Polar) \[Beta] = ", 
   ArcCos[(-$CellContext`k + $CellContext`q 
      Cos[$CellContext`\[Theta]]) ($CellContext`k^2 + $CellContext`q^2 - 
