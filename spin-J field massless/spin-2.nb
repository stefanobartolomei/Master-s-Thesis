  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox[
         StyleBox["D", "TI"], "2", 
         SuperscriptBox["\[Lambda]\[Lambda]", "\[Prime]"]], "\[LongEqual]", 
        SubscriptBox["\[Eta]", "\[Mu]\[Nu]"], 
        RowBox[{"[", 
          RowBox[{"-", 
            SuperscriptBox["\[Omega]", "\[Mu]"], 
            SuperscriptBox[
             StyleBox["k", "TI"], "\[Nu]"], "+", 
