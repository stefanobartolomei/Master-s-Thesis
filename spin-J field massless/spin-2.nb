Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalGamma]", "\[LongEqual]", 
         FractionBox["1", 
          RowBox[{"16", "\[Pi]", 
            SqrtBox[
             RowBox[{
               SubsuperscriptBox[
                StyleBox["q", "TI"], "0", "2"], "-", 
               SuperscriptBox[
                StyleBox["q", "TI"], "2"]}]]}]], 
         SubsuperscriptBox["\[Integral]", "0", "\[Pi]"], 
         StyleBox["d", "TI"], "\[Theta] ", "sin", "\[Theta] ", 
         SubscriptBox[
          StyleBox["F", "TI"], 
          StyleBox["J", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["M", "TI"], ",", 
             SubscriptBox[
              StyleBox["q", "TI"], ","], 
             SubscriptBox[
              StyleBox["q", "TI"], "0"], ",", "\[Theta]"}], ")"}]}], 
