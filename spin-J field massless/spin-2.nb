          RowBox[{"-", "2"}], "*", "k", "*", "q"}], ")"}]}], "]"}]}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"assumps2", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"k", ">", "0"}], ",", 
       RowBox[{"q", ">", "0"}], ",", 
       RowBox[{"0", "<", "\[Theta]", "<", "\[Pi]"}], ",", 
       RowBox[{"0", "<", "\[Phi]", "<", 
        RowBox[{"2", "\[Pi]"}]}]}], "}"}]}], ";"}]}]}]], "Input",
