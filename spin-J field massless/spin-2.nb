   RowBox[{"ArcCos", "[", 
    FractionBox[
     RowBox[{
      RowBox[{"-", "k"}], "+", 
      RowBox[{"q", " ", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], 
     SqrtBox[
      RowBox[{
       SuperscriptBox["k", "2"], "+", 
       SuperscriptBox["q", "2"], "-", 
