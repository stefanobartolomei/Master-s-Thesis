Cell[CellGroupData[{

Cell[TextData[{
 "Finding angles ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Alpha] ", ", ", "\[Beta]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\alpha \\ , \\ \\beta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "088d9811-0142-4d1e-9f95-f54734b1b22b"]
}], "Subsubsection",
