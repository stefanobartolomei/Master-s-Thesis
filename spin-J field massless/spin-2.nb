 RowBox[{
  RowBox[{"Mh", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"2", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", "ResultCPPP", "]"}], "*", "ResultCPPP"}], 
        " ", "+", "  ", 
        RowBox[{
         RowBox[{"Conjugate", "[", "ResultCPPM", "]"}], "*", "ResultCPPM"}], 
        " ", "+", 
        RowBox[{
         RowBox[{"Conjugate", "[", "ResultCPMP", "]"}], "*", "ResultCPMP"}], "+",
         " ", 
        RowBox[{
         RowBox[{"Conjugate", "[", "ResultCPMM", "]"}], "*", "ResultCPMM"}]}],
        " ", ")"}]}], ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"M", ">", "0"}], ",", 
        RowBox[{"k", ">", "0"}], ",", 
        RowBox[{"q", ">", "0"}], ",", 
        RowBox[{"\[CapitalOmega]", ">", "0"}], ",", 
        RowBox[{"0", "<", "\[Phi]", "<", 
         RowBox[{"2", "\[Pi]"}]}]}], "}"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Mhsub\[CapitalOmega]", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Mh", "/.", " ", 
      RowBox[{"\[CapitalOmega]", "->", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"k", "^", "2"}], " ", "+", " ", 
         RowBox[{"q", "^", "2"}], " ", "-", " ", 
         RowBox[{"2", " ", "k", " ", "q", " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "]"}]}]}], ",", " ", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"M", ">", "0"}], ",", 
        RowBox[{"k", ">", "0"}], ",", 
        RowBox[{"q", ">", "0"}], ",", 
        RowBox[{"0", "<", "\[Theta]", "<", "\[Pi]"}]}], "}"}]}]}], "]"}]}], 
