Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Dcoeff", "[", 
    RowBox[{"\[Epsilon]\[Omega]_", ",", "\[Epsilon]K_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"D", ",", "ResultD"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"D", " ", "=", " ", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"eta", ".", "\[Omega]mu"}], ")"}], ".", "Kmu"}], 
              ")"}]}], " ", "+", " ", 
            RowBox[{"2", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"eta", ".", "\[Omega]mu"}], ")"}], ".", "Kmu"}], 
              ")"}]}]}], ")"}], "*", 
          RowBox[{"Tr", "[", 
           RowBox[{"\[Epsilon]\[Omega]", ".", "\[Epsilon]K"}], "]"}]}], ",", 
         " ", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ResultD", "=", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"D", "/.", " ", "substitution\[Theta]"}], ")"}], "/.", " ", 
          RowBox[{"omega", "->", "\[CapitalOmega]"}]}], ",", " ", 
         RowBox[{"Assumptions", "->", 
          RowBox[{"q", ">", "0"}]}]}], "]"}]}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
