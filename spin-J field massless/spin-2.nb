Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Epsilon]", 
          OverscriptBox["\[Omega]", "\[RightVector]"], "\[PlusMinus]"], 
         "\[LongEqual]", 
         SubsuperscriptBox["\[Epsilon]", "3", "\[PlusMinus]"]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\epsilon_{\\vec{\\omega}}^\\pm = \\epsilon_3^\\pm", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Epsilon]Plus\[Omega]", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}], "*", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "I", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"I", ",", 
          RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]Minus\[Omega]", " ", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}], "*", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"-", "I"}], ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "I"}], ",", 
          RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubsuperscriptBox["\[Epsilon]", 
           OverscriptBox[
            StyleBox["k", "TI"], "\[RightVector]"], "\[PlusMinus]"], 
          "\[LongEqual]", 
          StyleBox["R", "TI"], 
          RowBox[{"(", 
            RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}], 
          SubsuperscriptBox["\[Epsilon]", "3", "\[PlusMinus]"], 
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{
               StyleBox["R", "TI"], "(", 
               RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}], ")"}], 
           StyleBox["T", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
      "\\epsilon_{\\vec{k}}^\\pm = R(\\theta,\\phi)\\epsilon_3^\\pm \
\\qty(R(\\theta,\\phi))^T", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]PlusK", "=", " ", 
     RowBox[{"R", ".", "\[Epsilon]Plus\[Omega]", ".", 
      RowBox[{"Transpose", "[", "R", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]MinusK", " ", "=", " ", 
     RowBox[{"R", ".", "\[Epsilon]Minus\[Omega]", ".", 
      RowBox[{"Transpose", "[", "R", "]"}]}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.972408070326768*^9, 3.9724082588265457`*^9}, {
