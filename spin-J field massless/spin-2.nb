   FractionBox[
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"k", "-", "q", "+", "\[CapitalOmega]"}], ")"}], "2"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"k", "+", "q", "+", "\[CapitalOmega]"}], ")"}], "2"]}], 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"k", "+", "q", "-", "\[CapitalOmega]"}], ")"}], "2"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "k"}], "+", "q", "+", "\[CapitalOmega]"}], ")"}], 
      "2"]}]]}],
  SequenceForm[
  "\n (should NOT be a phase factor): ", ($CellContext`k + $CellContext`q - \
$CellContext`\[CapitalOmega])^(-2) ($CellContext`k - $CellContext`q + \
$CellContext`\[CapitalOmega])^2 (-$CellContext`k + $CellContext`q + \
$CellContext`\[CapitalOmega])^(-2) ($CellContext`k + $CellContext`q + \
