Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Rq", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", "\[Alpha]", "]"}], " ", 
        RowBox[{"Cos", "[", "\[Beta]", "]"}]}], ",", 
       RowBox[{"-", 
        RowBox[{"Sin", "[", "\[Alpha]", "]"}]}], ",", 
       RowBox[{
        RowBox[{"Cos", "[", "\[Alpha]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Beta]", "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Sin", "[", "\[Alpha]", "]"}], " ", 
        RowBox[{"Cos", "[", "\[Beta]", "]"}]}], ",", 
       RowBox[{"Cos", "[", "\[Alpha]", "]"}], ",", 
       RowBox[{
        RowBox[{"Sin", "[", "\[Alpha]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Beta]", "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Sin", "[", "\[Beta]", "]"}]}], ",", "0", ",", 
       RowBox[{"Cos", "[", "\[Beta]", "]"}]}], "}"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Qrot", "=", 
    RowBox[{
     RowBox[{"Norm", "[", "Q", "]"}], "*", 
     RowBox[{"(", 
      RowBox[{"Rq", ".", "z"}], ")"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"check\[Alpha]\[Beta]", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Qrot", "/.", " ", "solRule"}], ")"}], "-", " ", "Q"}], ",", 
     RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Check (should be zero) \!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{
RowBox[{\"[\", 
RowBox[{
OverscriptBox[
StyleBox[\"q\", \"TI\"], \"\[RightVector]\"], \"\[LongEqual]\", \"|\", 
OverscriptBox[
StyleBox[\"q\", \"TI\"], \"\[RightVector]\"], \"|\", 
StyleBox[\"R\", \"TI\"], 
RowBox[{\"(\", 
RowBox[{\"\[Alpha]\", \",\", \"\[Beta]\"}], \")\"}], 
OverscriptBox[
StyleBox[\"z\", \"TI\"], \"^\"]}], \"]\"}], \"-\", 
RowBox[{\"[\", 
RowBox[{
OverscriptBox[
StyleBox[\"q\", \"TI\"], \"\[RightVector]\"], \"\[LongEqual]\", 
OverscriptBox[\"\[Omega]\", \"\[RightVector]\"], \"+\", 
OverscriptBox[
StyleBox[\"k\", \"TI\"], \"\[RightVector]\"]}], \"]\"}], \"\[LongEqual]\"}], \
TraditionalForm], \"errors\" -> {}, \"input\" -> \"\\\\qty[\\\\vec{q} = \
|\\\\vec{q}|R(\\\\alpha,\\\\beta)\\\\hat{z}] - \\\\qty[\\\\vec{q} = \
\\\\vec{\\\\omega} + \\\\vec{k}] =\", \"state\" -> \
\"Boxes\"|>,\"TeXAssistantTemplate\"]\)  \>\"", ",", 
   RowBox[{"MatrixForm", "[", "check\[Alpha]\[Beta]", "]"}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.975499168994956*^9, 3.975499168994956*^9}, {
