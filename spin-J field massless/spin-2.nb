Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Momentum", " ", "definitions"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"K", "=", " ", 
     RowBox[{"k", "*", "z"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Q", "=", " ", 
     RowBox[{"q", "*", "n"}]}], ";"}], "          ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Omega]", " ", "=", " ", 
     RowBox[{"Q", "-", " ", "K"}]}], ";"}], "  ", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Kmu", " ", "=", " ", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", "k", "}"}], ",", " ", "K"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Omega]mu", " ", "=", " ", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", " ", 
        RowBox[{"Norm", "[", "\[Omega]", "]"}], "}"}], ",", " ", "\[Omega]"}],
       "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Qmu", " ", "=", " ", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Omega]mu", "[", 
          RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
         RowBox[{"Kmu", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "}"}], ",", "Q"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Rules", " ", "for", " ", "Substitute", " ", "and", " ", "Assumptions"}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"substitution\[Theta]2", " ", "=", " ", 
     RowBox[{"\[Theta]", "->", 
      RowBox[{"ArcCos", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[CapitalOmega]", "^", "2"}], " ", "-", " ", 
          RowBox[{"k", "^", "2"}], " ", "-", " ", 
          RowBox[{"q", "^", "2"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "2"}], "*", "k", "*", "q"}], ")"}]}], "]"}]}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"assumps2", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"k", ">", "0"}], ",", 
       RowBox[{"q", ">", "0"}], ",", 
       RowBox[{"0", "<", "\[Theta]", "<", "\[Pi]"}], ",", 
