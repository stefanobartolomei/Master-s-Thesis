             SubscriptBox["\[Alpha]", "sol"], ",", 
             SubscriptBox["\[Beta]", "sol"]}], ")"}], 
         OverscriptBox[
          StyleBox["z", "TI"], "^"], "\[LongEqual]", 
         OverscriptBox["\[Omega]", "\[RightVector]"], "+", 
         OverscriptBox[
          StyleBox["k", "TI"], "\[RightVector]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
