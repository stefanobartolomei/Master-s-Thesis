         RowBox[{"q", "^", "2"}], " ", "-", " ", 
         RowBox[{"2", " ", "k", " ", "q", " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "]"}]}]}], ",", " ", 
