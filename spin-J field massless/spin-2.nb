  RowBox[{
   RowBox[{
    RowBox[{"solAlpha", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"ArcTan", "[", 
        RowBox[{
         RowBox[{"\[Omega]", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"\[Omega]", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ",", 
       RowBox[{"Assumptions", "->", "assumps2"}]}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox["\[Alpha]", "sol"], "\[LongEqual]", "arctan", 
          RowBox[{"(", 
            FractionBox[
             SubscriptBox["\[Omega]", "1"], 
             SubscriptBox["\[Omega]", "2"]], ")"}]}], TraditionalForm], 
      "errors" -> {}, "input" -> 
      "\\alpha_{\\text{sol}} = \\arctan\\qty(\\frac{\\omega_1}{\\omega_2})", 
      "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"solBeta", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"ArcCos", "[", 
        RowBox[{
         RowBox[{"\[Omega]", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "/", 
         RowBox[{"Norm", "[", "\[Omega]", "]"}]}], "]"}], ",", 
       RowBox[{"Assumptions", "->", "assumps2"}]}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox["\[Beta]", "sol"], "\[LongEqual]", "arccos", 
          RowBox[{"(", 
            FractionBox[
             SubscriptBox["\[Omega]", "3"], 
             TemplateBox[{
               RowBox[{
                 OverscriptBox["\[Omega]", "\[RightVector]"]}]}, "Abs"]], 
            ")"}]}], TraditionalForm], "errors" -> {}, "input" -> 
      "\\beta_{\\text{sol}} = \
\\arccos\\qty(\\frac{\\omega_3}{|\\vec{\\omega}|})", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solRule", "=", 
     RowBox[{"{", 
      RowBox[{
