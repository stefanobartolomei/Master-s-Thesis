Cell[CellGroupData[{

Cell[TextData[{
 "Check that for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox["\[Alpha]", "sol"], " ", ", ", 
          SubscriptBox["\[Beta]", "sol"]}], TraditionalForm], "errors" -> {}, 
      "input" -> "\\alpha_{\\text{sol}} \\ , \\ \\beta_{\\text{sol}}", 
      "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "3eb6bd5c-e73e-4230-8fe7-ab0b6cfab7d5"],
 " the Rotation matrix is such that: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         OverscriptBox[
          StyleBox["q", "TI"], "\[RightVector]"], "|", 
         StyleBox["R", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[Alpha]", "sol"], ",", 
             SubscriptBox["\[Beta]", "sol"]}], ")"}], 
         OverscriptBox[
          StyleBox["z", "TI"], "^"], "\[LongEqual]", 
         OverscriptBox["\[Omega]", "\[RightVector]"], "+", 
         OverscriptBox[
          StyleBox["k", "TI"], "\[RightVector]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "|\\vec{q}| R(\\alpha_{\\text{sol}}, \\beta_{\\text{sol}}) \\hat{z}  = \
\\vec{\\omega} + \\vec{k}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d5ca7bee-7211-4b6e-b3eb-d3b386b759e9"],
 " "
}], "Subsubsection",
 CellChangeTimes->{{3.976274215279505*^9, 3.976274285508155*^9}, {
  3.9762743363565826`*^9, 
  3.9762743472210007`*^9}},ExpressionUUID->"8c3519a8-eed7-4fdf-8e6c-\
91a522a4bce8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"R\[Omega]", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", "\[Alpha]", "]"}], " ", 
        RowBox[{"Cos", "[", "\[Beta]", "]"}]}], ",", 
       RowBox[{"-", 
        RowBox[{"Sin", "[", "\[Alpha]", "]"}]}], ",", 
       RowBox[{
        RowBox[{"Cos", "[", "\[Alpha]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Beta]", "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Sin", "[", "\[Alpha]", "]"}], " ", 
        RowBox[{"Cos", "[", "\[Beta]", "]"}]}], ",", 
       RowBox[{"Cos", "[", "\[Alpha]", "]"}], ",", 
       RowBox[{
        RowBox[{"Sin", "[", "\[Alpha]", "]"}], " ", 
        RowBox[{"Sin", "[", "\[Beta]", "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Sin", "[", "\[Beta]", "]"}]}], ",", "0", ",", 
       RowBox[{"Cos", "[", "\[Beta]", "]"}]}], "}"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Omega]rot", "=", 
    RowBox[{
