Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox[
         StyleBox["B", "TI"], "2", 
         SuperscriptBox["\[Lambda]\[Lambda]", "\[Prime]"]], "\[LongEqual]", 
        SubscriptBox["\[Delta]", "\[Mu]\[Nu]"], 
        RowBox[{"[", 
          RowBox[{"-", 
            SuperscriptBox["\[Omega]", "\[Mu]"], 
            SuperscriptBox[
             StyleBox["k", "TI"], "\[Nu]"], "+", 
            FractionBox["1", "2"], 
            SuperscriptBox["\[Eta]", "\[Mu]\[Nu]"], 
            RowBox[{"(", 
              RowBox[{"\[Omega]", "\[CenterDot]", 
                StyleBox["k", "TI"]}], ")"}]}], "]"}], "Tr", 
        RowBox[{"[", 
          RowBox[{
            SubsuperscriptBox["\[Epsilon]", "1", 
             RowBox[{"\[Lambda]", "*"}]], 
            RowBox[{"(", "\[Omega]", ")"}], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", "2", 
             RowBox[{
               SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]], 
            RowBox[{"(", 
              StyleBox["k", "TI"], ")"}]}], "]"}]}], TraditionalForm], 
    "errors" -> {}, "input" -> 
    "B_2^{\\lambda\\lambda'} =\\delta_{\\mu \\nu}\\qty[- \\omega^\\mu k^\\nu+\
\\frac{1}{2} \\eta^{\\mu \\nu} \\qty(\\omega \\cdot k)] \
\\text{Tr}\\Big[\\epsilon^{\\lambda*}_1(\\omega) \\cdot \\epsilon^{\\lambda' \
*}_2(k)\\Big]", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"b7d5d0a6-d540-4d0f-a4b8-aa7360aff5de"]], \
"Chapter",
 CellChangeTimes->{{3.973055506430555*^9, 3.9730555137590146`*^9}, {
   3.973055544992835*^9, 3.9730555483077726`*^9}, 3.973055596027047*^9, 
   3.976272768769394*^9},ExpressionUUID->"74769a16-8525-4403-99d9-\
a4b896d556df"],

Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubscriptBox["\[Delta]", "\[Mu]\[Nu]"], 
        SuperscriptBox[
         StyleBox["A", "TI"], "\[Mu]"], 
        SuperscriptBox[
         StyleBox["B", "TI"], "\[Nu]"], "\[LongEqual]", 
        StyleBox["A", "TI"], ".", 
        StyleBox["B", "TI"], "    ", ",    ", 
        SubscriptBox["\[Delta]", "\[Mu]\[Nu]"], 
        SuperscriptBox["\[Eta]", "\[Mu]\[Nu]"], "\[LongEqual]", "-2"}], 
      TraditionalForm], "errors" -> {}, "input" -> 
    "\\delta_{\\mu \\nu}A^\\mu B^\\nu = A.B \\qquad , \\qquad \\delta_{\\mu \
\\nu}\\eta^{\\mu \\nu} = -2", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"067bbee7-2ddf-4d27-96d3-99c55ca4da1b"]], \
"Subsubsection",
