Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"relations", "[", 
     RowBox[{"B1_", ",", "B2_"}], "]"}], ":=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"B1", "/", "B2"}], ",", " ", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"k", ">", "0"}], ",", 
         RowBox[{"q", ">", "0"}], ",", 
         RowBox[{"\[CapitalOmega]", ">", "0"}], ",", 
         RowBox[{"0", "<", "\[Phi]", "<", 
          RowBox[{"2", "\[Pi]"}]}]}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"relation\[Omega]K", "[", 
    RowBox[{"B1_", ",", "B2_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"B1new", ",", "B2new", ",", "rappB"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"B1new", " ", "=", " ", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"B1", " ", "/.", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"\[CapitalOmega]", "->", "p1"}], ",", " ", 
            RowBox[{"k", "->", "p2"}]}], "}"}]}], ",", " ", 
         RowBox[{"Assumptions", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"p1", ">", "0"}], ",", 
            RowBox[{"p2", ">", "0"}], ",", 
            RowBox[{"q", ">", "0"}]}], "}"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"B2new", " ", "=", " ", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"B2", " ", "/.", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"\[CapitalOmega]", "->", "p2"}], ",", " ", 
