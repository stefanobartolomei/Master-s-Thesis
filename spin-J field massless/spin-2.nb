  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox[
         StyleBox["V", "TI"], "2", 
         RowBox[{"\[PlusMinus]", ",", 
           SuperscriptBox["\[Lambda]\[Lambda]", "\[Prime]"]}]], 
        "\[LongEqual]", "-", 
        RowBox[{"[", 
          RowBox[{
            RowBox[{"(", 
              RowBox[{
                OverscriptBox[
                 StyleBox["q", "TI"], "\[RightVector]"], "\[CenterDot]", 
                OverscriptBox["\[Omega]", "\[RightVector]"]}], ")"}], 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox[
                 OverscriptBox["\[Epsilon]", "\[RightVector]"], 
                 OverscriptBox[
                  StyleBox["q", "TI"], "\[RightVector]"], 
                 RowBox[{" ", "\[PlusMinus]"}]], "\[CenterDot]", 
                OverscriptBox[
                 StyleBox["k", "TI"], "\[RightVector]"]}], ")"}], "+", 
            RowBox[{"(", 
              RowBox[{
                OverscriptBox[
                 StyleBox["q", "TI"], "\[RightVector]"], "\[CenterDot]", 
                OverscriptBox[
                 StyleBox["k", "TI"], "\[RightVector]"]}], ")"}], 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox[
                 OverscriptBox["\[Epsilon]", "\[RightVector]"], 
                 OverscriptBox[
                  StyleBox["q", "TI"], "\[RightVector]"], 
                 RowBox[{" ", "\[PlusMinus]"}]], "\[CenterDot]", 
                OverscriptBox["\[Omega]", "\[RightVector]"]}], ")"}]}], "]"}],
         "Tr", 
        RowBox[{"[", 
          RowBox[{
            SubsuperscriptBox["\[Epsilon]", "1", "\[Lambda]"], 
            RowBox[{"(", "\[Omega]", ")"}], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", "2", 
             SuperscriptBox["\[Lambda]", "\[Prime]"]], 
            RowBox[{"(", 
              StyleBox["k", "TI"], ")"}]}], "]"}]}], TraditionalForm], 
    "errors" -> {}, "input" -> 
    "V^{\\pm,\\lambda\\lambda'}_2 = -\\Big[\\qty(\\vec{q} \\cdot \
\\vec{\\omega})\\qty(\\vec{\\epsilon}^{\\ \\pm}_{\\vec{q}}\\cdot \\vec{k}) + \
\\qty(\\vec{q} \\cdot \\vec{k})\\qty(\\vec{\\epsilon}^{\\ \
\\pm}_{\\vec{q}}\\cdot \\vec{\\omega}) \
