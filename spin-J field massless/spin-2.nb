\\qty(R(\\alpha,\\beta))^T", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"ae462c0d-cb7f-4d2e-8e17-afd5cc3d891e"]], \
