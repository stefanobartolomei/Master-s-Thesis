            RowBox[{"k", ">", "0"}], ",", 
            RowBox[{"q", ">", "0"}], ",", 
            RowBox[{"\[CapitalOmega]", ">", "0"}], ",", 
            RowBox[{"0", "<", "\[Phi]", "<", 
             RowBox[{"2", "\[Pi]"}]}]}], "}"}]}]}], "]"}]}]}]}], 
