Cell[TextData[{
 "Frame ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["k", "TI"], "\[RightVector]"], "\[LongEqual]", "|", 
         OverscriptBox[
          StyleBox["k", "TI"], "\[RightVector]"], "|", 
         RowBox[{"(", 
           RowBox[{"0", ",", "0", ",", "1"}], ")"}], ",", 
         OverscriptBox[
          StyleBox["q", "TI"], "\[RightVector]"], "\[LongEqual]", "|", 
         OverscriptBox[
          StyleBox["q", "TI"], "\[RightVector]"], "|", 
         RowBox[{"(", 
           
           RowBox[{"cos", "\[Phi]", "sin", "\[Theta]", ",", "sin", "\[Phi]", 
             "sin", "\[Theta]", ",", "cos", "\[Theta]"}], ")"}], ",", 
         OverscriptBox["\[Omega]", "\[RightVector]"], "\[LongEqual]", 
         OverscriptBox[
          StyleBox["q", "TI"], "\[RightVector]"], "-", 
         OverscriptBox[
          StyleBox["k", "TI"], "\[RightVector]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\vec{k} =|\\vec{k}|(0,0,1), \
\\vec{q}=|\\vec{q}|(\\cos\\phi\\sin\\theta, \\sin\\phi\\sin\\theta, \
\\cos\\theta), \\vec{\\omega} = \\vec{q} -  \\vec{k}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "33d84723-d90d-4981-bd14-5536d5f04878"]
}], "Chapter",
