      "\[IndentingNewLine]", 
      RowBox[{"ResultB", "=", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"B", " ", "/.", " ", "substitution\[Theta]"}], ")"}], "/.", 
          RowBox[{"omega", "->", "\[CapitalOmega]"}]}], ",", " ", 
         RowBox[{"Assumptions", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"\[CapitalOmega]", ">", "0"}], ",", 
            RowBox[{"q", ">", "0"}], ",", 
            RowBox[{"k", ">", "0"}], ",", 
            RowBox[{"0", "<", "\[Phi]", "<", 
