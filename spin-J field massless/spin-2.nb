Cell[TextData[{
 "Polarization tensor for gravitons ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Epsilon]", 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}], "\[PlusMinus]"], 
         RowBox[{"(", 
           OverscriptBox["\[Omega]", "\[RightVector]"], ")"}], " ", ", ", 
         SubsuperscriptBox["\[Epsilon]", 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}], "\[PlusMinus]"], 
         RowBox[{"(", 
           OverscriptBox[
            StyleBox["k", "TI"], "\[RightVector]"], ")"}]}], TraditionalForm],
      "errors" -> {}, "input" -> 
     "\\epsilon^\\pm_{ij}(\\vec{\\omega}) \\ , \\ \
\\epsilon^\\pm_{ij}(\\vec{k})", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3bb607e0-5c6a-43bc-8f87-0ddf30e155ef"]
}], "Subtitle",
