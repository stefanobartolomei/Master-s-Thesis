Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox[
         StyleBox["B", "TI"], "2", 
         SuperscriptBox["\[Lambda]\[Lambda]", "\[Prime]"]], "\[LongEqual]", 
        SubscriptBox["\[Delta]", "\[Mu]\[Nu]"], 
        RowBox[{"[", 
          RowBox[{"-", 
            SuperscriptBox["\[Omega]", "\[Mu]"], 
            SuperscriptBox[
             StyleBox["k", "TI"], "\[Nu]"], "+", 
            FractionBox["1", "2"], 
            SuperscriptBox["\[Eta]", "\[Mu]\[Nu]"], 
            RowBox[{"(", 
              RowBox[{"\[Omega]", "\[CenterDot]", 
                StyleBox["k", "TI"]}], ")"}]}], "]"}], "Tr", 
        RowBox[{"[", 
          RowBox[{
            SubsuperscriptBox["\[Epsilon]", "1", 
             RowBox[{"\[Lambda]", "*"}]], 
            RowBox[{"(", "\[Omega]", ")"}], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", "2", 
             RowBox[{
               SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]], 
            RowBox[{"(", 
              StyleBox["k", "TI"], ")"}]}], "]"}]}], TraditionalForm], 
    "errors" -> {}, "input" -> 
    "B_2^{\\lambda\\lambda'} =\\delta_{\\mu \\nu}\\qty[- \\omega^\\mu k^\\nu+\
\\frac{1}{2} \\eta^{\\mu \\nu} \\qty(\\omega \\cdot k)] \
\\text{Tr}\\Big[\\epsilon^{\\lambda*}_1(\\omega) \\cdot \\epsilon^{\\lambda' \
*}_2(k)\\Big]", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"b7d5d0a6-d540-4d0f-a4b8-aa7360aff5de"]], \
