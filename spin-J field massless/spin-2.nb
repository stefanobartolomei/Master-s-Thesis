            RowBox[{"\[CapitalOmega]", ">", "0"}], ",", 
            RowBox[{"0", "<", "\[Phi]", "<", 
             RowBox[{"2", "\[Pi]"}]}]}], "}"}]}]}], "]"}]}]}]}], 
