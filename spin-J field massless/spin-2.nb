              RowBox[{"(", 
               RowBox[{"\[Epsilon]q", ".", "\[Omega]"}], ")"}]}]}], ")"}]}], "*", 
          RowBox[{"Tr", "[", 
           RowBox[{"\[Epsilon]\[Omega]", ".", "\[Epsilon]K"}], "]"}]}], ",", 
         " ", 
