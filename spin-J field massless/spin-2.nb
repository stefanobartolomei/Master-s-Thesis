  3.976273879749118*^9}},ExpressionUUID->"55d36e9c-551c-4a95-80ce-\
35a0677131d6"],

Cell[TextData[{
 "Definition for Polarization tensors ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Epsilon]", 
          RowBox[{
            OverscriptBox[
             StyleBox["q", "TI"], "\[RightVector]"], "\[LongEqual]", 
            OverscriptBox["\[Omega]", "\[RightVector]"], "+", 
            OverscriptBox[
             StyleBox["k", "TI"], "\[RightVector]"], "\[LongEqual]", "|", 
            OverscriptBox[
             StyleBox["q", "TI"], "\[RightVector]"], "|", 
            StyleBox["R", "TI"], 
            RowBox[{"(", 
              RowBox[{"\[Alpha]", ",", "\[Beta]"}], ")"}], 
            OverscriptBox[
             StyleBox["z", "TI"], "^"]}], "\[PlusMinus]"], "\[LongEqual]", 
         StyleBox["R", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Alpha]", ",", "\[Beta]"}], ")"}], 
         SubsuperscriptBox["\[Epsilon]", "\[PlusMinus]", "3"], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              StyleBox["R", "TI"], "(", 
              RowBox[{"\[Alpha]", ",", "\[Beta]"}], ")"}], ")"}], 
          StyleBox["T", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\epsilon^\\pm_{\\vec{q} =  \\vec{\\omega} + \\vec{k} = \
|\\vec{q}|R(\\alpha, \\beta) \\hat{z}}} = R(\\alpha,\\beta) \\epsilon^3_\\pm \
\\qty(R(\\alpha,\\beta))^T", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2c8239d4-55f4-40c0-a8d9-c2f056472235"]
}], "Subtitle",
 CellChangeTimes->{{3.972408070326768*^9, 3.9724082588265457`*^9}, {
  3.9725625113664684`*^9, 3.972562521338056*^9}, {3.9725625515786934`*^9, 
  3.9725626908599815`*^9}, {3.97263811831145*^9, 3.972638155445081*^9}, {
  3.9730517132691813`*^9, 3.973051746048617*^9}, {3.9730527916633205`*^9, 
