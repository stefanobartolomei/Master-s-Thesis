Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Bcoeff", "[", 
    RowBox[{"\[Epsilon]\[Omega]_", ",", "\[Epsilon]K_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"B", ",", " ", "ResultB"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"B", " ", "=", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"(", 
              RowBox[{"\[Omega]mu", ".", "Kmu"}], ")"}]}], "  ", "-", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"eta", ".", "\[Omega]mu"}], ")"}], ".", "Kmu"}], 
             ")"}]}], ")"}], "*", 
          RowBox[{"Tr", "[", 
           RowBox[{"\[Epsilon]\[Omega]", ".", "\[Epsilon]K"}], "]"}]}], ",", 
         " ", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ResultB", "=", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"B", " ", "/.", " ", "substitution\[Theta]"}], ")"}], "/.", 
          RowBox[{"omega", "->", "\[CapitalOmega]"}]}], ",", " ", 
         RowBox[{"Assumptions", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"\[CapitalOmega]", ">", "0"}], ",", 
            RowBox[{"q", ">", "0"}], ",", 
            RowBox[{"k", ">", "0"}], ",", 
            RowBox[{"0", "<", "\[Phi]", "<", 
             RowBox[{"2", "\[Pi]"}]}]}], "}"}]}]}], "]"}]}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
