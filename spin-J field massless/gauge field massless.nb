Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox[
         StyleBox["V", "TI"], "1", 
         RowBox[{"\[PlusMinus]", ",", "\[MinusPlus]\[PlusMinus]"}]], 
        "\[LongEqual]", 
        RowBox[{"(", 
          RowBox[{
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{" ", "\[MinusPlus]", "*"}]], "\[CenterDot]", 
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{" ", "\[PlusMinus]", "*"}]]}], ")"}], 
        RowBox[{"[", 
          RowBox[{
            RowBox[{"(", 
              RowBox[{
                OverscriptBox[
                 StyleBox["q", "TI"], "\[RightVector]"], "\[CenterDot]", 
                OverscriptBox["\[Omega]", "\[RightVector]"]}], ")"}], 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox[
                 OverscriptBox["\[Epsilon]", "\[RightVector]"], 
                 OverscriptBox[
                  StyleBox["q", "TI"], "\[RightVector]"], 
                 RowBox[{" ", "\[PlusMinus]"}]], "\[CenterDot]", 
                OverscriptBox[
                 StyleBox["k", "TI"], "\[RightVector]"]}], ")"}], "+", 
            RowBox[{"(", 
              RowBox[{
                OverscriptBox[
                 StyleBox["q", "TI"], "\[RightVector]"], "\[CenterDot]", 
                OverscriptBox[
                 StyleBox["k", "TI"], "\[RightVector]"]}], ")"}], 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox[
                 OverscriptBox["\[Epsilon]", "\[RightVector]"], 
                 OverscriptBox[
                  StyleBox["q", "TI"], "\[RightVector]"], 
                 RowBox[{" ", "\[PlusMinus]"}]], "\[CenterDot]", 
                OverscriptBox["\[Omega]", "\[RightVector]"]}], ")"}]}], "]"}],
         "-", 
        RowBox[{"(", 
          RowBox[{
            OverscriptBox[
             StyleBox["k", "TI"], "\[RightVector]"], "\[CenterDot]", 
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{" ", "\[MinusPlus]", "*"}]]}], ")"}], 
        RowBox[{"[", 
          RowBox[{
            RowBox[{"(", 
              RowBox[{
                OverscriptBox[
                 StyleBox["q", "TI"], "\[RightVector]"], "\[CenterDot]", 
                OverscriptBox["\[Omega]", "\[RightVector]"]}], ")"}], 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox[
