     "\\epsilon^\\pm_{\\vec{\\omega}} \\ , \\ \\epsilon^\\pm_{\\vec{k}}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8f677a5d-e6e4-4513-ba7b-7cf3da6ebdb1"],
