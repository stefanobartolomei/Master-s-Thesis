Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalGamma]", "\[LongEqual]", 
         FractionBox["1", 
          RowBox[{"16", "\[Pi]", 
            SqrtBox[
             RowBox[{
               SubsuperscriptBox[
                StyleBox["q", "TI"], "0", "2"], "-", 
               SuperscriptBox[
                StyleBox["q", "TI"], "2"]}]]}]], 
         SubsuperscriptBox["\[Integral]", "0", "\[Pi]"], 
         StyleBox["d", "TI"], "\[Theta] ", "sin", "\[Theta] ", 
         SubscriptBox[
          StyleBox["F", "TI"], 
          StyleBox["J", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["M", "TI"], ",", 
             SubscriptBox[
              StyleBox["q", "TI"], ","], 
             SubscriptBox[
              StyleBox["q", "TI"], "0"], ",", "\[Theta]"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\Gamma = \\frac{1}{16\\pi \\sqrt{q_0^2 - q^2}}\\int_0^\\pi d\\theta \\ \
\\sin\\theta \\ F_J(M,q_,q_0,\\theta)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "11132316-387d-4ace-87b9-67b51803ba5e"],
