Cell[BoxData[{
 RowBox[{
  RowBox[{"tensorListz", "=", 
   RowBox[{"{", 
    RowBox[{
    "\[Epsilon]Plus2z", ",", "\[Epsilon]Minus2z", ",", "\[Epsilon]Plus1z", 
     ",", "\[Epsilon]Minus1z", ",", "\[Epsilon]Zero0z"}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"labels", "=", 
    RowBox[{"{", 
     RowBox[{
     "\"\<+2\>\"", ",", "\"\<-2\>\"", ",", "\"\<+1\>\"", ",", "\"\<-1\>\"", 
      ",", "\"\<0\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Definition", " ", "of", " ", "the", " ", "Contraction", " ", "Function"}],
    " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ContractTensors", "[", 
     RowBox[{"t1_", ",", "t2_", ",", "assumps_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "t2Lowered", "}"}], ",", 
      RowBox[{
       RowBox[{"t2Lowered", "=", 
        RowBox[{"eta", ".", 
         RowBox[{"Conjugate", "[", "t2", "]"}], ".", "eta"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{
           RowBox[{"t1", "*", "t2Lowered"}], ",", "2"}], "]"}], ",", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Orthonormality", " ", "Matrix"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"orthoMatrixz", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"ContractTensors", "[", 
       RowBox[{
        RowBox[{"tensorListz", "[", 
         RowBox[{"[", "i", "]"}], "]"}], ",", 
        RowBox[{"tensorListz", "[", 
         RowBox[{"[", "j", "]"}], "]"}], ",", "assumpsz"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", 
        RowBox[{"Length", "[", "tensorListz", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", 
        RowBox[{"Length", "[", "tensorListz", "]"}]}], "}"}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  "\"\<\\n (should be identity matrix) Orthonormality Check (Rows = \
\[Lambda], Cols = \[Lambda]'):\>\"", "]"}], "\n", 
 RowBox[{"TableForm", "[", 
  RowBox[{"orthoMatrixz", ",", 
   RowBox[{"TableHeadings", "->", 
    RowBox[{"{", 
     RowBox[{"labels", ",", "labels"}], "}"}]}]}], "]"}]}], "Input",
