Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Flat", " ", "Metric"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eta", "=", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}]}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Momentum", " ", "definition"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"z", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"qmu", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"q", "^", "2"}], " ", "+", " ", 
          RowBox[{"M", "^", "2"}]}], "]"}], "}"}], ",", 
       RowBox[{"q", "*", "z"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Assumption", " ", "to", " ", "use"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"assumpsz", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"q", ">", "0"}], ",", 
       RowBox[{"M", ">", "0"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Definition", " ", "for", " ", "the", " ", "Matrix", " ", "operator", 
      " ", "of", " ", "the", " ", "angular", " ", "momentum", " ", "in", " ", 
      "3"}], "-", 
     RowBox[{"dim", " ", "representation"}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"J", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"(", GridBox[{
          {"0", "0", "0"},
          {"0", "0", 
           RowBox[{"-", "I"}]},
          {"0", "I", "0"}
         }], ")"}], ",", 
       RowBox[{"(", GridBox[{
          {"0", "0", "I"},
          {"0", "0", "0"},
          {
           RowBox[{"-", "I"}], "0", "0"}
         }], ")"}], ",", 
       RowBox[{"(", GridBox[{
          {"0", 
           RowBox[{"-", "I"}], "0"},
          {"I", "0", "0"},
          {"0", "0", "0"}
         }], ")"}]}], "}"}]}], ";"}], " ", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Helcity", " ", "operator"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Jz", "=", " ", 
     RowBox[{"J", ".", "z"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solz", " ", "=", " ", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"Eigensystem", "[", "Jz", "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]Plusz", " ", "=", " ", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", "0", "}"}], ",", 
       RowBox[{"Normalize", "[", 
        RowBox[{"solz", "[", 
         RowBox[{"[", 
          RowBox[{"2", ",", "2"}], "]"}], "]"}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]Minusz", "=", " ", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", "0", "}"}], ",", 
       RowBox[{"Normalize", "[", 
        RowBox[{"solz", "[", 
         RowBox[{"[", 
          RowBox[{"2", ",", "1"}], "]"}], "]"}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]Zeroz", " ", "=", " ", 
     RowBox[{"Simplify", "[", " ", 
      RowBox[{
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"q", "/", "M"}], "}"}], ",", 
         RowBox[{
          FractionBox[
           SqrtBox[
            RowBox[{
             SuperscriptBox["M", "2"], "+", 
             SuperscriptBox["q", "2"]}]], "M"], " ", 
          RowBox[{"Normalize", "[", 
           RowBox[{"solz", "[", 
            RowBox[{"[", 
             RowBox[{"2", ",", "3"}], "]"}], "]"}], "]"}]}]}], "]"}], ",", 
       " ", 
       RowBox[{"Assumptions", "->", "assumpsz"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<\\n \!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{
SubsuperscriptBox[\"\[Epsilon]\", \"\[Mu]\", \"+\"], 
