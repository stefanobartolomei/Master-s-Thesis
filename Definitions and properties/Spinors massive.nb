            RowBox[{"Pmu", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}]}], ",", 
          RowBox[{"Assumptions", "->", "assumps"}]}], "]"}], " ", "==", 
        "0"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
