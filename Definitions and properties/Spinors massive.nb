    RowBox[{
     RowBox[{"{", 
      RowBox[{"helicity", ",", "u", ",", "uexpected", ",", "result"}], "}"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"helicity", "=", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Pmu", "[", 
