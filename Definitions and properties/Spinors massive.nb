Cell[CellGroupData[{

Cell["Work in the Helicity basis", "Subsection",
 CellChangeTimes->{{3.981628327453602*^9, 3.981628329782221*^9}, {
  3.9816303455339756`*^9, 
  3.981630354501009*^9}},ExpressionUUID->"019f39fb-4926-0f49-af94-\
26715f2644ca"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HelicityBasis", "[", 
    RowBox[{"P_", ",", "helValue_", ",", "assumps_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"EigenEq", ",", "nullBasis", ",", "\[Xi]", ",", "norm\[Xi]"}], 
      "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"EigenEq", "=", " ", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             FractionBox[
              RowBox[{"P", "[", 
               RowBox[{"[", "i", "]"}], "]"}], 
              RowBox[{"Norm", "[", "P", "]"}]], "*", 
             RowBox[{"vecsigma", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}], " ", "-", " ", 
          RowBox[{"helValue", "*", 
           RowBox[{"IdentityMatrix", "[", "2", "]"}]}]}], ",", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nullBasis", "=", 
       RowBox[{"NullSpace", "[", 
        RowBox[{"EigenEq", ",", 
         RowBox[{"ZeroTest", "->", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"FullSimplify", "[", 
              RowBox[{"#", ",", 
               RowBox[{"Assumptions", "->", "assumps"}]}], "]"}], "==", "0"}],
             "&"}], ")"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Xi]", "=", 
       RowBox[{"nullBasis", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"norm\[Xi]", "=", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"ComplexExpand", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Xi]", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "*", 
            RowBox[{"Conjugate", "[", 
             RowBox[{"\[Xi]", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "+", 
           RowBox[{
            RowBox[{"\[Xi]", "[", 
             RowBox[{"[", "2", "]"}], "]"}], "*", 
            RowBox[{"Conjugate", "[", 
             RowBox[{"\[Xi]", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "]"}]}]}], "]"}], ",", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"\[Xi]", "/", 
         RowBox[{"Sqrt", "[", "norm\[Xi]", "]"}]}], ",", 
        RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9816298760029564`*^9, 3.9816299540122185`*^9}, {
  3.981629996539049*^9, 3.9816301812258606`*^9}, {3.9816303618180714`*^9, 
  3.9816304158605328`*^9}},
 CellLabel->
  "In[705]:=",ExpressionUUID->"f3e03c46-5646-e948-bf2c-b0cf32fc4667"],

