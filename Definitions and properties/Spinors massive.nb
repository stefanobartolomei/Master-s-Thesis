        RowBox[{"v1", ",", "v2", ",", "v3", ",", "v4"}], "}"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Pslash", " ", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Pmu", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "*", "\[Gamma]0"}], " ", "-", " ", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Pmu", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "*", 
           RowBox[{"\[Gamma]Matricies", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "2", ",", "4"}], "}"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"DiracEq", " ", "=", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Pslash", " ", "+", " ", 
          RowBox[{"M", "*", 
           RowBox[{"IdentityMatrix", "[", "4", "]"}]}]}], ")"}], ".", 
        "vGeneric"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"solv", " ", "=", " ", 
       RowBox[{"Solve", "[", 
