Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"checkNormalizat", "[", 
    RowBox[{"spinor_", ",", "Pmu_", ",", "assumps_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"UU", ",", "result"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"UU", " ", "=", " ", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"ComplexExpand", "[", "spinor", "]"}], ".", "spinor"}], ",",
          " ", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"result", " ", "=", " ", 
       RowBox[{
        RowBox[{"Simplify", "[", 
