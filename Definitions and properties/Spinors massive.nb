Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"vfunz", "[", 
    RowBox[{"Pmu_", ",", "assumps_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "vGeneric", ",", "v1", ",", "v2", ",", "Pslash", ",", "DiracEq", ",", 
       "solv", ",", "vfinal"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
