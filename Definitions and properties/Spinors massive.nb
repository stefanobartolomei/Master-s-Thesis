Cell[CellGroupData[{

Cell[TextData[{
 "Check Normalization such that ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["u", "TI"], "\[Dagger]"], 
         RowBox[{"(", 
           StyleBox["p", "TI"], ")"}], 
         StyleBox["u", "TI"], 
         RowBox[{"(", 
           StyleBox["p", "TI"], ")"}], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["v", "TI"], "\[Dagger]"], 
         RowBox[{"(", 
           StyleBox["p", "TI"], ")"}], 
         StyleBox["v", "TI"], 
         RowBox[{"(", 
           StyleBox["p", "TI"], ")"}], "\[LongEqual]", "2", 
         StyleBox["E", "TI"], "\[LongEqual]", "2", 
         SqrtBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["M", "TI"], "2"], "+", "|", 
            OverscriptBox[
             StyleBox["p", "TI"], "\[RightVector]"], 
            SuperscriptBox["|", "2"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "u^\\dagger(p)u(p) = v^\\dagger(p) v(p) = 2E = 2\\sqrt{M^2 + \
|\\vec{p}|^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b3728bc8-4210-0846-8eb5-e2db5c9dd300"]
}], "Subsubsection",
