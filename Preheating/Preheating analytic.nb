         RowBox[{"Thick", ",", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "}"}]}], ",", 
       RowBox[{"Frame", "->", "True"}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<Inflaton Field \[Phi](t)\>\""}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
