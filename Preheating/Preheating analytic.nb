Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "Plots", " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"aHPlot", " ", "=", " ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"asol", "[", "t", "]"}], ",", 
         RowBox[{"Hsol", "[", "t", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "tMax"}], "}"}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<a(t)\>\"", ",", "\"\<H(t)\>\""}], "}"}]}], ",", 
       RowBox[{"Frame", "->", "True"}], ",", 
       RowBox[{
       "PlotLabel", "->", "\"\<Scale factor and Hubble evolution\>\""}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Phi]Plot", " ", "=", " ", 
     RowBox[{"Plot", "[", 
      RowBox[{
