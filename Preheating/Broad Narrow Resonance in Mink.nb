Cell[CellGroupData[{

Cell["Stability/Instability chart", "Subtitle",
 CellChangeTimes->{{3.984566610822836*^9, 
  3.98456662842338*^9}},ExpressionUUID->"46fc95b2-9baf-344e-b678-\
ce772fb721b6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qMaxChart", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"AMaxChart", "=", "5"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Mu]", "[", 
     RowBox[{"A_", ",", "q_"}], "]"}], ":=", 
    RowBox[{"Abs", "[", 
     RowBox[{"Im", "[", 
      RowBox[{"MathieuCharacteristicExponent", "[", 
       RowBox[{"A", ",", "q"}], "]"}], "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"plotFloquet", "=", 
   RowBox[{"DensityPlot", "[", 
    RowBox[{
     RowBox[{"\[Mu]", "[", 
      RowBox[{"A", ",", "q"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"q", ",", "0", ",", "qMaxChart"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"A", ",", "0", ",", "AMaxChart"}], "}"}], ",", 
     RowBox[{"PlotPoints", "->", "80"}], ",", 
     RowBox[{"MaxRecursion", "->", "2"}], ",", 
     RowBox[{"ColorFunction", "->", "\"\<BlueGreenYellow\>\""}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"BarLegend", "[", 
       RowBox[{"Automatic", ",", 
        RowBox[{
        "LegendLabel", 
         "->", "\"\<\!\(\*SubscriptBox[\(\[Mu]\), \(k\)]\)\>\""}]}], "]"}]}], 
     ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Resonance parameter q\>\"", ",", "\"\<A\>\""}], "}"}]}], ",", 
     RowBox[{
     "PlotLabel", 
      "->", "\"\<Floquet Exponent \!\(\*SubscriptBox[\(\[Mu]\), \
\(k\)]\)\>\""}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"unphysicalRegion", "=", 
    RowBox[{"RegionPlot", "[", 
     RowBox[{
      RowBox[{"A", "<", 
       RowBox[{"2", "*", "q"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"q", ",", "0", ",", "qMaxChart"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A", ",", "0", ",", "AMaxChart"}], "}"}], ",", 
      RowBox[{"BoundaryStyle", "->", "None"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Gray", ",", 
         RowBox[{"Opacity", "[", "1.", "]"}]}], "]"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Aupper", "[", "q_", "]"}], ":=", 
   RowBox[{"1", "+", "q"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Abelow", "[", "q_", "]"}], ":=", 
   RowBox[{"1", "-", "q"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"plotAqLines", "=", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Aupper", "[", "q", "]"}], ",", 
        RowBox[{"Abelow", "[", "q", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"q", ",", "0", ",", "qMaxChart"}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Directive", "[", 
          RowBox[{"Thick", ",", "White"}], "]"}], ",", 
         RowBox[{"Directive", "[", 
          RowBox[{"Thick", ",", "White"}], "]"}]}], "}"}]}]}], "]"}]}], ";"}],
   "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"regionPeakUP", " ", "=", " ", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"qvalue", ",", "AUp"}], "}"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"PointSize", "[", "Large", "]"}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"regionPeakBelow", " ", "=", " ", 
    RowBox[{"ListPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"qvalue", ",", "ABelow"}], "}"}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"Red", ",", 
         RowBox[{"PointSize", "[", "Large", "]"}]}], "}"}]}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
  "plotFloquet", ",", "plotAqLines", ",", "regionPeakUP", ",", 
   "regionPeakBelow", ",", "unphysicalRegion", ",", 
   RowBox[{"Epilog", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Text", "[", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<Unphysical (\!\(\*SuperscriptBox[\(k\), \(2\)]\) < 0)\>\
\"", ",", "Black", ",", "Bold", ",", "14"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"qMaxChart", "*", "0.7"}], ",", 
          RowBox[{"qMaxChart", "*", "0.7"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"Text", "[", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<A = 1 + q\>\"", ",", "White", ",", "Bold", ",", "12"}], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"qMaxChart", "*", "0.1"}], ",", 
          RowBox[{"Aupper", "[", 
           RowBox[{"qMaxChart", "*", "0.4"}], "]"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"Text", "[", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<A = 1 - q\>\"", ",", "White", ",", "Bold", ",", "12"}], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"qMaxChart", "*", "0.1"}], ",", 
          RowBox[{"Abelow", "[", 
           RowBox[{"qMaxChart", "*", "0.4"}], "]"}]}], "}"}]}], "]"}]}], 
     "}"}]}]}], "]"}]}], "Input",
