Cell[TextData[{
 "Solve: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Chi]", 
          StyleBox["k", "TI"], 
          SuperscriptBox["\[Null]", "\[Prime]\[Prime]"]], "+", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["A", "TI"], "-", "2", 
             StyleBox["q", "TI"], "cos", 
             RowBox[{"(", 
               RowBox[{"2", 
                 StyleBox["z", "TI"]}], ")"}]}], ")"}], 
         SubscriptBox["\[Chi]", 
          StyleBox["k", "TI"]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\chi_k^{''} + (A - 2 q \\cos(2 z))\\chi_k = 0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dc0cd55f-78b9-6d4c-8d08-1c61b553edb8"]
}], "Chapter",
