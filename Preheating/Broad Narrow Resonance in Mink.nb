Cell[TextData[{
 "Broad resonance ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["q", "TI"], "\[GreaterGreater]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "q \\gg 1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d43c014a-7b5b-1b4a-8fa0-7b9bd7fcb8b3"]
}], "Title",
 CellChangeTimes->{{3.984563740183283*^9, 3.984563750863846*^9}, {
