Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"A", "[", 
     RowBox[{"k_", ",", "q_"}], "]"}], " ", ":=", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["k", "2"], 
      SuperscriptBox["m\[Phi]", "2"]], "+", 
     RowBox[{"2", "q"}]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Omega]", "[", 
     RowBox[{"z_", ",", "k_", ",", "q_"}], "]"}], ":=", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"A", "[", 
       RowBox[{"k", ",", "q"}], "]"}], "-", 
      RowBox[{"2", "*", "q", "*", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", "*", "z"}], "]"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"EOM", " ", "daughter", " ", "\[Chi]"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"eqn\[Chi]", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"\[Chi]", "''"}], "[", "z", "]"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"A", "[", 
          RowBox[{"k", ",", "q"}], "]"}], "-", 
         RowBox[{"2", "*", "q", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", "*", "z"}], "]"}]}]}], ")"}], "*", 
       RowBox[{"\[Chi]", "[", "z", "]"}]}]}], "==", "0"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Initial", " ", "conditions"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Chi]conditions", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Chi]", "[", "0", "]"}], "==", 
       FractionBox["1", 
        SqrtBox[
         RowBox[{"2", 
          RowBox[{"\[Omega]", "[", 
           RowBox[{"0", ",", "k", ",", "q"}], "]"}]}]]]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "'"}], "[", "0", "]"}], "==", 
       RowBox[{
        RowBox[{"-", "I"}], "*", 
        SqrtBox[
         FractionBox[
          RowBox[{"\[Omega]", "[", 
           RowBox[{"0", ",", "k", ",", "q"}], "]"}], "2"]]}]}]}], "}"}]}], 
   ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"Initial", " ", "conditions", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox["\[Chi]", 
           StyleBox["k", "TI"]], 
          RowBox[{"(", 
            StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
          FractionBox[
           SuperscriptBox[
            StyleBox["e", "TI"], 
            RowBox[{"-", 
              StyleBox["i", "TI"], 
              SubscriptBox["\[Omega]", 
               StyleBox["k", "TI"]], 
              StyleBox["x", "TI"]}]], 
           SqrtBox[
            RowBox[{"2", 
              SubscriptBox["\[Omega]", 
               StyleBox["k", "TI"]]}]]]}], TraditionalForm], "errors" -> {}, 
      "input" -> "\\chi_k(x) =\\frac{e^{-i\\omega_k x}}{\\sqrt{2\\omega_k}}", 
      "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "to", " ", "be", " ", "valued", " ", "at", 
    " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
      "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], " ", "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Solve", " ", "\[Chi]", " ", "dynamic"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"sol\[Chi]", "=", 
   RowBox[{"ParametricNDSolveValue", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"eqn\[Chi]", ",", 
       RowBox[{"\[Chi]conditions", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", 
       RowBox[{"\[Chi]conditions", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", "\[Chi]", ",", 
     RowBox[{"{", 
      RowBox[{"z", ",", "0", ",", "tMax"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "q"}], "}"}], ",", 
     RowBox[{"MaxSteps", "->", "Infinity"}], ",", 
     RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}]}], "]"}]}], 
  ";"}]}], "Input",
