Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{"For", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["q", "TI"], "\[GreaterGreater]", "1"}], TraditionalForm], 
      "errors" -> {}, "input" -> "q \\gg 1", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", 
    RowBox[{"(", 
     RowBox[{
     "or", " ", "equivalently", " ", "large", " ", "amplitude", " ", 
      "oscillations"}], ")"}]}], ",", " ", 
   RowBox[{"the", " ", "resonance", " ", "occurs", " ", "for", " ", "modes", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SuperscriptBox[
           StyleBox["k", "TI"], "2"], "\[LongEqual]", 
          SubsuperscriptBox[
           StyleBox["m", "TI"], "\[Phi]", "2"], 
          RowBox[{"(", 
            RowBox[{
              StyleBox["A", "TI"], "-", "2", 
              StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], 
      "errors" -> {}, "input" -> "k^2 = m^2_\\phi(A - 2q)", "state" -> 
      "Boxes"|>,
     "TeXAssistantTemplate"], " ", 
    RowBox[{"(", 
     RowBox[{"above", " ", "the", " ", "line", " ", 
      TemplateBox[<|"boxes" -> FormBox[
          RowBox[{
            StyleBox["A", "TI"], "\[LongEqual]", "2", 
            StyleBox["q", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
        "A=2q", "state" -> "Boxes"|>,
       "TeXAssistantTemplate"], " ", "in", " ", "the", " ", 
      RowBox[{"stability", "/", "instability"}], " ", "chart"}], ")"}]}]}], 
  " ", "*)"}]], "Input",
