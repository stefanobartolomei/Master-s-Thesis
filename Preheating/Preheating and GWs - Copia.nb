Cell[CellGroupData[{

Cell["Daughter dynamic", "Chapter",
 CellChangeTimes->{{3.98626417586549*^9, 
  3.986264204808403*^9}},ExpressionUUID->"75ade75a-8c35-164c-8f16-\
b809e387ddbd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", "Frequency", " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]2", "[", 
      RowBox[{"t_", ",", "k_"}], "]"}], ":=", 
     RowBox[{
      SuperscriptBox["k", "2"], "+", 
      RowBox[{
       SuperscriptBox["g", "2"], 
       SuperscriptBox[
        RowBox[{"\[Phi]sol", "[", "t", "]"}], "2"]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]", "[", 
      RowBox[{"t_", ",", "k_"}], "]"}], ":=", 
     SqrtBox[
      RowBox[{"\[Omega]2", "[", 
       RowBox[{"t", ",", "k"}], "]"}]]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"EOM", " ", "daughter", " ", "\[Chi]"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eq\[Chi]", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "''"}], "[", "t", "]"}], "+", 
       RowBox[{
        RowBox[{"\[Omega]2", "[", 
         RowBox[{"t", ",", "k"}], "]"}], "*", 
        RowBox[{"\[Chi]", "[", "t", "]"}]}]}], "==", "0"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "conditions"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"\[Chi]conditions", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "[", "0", "]"}], "==", 
        FractionBox["1", 
         SqrtBox[
          RowBox[{"2", 
           RowBox[{"\[Omega]", "[", 
            RowBox[{"0", ",", "k"}], "]"}]}]]]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Chi]", "'"}], "[", "0", "]"}], "==", 
        RowBox[{
         RowBox[{"-", "I"}], "*", 
         SqrtBox[
          FractionBox[
           RowBox[{"\[Omega]", "[", 
            RowBox[{"0", ",", "k"}], "]"}], "2"]]}]}]}], "}"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Initial", " ", "conditions", " ", 
     TemplateBox[<|"boxes" -> FormBox[
         RowBox[{
           SubscriptBox["\[Chi]", 
            StyleBox["k", "TI"]], 
           RowBox[{"(", 
