        RowBox[{"tail", ":", 
         RowBox[{
         "out", " ", "to", " ", "15", " ", "to", " ", "see", " ", "it", " ", 
          "drop", " ", "off"}]}]}], "*)"}], "\[IndentingNewLine]", "]"}]}], ";",
     "\[IndentingNewLine]", "\n", 
    RowBox[{"kValsGW", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"Range", "[", 
        RowBox[{"0.1", ",", "1.0", ",", "0.1"}], "]"}], ",", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Captures", " ", "the", " ", "low"}], "-", 
         RowBox[{"k", " ", "IR", " ", "tail"}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"Range", "[", 
        RowBox[{"1.2", ",", "4.5", ",", "0.2"}], "]"}], ",", 
       RowBox[{"(*", 
        RowBox[{
        "High", " ", "resolution", " ", "over", " ", "the", " ", "peak"}], 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"Range", "[", 
        RowBox[{"4.25", ",", "6.0", ",", "0.25"}], "]"}]}], "  ", 
