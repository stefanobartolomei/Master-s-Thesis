Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{
   "For", " ", "the", " ", "prereheting", " ", "scenario", " ", "with", " ", 
    "inflaton", " ", "potential", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["V", "TI"], 
          RowBox[{"(", "\[Phi]", ")"}], "\[LongEqual]", 
          FractionBox["1", "2"], 
          SubsuperscriptBox[
           StyleBox["m", "TI"], "\[Phi]", "2"], 
          SuperscriptBox["\[Phi]", "2"], "+", 
          FractionBox["\[Lambda]", "4"], 
          SuperscriptBox["\[Phi]", "4"]}], TraditionalForm], "errors" -> {}, 
      "input" -> 
      "V(\\phi) = \\frac{1}{2}m^2_\\phi \\phi^2 + \\frac{\\lambda}{4}\\phi^4",
       "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], ",", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"(", "1", ")"}], " ", "we", " ", "solve", " ", "numerically", " ",
     "the", " ", "background", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"inflaton", " ", 
       TemplateBox[<|
        "boxes" -> FormBox["\[Phi]", TraditionalForm], "errors" -> {}, 
         "input" -> "\\phi", "state" -> "Boxes"|>,
        "TeXAssistantTemplate"]}], ",", " ", 
      RowBox[{"Hubble", " ", 
       TemplateBox[<|"boxes" -> FormBox[
           StyleBox["H", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
         "H", "state" -> "Boxes"|>,
        "TeXAssistantTemplate"]}]}], ")"}]}], ",", 
   RowBox[{"the", " ", "daughter", " ", "mode", " ", "function", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox["\[Chi]", 
           StyleBox["k", "TI"]], "(", "\[Eta]", ")"}], TraditionalForm], 
      "errors" -> {}, "input" -> "\\chi_k(\\eta)", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "and", " ", "number", " ", "density", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           StyleBox["n", "TI"], 
           StyleBox["k", "TI"]], "(", "\[Eta]", ")"}], TraditionalForm], 
      "errors" -> {}, "input" -> "n_k(\\eta)", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "for", " ", "different", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        StyleBox["k", "TI"], TraditionalForm], "errors" -> {}, "input" -> "k",
       "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", 
    RowBox[{"modes", ".", " ", "In"}], " ", "the", " ", "spectator", " ", 
    "dynamics", " ", 
    TemplateBox[<|
     "boxes" -> FormBox["\[Chi]", TraditionalForm], "errors" -> {}, "input" -> 
      "\\chi", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], ",", " ", 
   RowBox[{
   "we", " ", "neglet", " ", "the", " ", "contribution", " ", "from", " ", 
    RowBox[{"universe", "'"}], "s", " ", 
    RowBox[{"expansion", ".", "\[IndentingNewLine]", 
     RowBox[{"(", "2", ")"}]}], " ", "we", " ", "plot", " ", "the", " ", 
    "Power", " ", "spectrum", " ", "of", " ", "the", " ", "daughter", " ", 
    "field", " ", "and", " ", "the", " ", "number", " ", "density", " ", "of",
     " ", "the", " ", "daughter", " ", 
    RowBox[{"specie", ".", "\[IndentingNewLine]", 
     RowBox[{"(", "3", ")"}]}], " ", "Finally"}], ",", " ", 
   RowBox[{
   "we", " ", "compute", " ", "the", " ", "GW", " ", "generation", " ", "due",
     " ", "to", " ", "daughter", " ", "energy", " ", "stress", " ", 
    RowBox[{"tensor", "."}]}]}], " ", "*)"}]], "Input",
