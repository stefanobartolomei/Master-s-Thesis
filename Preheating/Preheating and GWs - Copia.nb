Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Mpl", "=", "1.0"}], ";"}], "                    ", 
  RowBox[{"(*", " ", 
   RowBox[{"reduced", " ", "mass", " ", "Planck"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"m\[Phi]", "=", 
    RowBox[{"1.0", "*", "Mpl"}]}], ";"}], "           ", 
  RowBox[{"(*", " ", 
   RowBox[{"inflation", " ", "mass"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Lambda]", " ", "=", " ", "1.0"}], ";"}], 
  "                       ", 
  RowBox[{"(*", " ", 
   RowBox[{"self", "-", 
    RowBox[{"coupling", " ", "constant"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g", "=", "200.0"}], ";"}], "                    ", 
