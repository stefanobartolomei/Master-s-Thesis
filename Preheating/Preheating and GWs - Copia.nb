Cell[CellGroupData[{

Cell["Compute the Power spectrum of GWs", "Chapter",
 CellChangeTimes->{{3.9862083362050114`*^9, 
  3.9862083521745014`*^9}},ExpressionUUID->"85cd933d-4841-cc48-9fdd-\
097c05e2e310"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           StyleBox["I", "TI"], 
           StyleBox["c", "TI"]], "\[Congruent]", 
          SubsuperscriptBox["\[Integral]", "0", "\[Tau]"], 
          StyleBox["d", "TI"], 
          StyleBox["t", "TI"], " ", "cos", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["k", "TI"], 
              StyleBox["t", "TI"]}], ")"}], 
          SubscriptBox["\[Chi]", 
           StyleBox["p", "TI"]], 
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}], 
          SubscriptBox["\[Chi]", 
           TemplateBox[{
             RowBox[{
               StyleBox["k", "TI"], "-", 
               StyleBox["p", "TI"]}]}, "Abs"]], 
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
      "input" -> 
      "I_c \\equiv \\int_0^\\tau dt \\ \\cos(k t) \\chi_p(t)\\chi_{|k-p|}(t)",
       "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", ",", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           StyleBox["I", "TI"], 
           StyleBox["s", "TI"]], "\[Congruent]", 
          SubsuperscriptBox["\[Integral]", "0", "\[Tau]"], 
          StyleBox["d", "TI"], 
          StyleBox["t", "TI"], " ", "sin", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["k", "TI"], 
              StyleBox["t", "TI"]}], ")"}], 
          SubscriptBox["\[Chi]", 
           StyleBox["p", "TI"]], 
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}], 
          SubscriptBox["\[Chi]", 
           TemplateBox[{
             RowBox[{
               StyleBox["k", "TI"], "-", 
               StyleBox["p", "TI"]}]}, "Abs"]], 
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
      "input" -> 
      "I_s \\equiv \\int_0^\\tau dt \\ \\sin(kt) \\chi_p(t)\\chi_{|k-p|}(t)", 
      "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"TimeIntegral", "[", 
      RowBox[{"k_", ",", "p_", ",", "x_", ",", "\[Tau]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"kp", ",", "Ic", ",", "Is"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"kp", "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"k", "^", "2"}], "+", 
           RowBox[{"p", "^", "2"}], "-", 
           RowBox[{"2", "*", "k", "*", "p", "*", "x"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"Quiet", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Ic", "=", 
           RowBox[{"NIntegrate", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Cos", "[", 
               RowBox[{"k", "*", "t"}], "]"}], "*", 
              RowBox[{"\[Chi]sol", "[", 
               RowBox[{"p", ",", "t"}], "]"}], "*", 
              RowBox[{"\[Chi]sol", "[", 
               RowBox[{"kp", ",", "t"}], "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"t", ",", "0", ",", "\[Tau]"}], "}"}], ",", 
             RowBox[{"Method", "->", "\"\<LevinRule\>\""}], ",", 
             RowBox[{"MaxRecursion", "->", "30"}], ",", 
             RowBox[{"AccuracyGoal", "->", "4"}], ",", 
             RowBox[{"PrecisionGoal", "->", "4"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Is", "=", 
           RowBox[{"NIntegrate", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Sin", "[", 
               RowBox[{"k", "*", "t"}], "]"}], "*", 
              RowBox[{"\[Chi]sol", "[", 
               RowBox[{"p", ",", "t"}], "]"}], "*", 
              RowBox[{"\[Chi]sol", "[", 
               RowBox[{"kp", ",", "t"}], "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"t", ",", "0", ",", "\[Tau]"}], "}"}], ",", 
             RowBox[{"Method", "->", "\"\<LevinRule\>\""}], ",", 
             RowBox[{"MaxRecursion", "->", "30"}], ",", 
             RowBox[{"AccuracyGoal", "->", "4"}], ",", 
             RowBox[{"PrecisionGoal", "->", "4"}]}], "]"}]}], ";", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"NIntegrate", "::", "slwcon"}], ",", 
            RowBox[{"NIntegrate", "::", "ncvb"}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         TemplateBox[<|"boxes" -> FormBox[
             RowBox[{
               SuperscriptBox[
                RowBox[{"(", 
                  RowBox[{"1", "-", 
                    SuperscriptBox[
                    StyleBox["x", "TI"], "2"]}], ")"}], "2"], " ", 
               SuperscriptBox[
                StyleBox["p", "TI"], "6"], 
               RowBox[{"(", 
                 RowBox[{"|", 
                   SubscriptBox[
                    StyleBox["I", "TI"], 
                    StyleBox["c", "TI"]], 
                   SuperscriptBox["|", "2"], "+", "|", 
                   SubscriptBox[
                    StyleBox["I", "TI"], 
                    StyleBox["s", "TI"]], 
                   SuperscriptBox["|", "2"]}], ")"}]}], TraditionalForm], 
           "errors" -> {}, "input" -> 
           "(1-x^2)^2  \\ p^6 \\qty(|I_c|^2 + |I_s|^2)", "state" -> "Boxes"|>,
          "TeXAssistantTemplate"], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"x", "^", "2"}]}], ")"}], "^", "2"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", "Ic", "]"}], "^", "2"}], "+", 
           RowBox[{
            RowBox[{"Abs", "[", "Is", "]"}], "^", "2"}]}], ")"}], "*", 
         RowBox[{"p", "^", "6"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
          StyleBox["d", "TI"], 
          StyleBox["p", "TI"], " ", 
          SubsuperscriptBox["\[Integral]", "-1", "1"], 
          StyleBox["d", "TI"], 
          StyleBox["x", "TI"], 
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{"1", "-", 
               SuperscriptBox[
                StyleBox["x", "TI"], "2"]}], ")"}], "2"], " ", 
          SuperscriptBox[
           StyleBox["p", "TI"], "6"], 
          RowBox[{"(", 
            RowBox[{"|", 
              SubscriptBox[
               StyleBox["I", "TI"], 
               StyleBox["c", "TI"]], 
              SuperscriptBox["|", "2"], "+", "|", 
              SubscriptBox[
               StyleBox["I", "TI"], 
               StyleBox["s", "TI"]], 
              SuperscriptBox["|", "2"]}], ")"}]}], TraditionalForm], 
      "errors" -> {}, "input" -> 
      "\\int_0^\\infty dp \\ \\int_{-1}^1 dx (1-x^2)^2  \\ p^6 \\qty(|I_c|^2 \
+ |I_s|^2)", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"GWGrid", "[", 
      RowBox[{"k_", ",", "\[Tau]_", ",", 
       RowBox[{"pMax_", ":", "100"}], ",", 
       RowBox[{"dp_", ":", "2"}], ",", 
       RowBox[{"dx_", ":", "0.1"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "grid", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"grid", "=", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"ParallelTable", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"p", ",", "x"}], "}"}], ",", 
               RowBox[{"TimeIntegral", "[", 
                RowBox[{"k", ",", "p", ",", "x", ",", "\[Tau]"}], "]"}]}], 
              "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"p", ",", "0.001", ",", "pMax", ",", "dp"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"x", ",", 
               RowBox[{"-", "1.0"}], ",", "1.0", ",", "dx"}], "}"}]}], "]"}], 
           ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", "grid"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"funz\[Rho]GWO", "[", 
      RowBox[{"k_", ",", "\[Tau]_", ",", 
       RowBox[{"pMax_", ":", "100"}], ",", 
       RowBox[{"dp_", ":", "2"}], ",", 
       RowBox[{"dx_", ":", "0.1"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"gridData", ",", "interpFunc", ",", "res"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"gridData", "=", 
         RowBox[{"GWGrid", "[", 
          RowBox[{"k", ",", "\[Tau]", ",", "pMax", ",", "dp", ",", "dx"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"interpFunc", "=", 
         RowBox[{"Interpolation", "[", 
          RowBox[{"gridData", ",", 
           RowBox[{"InterpolationOrder", "->", "2"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", "integrate", " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"res", "=", 
         RowBox[{"NIntegrate", "[", 
          RowBox[{
           RowBox[{"interpFunc", "[", 
            RowBox[{"p", ",", "x"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"p", ",", "0.001", ",", "pMax"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", 
             RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
           RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}]}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{
         FractionBox[
          SuperscriptBox["k", "3"], 
          RowBox[{"2", 
           SuperscriptBox["\[Pi]", "3"]}]], " ", "*", "res"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"GWSpectrum", "[", 
      RowBox[{"kList_List", ",", "\[Tau]_", ",", 
       RowBox[{"pMax_", ":", "100"}], ",", 
       RowBox[{"dp_", ":", "2"}], ",", 
       RowBox[{"dx_", ":", "0.1"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "currentK", "}"}], ",", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"Monitor", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"currentK", "=", "k"}], ";", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"funz\[Rho]GWO", "[", 
               RowBox[{
               "k", ",", "\[Tau]", ",", "pMax", ",", "dp", ",", "dx"}], 
               "]"}]}], "}"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "kList"}], "}"}]}], "]"}], ",", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           
           RowBox[{"\"\<Calculating spectrum... currently evaluating k = \>\"",
             ",", "currentK"}], "}"}], "]"}]}], "]"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.9861973092930737`*^9, 3.986197449153702*^9}, {
  3.98619753232745*^9, 3.9861975343897076`*^9}, {3.9862021262171726`*^9, 
  3.986202126995575*^9}, {3.9862105109281673`*^9, 3.9862105428586464`*^9}, {
  3.9862105757283*^9, 3.986210578412737*^9}, {3.986210613155281*^9, 
