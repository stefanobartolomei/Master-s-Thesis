       RowBox[{"(*", 
        RowBox[{"Main", " ", "peak", " ", 
         RowBox[{"region", ":", 
          RowBox[{"fine", " ", "resolution"}]}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"Range", "[", 
        RowBox[{"6.2", ",", "10.0", ",", "0.5"}], "]"}]}], "   ", 
      RowBox[{"(*", 
