Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"PS\[Chi]", "[", 
     RowBox[{"k_", ",", "\[Tau]_"}], "]"}], ":=", 
    RowBox[{
     FractionBox[
      SuperscriptBox["k", "3"], 
      RowBox[{"2", 
       SuperscriptBox["\[Pi]", "2"]}]], "  ", 
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{"\[Chi]sol", "[", 
        RowBox[{"k", ",", "\[Tau]"}], "]"}], "]"}], "^", "2"}]}]}], " ", 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Chi]Spectrum", "[", 
     RowBox[{"kList_List", ",", "\[Tau]_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "currentK", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Monitor", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"currentK", "=", "k"}], ";", "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{"k", ",", 
             RowBox[{"PS\[Chi]", "[", 
              RowBox[{"k", ",", "\[Tau]"}], "]"}]}], "}"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "kList"}], "}"}]}], "]"}], ",", 
        RowBox[{"Row", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<Computation \[Chi] for k = \>\"", ",", "currentK"}], 
          "}"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"n\[Chi]Spectrum", "[", 
    RowBox[{"kList_List", ",", "\[Tau]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "currentK", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Monitor", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"currentK", "=", "k"}], ";", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{"number\[Chi]", "[", 
             RowBox[{"\[Tau]", ",", "k"}], "]"}]}], "}"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "kList"}], "}"}]}], "]"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<Computation n\[Chi] for k = \>\"", ",", "currentK"}], 
         "}"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]}], "Input",
