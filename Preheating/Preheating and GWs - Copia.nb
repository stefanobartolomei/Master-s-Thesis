Cell[TextData[{
 "Resonance parameter ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["q", "TI"], TraditionalForm], "errors" -> {}, "input" -> "q", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6111dba2-d0f2-d14b-886e-662279e31dde"]
}], "Chapter",
 CellChangeTimes->{{3.9862181193884296`*^9, 
  3.9862181339494286`*^9}},ExpressionUUID->"03684c8d-069e-7a4e-b08b-\
7fd76d6b35e0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Omega]star", "[", 
    RowBox[{"\[CapitalPhi]_", ",", "t_"}], "]"}], ":=", 
   SqrtBox[
    RowBox[{
     SuperscriptBox["m\[Phi]", "2"], "+", " ", 
     RowBox[{"3", "\[Lambda]", " ", 
      SuperscriptBox[
       RowBox[{"\[CapitalPhi]", "[", "t", "]"}], "2"]}]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalPhi]", "[", "t_", "]"}], ":=", 
   SqrtBox[
    RowBox[{
     SuperscriptBox[
      RowBox[{"\[Phi]sol", "[", "t", "]"}], "2"], " ", "+", " ", 
     FractionBox[
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Phi]sol", "'"}], "[", "t", "]"}], ")"}], "2"], 
      SuperscriptBox[
       RowBox[{"\[Omega]star", "[", 
        RowBox[{"\[Phi]sol", ",", "t"}], "]"}], "2"]]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"q", "[", "t_", "]"}], ":=", 
    FractionBox[
     RowBox[{
      SuperscriptBox["g", "2"], " ", 
      SuperscriptBox[
       RowBox[{"\[CapitalPhi]", "[", "t", "]"}], "2"]}], 
     SuperscriptBox[
      RowBox[{"\[Omega]star", "[", 
       RowBox[{"\[CapitalPhi]", ",", "t"}], "]"}], "2"]]}], ";"}], " ", 
  RowBox[{"(*", " ", "definition", " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"q", "[", "t", "]"}], ",", 
     RowBox[{
      RowBox[{"q", "[", "0", "]"}], "*", 
      RowBox[{
       RowBox[{"asol", "[", "t", "]"}], "^", 
       RowBox[{"-", "3"}]}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "tMax"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"PlotStyle", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Thick", ",", "Blue"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Thick", ",", "Red"}], "}"}]}], "}"}]}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<t (Time)\>\"", ",", "\"\<q(t)\>\""}], "}"}]}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<q(t)= \!\(\*FractionBox[\(\*SuperscriptBox[\(g\), \(2\)] \
\*SuperscriptBox[\(\[CapitalPhi]\), \(2\)] \((t)\)\), \
SuperscriptBox[SubscriptBox[\(\[Omega]\), \(*\)], \(2\)]]\)\>\"", 
      ",", "\"\<q(0)\!\(\*SuperscriptBox[\(a\), \(-3\)]\)(t)\>\""}], "}"}]}], 
   ",", 
   RowBox[{"PlotLabel", "->", "\"\<Resonance parameter q(t)\>\""}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"q", "[", "0", "]"}], ">", "1"}], ",", 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\\n (Broad resonance regime) Maximum resonance parameter: \
\>\"", ",", 
      RowBox[{"q", "[", "0", "]"}]}], "]"}], ",", 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\\n (Narrow resonance regime) Maximum resonance parameter: \
\>\"", ",", 
      RowBox[{"q", "[", "0", "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<\\n Parametric resonance up to \!\(\*SubscriptBox[\(k\), \
\(*\)]\) = \!\(\*SuperscriptBox[\(q\), \(1/4\)]\) = \>\"", ",", 
   RowBox[{
    RowBox[{"q", "[", "0", "]"}], "^", 
    RowBox[{"(", 
     RowBox[{"1", "/", "4"}], ")"}]}]}], "]"}]}], "Input",
 CellChangeTimes->CompressedData["
