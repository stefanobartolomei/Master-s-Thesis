    RowBox[{"coupling", " ", "constant", " ", "\[Phi]"}], "-", "\[Chi]"}], 
   " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tMax", "=", "50.0"}], ";"}], "               ", 
  RowBox[{"(*", " ", "time", " ", "*)"}]}], "\n", 
