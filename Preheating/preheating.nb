Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "2.", " ", "Definizione", " ", "della", " ", "funzione", " ", "per", " ", 
    "il", " ", "calcolo", " ", "del", " ", "tasso", " ", "di", " ", 
    "crescita", " ", "fisico"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"tassoCrescita", "[", 
     RowBox[{"k_", ",", "qVal_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"AVal", ",", "nu"}], "}"}], ",", 
      RowBox[{
       RowBox[{"AVal", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"k", "^", "2"}], "/", 
          RowBox[{"m\[Phi]", "^", "2"}]}], "+", 
         RowBox[{"2", "*", "qVal"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nu", "=", 
        RowBox[{"MathieuCharacteristicExponent", "[", 
         RowBox[{"AVal", ",", "qVal"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"Element", "[", 
          RowBox[{"nu", ",", "Reals"}], "]"}], ",", "0.0", ",", 
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{"Im", "[", "nu", "]"}], "]"}], "*", 
          RowBox[{"(", 
           RowBox[{"m\[Phi]", "/", "2"}], ")"}]}]}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Grafico", " ", "di", " ", "confronto", " ", "degli", " ", 
     "spettri", " ", "di", " ", "produzione"}], "*)"}], "\n", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"tassoCrescita", "[", 
      RowBox[{"k", ",", "qFisico"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "0", ",", "20"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Momento del modo k [GeV]\>\"", 
        ",", "\"\<Tasso di crescita \[Gamma](k) [GeV]\>\""}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{"Directive", "[", 
        RowBox[{"Blue", ",", "Thick"}], "]"}], "}"}]}], ",", 
     RowBox[{"Filling", "->", 
      RowBox[{"{", 
       RowBox[{"1", "->", 
        RowBox[{"{", 
         RowBox[{"Axis", ",", "LightBlue"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"LineLegend", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Coupling g = 2.5*10^-4\>\"", ",", "11"}], "]"}], 
           "}"}], ",", 
          RowBox[{"LegendFunction", "->", "\"\<Panel\>\""}]}], "]"}], ",", 
        "Above"}], "]"}]}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<Transizione al Regime di Broad Resonance\>\"", ",", 
        "Bold", ",", "14"}], "]"}]}], ",", 
     RowBox[{"GridLines", "->", "Automatic"}], ",", 
     RowBox[{"ImageSize", "->", "Large"}]}], "]"}], "\n"}]}]], "Input",
 CellChangeTimes->{{3.9893173354898853`*^9, 3.9893173354898853`*^9}, {
  3.9893183294998875`*^9, 3.9893184179036617`*^9}},
