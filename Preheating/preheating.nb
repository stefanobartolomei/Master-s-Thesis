Cell[CellGroupData[{

Cell[TextData[{
 "Solve: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Chi]", 
          StyleBox["k", "TI"], 
          SuperscriptBox["\[Null]", "\[Prime]\[Prime]"]], "+", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["A", "TI"], "-", "2", 
             StyleBox["q", "TI"], "cos", 
             RowBox[{"(", 
               RowBox[{"2", 
                 StyleBox["z", "TI"]}], ")"}]}], ")"}], 
         SubscriptBox["\[Chi]", 
          StyleBox["k", "TI"]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\chi_k^{''} + (A - 2 q \\cos(2 z))\\chi_k = 0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6d8713cc-2ff9-184a-811c-321e16b86233"]
}], "Chapter",
 CellChangeTimes->{{3.9842820667261467`*^9, 3.9842820762947807`*^9}, {
  3.9845641804845333`*^9, 
  3.9845641842038383`*^9}},ExpressionUUID->"7955b477-8959-6548-936c-\
941803eb60b4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Omega]2", "[", 
    RowBox[{"z_", ",", "k_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"A", "[", "k", "]"}], "-", 
    RowBox[{"2", "*", "q", "*", 
     RowBox[{"Cos", "[", 
      RowBox[{"2", "*", "z"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Omega]", "[", 
     RowBox[{"z_", ",", "k_"}], "]"}], ":=", 
    SqrtBox[
     RowBox[{"\[Omega]2", "[", 
      RowBox[{"z", ",", "k"}], "]"}]]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"EOM", " ", "daughter", " ", "\[Chi]"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"eqn\[Chi]", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"\[Chi]", "''"}], "[", "z", "]"}], "+", 
      RowBox[{
       RowBox[{"\[Omega]2", "[", 
        RowBox[{"z", ",", "k"}], "]"}], "*", 
       RowBox[{"\[Chi]", "[", "z", "]"}]}]}], "==", "0"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Initial", " ", "conditions"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Chi]conditions", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Chi]", "[", "0", "]"}], "==", 
       FractionBox["1", 
        SqrtBox[
         RowBox[{"2", 
          RowBox[{"\[Omega]", "[", 
           RowBox[{"0", ",", "k"}], "]"}]}]]]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "'"}], "[", "0", "]"}], "==", 
       RowBox[{
        RowBox[{"-", "I"}], "*", 
        SqrtBox[
         FractionBox[
          RowBox[{"\[Omega]", "[", 
           RowBox[{"0", ",", "k"}], "]"}], "2"]]}]}]}], "}"}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"Initial", " ", "conditions", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox["\[Chi]", 
           StyleBox["k", "TI"]], 
          RowBox[{"(", 
            StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
          FractionBox[
           SuperscriptBox[
            StyleBox["e", "TI"], 
            RowBox[{"-", 
              StyleBox["i", "TI"], 
              SubscriptBox["\[Omega]", 
               StyleBox["k", "TI"]], 
              StyleBox["x", "TI"]}]], 
           SqrtBox[
            RowBox[{"2", 
              SubscriptBox["\[Omega]", 
               StyleBox["k", "TI"]]}]]]}], TraditionalForm], "errors" -> {}, 
      "input" -> "\\chi_k(x) =\\frac{e^{-i\\omega_k x}}{\\sqrt{2\\omega_k}}", 
      "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "to", " ", "be", " ", "valued", " ", "at", 
    " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
      "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], " ", "*)"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Solve", " ", "\[Chi]", " ", "dynamic"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"sol\[Chi]", "=", 
    RowBox[{"ParametricNDSolveValue", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"eqn\[Chi]", ",", 
        RowBox[{"\[Chi]conditions", "[", 
         RowBox[{"[", "1", "]"}], "]"}], ",", 
        RowBox[{"\[Chi]conditions", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", "\[Chi]", ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", "0", ",", "zMax"}], "}"}], ",", 
      RowBox[{"{", "k", "}"}], ",", 
      RowBox[{"MaxSteps", "->", "Infinity"}], ",", 
      RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Solution", " ", "\[Chi]"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Chi]sol", "[", 
     RowBox[{"k_", ",", "z_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"sol\[Chi]", "[", "k", "]"}], "[", "z", "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Number", " ", "density", " ", "particles"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"number\[Chi]", "[", 
    RowBox[{"z_", ",", "k_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "\[Chi]solK", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Chi]solK", " ", "=", " ", 
       RowBox[{"sol\[Chi]", "[", "k", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       FractionBox[
        SuperscriptBox[
         RowBox[{"Abs", "[", 
          RowBox[{
           RowBox[{"\[Chi]solK", "'"}], "[", "z", "]"}], "]"}], "2"], 
        RowBox[{"\[Omega]", "[", 
         RowBox[{"z", ",", "k"}], "]"}]], "+", 
       RowBox[{
        FractionBox[
         RowBox[{"\[Omega]", "[", 
          RowBox[{"z", ",", "k"}], "]"}], "2"], 
        SuperscriptBox[
         RowBox[{"Abs", "[", 
          RowBox[{"\[Chi]solK", "[", "z", "]"}], "]"}], "2"]}], "-", 
       FractionBox["1", "2"]}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9838691903834076`*^9, 3.9838692036892986`*^9}, {
