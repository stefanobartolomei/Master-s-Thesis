        RowBox[{"p", "^", "6"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"FastGWSpectrumPoint", "[", 
     RowBox[{"k_", ",", "\[Tau]_", ",", 
      RowBox[{"pMax_", ":", "10.0"}], ",", 
      RowBox[{"dp_", ":", "0.1"}], ",", 
      RowBox[{"dx_", ":", "0.05"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "pList", ",", "xList", ",", "totalSum", ",", "pVal", ",", "xVal", ",", 
        "term"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"pList", "=", 
        RowBox[{"Range", "[", 
         RowBox[{"0.05", ",", "pMax", ",", "dp"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"xList", "=", 
        RowBox[{"Range", "[", 
         RowBox[{
          RowBox[{"-", "0.95"}], ",", "0.95", ",", "dx"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"totalSum", "=", 
        RowBox[{"ParallelSum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"term", "=", 
            RowBox[{"DiscreteTimeIntegral", "[", 
             RowBox[{"k", ",", "pVal", ",", "xVal", ",", "\[Tau]"}], "]"}]}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"term", "*", "dp", "*", "dx"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"pVal", ",", "pList"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"xVal", ",", "xList"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"k", "^", "3"}], "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", 
            RowBox[{"Pi", "^", "3"}]}], ")"}]}], ")"}], "*", "totalSum"}]}]}],
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"FastGWSpectrum", "[", 
    RowBox[{"kList_List", ",", "\[Tau]_", ",", 
     RowBox[{"pMax_", ":", "10.0"}], ",", 
     RowBox[{"dp_", ":", "0.1"}], ",", 
     RowBox[{"dx_", ":", "0.05"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"currentK", ",", "result"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Monitor", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"result", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"currentK", "=", "k"}], ";", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"FastGWSpectrumPoint", "[", 
               RowBox[{
               "k", ",", "\[Tau]", ",", "pMax", ",", "dp", ",", "dx"}], 
               "]"}]}], "}"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "kList"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "result"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<Evaluating CORRECTED GW point for k = \>\"", ",", 
          "currentK"}], "}"}], "]"}]}], "]"}]}], "]"}]}], ";"}]}], "Input",
