Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"kprova", " ", "=", ".5"}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"3.", " ", "Generazione", " ", "dei", " ", "grafici"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Grid", "[", 
  RowBox[{"{", 
   RowBox[{"{", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Grafico", " ", "1"}], ":", 
      RowBox[{"Soluzione", " ", "\[Chi]", 
       RowBox[{"(", "z", ")"}], " ", "in", " ", "funzione", " ", "del", " ", 
       "tempo", " ", "z"}]}], "*)"}], 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Evaluate", "[", 
        RowBox[{"Abs", "[", 
         RowBox[{"\[Chi]sol", "[", 
          RowBox[{"kprova", ",", "z"}], "]"}], "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "0", ",", "zMax"}], "}"}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"Frame", "->", "True"}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<z\>\"", ",", "\"\<\[Chi](z)\>\""}], "}"}]}], ",", 
       RowBox[{"PlotStyle", "->", "Blue"}], ",", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"Style", "[", 
         RowBox[{
          RowBox[{"StringForm", "[", 
