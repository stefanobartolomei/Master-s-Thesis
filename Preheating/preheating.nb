   RowBox[{
    RowBox[{
     RowBox[{"GWGrid", "[", 
      RowBox[{"k_", ",", "\[Tau]_", ",", 
       RowBox[{"pMax_", ":", "10.0"}], ",", 
       RowBox[{"dp_", ":", "0.5"}], ",", 
       RowBox[{"dx_", ":", "0.1"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "grid", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"grid", "=", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"ParallelTable", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"p", ",", "x"}], "}"}], ",", 
               RowBox[{"TimeIntegral", "[", 
                RowBox[{"k", ",", "p", ",", "x", ",", "\[Tau]"}], "]"}]}], 
              "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"p", ",", "0.01", ",", "pMax", ",", "dp"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"x", ",", 
               RowBox[{"-", "1.0"}], ",", "1.0", ",", "dx"}], "}"}]}], "]"}], 
           ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", "grid"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"funz\[Rho]GWO", "[", 
      RowBox[{"k_", ",", "\[Tau]_", ",", 
       RowBox[{"pMax_", ":", "10.0"}], ",", 
       RowBox[{"dp_", ":", "0.5"}], ",", 
       RowBox[{"dx_", ":", "0.1"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"gridData", ",", "interpFunc", ",", "res"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"gridData", "=", 
         RowBox[{"GWGrid", "[", 
          RowBox[{"k", ",", "\[Tau]", ",", "pMax", ",", "dp", ",", "dx"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"interpFunc", "=", 
         RowBox[{"Interpolation", "[", 
          RowBox[{"gridData", ",", 
