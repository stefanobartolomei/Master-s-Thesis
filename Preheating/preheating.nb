Cell[CellGroupData[{

Cell["Power spectrum of the Daughter field", "Chapter",
 CellChangeTimes->{{3.986207547819771*^9, 
  3.9862075628888817`*^9}},ExpressionUUID->"e844c691-a2a4-804d-b7c3-\
61ff70033b75"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"PS\[Chi]", "[", 
     RowBox[{"k_", ",", "z_"}], "]"}], ":=", 
    RowBox[{
     FractionBox[
      SuperscriptBox["k", "3"], 
      RowBox[{"2", 
       SuperscriptBox["\[Pi]", "2"]}]], "  ", 
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{"\[Chi]sol", "[", 
        RowBox[{"k", ",", "z"}], "]"}], "]"}], "^", "2"}]}]}], " ", ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Chi]Spectrum", "[", 
     RowBox[{"kList_List", ",", "z_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "currentK", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Monitor", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"currentK", "=", "k"}], ";", "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{"k", ",", 
             RowBox[{"PS\[Chi]", "[", 
              RowBox[{"k", ",", "z"}], "]"}]}], "}"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "kList"}], "}"}]}], "]"}], ",", 
        RowBox[{"Row", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<Computation \[Chi] for k = \>\"", ",", "currentK"}], 
          "}"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"n\[Chi]Spectrum", "[", 
    RowBox[{"kList_List", ",", "z_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "currentK", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Monitor", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"currentK", "=", "k"}], ";", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{"number\[Chi]", "[", 
             RowBox[{"z", ",", "k"}], "]"}]}], "}"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "kList"}], "}"}]}], "]"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<Computation n\[Chi] for k = \>\"", ",", "currentK"}], 
         "}"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9862048506209717`*^9, 3.986205034825388*^9}, {
   3.986207582773304*^9, 3.986207649113098*^9}, {3.986207830796232*^9, 
   3.986207848783087*^9}, {3.986208528693735*^9, 3.98620853904533*^9}, {
   3.986208588467291*^9, 3.986208589139244*^9}, 3.9862086946105385`*^9, {
   3.986210970197111*^9, 3.986211001073391*^9}, 3.98626475670278*^9, {
   3.9893119143522415`*^9, 3.98931192801618*^9}},
 CellLabel->
  "In[160]:=",ExpressionUUID->"6a1b84b3-f9a8-1a4a-8215-c6fbb7cfb8a8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Range", " ", "values"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"kVals\[Chi]", "=", 
     RowBox[{"Range", "[", 
      RowBox[{"0.5", ",", "40.0", ",", "0.5"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"spectrum\[Chi]", "=", 
     RowBox[{"\[Chi]Spectrum", "[", 
      RowBox[{"kVals\[Chi]", ",", "zMax"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"spectrumn\[Chi]", "=", 
     RowBox[{"n\[Chi]Spectrum", "[", 
      RowBox[{"kVals\[Chi]", ",", "zMax"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", "Plot", " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"plotSpectrum\[Chi]", "=", 
    RowBox[{"ListLogPlot", "[", 
     RowBox[{"spectrum\[Chi]", ",", 
      RowBox[{"Joined", "->", "True"}], ",", 
      RowBox[{"InterpolationOrder", "->", "2"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<k (Momentum)\>\"", 
         ",", "\"\<\!\(\*SubscriptBox[\(P\), \(\[Chi]\)]\)(k)\>\""}], "}"}]}],
       ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", "0.005", "]"}], ",", 
         RowBox[{"Darker", "[", "Blue", "]"}]}], "}"}]}], ",", 
      RowBox[{"GridLines", "->", "Automatic"}], ",", 
      RowBox[{"PlotLabel", "->", "\"\<Daughter Field Power Spectrum\>\""}]}], 
     "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"plotSpectrumn\[Chi]", "=", 
    RowBox[{"ListLogPlot", "[", 
     RowBox[{"spectrumn\[Chi]", ",", 
      RowBox[{"Joined", "->", "True"}], ",", 
      RowBox[{"InterpolationOrder", "->", "2"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<k (Momentum)\>\"", 
         ",", "\"\<\!\(\*SubscriptBox[\(n\), \(\[Chi]\)]\)(k)\>\""}], "}"}]}],
       ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", "0.005", "]"}], ",", 
         RowBox[{"Darker", "[", "Red", "]"}]}], "}"}]}], ",", 
      RowBox[{"GridLines", "->", "Automatic"}], ",", 
      RowBox[{
      "PlotLabel", "->", "\"\<Daughter Field Occupation Number\>\""}]}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9862048506209717`*^9, 3.986205034825388*^9}, {
   3.986207582773304*^9, 3.9862076151521015`*^9}, {3.986207679108637*^9, 
