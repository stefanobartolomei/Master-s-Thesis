                   SubscriptBox[
                    StyleBox["I", "TI"], 
                    StyleBox["s", "TI"]], 
                   SuperscriptBox["|", "2"]}], ")"}]}], TraditionalForm], 
           "errors" -> {}, "input" -> 
           "(1-x^2)^2  \\ p^6 \\qty(|I_c|^2 + |I_s|^2)", "state" -> "Boxes"|>,
          "TeXAssistantTemplate"], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
