            RowBox[{"k", ",", "kList"}], "}"}]}], "]"}], ",", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           
           RowBox[{"\"\<Calculating spectrum... currently evaluating k = \>\"",
             ",", "currentK"}], "}"}], "]"}]}], "]"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}]}]}]], "Input",
