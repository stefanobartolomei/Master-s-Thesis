Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", "Frequency", " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]2", "[", 
      RowBox[{"z_", ",", "k_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"A", "[", "k", "]"}], "-", 
      RowBox[{"2", " ", "qFisico", "*", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "z"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]", "[", 
      RowBox[{"z_", ",", "k_"}], "]"}], ":=", 
     SqrtBox[
      RowBox[{"\[Omega]2", "[", 
       RowBox[{"z", ",", "k"}], "]"}]]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"EOM", " ", "daughter", " ", "\[Chi]"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eq\[Chi]", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "''"}], "[", "z", "]"}], "+", 
       RowBox[{
        RowBox[{"\[Omega]2", "[", 
         RowBox[{"z", ",", "k"}], "]"}], "*", 
        RowBox[{"\[Chi]", "[", "z", "]"}]}]}], "==", "0"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "conditions"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"\[Chi]conditions", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "[", "0", "]"}], "==", 
        FractionBox["1", 
         SqrtBox[
          RowBox[{"2", 
           RowBox[{"\[Omega]", "[", 
            RowBox[{"0", ",", "k"}], "]"}]}]]]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Chi]", "'"}], "[", "0", "]"}], "==", 
        RowBox[{
         RowBox[{"-", "I"}], "*", 
         SqrtBox[
          FractionBox[
           RowBox[{"\[Omega]", "[", 
            RowBox[{"0", ",", "k"}], "]"}], "2"]]}]}]}], "}"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Initial", " ", "conditions", " ", 
     TemplateBox[<|"boxes" -> FormBox[
         RowBox[{
           SubscriptBox["\[Chi]", 
            StyleBox["k", "TI"]], 
           RowBox[{"(", 
             StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
           FractionBox[
            SuperscriptBox[
             StyleBox["e", "TI"], 
             RowBox[{"-", 
               StyleBox["i", "TI"], 
               SubscriptBox["\[Omega]", 
                StyleBox["k", "TI"]], 
               StyleBox["x", "TI"]}]], 
            SqrtBox[
             RowBox[{"2", 
               SubscriptBox["\[Omega]", 
                StyleBox["k", "TI"]]}]]]}], TraditionalForm], "errors" -> {}, 
       "input" -> "\\chi_k(x) =\\frac{e^{-i\\omega_kx}}{\\sqrt{2\\omega_k}}", 
       "state" -> "Boxes"|>,
      "TeXAssistantTemplate"], " ", "to", " ", "be", " ", "valued", " ", "at",
      " ", 
     TemplateBox[<|"boxes" -> FormBox[
         RowBox[{
           StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
       "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
      "TeXAssistantTemplate"]}], " ", "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Solve", " ", "\[Chi]", " ", "dynamic"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol\[Chi]", "=", 
     RowBox[{"ParametricNDSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"eq\[Chi]", ",", 
         RowBox[{"\[Chi]conditions", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"\[Chi]conditions", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", "\[Chi]", ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "0", ",", "zMax"}], "}"}], ",", 
       RowBox[{"{", "k", "}"}], ",", 
       RowBox[{"MaxSteps", "->", "Infinity"}], ",", 
       RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Daughter", " ", "solution"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Chi]sol", "[", 
      RowBox[{"k_", ",", "t_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"sol\[Chi]", "[", "k", "]"}], "[", "t", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Number", " ", "density", " ", "particles"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"number\[Chi]", "[", 
      RowBox[{"t_", ",", "k_"}], "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "\[Chi]solK", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\[Chi]solK", " ", "=", " ", 
         RowBox[{"sol\[Chi]", "[", "k", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         FractionBox[
          SuperscriptBox[
           RowBox[{"Abs", "[", 
            RowBox[{
             RowBox[{"\[Chi]solK", "'"}], "[", "t", "]"}], "]"}], "2"], 
          RowBox[{"\[Omega]", "[", 
           RowBox[{"t", ",", "k"}], "]"}]], "+", 
         RowBox[{
          FractionBox[
           RowBox[{"\[Omega]", "[", 
            RowBox[{"t", ",", "k"}], "]"}], "2"], 
          SuperscriptBox[
           RowBox[{"Abs", "[", 
            RowBox[{"\[Chi]solK", "[", "t", "]"}], "]"}], "2"]}], "-", 
         FractionBox["1", "2"]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"kScelto", " ", "=", " ", "4."}], ";"}], "\n", 
   RowBox[{"Grid", "[", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"LogPlot", "[", 
        RowBox[{
         RowBox[{"number\[Chi]", "[", 
