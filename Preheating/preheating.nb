Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Parametri", " ", "fisici"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"Mpl", "=", 
     RowBox[{"10", "^", "6"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"m\[Phi]", "=", 
     RowBox[{"6", "*", 
      RowBox[{"10", "^", 
       RowBox[{"-", "6"}]}], " ", "Mpl"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"\[CapitalPhi]0", "=", 
     RowBox[{"0.1", " ", "Mpl"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gForte", "=", 
     RowBox[{"2.5", "*", 
      RowBox[{"10", "^", 
       RowBox[{"-", "4"}]}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"qFisico", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"gForte", "*", "\[CapitalPhi]0"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"2", "*", "m\[Phi]"}], ")"}]}], ")"}], "^", "2"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Scegliamo", " ", "un", " ", "modo", " ", "k", " ", "ad", " ", "alta", " ",
      "energia", " ", "FUORI", " ", "dalle", " ", "lingue", " ", "di", " ", 
     "risonanza"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"kStabile", "=", "12.0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"aVal", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"kStabile", "^", "2"}], "/", 
       RowBox[{"m\[Phi]", "^", "2"}]}], "+", 
      RowBox[{"2", "*", "qFisico"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Frequenza", " ", "iniziale", " ", "esatta", " ", "al", " ", "tempo", " ",
       "z"}], "=", "0"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Omega]ini", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"aVal", "-", 
       RowBox[{"2", "*", "qFisico"}]}], "]"}]}], ";"}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Condizioni", " ", "Iniziali", " ", "del", " ", "Vuoto", " ", "di", " ", 
      "Bunch"}], "-", "Davies"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"chi0", "=", 
     RowBox[{"1", "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"2", "*", "\[Omega]ini"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dchi0", "=", 
     RowBox[{
      RowBox[{"-", "I"}], "*", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"\[Omega]ini", "/", "2"}], "]"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"zMax", "=", "12"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", "Risoluzione", " ", "numerica", " ", "complessa"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solComplex", "=", 
     RowBox[{"NDSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"chi", "''"}], "[", "z", "]"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"aVal", "-", 
              RowBox[{"2", " ", "qFisico", " ", 
               RowBox[{"Cos", "[", 
                RowBox[{"2", " ", "z"}], "]"}]}]}], ")"}], " ", 
            RowBox[{"chi", "[", "z", "]"}]}]}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{"chi", "[", "0", "]"}], "==", "chi0"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"chi", "'"}], "[", "0", "]"}], "==", "dchi0"}]}], "}"}], ",",
        "chi", ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "0", ",", "zMax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Frequenza", " ", "istantanea", " ", "adiabatica"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]", "[", "z_", "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"Max", "[", 
       RowBox[{"0.001", ",", 
        RowBox[{"aVal", "-", 
         RowBox[{"2", " ", "qFisico", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "z"}], "]"}]}]}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"3.", " ", "Coefficienti", " ", "di", " ", "Bogoliubov"}], "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Alpha]k", "[", "z_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Omega]", "[", "z", "]"}], "*", 
         RowBox[{"solComplex", "[", "z", "]"}]}], "+", 
        RowBox[{"I", "*", 
         RowBox[{
          RowBox[{"solComplex", "'"}], "[", "z", "]"}]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"2", "*", 
         RowBox[{"\[Omega]", "[", "z", "]"}]}], "]"}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Beta]k", "[", "z_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Omega]", "[", "z", "]"}], "*", 
         RowBox[{"solComplex", "[", "z", "]"}]}], "-", 
        RowBox[{"I", "*", 
         RowBox[{
          RowBox[{"solComplex", "'"}], "[", "z", "]"}]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"2", "*", 
         RowBox[{"\[Omega]", "[", "z", "]"}]}], "]"}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "Grafici", " ", "per", " ", "la", " ", "regione", " ", 
     "STABILE"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Grid", "[", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Grafico", " ", "1"}], ":", 
        RowBox[{
        "Numero", " ", "di", " ", "particelle", " ", "oscillante", " ", "ma", 
         " ", "confinato"}]}], "*)"}], 
      RowBox[{
       RowBox[{"Plot", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{"\[Beta]k", "[", "z", "]"}], "]"}], "^", "2"}], ",", 
         RowBox[{"{", 
          RowBox[{"z", ",", "0", ",", "zMax"}], "}"}], ",", 
         RowBox[{"PlotRange", "->", 
          RowBox[{"{", 
           RowBox[{"0", ",", "All"}], "}"}]}], ",", 
         RowBox[{"Frame", "->", "True"}], ",", 
         RowBox[{"FrameLabel", "->", 
          RowBox[{"{", 
           
           RowBox[{"\"\<Tempo z\>\"", 
            ",", "\"\<Numero di particelle N_k(z)\>\""}], "}"}]}], ",", 
         RowBox[{"PlotStyle", "->", 
          RowBox[{"{", 
           RowBox[{"Blue", ",", "Thick"}], "}"}]}], ",", 
         RowBox[{"PlotLabel", "->", 
          RowBox[{"Style", "[", 
           
           RowBox[{"\"\<N_k(z) = |\[Beta]_k|^2 (Nessuna crescita)\>\"", ",", 
            "Bold", ",", "11"}], "]"}]}], ",", 
         RowBox[{"GridLines", "->", "Automatic"}], ",", 
         RowBox[{"ImageSize", "->", "Medium"}]}], "]"}], ",", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Grafico", " ", "2"}], ":", 
         RowBox[{
         "Lo", " ", "spazio", " ", "delle", " ", "fasi", " ", "racchiuso", " ",
           "in", " ", 
          RowBox[{"un", "'"}], "orbita", " ", "chiusa"}]}], "*)"}], 
       RowBox[{"ParametricPlot", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Re", "[", 
            RowBox[{"\[Beta]k", "[", "z", "]"}], "]"}], ",", 
           RowBox[{"Im", "[", 
            RowBox[{"\[Beta]k", "[", "z", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"z", ",", "0", ",", "zMax"}], "}"}], ",", 
         RowBox[{"PlotRange", "->", "All"}], ",", 
         RowBox[{"Frame", "->", "True"}], ",", 
         RowBox[{"FrameLabel", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<Re[\[Beta]_k]\>\"", ",", "\"\<Im[\[Beta]_k]\>\""}], 
           "}"}]}], ",", 
         RowBox[{"PlotStyle", "->", 
          RowBox[{"Directive", "[", 
           RowBox[{
            RowBox[{"Darker", "[", "Cyan", "]"}], ",", 
            RowBox[{"Thickness", "[", "0.004", "]"}]}], "]"}]}], ",", 
         RowBox[{"PlotLabel", "->", 
          RowBox[{"Style", "[", 
           
           RowBox[{"\"\<Spazio delle Fasi di \[Beta]_k Confinato\>\"", ",", 
            "Bold", ",", "11"}], "]"}]}], ",", 
         RowBox[{"GridLines", "->", "Automatic"}], ",", 
         RowBox[{"ImageSize", "->", "Medium"}], ",", 
         RowBox[{"(*", 
          RowBox[{"Origine", " ", "evidenziata"}], "*)"}], 
         RowBox[{"Epilog", "->", 
          RowBox[{"{", 
           RowBox[{"Red", ",", 
            RowBox[{"PointSize", "[", "0.02", "]"}], ",", 
            RowBox[{"Point", "[", 
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], "]"}]}], "}"}]}]}], "]"}]}], 
      "}"}], "}"}], "]"}], "\n"}]}]], "Input",
