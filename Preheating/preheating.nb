           RowBox[{
            RowBox[{"Abs", "[", "Is", "]"}], "^", "2"}]}], ")"}], "*", 
         RowBox[{"p", "^", "6"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
