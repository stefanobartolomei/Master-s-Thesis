Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DiscreteTimeIntegral", "[", 
     RowBox[{"k_", ",", "p_", ",", "x_", ",", "\[Tau]_", ",", 
      RowBox[{"tSteps_", ":", "150"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "tList", ",", "dt", ",", "\[Chi]1", ",", "\[Chi]2", ",", "kp", ",", 
        "cosVec", ",", "sinVec", ",", "IntegrandCos", ",", "IntegrandSin", ",",
         "Ic", ",", "Is"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"kp", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"k", "^", "2"}], "+", 
          RowBox[{"p", "^", "2"}], "-", 
          RowBox[{"2", "*", "k", "*", "p", "*", "x"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dt", "=", 
        RowBox[{"\[Tau]", "/", "tSteps"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"tList", "=", 
        RowBox[{"Range", "[", 
         RowBox[{"0.", ",", "\[Tau]", ",", "dt"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"\[Chi]1", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"\[Chi]sol", "[", 
           RowBox[{"p", ",", "t"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", "tList"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Chi]2", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"\[Chi]sol", "[", 
           RowBox[{"kp", ",", "t"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", "tList"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"cosVec", "=", 
        RowBox[{"Cos", "[", 
         RowBox[{"k", "*", "tList"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sinVec", "=", 
        RowBox[{"Sin", "[", 
         RowBox[{"k", "*", "tList"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"IntegrandCos", "=", 
        RowBox[{"cosVec", "*", "\[Chi]1", "*", "\[Chi]2"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"IntegrandSin", "=", 
        RowBox[{"sinVec", "*", "\[Chi]1", "*", "\[Chi]2"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"Ic", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"dt", "/", "2"}], ")"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"IntegrandCos", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "+", 
           RowBox[{"2", "*", 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{"IntegrandCos", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "2", ",", "tSteps"}], "}"}]}], "]"}]}], "+", 
           RowBox[{"IntegrandCos", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Is", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"dt", "/", "2"}], ")"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"IntegrandSin", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "+", 
           RowBox[{"2", "*", 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{"IntegrandSin", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "2", ",", "tSteps"}], "}"}]}], "]"}]}], "+", 
           RowBox[{"IntegrandSin", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"x", "^", "2"}]}], ")"}], "^", "2"}], "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", "Ic", "]"}], "^", "2"}], "+", 
          RowBox[{
           RowBox[{"Abs", "[", "Is", "]"}], "^", "2"}]}], ")"}], "*", 
        RowBox[{"p", "^", "6"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\n", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"FastGWSpectrumPoint", "[", 
     RowBox[{"k_", ",", "\[Tau]_", ",", 
      RowBox[{"pMax_", ":", "10.0"}], ",", 
      RowBox[{"dp_", ":", "0.5"}], ",", 
      RowBox[{"dx_", ":", "0.1"}], ",", 
      RowBox[{"tSteps_", ":", "150"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "pList", ",", "xList", ",", "totalSum", ",", "pVal", ",", "xVal", ",", 
        "term"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"pList", "=", 
        RowBox[{"Range", "[", 
         RowBox[{"0.05", ",", "pMax", ",", "dp"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"xList", "=", 
        RowBox[{"Range", "[", 
         RowBox[{
          RowBox[{"-", "0.95"}], ",", "0.95", ",", "dx"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"totalSum", "=", 
        RowBox[{"ParallelSum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"term", "=", 
            RowBox[{"DiscreteTimeIntegral", "[", 
             RowBox[{
             "k", ",", "pVal", ",", "xVal", ",", "\[Tau]", ",", "tSteps"}], 
             "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"term", "*", "dp", "*", "dx"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"pVal", ",", "pList"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"xVal", ",", "xList"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"k", "^", "3"}], "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", 
            RowBox[{"Pi", "^", "3"}]}], ")"}]}], ")"}], "*", "totalSum"}]}]}],
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"3.", " ", "Spectrum", " ", "Wrapper"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"FastGWSpectrum", "[", 
    RowBox[{"kList_List", ",", "\[Tau]_", ",", 
     RowBox[{"pMax_", ":", "10.0"}], ",", 
     RowBox[{"dp_", ":", "0.5"}], ",", 
     RowBox[{"dx_", ":", "0.1"}], ",", 
     RowBox[{"tSteps_", ":", "150"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"currentK", ",", "result"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Monitor", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"result", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"currentK", "=", "k"}], ";", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"FastGWSpectrumPoint", "[", 
               RowBox[{
               "k", ",", "\[Tau]", ",", "pMax", ",", "dp", ",", "dx", ",", 
                "tSteps"}], "]"}]}], "}"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "kList"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "result"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<Evaluating GW point for k = \>\"", ",", "currentK"}], 
         "}"}], "]"}]}], "]"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9892256966273575`*^9, 3.989225776444422*^9}, {
   3.9892258810027504`*^9, 3.989225887369232*^9}, {3.989226632792692*^9, 
