        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", "integrate", " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"res", "=", 
         RowBox[{"NIntegrate", "[", 
          RowBox[{
           RowBox[{"interpFunc", "[", 
            RowBox[{"p", ",", "x"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"p", ",", "0.01", ",", "pMax"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", 
             RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
           RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}], ",", 
           RowBox[{"AccuracyGoal", "->", "4"}], ",", 
           RowBox[{"PrecisionGoal", "->", "4"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
