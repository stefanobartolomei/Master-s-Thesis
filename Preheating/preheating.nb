Cell[CellGroupData[{

Cell["GW", "Title",
 CellChangeTimes->{{3.9861966286376953`*^9, 
  3.986196636362591*^9}},ExpressionUUID->"475d0b11-07e0-104d-9a16-\
023669f9d033"],

Cell[CellGroupData[{

Cell["Compute the Power spectrum of GWs", "Chapter",
 CellChangeTimes->{{3.9862083362050114`*^9, 
  3.9862083521745014`*^9}},ExpressionUUID->"85cd933d-4841-cc48-9fdd-\
097c05e2e310"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           StyleBox["I", "TI"], 
           StyleBox["c", "TI"]], "\[Congruent]", 
          SubsuperscriptBox["\[Integral]", "0", "\[Tau]"], 
          StyleBox["d", "TI"], 
          StyleBox["t", "TI"], " ", "cos", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["k", "TI"], 
              StyleBox["t", "TI"]}], ")"}], 
          SubscriptBox["\[Chi]", 
           StyleBox["p", "TI"]], 
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}], 
          SubscriptBox["\[Chi]", 
           TemplateBox[{
             RowBox[{
               StyleBox["k", "TI"], "-", 
               StyleBox["p", "TI"]}]}, "Abs"]], 
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
      "input" -> 
      "I_c \\equiv \\int_0^\\tau dt \\ \\cos(k t) \\chi_p(t)\\chi_{|k-p|}(t)",
       "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", ",", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           StyleBox["I", "TI"], 
           StyleBox["s", "TI"]], "\[Congruent]", 
          SubsuperscriptBox["\[Integral]", "0", "\[Tau]"], 
          StyleBox["d", "TI"], 
          StyleBox["t", "TI"], " ", "sin", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["k", "TI"], 
              StyleBox["t", "TI"]}], ")"}], 
          SubscriptBox["\[Chi]", 
           StyleBox["p", "TI"]], 
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}], 
          SubscriptBox["\[Chi]", 
           TemplateBox[{
             RowBox[{
               StyleBox["k", "TI"], "-", 
               StyleBox["p", "TI"]}]}, "Abs"]], 
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
      "input" -> 
      "I_s \\equiv \\int_0^\\tau dt \\ \\sin(kt) \\chi_p(t)\\chi_{|k-p|}(t)", 
      "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"TimeIntegral", "[", 
      RowBox[{"k_", ",", "p_", ",", "x_", ",", "\[Tau]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"kp", ",", "Ic", ",", "Is"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"kp", "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"k", "^", "2"}], "+", 
           RowBox[{"p", "^", "2"}], "-", 
           RowBox[{"2", "*", "k", "*", "p", "*", "x"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"Quiet", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Ic", "=", 
           RowBox[{"NIntegrate", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Cos", "[", 
               RowBox[{"k", "*", "t"}], "]"}], "*", 
              RowBox[{"\[Chi]sol", "[", 
               RowBox[{"p", ",", "t"}], "]"}], "*", 
              RowBox[{"\[Chi]sol", "[", 
               RowBox[{"kp", ",", "t"}], "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"t", ",", "0", ",", "\[Tau]"}], "}"}], ",", 
             RowBox[{"Method", "->", "\"\<LocalAdaptive\>\""}], ",", 
             RowBox[{"MaxRecursion", "->", "15"}], ",", 
             RowBox[{"AccuracyGoal", "->", "5"}], ",", 
             RowBox[{"PrecisionGoal", "->", "5"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Is", "=", 
           RowBox[{"NIntegrate", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Sin", "[", 
               RowBox[{"k", "*", "t"}], "]"}], "*", 
              RowBox[{"\[Chi]sol", "[", 
               RowBox[{"p", ",", "t"}], "]"}], "*", 
              RowBox[{"\[Chi]sol", "[", 
               RowBox[{"kp", ",", "t"}], "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"t", ",", "0", ",", "\[Tau]"}], "}"}], ",", 
             RowBox[{"Method", "->", "\"\<LocalAdaptive\>\""}], ",", 
             RowBox[{"MaxRecursion", "->", "15"}], ",", 
             RowBox[{"AccuracyGoal", "->", "5"}], ",", 
             RowBox[{"PrecisionGoal", "->", "5"}]}], "]"}]}], ";"}], 
         "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         TemplateBox[<|"boxes" -> FormBox[
             RowBox[{
               SuperscriptBox[
                RowBox[{"(", 
                  RowBox[{"1", "-", 
                    SuperscriptBox[
                    StyleBox["x", "TI"], "2"]}], ")"}], "2"], " ", 
               SuperscriptBox[
                StyleBox["p", "TI"], "6"], 
               RowBox[{"(", 
                 RowBox[{"|", 
                   SubscriptBox[
                    StyleBox["I", "TI"], 
                    StyleBox["c", "TI"]], 
