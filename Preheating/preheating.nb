Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DiscreteTimeIntegral", "[", 
     RowBox[{"k_", ",", "p_", ",", "x_", ",", "\[Tau]_", ",", 
      RowBox[{"dt_", ":", "0.01"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "tList", ",", "\[Chi]1", ",", "\[Chi]2", ",", "kp", ",", "cosVec", ",",
         "sinVec", ",", "IntegrandCos", ",", "IntegrandSin", ",", "Ic", ",", 
        "Is"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"kp", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"k", "^", "2"}], "+", 
          RowBox[{"p", "^", "2"}], "-", 
          RowBox[{"2", "*", "k", "*", "p", "*", "x"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"tList", "=", 
        RowBox[{"Range", "[", 
         RowBox[{"0.", ",", "\[Tau]", ",", "dt"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"Quiet", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"\[Chi]1", "=", 
          RowBox[{
           RowBox[{"sol\[Chi]", "[", "p", "]"}], "[", "tList", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"\[Chi]2", "=", 
          RowBox[{
           RowBox[{"sol\[Chi]", "[", "kp", "]"}], "[", "tList", "]"}]}], 
         ";"}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"cosVec", "=", 
        RowBox[{"Cos", "[", 
         RowBox[{"k", "*", "tList"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sinVec", "=", 
        RowBox[{"Sin", "[", 
         RowBox[{"k", "*", "tList"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"IntegrandCos", "=", 
        RowBox[{"cosVec", "*", "\[Chi]1", "*", "\[Chi]2"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"IntegrandSin", "=", 
        RowBox[{"sinVec", "*", "\[Chi]1", "*", "\[Chi]2"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"Ic", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"dt", "/", "2"}], ")"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Total", "[", "IntegrandCos", "]"}], "*", "2"}], "-", 
           RowBox[{"IntegrandCos", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "-", 
           RowBox[{"IntegrandCos", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Is", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"dt", "/", "2"}], ")"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Total", "[", "IntegrandSin", "]"}], "*", "2"}], "-", 
           RowBox[{"IntegrandSin", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "-", 
           RowBox[{"IntegrandSin", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"x", "^", "2"}]}], ")"}], "^", "2"}], "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", "Ic", "]"}], "^", "2"}], "+", 
