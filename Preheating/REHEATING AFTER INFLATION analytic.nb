Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Map", " ", "to", " ", "Mathieu", " ", "equation"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"qvalue", " ", "=", " ", 
     FractionBox[
      RowBox[{
       SuperscriptBox["g", "2"], 
       SuperscriptBox["\[CapitalPhi]", "2"]}], 
      RowBox[{"4", " ", 
       SuperscriptBox["m\[Phi]", "2"]}]]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Avalue", " ", "=", " ", 
     RowBox[{
      FractionBox[
       SuperscriptBox["k", "2"], 
       SuperscriptBox["m\[Phi]", "2"]], "+", 
      RowBox[{"2", "qvalue"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Mu]Exp", " ", "=", " ", 
     RowBox[{"Abs", "[", 
      RowBox[{"Im", "[", 
       RowBox[{"MathieuCharacteristicExponent", "[", 
        RowBox[{"Avalue", ",", "qvalue"}], "]"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Chi]plot", " ", "=", " ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Re", "[", 
        RowBox[{"\[Chi]solMathieu", "[", "z", "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "0", ",", 
         RowBox[{
          RowBox[{"m\[Phi]", "*", "tMax"}], " ", "+", " ", 
          FractionBox["\[Pi]", "2"]}]}], "}"}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Red"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{
        "{", "\"\<\!\(\*SubscriptBox[\(\[Chi]\), \(k\)]\)\>\"", "}"}]}], ",", 
       RowBox[{"Frame", "->", "True"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Chi]\[Mu]plot", " ", "=", " ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"\[Mu]Exp", "*", "z"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "5", ",", 
         RowBox[{
          RowBox[{"m\[Phi]", "*", "tMax"}], "+", " ", 
          FractionBox["\[Pi]", "2"]}]}], "}"}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Blue"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{
        "{", "\"\<\!\(\*SuperscriptBox[\(e\), \(\*SubscriptBox[\(\[Mu]\), \(k\
\)] z\)]\)\>\"", "}"}]}], ",", 
       RowBox[{"Frame", "->", "True"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{"\[Chi]\[Mu]plot", ",", "\[Chi]plot", ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Time (z=\!\(\*SubscriptBox[\(m\), \(\[Phi]\)]\)t + \
\[Pi]/2)\>\"", ",", "\"\<\!\(\*SubscriptBox[\(\[Chi]\), \(k\)]\)\>\""}], 
       "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{"StringForm", "[", 
         RowBox[{"\"\<Spectator field \!\(\*SubscriptBox[\(\[Chi]\), \(k\)]\) \
for k = `` and q = ``\>\"", ",", "k", ",", "qvalue"}], "]"}], ",", "12"}], 
       "]"}]}]}], "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nplot", " ", "=", " ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Log", "[", 
        RowBox[{"numb\[Chi]", "[", "z", "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "5", ",", 
         RowBox[{
          RowBox[{"m\[Phi]", "*", "tMax"}], " ", "+", " ", 
          FractionBox["\[Pi]", "2"]}]}], "}"}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Red"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{
        "{", "\"\<Log(\!\(\*SubscriptBox[\(n\), \(k\)]\))\>\"", "}"}]}], ",", 
       RowBox[{"Frame", "->", "True"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"n\[Mu]plot", " ", "=", " ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"2", "*", "\[Mu]Exp", "*", "z"}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "5", ",", 
         RowBox[{
          RowBox[{"m\[Phi]", "*", "tMax"}], "+", " ", 
          FractionBox["\[Pi]", "2"]}]}], "}"}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Blue"}], "}"}]}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{
        "{", "\"\<2\!\(\*SubscriptBox[\(\[Mu]\), \(k\)]\)z\>\"", "}"}]}], ",", 
       RowBox[{"Frame", "->", "True"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{"n\[Mu]plot", ",", "nplot", ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Time (z=\!\(\*SubscriptBox[\(m\), \(\[Phi]\)]\)t + \
\[Pi]/2)\>\"", ",", "\"\<Log(\!\(\*SubscriptBox[\(n\), \(k\)]\))\>\""}], 
       "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{"StringForm", "[", 
         RowBox[{"\"\<Number density Log(\!\(\*SubscriptBox[\(n\), \(k\)]\)) \
for k = `` and q = ``\>\"", ",", "k", ",", "qvalue"}], "]"}], ",", "12"}], 
       "]"}]}]}], "]"}]}]}]], "Input",
