Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{
   "For", " ", "the", " ", "prereheting", " ", "scenario", " ", "with", " ", 
    "inflaton", " ", "potential", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["V", "TI"], 
          RowBox[{"(", "\[Phi]", ")"}], "\[LongEqual]", 
          FractionBox["1", "2"], 
          SubsuperscriptBox[
           StyleBox["m", "TI"], "\[Phi]", "2"], 
