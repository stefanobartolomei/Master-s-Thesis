      "errors" -> {}, "input" -> "\\chi_k(\\eta)", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "and", " ", "number", " ", "density", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           StyleBox["n", "TI"], 
           StyleBox["k", "TI"]], "(", "\[Eta]", ")"}], TraditionalForm], 
      "errors" -> {}, "input" -> "n_k(\\eta)", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "for", " ", "different", " ", "momentum", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        StyleBox["k", "TI"], TraditionalForm], "errors" -> {}, "input" -> "k",
       "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], " ", ",", " ", 
   RowBox[{"neglecting", " ", "the", " ", "universe", " ", "expansion"}], ",",
    "\[IndentingNewLine]", 
   RowBox[{
   "showing", " ", "the", " ", "equivalence", " ", "with", " ", "the", " ", 
    "Mathieu", " ", 
    RowBox[{"equation", ".", " ", "\[IndentingNewLine]", 
     RowBox[{"(", "2", ")"}]}], "Then"}], ",", " ", 
   RowBox[{
