      "input" -> "V(\\phi) = \\frac{1}{2}m^2_\\phi \\phi^2", "state" -> 
      "Boxes"|>,
     "TeXAssistantTemplate"]}], ",", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"(", "1", ")"}], " ", "we", " ", "study", " ", "analytically", " ",
     "the", " ", "inflaton", " ", "field"}], ",", " ", 
   RowBox[{"daughter", " ", "mode", " ", "function", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox["\[Chi]", 
