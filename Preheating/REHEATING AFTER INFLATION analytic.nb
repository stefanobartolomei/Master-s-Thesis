Cell[CellGroupData[{

Cell[TextData[{
 "Daughter dynamic: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          OverscriptBox["\[Chi]", "\:0308"], 
          StyleBox["k", "TI"]], "+", 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["k", "TI"], "2"], "+", 
             SuperscriptBox[
              StyleBox["g", "TI"], "2"], 
             SuperscriptBox["\[CapitalPhi]", "2"], 
             SuperscriptBox["sin", "2"], 
             RowBox[{"(", 
               RowBox[{
                 SubscriptBox[
                  StyleBox["m", "TI"], "\[Phi]"], 
                 StyleBox["t", "TI"]}], ")"}]}], ")"}], 
         SubscriptBox["\[Chi]", 
          StyleBox["k", "TI"]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\ddot{\\chi}_k + (k^2 + g^2 \\Phi^2 \\sin^2(m_\\phi t))\\chi_k =0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ebbe92e4-3ebd-6f46-86c0-1010c9d65999"]
}], "Chapter",
 CellChangeTimes->{{3.983877853843878*^9, 
  3.9838778692981396`*^9}},ExpressionUUID->"82dcd597-5e3b-0e4f-b057-\
44c510e3f923"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", "Frequency", " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]2", "[", "t_", "]"}], ":=", 
     RowBox[{
      SuperscriptBox["k", "2"], "+", 
      RowBox[{
       SuperscriptBox["g", "2"], 
       SuperscriptBox[
        RowBox[{"\[Phi]sol", "[", "t", "]"}], "2"]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]", "[", "t_", "]"}], ":=", 
     SqrtBox[
      RowBox[{"\[Omega]2", "[", "t", "]"}]]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"EOM", " ", "daughter", " ", "\[Chi]"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eq\[Chi]", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "''"}], "[", "t", "]"}], "+", 
       RowBox[{
        RowBox[{"\[Omega]2", "[", "t", "]"}], "*", 
        RowBox[{"\[Chi]", "[", "t", "]"}]}]}], "==", "0"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "conditions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Chi]conditions", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "[", "0", "]"}], "==", 
        FractionBox["1", 
         SqrtBox[
          RowBox[{"2", 
           RowBox[{"\[Omega]", "[", "0", "]"}]}]]]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Chi]", "'"}], "[", "0", "]"}], "==", 
        RowBox[{
         RowBox[{"-", "I"}], "*", 
         SqrtBox[
          FractionBox[
           RowBox[{"\[Omega]", "[", "0", "]"}], "2"]]}]}]}], "}"}]}], ";"}], 
   " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Initial", " ", "conditions", " ", 
     TemplateBox[<|"boxes" -> FormBox[
         RowBox[{
           SubscriptBox["\[Chi]", 
            StyleBox["k", "TI"]], 
           RowBox[{"(", 
             StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
           FractionBox[
            SuperscriptBox[
             StyleBox["e", "TI"], 
             RowBox[{"-", 
               StyleBox["i", "TI"], 
               SubscriptBox["\[Omega]", 
                StyleBox["k", "TI"]], 
               StyleBox["x", "TI"]}]], 
            SqrtBox[
             RowBox[{"2", 
               SubscriptBox["\[Omega]", 
                StyleBox["k", "TI"]]}]]]}], TraditionalForm], "errors" -> {}, 
       "input" -> "\\chi_k(x) =\\frac{e^{-i\\omega_k x}}{\\sqrt{2\\omega_k}}",
        "state" -> "Boxes"|>,
      "TeXAssistantTemplate"], " ", "to", " ", "be", " ", "valued", " ", "at",
      " ", 
     TemplateBox[<|"boxes" -> FormBox[
         RowBox[{
           StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
       "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
      "TeXAssistantTemplate"]}], " ", "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Solve", " ", "\[Chi]", " ", "dynamic"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"sol\[Chi]", "=", 
     RowBox[{"DSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"eq\[Chi]", ",", 
         RowBox[{"\[Chi]conditions", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"\[Chi]conditions", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"\[Chi]", "[", "t", "]"}], ",", "t"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Spectator", " ", "solution"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Chi]sol", "[", "t_", "]"}], "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{"\[Chi]", "[", "t", "]"}], " ", "/.", " ", 
       RowBox[{"sol\[Chi]", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Number", " ", "particles"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"numb\[Chi]", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        FractionBox["1", "2"], 
        FractionBox[
         SuperscriptBox[
          RowBox[{"Abs", "[", 
           RowBox[{
            RowBox[{"\[Chi]sol", "'"}], "[", "t", "]"}], "]"}], "2"], 
         RowBox[{"\[Omega]", "[", "t", "]"}]]}], "+", 
       RowBox[{
        FractionBox[
         RowBox[{"\[Omega]", "[", "t", "]"}], "2"], 
        SuperscriptBox[
         RowBox[{"Abs", "[", 
          RowBox[{"\[Chi]sol", "[", "t", "]"}], "]"}], "2"]}], "-", 
       FractionBox["1", "2"]}], " ", "//", "Simplify"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9838691903834076`*^9, 3.9838692036892986`*^9}, {
