Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Background", " ", 
     RowBox[{"equations", ":", " ", 
      RowBox[{"EOM", " ", "Inflaton", " ", "field"}]}]}], ",", " ", 
    RowBox[{"Friedman", " ", "equation"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"H", "[", 
      RowBox[{"\[Phi]_", ",", "d\[Phi]_"}], "]"}], ":=", 
     SqrtBox[
      RowBox[{
       FractionBox["1", 
        RowBox[{"3", 
         SuperscriptBox["Mpl", "2"]}]], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], 
          SuperscriptBox["d\[Phi]", "2"]}], " ", "+", " ", 
         RowBox[{
          FractionBox["1", "2"], 
          SuperscriptBox["m\[Phi]", "2"], " ", 
          SuperscriptBox["\[Phi]", "2"]}]}], ")"}]}]]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eqa", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"a", "'"}], "[", "t", "]"}], "==", 
      RowBox[{
       RowBox[{"a", "[", "t", "]"}], "*", 
       RowBox[{"H", "[", 
        RowBox[{
         RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
         RowBox[{
          RowBox[{"\[Phi]", "'"}], "[", "t", "]"}]}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eq\[Phi]", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"\[Phi]", "''"}], "[", "t", "]"}], "+", 
       RowBox[{
        SuperscriptBox["m\[Phi]", "2"], 
        RowBox[{"\[Phi]", "[", "t", "]"}]}]}], "==", "0"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "conditions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"backgroundconditions", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"a", "[", "0", "]"}], "==", "1"}], ",", 
       RowBox[{
        RowBox[{"\[Phi]", "[", "0", "]"}], "==", "\[CapitalPhi]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Phi]", "'"}], "[", "0", "]"}], "==", "0"}]}], "}"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Solve", " ", "Background", " ", "dynamic"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solbackground", "=", 
     RowBox[{"DSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"eq\[Phi]", ",", "eqa", ",", 
         RowBox[{"backgroundconditions", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"backgroundconditions", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ",", 
         RowBox[{"backgroundconditions", "[", 
          RowBox[{"[", "3", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
         RowBox[{"a", "[", "t", "]"}]}], "}"}], ",", "t"}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Solution", "'"}], "s", " ", "background"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Phi]sol", "[", "t_", "]"}], "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{"\[Phi]", "[", "t", "]"}], "/.", " ", 
       RowBox[{"solbackground", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"asol", "[", "t_", "]"}], "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{"a", "[", "t", "]"}], "/.", " ", 
       RowBox[{"solbackground", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}]}]}]], "Input",
