Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qMaxChart", "=", "150"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"AMaxChart", "=", "250"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Mu]", "[", 
     RowBox[{"A_", ",", "q_"}], "]"}], ":=", 
    RowBox[{"Abs", "[", 
     RowBox[{"Im", "[", 
      RowBox[{"MathieuCharacteristicExponent", "[", 
       RowBox[{"A", ",", "q"}], "]"}], "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"plotFloquet", "=", 
   RowBox[{"DensityPlot", "[", 
    RowBox[{
     RowBox[{"\[Mu]", "[", 
      RowBox[{"A", ",", "q"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"q", ",", "50", ",", "qMaxChart"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"A", ",", "150", ",", "AMaxChart"}], "}"}], ",", 
     RowBox[{"PlotPoints", "->", "80"}], ",", 
     RowBox[{"MaxRecursion", "->", "2"}], ",", 
     RowBox[{"ColorFunction", "->", "\"\<BlueGreenYellow\>\""}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"BarLegend", "[", 
       RowBox[{"Automatic", ",", 
        RowBox[{
        "LegendLabel", 
         "->", "\"\<\!\(\*SubscriptBox[\(\[Mu]\), \(k\)]\)\>\""}]}], "]"}]}], 
     ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Resonance parameter q\>\"", ",", "\"\<A\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<Floquet Exponent\>\""}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"unphysicalRegion", "=", 
   RowBox[{"RegionPlot", "[", 
    RowBox[{
     RowBox[{"A", "<", 
      RowBox[{"2", "*", "q"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"q", ",", "50", ",", "qMaxChart"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"A", ",", "150", ",", "AMaxChart"}], "}"}], ",", 
     RowBox[{"BoundaryStyle", "->", "None"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"Directive", "[", 
       RowBox[{"Gray", ",", 
        RowBox[{"Opacity", "[", "0.8", "]"}]}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PointK", " ", "=", " ", 
    RowBox[{"ListPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"qvalue", ",", "Avalue"}], "}"}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"Red", ",", 
         RowBox[{"PointSize", "[", "Large", "]"}]}], "}"}]}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
