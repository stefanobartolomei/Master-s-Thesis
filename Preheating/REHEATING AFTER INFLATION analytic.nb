Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"A", "[", "k_", "]"}], " ", ":=", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["k", "2"], 
      SuperscriptBox["m\[Phi]", "2"]], "+", 
     RowBox[{"2", 
      FractionBox[
       RowBox[{
        SuperscriptBox["g", "2"], 
        SuperscriptBox["\[CapitalPhi]", "2"]}], 
       RowBox[{"4", " ", 
        SuperscriptBox["m\[Phi]", "2"]}]]}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"eqn\[Chi]Mathieu", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"\[Chi]", "''"}], "[", "z", "]"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"A", "[", "k", "]"}], "-", 
         RowBox[{"2", "*", 
          FractionBox[
           RowBox[{
            SuperscriptBox["g", "2"], 
            SuperscriptBox["\[CapitalPhi]", "2"]}], 
           RowBox[{"4", " ", 
            SuperscriptBox["m\[Phi]", "2"]}]], "*", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", "*", "z"}], "]"}]}]}], ")"}], "*", 
       RowBox[{"\[Chi]", "[", "z", "]"}]}]}], "==", "0"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Omega]Mathieu", "[", 
     RowBox[{"z_", ",", "k_"}], "]"}], ":=", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"A", "[", "k", "]"}], "-", 
      RowBox[{"2", "*", 
       FractionBox[
        RowBox[{
         SuperscriptBox["g", "2"], 
         SuperscriptBox["\[CapitalPhi]", "2"]}], 
        RowBox[{"4", " ", 
         SuperscriptBox["m\[Phi]", "2"]}]], "*", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", "*", "z"}], "]"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Initial", " ", "condition", " ", "at", " ", "z"}], "=", "0"}], 
   " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Chi]in", "[", "k_", "]"}], ":=", 
   FractionBox["1", 
    SqrtBox[
     RowBox[{"2", " ", 
      RowBox[{"\[Omega]Mathieu", "[", 
       RowBox[{"0", ",", "k"}], "]"}]}]]]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"d\[Chi]in", "[", "k_", "]"}], ":=", 
    RowBox[{
     RowBox[{"-", "I"}], "*", 
     SqrtBox[
      FractionBox[
       RowBox[{" ", 
        RowBox[{"\[Omega]Mathieu", "[", 
         RowBox[{"0", ",", "k"}], "]"}]}], "2"]]}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", "Solve", " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"sol\[Chi]Mathieu", "=", 
    RowBox[{"DSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"eqn\[Chi]Mathieu", ",", 
        RowBox[{
         RowBox[{"\[Chi]", "[", "0", "]"}], "==", 
         RowBox[{"\[Chi]in", "[", "k", "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Chi]", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"d\[Chi]in", "[", "k", "]"}]}]}], "}"}], ",", 
      RowBox[{"\[Chi]", "[", "z", "]"}], ",", "z"}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", "Solution", " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Chi]solMathieu", "[", "z_", "]"}], "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{"\[Chi]", "[", "z", "]"}], "/.", " ", 
     RowBox[{"sol\[Chi]Mathieu", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9842818179007435`*^9, 3.984282049463833*^9}, {
  3.9842821059791317`*^9, 3.984282187891369*^9}, {3.9842822198875446`*^9, 
