Cell[CellGroupData[{

Cell["Compute the Power spectrum of GWs", "Chapter",
 CellChangeTimes->{{3.9862083362050114`*^9, 
  3.9862083521745014`*^9}},ExpressionUUID->"85cd933d-4841-cc48-9fdd-\
097c05e2e310"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           StyleBox["I", "TI"], 
           StyleBox["c", "TI"]], "\[Congruent]", 
          SubsuperscriptBox["\[Integral]", "0", "\[Tau]"], 
          StyleBox["d", "TI"], 
          StyleBox["t", "TI"], " ", "cos", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["k", "TI"], 
              StyleBox["t", "TI"]}], ")"}], 
          SubscriptBox["\[Chi]", 
           StyleBox["p", "TI"]], 
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}], 
          SubscriptBox["\[Chi]", 
           TemplateBox[{
             RowBox[{
               StyleBox["k", "TI"], "-", 
               StyleBox["p", "TI"]}]}, "Abs"]], 
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
      "input" -> 
      "I_c \\equiv \\int_0^\\tau dt \\ \\cos(k t) \\chi_p(t)\\chi_{|k-p|}(t)",
       "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", ",", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           StyleBox["I", "TI"], 
           StyleBox["s", "TI"]], "\[Congruent]", 
          SubsuperscriptBox["\[Integral]", "0", "\[Tau]"], 
          StyleBox["d", "TI"], 
          StyleBox["t", "TI"], " ", "sin", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["k", "TI"], 
              StyleBox["t", "TI"]}], ")"}], 
          SubscriptBox["\[Chi]", 
           StyleBox["p", "TI"]], 
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}], 
          SubscriptBox["\[Chi]", 
           TemplateBox[{
             RowBox[{
               StyleBox["k", "TI"], "-", 
               StyleBox["p", "TI"]}]}, "Abs"]], 
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
      "input" -> 
      "I_s \\equiv \\int_0^\\tau dt \\ \\sin(kt) \\chi_p(t)\\chi_{|k-p|}(t)", 
      "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"TimeIntegral", "[", 
      RowBox[{"k_", ",", "p_", ",", "x_", ",", "\[Tau]_"}], "]"}], ":=", 
