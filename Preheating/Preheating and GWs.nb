Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Range", " ", "values"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"kVals\[Chi]", "=", 
     RowBox[{"Range", "[", 
      RowBox[{"0.5", ",", "40.0", ",", "0.5"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"spectrum\[Chi]", "=", 
     RowBox[{"\[Chi]Spectrum", "[", 
      RowBox[{"kVals\[Chi]", ",", "zMax"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"spectrumn\[Chi]", "=", 
     RowBox[{"n\[Chi]Spectrum", "[", 
      RowBox[{"kVals\[Chi]", ",", "zMax"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", "Plot", " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"plotSpectrum\[Chi]", "=", 
    RowBox[{"ListLogPlot", "[", 
     RowBox[{"spectrum\[Chi]", ",", 
      RowBox[{"Joined", "->", "True"}], ",", 
      RowBox[{"InterpolationOrder", "->", "2"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<k (Momentum)\>\"", 
         ",", "\"\<\!\(\*SubscriptBox[\(P\), \(\[Chi]\)]\)(k)\>\""}], "}"}]}],
       ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", "0.005", "]"}], ",", 
         RowBox[{"Darker", "[", "Blue", "]"}]}], "}"}]}], ",", 
      RowBox[{"GridLines", "->", "Automatic"}], ",", 
      RowBox[{"PlotLabel", "->", "\"\<Daughter Field Power Spectrum\>\""}]}], 
     "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"plotSpectrumn\[Chi]", "=", 
    RowBox[{"ListLogPlot", "[", 
     RowBox[{"spectrumn\[Chi]", ",", 
      RowBox[{"Joined", "->", "True"}], ",", 
      RowBox[{"InterpolationOrder", "->", "2"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<k (Momentum)\>\"", 
         ",", "\"\<\!\(\*SubscriptBox[\(n\), \(\[Chi]\)]\)(k)\>\""}], "}"}]}],
       ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", "0.005", "]"}], ",", 
         RowBox[{"Darker", "[", "Red", "]"}]}], "}"}]}], ",", 
      RowBox[{"GridLines", "->", "Automatic"}], ",", 
      RowBox[{
      "PlotLabel", "->", "\"\<Daughter Field Occupation Number\>\""}]}], 
     "]"}]}]}]}]], "Input",
