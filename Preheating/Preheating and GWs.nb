Cell[CellGroupData[{

Cell["Power spectrum of the Daughter field", "Chapter",
 CellChangeTimes->{{3.986207547819771*^9, 
  3.9862075628888817`*^9}},ExpressionUUID->"e844c691-a2a4-804d-b7c3-\
61ff70033b75"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"PS\[Chi]", "[", 
     RowBox[{"k_", ",", "\[Tau]_"}], "]"}], ":=", 
    RowBox[{
     FractionBox[
      SuperscriptBox["k", "3"], 
      RowBox[{"2", 
       SuperscriptBox["\[Pi]", "2"]}]], "  ", 
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{"\[Chi]sol", "[", 
        RowBox[{"k", ",", "\[Tau]"}], "]"}], "]"}], "^", "2"}]}]}], " ", 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Chi]Spectrum", "[", 
     RowBox[{"kList_List", ",", "\[Tau]_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "currentK", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Monitor", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"currentK", "=", "k"}], ";", "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{"k", ",", 
             RowBox[{"PS\[Chi]", "[", 
              RowBox[{"k", ",", "\[Tau]"}], "]"}]}], "}"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "kList"}], "}"}]}], "]"}], ",", 
        RowBox[{"Row", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<Computation \[Chi] for k = \>\"", ",", "currentK"}], 
          "}"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"n\[Chi]Spectrum", "[", 
    RowBox[{"kList_List", ",", "\[Tau]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "currentK", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Monitor", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"currentK", "=", "k"}], ";", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{"number\[Chi]", "[", 
             RowBox[{"\[Tau]", ",", "k"}], "]"}]}], "}"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "kList"}], "}"}]}], "]"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<Computation n\[Chi] for k = \>\"", ",", "currentK"}], 
         "}"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9862048506209717`*^9, 3.986205034825388*^9}, {
   3.986207582773304*^9, 3.986207649113098*^9}, {3.986207830796232*^9, 
   3.986207848783087*^9}, {3.986208528693735*^9, 3.98620853904533*^9}, {
   3.986208588467291*^9, 3.986208589139244*^9}, 3.9862086946105385`*^9, {
