         "\[IndentingNewLine]", 
         RowBox[{"\[Chi]2", "=", 
          RowBox[{
           RowBox[{"sol\[Chi]", "[", "kp", "]"}], "[", "tList", "]"}]}], 
         ";"}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"cosVec", "=", 
        RowBox[{"Cos", "[", 
         RowBox[{"k", "*", "tList"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sinVec", "=", 
        RowBox[{"Sin", "[", 
         RowBox[{"k", "*", "tList"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"IntegrandCos", "=", 
        RowBox[{"cosVec", "*", "\[Chi]1", "*", "\[Chi]2"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"IntegrandSin", "=", 
        RowBox[{"sinVec", "*", "\[Chi]1", "*", "\[Chi]2"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"Ic", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"dt", "/", "2"}], ")"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Total", "[", "IntegrandCos", "]"}], "*", "2"}], "-", 
           RowBox[{"IntegrandCos", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "-", 
           RowBox[{"IntegrandCos", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Is", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"dt", "/", "2"}], ")"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Total", "[", "IntegrandSin", "]"}], "*", "2"}], "-", 
           RowBox[{"IntegrandSin", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "-", 
           RowBox[{"IntegrandSin", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"x", "^", "2"}]}], ")"}], "^", "2"}], "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", "Ic", "]"}], "^", "2"}], "+", 
          RowBox[{
           RowBox[{"Abs", "[", "Is", "]"}], "^", "2"}]}], ")"}], "*", 
        RowBox[{"p", "^", "6"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"FastGWSpectrumPoint", "[", 
     RowBox[{"k_", ",", "\[Tau]_", ",", 
      RowBox[{"pMax_", ":", "10.0"}], ",", 
      RowBox[{"dp_", ":", "0.1"}], ",", 
      RowBox[{"dx_", ":", "0.05"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "pList", ",", "xList", ",", "totalSum", ",", "pVal", ",", "xVal", ",", 
        "term"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"pList", "=", 
        RowBox[{"Range", "[", 
         RowBox[{"0.05", ",", "pMax", ",", "dp"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"xList", "=", 
        RowBox[{"Range", "[", 
         RowBox[{
          RowBox[{"-", "0.95"}], ",", "0.95", ",", "dx"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"totalSum", "=", 
        RowBox[{"ParallelSum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"term", "=", 
            RowBox[{"DiscreteTimeIntegral", "[", 
             RowBox[{"k", ",", "pVal", ",", "xVal", ",", "\[Tau]"}], "]"}]}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"term", "*", "dp", "*", "dx"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"pVal", ",", "pList"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"xVal", ",", "xList"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"k", "^", "3"}], "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", 
            RowBox[{"Pi", "^", "3"}]}], ")"}]}], ")"}], "*", "totalSum"}]}]}],
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
