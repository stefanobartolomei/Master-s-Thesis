          RowBox[{"2", "*", "k", "*", "p", "*", "x"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"tList", "=", 
        RowBox[{"Range", "[", 
         RowBox[{"0.", ",", "\[Tau]", ",", "dt"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"Quiet", "[", "\[IndentingNewLine]", 
        RowBox[{
