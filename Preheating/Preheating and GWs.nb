Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Background", " ", 
     RowBox[{"equations", ":", " ", 
      RowBox[{"EOM", " ", "Inflaton", " ", "field"}]}]}], ",", " ", 
    RowBox[{"Friedman", " ", "equation"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"H", "[", 
      RowBox[{"\[Phi]_", ",", "d\[Phi]_"}], "]"}], ":=", 
     SqrtBox[
      RowBox[{
       FractionBox["1", 
        RowBox[{"3", 
         SuperscriptBox["Mpl", "2"]}]], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], 
          SuperscriptBox["d\[Phi]", "2"]}], " ", "+", " ", 
         RowBox[{
          FractionBox["1", "2"], 
          SuperscriptBox["m\[Phi]", "2"], " ", 
          SuperscriptBox["\[Phi]", "2"]}], "+", " ", 
         RowBox[{
          FractionBox["\[Lambda]", "4"], 
          SuperscriptBox["\[Phi]", "4"]}]}], ")"}]}]]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eqa", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"a", "'"}], "[", "t", "]"}], "==", 
      RowBox[{
       RowBox[{"a", "[", "t", "]"}], "*", 
       RowBox[{"H", "[", 
        RowBox[{
         RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
         RowBox[{
          RowBox[{"\[Phi]", "'"}], "[", "t", "]"}]}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eq\[Phi]", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"\[Phi]", "''"}], "[", "t", "]"}], "+", 
       RowBox[{"3", 
        RowBox[{"H", "[", 
         RowBox[{
          RowBox[{"\[Phi]", "[", "t", "]"}], ",", 
          RowBox[{
           RowBox[{"\[Phi]", "'"}], "[", "t", "]"}]}], "]"}], 
        RowBox[{
         RowBox[{"\[Phi]", "'"}], "[", "t", "]"}]}], "+", 
       RowBox[{
        SuperscriptBox["m\[Phi]", "2"], 
        RowBox[{"\[Phi]", "[", "t", "]"}]}], "+", 
       RowBox[{"\[Lambda]", " ", 
        SuperscriptBox[
         RowBox[{"\[Phi]", "[", "t", "]"}], "3"]}]}], "==", "0"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "conditions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"backgroundconditions", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"a", "[", "0", "]"}], "==", "1"}], ",", 
       RowBox[{
        RowBox[{"\[Phi]", "[", "0", "]"}], "==", "\[CapitalPhi]0"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Phi]", "'"}], "[", "0", "]"}], "==", "0"}]}], "}"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Solve", " ", "Background", " ", "dynamic"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solbackground", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"eq\[Phi]", ",", "eqa", ",", 
         RowBox[{"backgroundconditions", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"backgroundconditions", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ",", 
         RowBox[{"backgroundconditions", "[", 
          RowBox[{"[", "3", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Phi]", ",", "a"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "zMax"}], "}"}], ",", 
       RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}], ",", 
       RowBox[{"MaxSteps", "->", "Infinity"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Solution", "'"}], "s", " ", "background"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Phi]sol", "[", "t_", "]"}], ":=", 
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"\[Phi]", "[", "t", "]"}], "/.", " ", 
       RowBox[{"solbackground", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"asol", "[", "t_", "]"}], ":=", 
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"a", "[", "t", "]"}], "/.", " ", 
       RowBox[{"solbackground", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Hsol", "[", "t_", "]"}], ":=", 
     RowBox[{"H", "[", 
      RowBox[{
       RowBox[{"\[Phi]sol", "[", "t", "]"}], ",", 
       RowBox[{
        RowBox[{"\[Phi]sol", "'"}], "[", "t", "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"\[Phi]Plot", " ", "=", " ", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"\[Phi]sol", "[", "t", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "zMax"}], "}"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", 
         RowBox[{"Darker", "[", "Green", "]"}]}], "}"}]}], ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<t (Time)\>\"", ",", "\"\<\[Phi](t)\>\""}], "}"}]}], ",", 
      RowBox[{"PlotLabel", "->", "\"\<Inflaton Field \[Phi](t)\>\""}]}], 
     "]"}]}]}]}]], "Input",
