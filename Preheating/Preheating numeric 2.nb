    RowBox[{"grid\[Chi]Rows", ",", 
     RowBox[{"ImageSize", "->", "500"}], ",", 
     RowBox[{"Spacings", "->", 
      RowBox[{"{", 
       RowBox[{"20", ",", "20"}], "}"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"number\[Chi]KPlot", "[", "k_", "]"}], ":=", 
   RowBox[{"LogPlot", "[", 
    RowBox[{
     RowBox[{"number\[Chi]", "[", 
      RowBox[{"t", ",", "k"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "tMax"}], "}"}], ",", 
