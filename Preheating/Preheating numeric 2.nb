Cell[CellGroupData[{

Cell[TextData[{
 "Find analytic solution for inflaton field: try ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Phi]", 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox["\[Theta]", "1"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SubscriptBox["\[Theta]", "2"], 
            StyleBox["t", "TI"]}]], "sin", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[Theta]", "3"], 
             StyleBox["t", "TI"], "+", 
             SubscriptBox["\[Theta]", "4"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\phi(t) = \\theta_1 e^{-\\theta_2 t}\\sin(\\theta_3 t + \\theta_4)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ff674341-a2a5-3a41-a054-daeff54d7b92"]
}], "Chapter",
 CellChangeTimes->{{3.984481170507271*^9, 3.9844812371703568`*^9}, {
  3.98449203568223*^9, 
  3.9844920367825527`*^9}},ExpressionUUID->"ec70b245-76c4-254a-aa5e-\
88e653f88300"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"data\[Phi]", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"t", ",", 
        RowBox[{"\[Phi]sol", "[", "t", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "tMax", ",", "0.001"}], "}"}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fit\[Phi]", "=", 
   RowBox[{"FindFit", "[", 
    RowBox[{"data\[Phi]", ",", 
     RowBox[{"\[Theta]1", "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "\[Theta]2"}], "*", "t"}], "]"}], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{
        RowBox[{"\[Theta]3", "*", "t"}], " ", "+", " ", "\[Theta]4"}], 
       "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Theta]1", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]2", ",", "0.01"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]3", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]4", ",", "0"}], "}"}]}], "}"}], ",", "t"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"analytical\[Phi]", "[", "t_", "]"}], "=", 
    RowBox[{
     RowBox[{"\[Theta]1", "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "\[Theta]2"}], "*", "t"}], "]"}], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{
        RowBox[{"\[Theta]3", "*", "t"}], "+", "\[Theta]4"}], "]"}]}], "/.", 
     " ", "fit\[Phi]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Fit parameters: \>\"", ",", "fit\[Phi]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"analytical\[Phi]", "[", "t", "]"}], ",", 
     RowBox[{"\[Phi]sol", "[", "t", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "tMax"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<Fit \[Phi](t)\>\"", 
      ",", "\"\<Numerical sol \[Phi](t)\>\""}], "}"}]}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"PlotLabel", "->", "\"\<Inflaton field\>\""}]}], "]"}]}], "Input",
