Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"kList", "=", 
    RowBox[{"{", 
     RowBox[{
     "0.1", ",", "0.5", ",", "1.0", ",", "1.5", ",", "2.0", ",", "5.0"}], 
     "}"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Chi]KPlot", "[", "k_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "\[Chi]solK", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Chi]solK", " ", "=", " ", 
       RowBox[{"sol\[Chi]", "[", "k", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"Re", "[", 
         RowBox[{"\[Chi]solK", "[", "t", "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "0", ",", "tMax"}], "}"}], ",", 
        RowBox[{"PlotLabel", "->", 
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"StringForm", "[", 
            RowBox[{"\"\<Spectator field \[Chi] for k = ``\>\"", ",", "k"}], 
            "]"}], ",", "12"}], "]"}]}], ",", 
        RowBox[{"Frame", "->", "True"}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{
          RowBox[{"ColorData", "[", "\"\<Rainbow\>\"", "]"}], "[", 
          RowBox[{"k", "/", "5"}], "]"}]}]}], " ", "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"all\[Chi]Plots", "=", 
   RowBox[{"\[Chi]KPlot", "/@", "kList"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"grid\[Chi]Rows", "=", 
   RowBox[{"Partition", "[", 
    RowBox[{"all\[Chi]Plots", ",", "2", ",", "2", ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1"}], "}"}], ",", "\"\<\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"autoGrid1", "=", 
