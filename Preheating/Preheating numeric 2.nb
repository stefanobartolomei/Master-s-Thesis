      RowBox[{"\[Omega]2", "[", 
       RowBox[{"t", ",", "k"}], "]"}]]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"EOM", " ", "daughter", " ", "\[Chi]"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eq\[Chi]", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "''"}], "[", "t", "]"}], "+", 
       RowBox[{
        RowBox[{"\[Omega]2", "[", 
         RowBox[{"t", ",", "k"}], "]"}], "*", 
        RowBox[{"\[Chi]", "[", "t", "]"}]}]}], "==", "0"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "conditions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Chi]conditions", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "[", "0", "]"}], "==", 
        FractionBox["1", 
         SqrtBox[
          RowBox[{"2", 
           RowBox[{"\[Omega]", "[", 
            RowBox[{"0", ",", "k"}], "]"}]}]]]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Chi]", "'"}], "[", "0", "]"}], "==", 
        RowBox[{
         RowBox[{"-", "I"}], "*", 
         SqrtBox[
          FractionBox[
           RowBox[{"\[Omega]", "[", 
            RowBox[{"0", ",", "k"}], "]"}], "2"]]}]}]}], "}"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Initial", " ", "conditions", " ", 
     TemplateBox[<|"boxes" -> FormBox[
         RowBox[{
           SubscriptBox["\[Chi]", 
            StyleBox["k", "TI"]], 
           RowBox[{"(", 
