Cell[CellGroupData[{

Cell[TextData[{
 "Mapping Spectator equation to the Mathieu equation: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Chi]", 
          StyleBox["k", "TI"], "\[Prime]\[Prime]"], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], "+", 
         RowBox[{"[", 
           RowBox[{
             StyleBox["A", "TI"], 
             RowBox[{"(", 
               StyleBox["z", "TI"], ")"}], "-", "2", 
             StyleBox["q", "TI"], 
             RowBox[{"(", 
               StyleBox["z", "TI"], ")"}], "cos", 
             RowBox[{"(", 
               RowBox[{"2", 
                 StyleBox["z", "TI"]}], ")"}]}], "]"}], 
         SubscriptBox["\[Chi]", 
          StyleBox["k", "TI"]], 
         RowBox[{"(", 
           StyleBox["z", "TI"], ")"}], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\chi''_k(z) + \\Big[A(z) - 2q(z) \\cos(2z)\\Big]\\chi_k(z) = 0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d497c885-1754-a341-be7f-eb516a79194b"],
 "\n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["z", "TI"], "\[Congruent]", 
         SubscriptBox["\[Theta]", "3"], 
         StyleBox["t", "TI"], "+", 
         SubscriptBox["\[Theta]", "4"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "z \\equiv \\theta_3 t + \\theta_4", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f2955960-3101-d449-a07e-1439fcbb7826"],
 ",  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["q", "TI"], "\[Congruent]", 
         FractionBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["g", "TI"], "2"], 
            SuperscriptBox[
             RowBox[{"(", 
               RowBox[{
                 SubscriptBox["\[Theta]", "1"], 
                 SuperscriptBox[
                  StyleBox["e", "TI"], 
                  RowBox[{"-", 
                    SubscriptBox["\[Theta]", "2"], 
                    StyleBox["t", "TI"]}]]}], ")"}], "2"]}], 
          RowBox[{"4", 
            SubsuperscriptBox["\[Theta]", "3", "2"]}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["g", "TI"], "2"], 
            SubsuperscriptBox["\[Theta]", "1", "2"], 
            SuperscriptBox[
             StyleBox["e", "TI"], 
             RowBox[{"-2", 
               SubscriptBox["\[Theta]", "2"], 
               FractionBox[
                RowBox[{
                  StyleBox["z", "TI"], "-", 
                  SubscriptBox["\[Theta]", "4"]}], 
                SubscriptBox["\[Theta]", "3"]]}]]}], 
          RowBox[{"4", 
            SubsuperscriptBox["\[Theta]", "3", "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "q \\equiv \\frac{g^2 (\\theta_1e^{-\\theta_2 t})^2}{4\\theta_3^2} = \
\\frac{g^2 \\theta_1^2e^{-2\\theta_2 \\frac{z - \
\\theta_4}{\\theta_3}}}{4\\theta_3^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "be7b250f-827a-354f-bca2-df08203d42d7"],
 " , ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["A", "TI"], "\[Congruent]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["k", "TI"], "2"], 
          SubsuperscriptBox["\[Theta]", "3", "2"]], "+", "2", 
         StyleBox["q", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "A \\equiv\\frac{k^2}{\\theta_3^2} + 2 q", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "aecbaf1c-a524-264b-9b24-0a761636bfbb"]
}], "Subtitle",
 CellChangeTimes->{{3.984481753023142*^9, 3.9844817684040394`*^9}, {
  3.984481865953493*^9, 3.9844818681370754`*^9}, {3.9844819119052887`*^9, 
  3.9844819130601597`*^9}, {3.984481947415785*^9, 3.984481954569702*^9}, {
  3.9844824135573425`*^9, 3.9844824321579685`*^9}, {3.984655503295698*^9, 
  3.9846555237598743`*^9}},ExpressionUUID->"08ca685d-ab71-f44d-8ce1-\
51d3851e9c99"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", "Parameters", " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"q", "[", "z_", "]"}], ":=", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{
         SuperscriptBox["g", "2"], 
         SuperscriptBox["\[Theta]1", "2"], 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "2"}], 
           FractionBox["\[Theta]2", "\[Theta]3"], 
           RowBox[{"(", 
            RowBox[{"z", " ", "-", " ", "\[Theta]4"}], ")"}]}], "]"}]}], 
        RowBox[{"4", " ", 
         SuperscriptBox["\[Theta]3", "2"]}]], "/.", "fit\[Phi]"}], " ", "//", 
      "Simplify"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Resonance", " ", "parameter"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", 
      RowBox[{"z_", ",", "k_"}], "]"}], ":=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        FractionBox[
         SuperscriptBox["k", "2"], 
         SuperscriptBox["\[Theta]3", "2"]], " ", "+", " ", 
        RowBox[{"2", " ", 
         RowBox[{"q", "[", "z", "]"}]}]}], " ", "/.", " ", "fit\[Phi]"}], " ",
       "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Mathieu", " ", "equation", " ", "for", " ", "daughter", " ", "\[Chi]"}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eq\[Chi]Mathieu", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "''"}], "[", "z", "]"}], " ", "+", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"A", "[", 
           RowBox[{"z", ",", "k"}], "]"}], " ", "-", " ", 
          RowBox[{"2", " ", 
           RowBox[{"q", "[", "z", "]"}], 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "z"}], "]"}]}]}], ")"}], 
        RowBox[{"\[Chi]", "[", "z", "]"}]}]}], "==", "0"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "conditions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Chi]conditionsM", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "[", "0", "]"}], "==", 
        FractionBox["1", 
         SqrtBox[
          RowBox[{"2", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{"A", "[", 
              RowBox[{"0", ",", "k"}], "]"}], " ", "-", " ", 
             RowBox[{"2", 
              RowBox[{"q", "[", "0", "]"}]}]}], "]"}]}]]]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Chi]", "'"}], "[", "0", "]"}], "==", 
        RowBox[{
         RowBox[{"-", "I"}], "*", 
         SqrtBox[
          FractionBox[
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{"A", "[", 
              RowBox[{"0", ",", "k"}], "]"}], " ", "-", " ", 
             RowBox[{"2", 
              RowBox[{"q", "[", "0", "]"}]}]}], "]"}], "2"]]}]}]}], "}"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Solve", " ", "\[Chi]", " ", "dynamic"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"zMax", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Theta]3", "*", "tMax"}], " ", "+", " ", "\[Theta]4"}], " ", 
      "/.", " ", "fit\[Phi]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol\[Chi]Mathieu", "=", 
     RowBox[{"ParametricNDSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"eq\[Chi]Mathieu", ",", 
         RowBox[{"\[Chi]conditionsM", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"\[Chi]conditionsM", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", "\[Chi]", ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "0", ",", "zMax"}], "}"}], ",", 
       RowBox[{"{", "k", "}"}], ",", 
       RowBox[{"MaxSteps", "->", "Infinity"}], ",", 
       RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}]}], "]"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.984482244612976*^9, 3.9844823343773384`*^9}, {
  3.9844823861924896`*^9, 3.984482409177698*^9}, {3.98448250662298*^9, 
