       RowBox[{"2", 
        RowBox[{"q", "[", 
         RowBox[{
          RowBox[{"\[Theta]3", "*", "t"}], " ", "+", " ", "\[Theta]4"}], 
         "]"}], 
        RowBox[{"Cos", "[", 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[Theta]3", " ", "t"}], " ", "+", " ", "\[Theta]4"}], 
