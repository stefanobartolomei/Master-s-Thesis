               SubscriptBox["\[Omega]", 
                StyleBox["k", "TI"]], 
               StyleBox["x", "TI"]}]], 
            SqrtBox[
             RowBox[{"2", 
               SubscriptBox["\[Omega]", 
                StyleBox["k", "TI"]]}]]]}], TraditionalForm], "errors" -> {}, 
       "input" -> "\\chi_k(x) =\\frac{e^{-i\\omega_kx}}{\\sqrt{2\\omega_k}}", 
       "state" -> "Boxes"|>,
      "TeXAssistantTemplate"], " ", "to", " ", "be", " ", "valued", " ", "at",
      " ", 
     TemplateBox[<|"boxes" -> FormBox[
         RowBox[{
           StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
