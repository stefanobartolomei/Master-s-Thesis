Cell[BoxData[{
 RowBox[{
  RowBox[{"Manipulate", "[", 
   RowBox[{
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"Re", "[", 
       RowBox[{
        RowBox[{"sol\[Chi]", "[", "k", "]"}], "[", "t", "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "tMax"}], "}"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
      RowBox[{"AxesLabel", "->", "Automatic"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", 
         RowBox[{"Darker", "[", "Blue", "]"}]}], "}"}]}], ",", 
      RowBox[{"PlotLabel", "->", 
       RowBox[{"Style", "[", 
