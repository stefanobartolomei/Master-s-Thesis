       RowBox[{"{", 
        RowBox[{"eq\[Phi]", ",", "eqa", ",", 
         RowBox[{"backgroundconditions", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"backgroundconditions", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ",", 
         RowBox[{"backgroundconditions", "[", 
          RowBox[{"[", "3", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Phi]", ",", "a"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "tMax"}], "}"}], ",", 
       RowBox[{"MaxSteps", "->", "Infinity"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Solution", "'"}], "s", " ", "background"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Phi]sol", "[", "t_", "]"}], ":=", 
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"\[Phi]", "[", "t", "]"}], "/.", " ", 
       RowBox[{"solbackground", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"asol", "[", "t_", "]"}], ":=", 
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"a", "[", "t", "]"}], "/.", " ", 
       RowBox[{"solbackground", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Hsol", "[", "t_", "]"}], ":=", 
