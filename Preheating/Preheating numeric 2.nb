      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{"StringForm", "[", 
         RowBox[{"\"\<Number density of \[Chi] for k = ``\>\"", ",", "k"}], 
         "]"}], ",", "12"}], "]"}]}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{
       RowBox[{"ColorData", "[", "\"\<Rainbow\>\"", "]"}], "[", 
       RowBox[{"k", "/", "5"}], "]"}]}]}], " ", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"allnumber\[Chi]Plots", "=", 
