     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"StringForm", "[", 
       RowBox[{"\"\<Non-adiabatic condition: \!\(\*TemplateBox[<|\"boxes\" -> \
FormBox[
RowBox[{
FractionBox[
OverscriptBox[
SubscriptBox[\"\[Omega]\", 
StyleBox[\"k\", \"TI\"]], \".\"], 
SubsuperscriptBox[\"\[Omega]\", 
StyleBox[\"k\", \"TI\"], \"2\"]], \"\[GreaterGreater]\", \"1\"}], \
TraditionalForm], \"errors\" -> {}, \"input\" -> \
\"\\\\frac{\\\\dot{\\\\omega_k}}{\\\\omega_k^2} \\\\gg 1\", \"state\" -> \
\"Boxes\"|>,\"TeXAssistantTemplate\"]\) for k = ``\>\"", ",", "k"}], 
       "]"}]}]}], "]"}], "\[IndentingNewLine]", 
