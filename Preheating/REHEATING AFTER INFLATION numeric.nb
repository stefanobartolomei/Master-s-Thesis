44c510e3f923"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", "Frequency", " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]2", "[", "t_", "]"}], ":=", 
     RowBox[{
      SuperscriptBox["k", "2"], "+", 
      RowBox[{
       SuperscriptBox["g", "2"], 
       SuperscriptBox["\[CapitalPhi]", "2"], 
       SuperscriptBox[
        RowBox[{"Sin", "[", 
         RowBox[{"m\[Phi]", " ", "t"}], "]"}], "2"]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]", "[", "t_", "]"}], ":=", 
     SqrtBox[
      RowBox[{"\[Omega]2", "[", "t", "]"}]]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"EOM", " ", "daughter", " ", "\[Chi]"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eq\[Chi]", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "''"}], "[", "t", "]"}], "+", 
       RowBox[{
        RowBox[{"\[Omega]2", "[", "t", "]"}], "*", 
        RowBox[{"\[Chi]", "[", "t", "]"}]}]}], "==", "0"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "conditions"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"\[Chi]conditions", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "[", "0", "]"}], "==", 
        FractionBox["1", 
         SqrtBox[
          RowBox[{"2", 
           RowBox[{"\[Omega]", "[", "0", "]"}]}]]]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Chi]", "'"}], "[", "0", "]"}], "==", 
        RowBox[{
         RowBox[{"-", "I"}], "*", 
         SqrtBox[
          FractionBox[
           RowBox[{"\[Omega]", "[", "0", "]"}], "2"]]}]}]}], "}"}]}], ";"}], 
   " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Initial", " ", "conditions", " ", 
     TemplateBox[<|"boxes" -> FormBox[
         RowBox[{
           SubscriptBox["\[Chi]", 
            StyleBox["k", "TI"]], 
           RowBox[{"(", 
             StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
           FractionBox[
            SuperscriptBox[
             StyleBox["e", "TI"], 
             RowBox[{"-", 
               StyleBox["i", "TI"], 
               SubscriptBox["\[Omega]", 
                StyleBox["k", "TI"]], 
               StyleBox["x", "TI"]}]], 
            SqrtBox[
             RowBox[{"2", 
               SubscriptBox["\[Omega]", 
                StyleBox["k", "TI"]]}]]]}], TraditionalForm], "errors" -> {}, 
       "input" -> "\\chi_k(x) =\\frac{e^{-i\\omega_k x}}{\\sqrt{2\\omega_k}}",
        "state" -> "Boxes"|>,
      "TeXAssistantTemplate"], " ", "to", " ", "be", " ", "valued", " ", "at",
      " ", 
     TemplateBox[<|"boxes" -> FormBox[
         RowBox[{
           StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
       "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
      "TeXAssistantTemplate"]}], " ", "*)"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Solve", " ", "\[Chi]", " ", "dynamic"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol\[Chi]", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"eq\[Chi]", ",", 
         RowBox[{"\[Chi]conditions", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"\[Chi]conditions", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", "\[Chi]", ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "tMax"}], "}"}], ",", 
       RowBox[{"MaxSteps", "->", "Infinity"}], ",", 
       RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Solution", " ", "\[Chi]"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Chi]sol", "[", "t_", "]"}], ":=", 
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"\[Chi]", "[", "t", "]"}], "/.", " ", 
       RowBox[{"sol\[Chi]", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Number", " ", "particles"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"numb\[Chi]", "[", "t_", "]"}], ":=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      FractionBox[
       SuperscriptBox[
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"\[Chi]", "'"}], "[", "t", "]"}], "]"}], "2"], 
       RowBox[{"\[Omega]", "[", "t", "]"}]]}], "+", 
     RowBox[{
      FractionBox[
       RowBox[{"\[Omega]", "[", "t", "]"}], "2"], 
      SuperscriptBox[
       RowBox[{"Abs", "[", 
        RowBox[{"\[Chi]", "[", "t", "]"}], "]"}], "2"]}], "-", 
     FractionBox["1", "2"]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"numb\[Chi]sol", "[", "t_", "]"}], ":=", 
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"numb\[Chi]", "[", "t", "]"}], "/.", " ", 
       RowBox[{"sol\[Chi]", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}]}]}]], "Input",
