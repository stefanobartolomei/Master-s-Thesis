          FractionBox["1", "2"], 
          SubsuperscriptBox[
           StyleBox["m", "TI"], "\[Phi]", "2"], 
          SuperscriptBox["\[Phi]", "2"]}], TraditionalForm], "errors" -> {}, 
      "input" -> "V(\\phi) = \\frac{1}{2}m^2_\\phi \\phi^2", "state" -> 
      "Boxes"|>,
     "TeXAssistantTemplate"]}], ",", " ", "\[IndentingNewLine]", 
   RowBox[{
   "we", " ", "study", " ", "numerically", " ", "the", " ", "daughter", " ", 
    "mode", " ", "function", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox["\[Chi]", 
