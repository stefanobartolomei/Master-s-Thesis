Cell[CellGroupData[{

Cell[TextData[{
 "Check equivalence with Mathieu equation: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Chi]", 
          StyleBox["k", "TI"], 
          SuperscriptBox["\[Null]", "\[Prime]\[Prime]"]], "+", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["A", "TI"], "-", "2", 
             StyleBox["q", "TI"], "cos", 
             RowBox[{"(", 
               RowBox[{"2", 
                 StyleBox["z", "TI"]}], ")"}]}], ")"}], 
         SubscriptBox["\[Chi]", 
          StyleBox["k", "TI"]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\chi_k^{''} + (A - 2 q \\cos(2 z))\\chi_k = 0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5495159d-21ee-884e-a449-70ec17a7a84c"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["q", "TI"], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["g", "TI"], "2"], 
            SuperscriptBox["\[CapitalPhi]", "2"]}], 
          RowBox[{"4", 
            SubsuperscriptBox[
             StyleBox["m", "TI"], "\[Phi]", "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "q = \\frac{g^2 \\Phi^2}{4 m_\\phi^2}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e13ba6ab-8f4f-9146-b511-ec02fd216ec7"],
 " , ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["A", "TI"], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["k", "TI"], "2"], 
          SubsuperscriptBox[
           StyleBox["m", "TI"], "\[Phi]", "2"]], "+", "2", 
         StyleBox["q", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "A = \\frac{k^2}{m_\\phi^2} + 2 q", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9735745d-4c82-9a49-8b80-2447faeb83c3"]
}], "Subtitle",
 CellChangeTimes->{{3.9838779235590973`*^9, 3.98387794396027*^9}, {
  3.9838779754859867`*^9, 
  3.9838779988876743`*^9}},ExpressionUUID->"4e526069-c8e8-9942-a1e2-\
1b6237c17492"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Map", " ", "to", " ", "Mathieu", " ", "equation"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"q", " ", "=", " ", 
     FractionBox[
      RowBox[{
       SuperscriptBox["g", "2"], 
       SuperscriptBox["\[CapitalPhi]", "2"]}], 
      RowBox[{"4", " ", 
       SuperscriptBox["m\[Phi]", "2"]}]]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"A", " ", "=", " ", 
     RowBox[{
      FractionBox[
       SuperscriptBox["k", "2"], 
       SuperscriptBox["m\[Phi]", "2"]], "+", 
      RowBox[{"2", "q"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Mathieu", " ", "equation", " ", "for", " ", "the", " ", "daughter", " ", 
     "field"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eq\[Chi]Mathieu", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]new", "''"}], "[", "z", "]"}], " ", "+", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"A", " ", "-", " ", 
          RowBox[{"2", "q", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "z"}], "]"}]}]}], ")"}], 
        RowBox[{"\[Chi]new", "[", "z", "]"}]}]}], "==", "0"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Solve", " ", "it"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol\[Chi]Mathieu", " ", "=", " ", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"eq\[Chi]Mathieu", ",", 
         RowBox[{
          RowBox[{"\[Chi]new", "[", "0", "]"}], "==", 
          FractionBox["1", 
           SqrtBox[
            RowBox[{"2", 
             SqrtBox[
              RowBox[{"A", " ", "-", " ", 
               RowBox[{"2", " ", "q", " ", 
                RowBox[{"Cos", "[", "0", "]"}]}]}]]}]]]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"\[Chi]new", "'"}], "[", "0", "]"}], "==", 
          RowBox[{
           RowBox[{"-", "I"}], "*", 
           SqrtBox[
            FractionBox[
             SqrtBox[
              RowBox[{"A", " ", "-", " ", 
               RowBox[{"2", " ", "q", " ", 
                RowBox[{"Cos", "[", "0", "]"}]}]}]], "2"]]}]}]}], "}"}], ",", 
       "\[Chi]new", ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "0", ",", " ", 
         RowBox[{"m\[Phi]", "*", "tMax"}]}], "}"}], ",", 
       RowBox[{"MaxSteps", "->", "Infinity"}], ",", 
       RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Chi]newsol", "[", "z_", "]"}], ":=", 
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"\[Chi]new", "[", "z", "]"}], "/.", 
       RowBox[{"sol\[Chi]Mathieu", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Number", " ", "particles"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"numb\[Chi]newsol", "[", "z_", "]"}], ":=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      FractionBox[
       SuperscriptBox[
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"\[Chi]newsol", "'"}], "[", "z", "]"}], "]"}], "2"], 
       SqrtBox[
        RowBox[{"A", " ", "-", " ", 
         RowBox[{"2", " ", "q", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "z"}], "]"}]}]}]]]}], "+", 
     RowBox[{
      FractionBox[
       SqrtBox[
        RowBox[{"A", " ", "-", " ", 
         RowBox[{"2", " ", "q", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "z"}], "]"}]}]}]], "2"], 
      SuperscriptBox[
       RowBox[{"Abs", "[", 
        RowBox[{"\[Chi]newsol", "[", "z", "]"}], "]"}], "2"]}], "-", 
     FractionBox["1", "2"]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"y", "=", " ", 
     RowBox[{"2", "*", 
      RowBox[{"Abs", "[", 
       RowBox[{"Im", "[", 
        RowBox[{"MathieuCharacteristicExponent", "[", 
         RowBox[{"A", ",", "q"}], "]"}], "]"}], "]"}], "*", "z"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", "Plot", " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"numb\[Chi]newsol", "[", "z", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"z", ",", "0", ",", 
       RowBox[{"m\[Phi]", "*", "tMax"}]}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"PlotStyle", "->", 
