Cell[CellGroupData[{

Cell["Stability / Instability chart", "Chapter",
 CellChangeTimes->{{3.983878031217863*^9, 
  3.9838780491446667`*^9}},ExpressionUUID->"fe65427b-9712-454c-a6b3-\
2c5da40a350d"],

Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{"Look", " ", "that", " ", "the", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        StyleBox["k", "TI"], TraditionalForm], "errors" -> {}, "input" -> "k",
       "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "mode", " ", "chosen", " ", "for", " ", 
    "the", " ", "specific", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        StyleBox["q", "TI"], TraditionalForm], "errors" -> {}, "input" -> "q",
       "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", 
    RowBox[{"(", 
     RowBox[{"and", " ", "consequentely", " ", 
      TemplateBox[<|"boxes" -> FormBox[
          StyleBox["A", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
        "A", "state" -> "Boxes"|>,
       "TeXAssistantTemplate"]}], ")"}], " ", "value", " ", "fits", " ", "in",
     " ", "the", " ", "resonance", " ", 
    RowBox[{"region", ".", " ", "For"}], " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["q", "TI"], "\[TildeTilde]", "100"}], TraditionalForm], 
      "errors" -> {}, "input" -> "q \\approx 100", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], ",", " ", 
   RowBox[{"chosing", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["k", "TI"], "\[LongEqual]", "1"}], TraditionalForm], 
      "errors" -> {}, "input" -> "k=1", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "we", " ", "sit", " ", "in", " ", "a", " ",
     "resonance", " ", "band", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"see", " ", "the", " ", "figure"}], ")"}], ".", " ", "This"}], " ",
     "implies", " ", "that", " ", "the", " ", "previous", " ", "plots", " ", 
    "for", " ", "the", " ", "mode", " ", "function", " ", "and", " ", 
    "number", " ", "density", " ", "grows", " ", "exponentially", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           StyleBox["n", "TI"], 
           StyleBox["k", "TI"]], 
          RowBox[{"(", 
            StyleBox["z", "TI"], ")"}], "\[Tilde]", 
          SuperscriptBox[
           StyleBox["e", "TI"], 
           RowBox[{"2", 
             SubscriptBox["\[Mu]", 
              StyleBox["k", "TI"]], 
             StyleBox["z", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
      "input" -> "n_k(z) \\sim e^{2\\mu_k z}", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}]}], " ", "*)"}]], "Input",
 CellChangeTimes->{{3.984644757731476*^9, 
  3.984644934697878*^9}},ExpressionUUID->"4450bb61-81af-914b-86dc-\
4eb83796a8de"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qMaxChart", "=", "150"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"AMaxChart", "=", "250"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Mu]", "[", 
     RowBox[{"A_", ",", "q_"}], "]"}], ":=", 
    RowBox[{"Abs", "[", 
     RowBox[{"Im", "[", 
      RowBox[{"MathieuCharacteristicExponent", "[", 
       RowBox[{"A", ",", "q"}], "]"}], "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"plotFloquet", "=", 
   RowBox[{"DensityPlot", "[", 
    RowBox[{
     RowBox[{"\[Mu]", "[", 
      RowBox[{"A", ",", "q"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"q", ",", "50", ",", "qMaxChart"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"A", ",", "150", ",", "AMaxChart"}], "}"}], ",", 
     RowBox[{"PlotPoints", "->", "80"}], ",", 
     RowBox[{"MaxRecursion", "->", "2"}], ",", 
     RowBox[{"ColorFunction", "->", "\"\<BlueGreenYellow\>\""}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"BarLegend", "[", 
       RowBox[{"Automatic", ",", 
        RowBox[{
        "LegendLabel", 
         "->", "\"\<\!\(\*SubscriptBox[\(\[Mu]\), \(k\)]\)\>\""}]}], "]"}]}], 
     ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Resonance parameter q\>\"", ",", "\"\<A\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<Floquet Exponent\>\""}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"unphysicalRegion", "=", 
   RowBox[{"RegionPlot", "[", 
    RowBox[{
     RowBox[{"A", "<", 
      RowBox[{"2", "*", "q"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"q", ",", "50", ",", "qMaxChart"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"A", ",", "150", ",", "AMaxChart"}], "}"}], ",", 
     RowBox[{"BoundaryStyle", "->", "None"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"Directive", "[", 
       RowBox[{"Gray", ",", 
        RowBox[{"Opacity", "[", "0.8", "]"}]}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PointK", " ", "=", " ", 
    RowBox[{"ListPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"q", ",", "A"}], "}"}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"Red", ",", 
         RowBox[{"PointSize", "[", "Large", "]"}]}], "}"}]}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"plotFloquet", ",", "PointK", ",", "unphysicalRegion", ",", 
   RowBox[{"Epilog", "->", 
    RowBox[{"Text", "[", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{"\"\<Unphysical (\!\(\*SuperscriptBox[\(k\), \(2\)]\) < 0)\>\"",
         ",", "Black", ",", "Bold", ",", "14"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"qMaxChart", "*", "0.7"}], ",", 
        RowBox[{"qMaxChart", "*", "0.7"}]}], "}"}]}], "]"}]}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.983878348017832*^9, 3.9838783604462395`*^9}, {
