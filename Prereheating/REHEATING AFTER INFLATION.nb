Cell[TextData[{
 "Daughter dynamic: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          OverscriptBox["\[Chi]", "\:0308"], 
          StyleBox["k", "TI"]], "+", 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["k", "TI"], "2"], "+", 
             SuperscriptBox[
              StyleBox["g", "TI"], "2"], 
             SuperscriptBox["\[CapitalPhi]", "2"], 
             SuperscriptBox["sin", "2"], 
             RowBox[{"(", 
               RowBox[{
                 SubscriptBox[
                  StyleBox["m", "TI"], "\[Phi]"], 
                 StyleBox["t", "TI"]}], ")"}]}], ")"}], 
         SubscriptBox["\[Chi]", 
          StyleBox["k", "TI"]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\ddot{\\chi}_k + (k^2 + g^2 \\Phi^2 \\sin^2(m_\\phi t))\\chi_k =0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ebbe92e4-3ebd-6f46-86c0-1010c9d65999"]
