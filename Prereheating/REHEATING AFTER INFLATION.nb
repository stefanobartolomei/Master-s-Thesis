      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", "nBands"}], "}"}]}], "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"plotBands", "=", 
