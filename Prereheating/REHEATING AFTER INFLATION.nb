          RowBox[{"0", ",", "AMaxChart"}], "}"}]}], "}"}]}]}], "]"}]}], ";"}],
   "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"lineK", "[", 
     RowBox[{"k_", ",", "q_"}], "]"}], ":=", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["k", "2"], 
      SuperscriptBox["m\[Phi]", "2"]], "+", 
     RowBox[{"2", "q"}]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
