Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"unphysicalRegion", "=", 
    RowBox[{"RegionPlot", "[", 
     RowBox[{
      RowBox[{"A", "<", 
       RowBox[{"2", "*", "q"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"q", ",", "0", ",", "qMaxChart"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"A", ",", "0", ",", "AMaxChart"}], "}"}], ",", 
      RowBox[{"BoundaryStyle", "->", "None"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Gray", ",", 
         RowBox[{"Opacity", "[", "0.8", "]"}]}], "]"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nBands", "=", "10"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"bands", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"MathieuCharacteristicB", "[", 
