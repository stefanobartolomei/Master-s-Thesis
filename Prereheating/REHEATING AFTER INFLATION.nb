Cell[CellGroupData[{

Cell["Stability / Instability chart", "Chapter",
 CellChangeTimes->{{3.983878031217863*^9, 
  3.9838780491446667`*^9}},ExpressionUUID->"fe65427b-9712-454c-a6b3-\
2c5da40a350d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qMaxChart", "=", "25"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"AMaxChart", "=", "45"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Mu]", "[", 
     RowBox[{"A_", ",", "q_"}], "]"}], ":=", 
    RowBox[{"Abs", "[", 
     RowBox[{"Im", "[", 
      RowBox[{"MathieuCharacteristicExponent", "[", 
       RowBox[{"A", ",", "q"}], "]"}], "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"plotFloquet", "=", 
  RowBox[{"DensityPlot", "[", 
   RowBox[{
    RowBox[{"\[Mu]", "[", 
     RowBox[{"A", ",", "q"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"q", ",", "0", ",", "qMaxChart"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"A", ",", "0", ",", "AMaxChart"}], "}"}], ",", 
    RowBox[{"PlotPoints", "->", "80"}], ",", 
    RowBox[{"MaxRecursion", "->", "2"}], ",", 
    RowBox[{"ColorFunction", "->", "\"\<SunsetColors\>\""}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"BarLegend", "[", 
      RowBox[{"Automatic", ",", 
       RowBox[{
       "LegendLabel", 
        "->", "\"\<\!\(\*SubscriptBox[\(\[Mu]\), \(k\)]\)\>\""}]}], "]"}]}], ",", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<Resonance parameter q\>\"", ",", "\"\<A\>\""}], "}"}]}], ",", 
    RowBox[{"PlotLabel", "->", "\"\<Floquet Exponent\>\""}]}], 
   "]"}]}]}], "Input",
