Notebook[{
Cell[BoxData[
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.983534651741276*^9, 3.983534684112362*^9}, {
  3.983534791668928*^9, 3.983534933812853*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"18b44fc9-be81-2149-b68f-a12614a8d679"],

Cell[CellGroupData[{

Cell[TextData[{
 "Mathieu equation: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["x", "TI"], "\:0308"], "+", 
         RowBox[{"[", 
           RowBox[{
             StyleBox["a", "TI"], "-", "2", 
             StyleBox["q", "TI"], "cos", 
             RowBox[{"(", 
               RowBox[{"2", 
                 StyleBox["t", "TI"]}], ")"}]}], "]"}], 
         StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\ddot{x} + \\qty[a - 2q\\cos(2t)]x = 0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "df75cd4d-2015-b848-9227-1c8867af190e"]
}], "Chapter",
 CellChangeTimes->{{3.983782349243538*^9, 
  3.983782368271538*^9}},ExpressionUUID->"be0f2111-7421-aa4c-8f20-\
bd603f457e65"],

Cell[TextData[{
 "Daughter equation: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          OverscriptBox["\[Chi]", "\:0308"], 
          StyleBox["k", "TI"]], "+", 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["k", "TI"], "2"], "+", 
             SuperscriptBox[
              StyleBox["g", "TI"], "2"], 
             SuperscriptBox["\[Phi]", "2"]}], ")"}], 
         SubscriptBox["\[Chi]", 
          StyleBox["k", "TI"]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\ddot{\\chi}_k + \\qty(k^2 + g^2\\phi^2)\\chi_k =0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6c00d968-3621-8b4c-9a96-e8e87def37be"]
}], "Subtitle",
 CellChangeTimes->{{3.98378317664073*^9, 3.983783201599407*^9}, {
  3.9837833414289417`*^9, 3.9837833420090294`*^9}, {3.983783379547699*^9, 
  3.9837833954691887`*^9}},ExpressionUUID->"06127d69-73df-1f4b-b815-\
4e52e2590115"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"floquetMu", "[", 
     RowBox[{
      RowBox[{"k_", "?", "NumericQ"}], ",", 
      RowBox[{"q_", "?", "NumericQ"}]}], "]"}], ":=", 
    RowBox[{"Abs", "[", 
     RowBox[{"Im", "[", 
      RowBox[{"MathieuCharacteristicExponent", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"k", "^", "2"}], "+", 
         RowBox[{"2", "*", "q"}]}], ",", 
        RowBox[{"-", "q"}]}], "]"}], "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kMax", "=", "10"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"qMax", "=", "50"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"stabilityChart", "=", 
    RowBox[{"DensityPlot", "[", 
     RowBox[{
      RowBox[{"floquetMu", "[", 
       RowBox[{"k", ",", "q"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", "kMax"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"q", ",", "0", ",", "qMax"}], "}"}], ",", 
      RowBox[{"PlotPoints", "->", "150"}], ",", 
      RowBox[{"MaxRecursion", "->", "2"}], ",", 
      RowBox[{"ColorFunction", "->", "\"\<SunsetColors\>\""}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"PlotLegends", "->", 
       RowBox[{"BarLegend", "[", 
        RowBox[{"Automatic", ",", 
         RowBox[{
         "LegendLabel", 
          "->", "\"\<Re[\!\(\*SubscriptBox[\(\[Mu]\), \(k\)]\)]\>\""}]}], 
        "]"}]}], ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<Comoving Momentum (k/m)\>\"", 
         ",", "\"\<Resonance Parameter (q)\>\""}], "}"}]}], ",", 
      RowBox[{
      "PlotLabel", 
       "->", "\"\<Instability Bands (Re[\!\(\*SubscriptBox[\(\[Mu]\), \
\(k\)]\)] > 0)\>\""}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Display", " ", "the", " ", "chart"}], "*)"}]}], "\n", 
 RowBox[{"Print", "[", "stabilityChart", "]"}]}], "Input",
 CellChangeTimes->{{3.983534651741276*^9, 3.983534684112362*^9}, {
   3.983534791668928*^9, 3.983534933812853*^9}, {3.9837822888069496`*^9, 
   3.983782289456991*^9}, {3.9837823412850666`*^9, 3.983782346878311*^9}, {
   3.9837831091852264`*^9, 3.9837831298007927`*^9}, 3.9837834107915993`*^9},
 CellLabel->"In[19]:=",ExpressionUUID->"87e3127d-f086-ed44-ac5b-0314b9039ba6"],

