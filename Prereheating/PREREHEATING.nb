        RowBox[{
         FractionBox["\[Lambda]", "4"], 
         SuperscriptBox["\[Phi]", "4"]}]}], ")"}]}]]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eqa", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"a", "'"}], "[", "t", "]"}], "==", 
      RowBox[{
       RowBox[{"a", "[", "t", "]"}], "*", 
       RowBox[{"H", "[", 
