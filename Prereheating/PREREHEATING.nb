         SqrtBox[
          RowBox[{"2", 
           RowBox[{"\[Omega]", "[", "0", "]"}]}]]]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Chi]", "'"}], "[", "0", "]"}], "==", 
        RowBox[{
         RowBox[{"-", "I"}], "*", 
