Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Mpl", "=", "1.0"}], ";"}], "                 ", 
  RowBox[{"(*", " ", 
   RowBox[{"reduced", " ", "mass", " ", "Planck"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"m\[Phi]", "=", "1.0"}], ";"}], "                   ", 
  RowBox[{"(*", " ", 
   RowBox[{"inflation", " ", "mass"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Lambda]", "=", "0.0"}], ";"}], "                     ", 
  RowBox[{"(*", " ", 
   RowBox[{"self", "-", 
    RowBox[{"coupling", " ", "constant"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"g", "=", "200.0"}], ";"}], "                 ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"coupling", " ", "constant", " ", "\[Phi]"}], "-", "\[Chi]"}], 
   " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tMax", "=", "50.0"}], ";"}], "            ", 
  RowBox[{"(*", " ", "Time", " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Phi]0", "=", 
    RowBox[{"0.1", " ", "Mpl"}]}], ";"}], "           ", 
  RowBox[{"(*", " ", 
   RowBox[{"Initial", " ", "amplitude", " ", "\[Phi]"}], " ", "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"q", " ", "=", " ", 
    FractionBox[
     RowBox[{
      SuperscriptBox["g", "2"], 
      SuperscriptBox["\[Phi]0", "2"]}], 
     RowBox[{"4", " ", 
      SuperscriptBox["m\[Phi]", "2"]}]]}], ";"}], "               ", 
  RowBox[{"(*", " ", 
   RowBox[{"Resonant", " ", "parameter"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"A", "[", "k_", "]"}], " ", ":=", " ", 
   RowBox[{
    FractionBox[
     SuperscriptBox["k", "2"], 
     SuperscriptBox["m\[Phi]", "2"]], "+", 
    RowBox[{"2", "q"}]}]}], ";"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.9838691903834076`*^9, 3.9838692036892986`*^9}, {
   3.983869340249071*^9, 3.9838693956222153`*^9}, {3.9838694545777054`*^9, 
