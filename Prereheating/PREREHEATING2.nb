Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"kvalues", "=", " ", 
    RowBox[{"10", "^", 
     RowBox[{"Subdivide", "[", 
      RowBox[{"0", ",", "3", ",", "10"}], "]"}]}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", "Frequency", " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Omega]2", "[", 
    RowBox[{"t_", ",", "k_"}], "]"}], ":=", 
   RowBox[{
    SuperscriptBox["k", "2"], "+", 
    RowBox[{
     SuperscriptBox["g", "2"], 
     SuperscriptBox[
      RowBox[{"\[Phi]sol", "[", "t", "]"}], "2"]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Omega]", "[", 
     RowBox[{"t_", ",", "k_"}], "]"}], ":=", 
    SqrtBox[
     RowBox[{"\[Omega]2", "[", 
      RowBox[{"t", ",", "k"}], "]"}]]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"EOM", " ", "daughter", " ", "\[Chi]"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"eq\[Chi]", "[", "k_", "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"\[Chi]", "''"}], "[", "t", "]"}], "+", 
      RowBox[{
       RowBox[{"\[Omega]2", "[", 
        RowBox[{"t", ",", "k"}], "]"}], "*", 
       RowBox[{"\[Chi]", "[", "t", "]"}]}]}], "==", "0"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", 
    RowBox[{"i", "<=", 
     RowBox[{"Length", "[", "kvalues", "]"}]}], ",", 
    RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"Initial", " ", "conditions", " ", 
      TemplateBox[<|"boxes" -> FormBox[
          RowBox[{
            SubscriptBox["\[Chi]", 
             StyleBox["k", "TI"]], 
            RowBox[{"(", 
              StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
            FractionBox[
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                StyleBox["i", "TI"], 
                SubscriptBox["\[Omega]", 
                 StyleBox["k", "TI"]], 
                StyleBox["x", "TI"]}]], 
             SqrtBox[
              RowBox[{"2", 
                SubscriptBox["\[Omega]", 
                 StyleBox["k", "TI"]]}]]]}], TraditionalForm], "errors" -> {},
         "input" -> 
        "\\chi_k(x) =\\frac{e^{-i\\omega_kx}}{\\sqrt{2\\omega_k}}", "state" -> 
        "Boxes"|>,
       "TeXAssistantTemplate"], " ", "to", " ", "be", " ", "valued", " ", 
      "at", " ", 
      TemplateBox[<|"boxes" -> FormBox[
          RowBox[{
            StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
        "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
       "TeXAssistantTemplate"]}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Chi]conditions", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Chi]", "[", "0", "]"}], "==", 
         FractionBox["1", 
          SqrtBox[
           RowBox[{"2", 
            RowBox[{"\[Omega]", "[", 
             RowBox[{"0", ",", 
              RowBox[{"kvalues", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}]]]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Chi]", "'"}], "[", "0", "]"}], "==", 
         RowBox[{
          RowBox[{"-", "I"}], "*", 
          SqrtBox[
           FractionBox[
            RowBox[{"\[Omega]", "[", 
             RowBox[{"0", ",", 
              RowBox[{"kvalues", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "2"]]}]}]}], "}"}]}], 
     ";", " ", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Solve", " ", "\[Chi]", " ", "dynamic"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"sol\[Chi]", " ", "=", " ", 
      RowBox[{"NDSolve", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"eq\[Chi]", "[", 
           RowBox[{"kvalues", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
          RowBox[{"\[Chi]conditions", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{"\[Chi]conditions", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", "\[Chi]", ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "0", ",", "tMax"}], "}"}], ",", 
        RowBox[{"MaxSteps", "->", "Infinity"}], ",", 
        RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}]}], "]"}]}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"Solution", " ", "\[Chi]"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Chi]sol", "[", "t_", "]"}], ":=", 
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"\[Chi]", "[", "t", "]"}], "/.", " ", 
        RowBox[{"sol\[Chi]", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"Number", " ", "particles"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"numb\[Chi]", "[", "t_", "]"}], ":=", 
      RowBox[{
       RowBox[{
        FractionBox["1", "2"], 
        FractionBox[
         SuperscriptBox[
          RowBox[{"Abs", "[", 
           RowBox[{
            RowBox[{"\[Chi]", "'"}], "[", "t", "]"}], "]"}], "2"], 
         RowBox[{"\[Omega]", "[", 
          RowBox[{"t", ",", 
           RowBox[{"kvalues", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "]"}]]}], "+", 
       RowBox[{
        FractionBox[
         RowBox[{"\[Omega]", "[", 
          RowBox[{"t", ",", 
           RowBox[{"kvalues", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "2"], 
        SuperscriptBox[
         RowBox[{"Abs", "[", 
          RowBox[{"\[Chi]", "[", "t", "]"}], "]"}], "2"]}], "-", 
       FractionBox["1", "2"]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"numb\[Chi]sol", "[", "t_", "]"}], ":=", 
      RowBox[{"Evaluate", "[", 
