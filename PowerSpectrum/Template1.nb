Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["g", "TI"], 
          StyleBox["n", "TI"]], 
         RowBox[{"(", "\[Tau]", ")"}], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"[", 
            RowBox[{"4", 
              SuperscriptBox["\[Beta]", "2"], "\[Tau]", 
              RowBox[{"(", 
                RowBox[{
                  FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
            "]"}], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]], "\[Theta]", 
         RowBox[{"(", "\[Tau]", ")"}], "\[Theta]", 
         RowBox[{"(", 
           RowBox[{
             FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "g_n(\\tau) = \\Big[4\\beta^2 \\tau \\Big(\\frac{1}{\\beta} - \
\\tau\\Big)\\Big]^{n-1} \\theta(\\tau) \\theta(\\frac{1}{\\beta} - \\tau)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "40c6c858-8ead-984e-836d-5f138b607f18"],
 " ,\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["R", "TI"], 
         RowBox[{"(", "\[Tau]", ")"}], "\[LongEqual]", 
         StyleBox["v", "TI"], "\[Tau]"}], TraditionalForm], "errors" -> {}, 
     "input" -> "R(\\tau) = v\\tau", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "27d55125-7628-1146-961f-b962dd02495e"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["g", "TI"], 
          StyleBox["n", "TI"]], 
         RowBox[{"(", "\[Tau]", ")"}], 
         SuperscriptBox[
          StyleBox["R", "TI"], 
          RowBox[{"3", "/", "2"}]], 
         RowBox[{"(", "\[Tau]", ")"}], 
         SqrtBox[
          FractionBox[
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["R", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "3"], ")"}], "2"]}], 
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["R", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "2"], ")"}], "2"], "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["R", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "3"], ")"}], "6"]}]]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "f(\\tau,q) = g_n(\\tau) R^{3/2}(\\tau)\\sqrt{\\frac{1 + \\qty(\\frac{q \
R(\\tau)}{3})^2}{1 + \\qty(\\frac{q R(\\tau)}{2})^2 + \\qty(\\frac{q \
R(\\tau)}{3})^6}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1b13b8ee-7eb9-0149-aad9-eba26ba30ffc"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["q", "TI"], ",", "\[Tau]", ",", 
             SuperscriptBox["\[Tau]", "\[Prime]"]}], ")"}], "\[LongEqual]", 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], 
         SuperscriptBox[
          StyleBox["f", "TI"], "*"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox["\[Tau]", "\[Prime]"], ",", 
             StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "\\Delta(q,\\tau,\\tau') = f(\\tau,q) f^*(\\tau',q)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0a78cf98-cd91-fd4f-a170-ffdf87daf515"]
