Cell[BoxData[
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}]], "Input",
 CellLabel->
  "In[105]:=",ExpressionUUID->"81a0e6e4-0735-6240-9f5c-2fc9c11590f6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"g2", "[", 
    RowBox[{"tau_", ",", "beta_"}], "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"4", "*", 
         SuperscriptBox["beta", "2"], " ", "tau", " ", "*", 
         RowBox[{"(", 
          RowBox[{
           FractionBox["1", "beta"], "-", "tau"}], ")"}]}], ",", 
        RowBox[{"0", "<", "tau", "<", 
         RowBox[{"1", "/", "beta"}]}]}], "}"}], "}"}], ",", "0"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"R", "[", 
    RowBox[{"tau_", ",", "v_"}], "]"}], " ", ":=", " ", 
   RowBox[{"v", "*", "tau"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"tau_", ",", "q_", ",", "beta_", ",", "v_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"g2", "[", 
     RowBox[{"tau", ",", "beta"}], "]"}], "*", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"R", "[", 
       RowBox[{"tau", ",", "v"}], "]"}], ")"}], 
     FractionBox["3", "2"]], " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", 
            RowBox[{"tau", ",", "v"}], "]"}]}], "3"], ")"}], "2"]}], 
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", 
            RowBox[{"tau", ",", "v"}], "]"}]}], "2"], ")"}], "2"], " ", "+", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", 
            RowBox[{"tau", ",", "v"}], "]"}]}], "3"], ")"}], "6"]}]]]}]}], 
  " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fTdf", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}], ",", 
     RowBox[{"beta_", "?", "NumericQ"}], ",", 
     RowBox[{"v_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"tau", ",", "q", ",", "beta", ",", "v"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], "*", "q0", "*", "tau"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"tau", ",", "0", ",", 
       RowBox[{"1", "/", "beta"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fstarTdf", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}], ",", 
     RowBox[{"beta_", "?", "NumericQ"}], ",", 
     RowBox[{"v_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ComplexExpand", "[", 
       RowBox[{"f", "[", 
        RowBox[{"tau", ",", "q", ",", "beta", ",", "v"}], "]"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", "*", "q0", "*", "tau"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"tau", ",", "0", ",", 
       RowBox[{"1", "/", "beta"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DeltaS", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}], ",", 
     RowBox[{"beta_", "?", "NumericQ"}], ",", 
     RowBox[{"v_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{"fTdf", "[", 
     RowBox[{"q0", ",", "q", ",", "beta", ",", "v"}], "]"}], "*", 
    RowBox[{"fstarTdf", "[", 
     RowBox[{"q0", ",", "q", ",", "beta", ",", "v"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"spectrum", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"r_", "?", "NumericQ"}], ",", 
     RowBox[{"beta_", "?", "NumericQ"}], ",", 
     RowBox[{"v_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{"q0", "^", "3"}], " ", 
    RowBox[{"DeltaS", "[", 
     RowBox[{"q0", ",", 
      RowBox[{"q0", "/", "r"}], ",", "beta", ",", "v"}], "]"}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.98214914512698*^9, 3.9821494010735016`*^9}, {
   3.9821495545873337`*^9, 3.9821495605698776`*^9}, 3.982149591188259*^9, {
   3.9821497594394913`*^9, 3.9821497763907967`*^9}, {3.9821500228642216`*^9, 
   3.982150092840908*^9}, {3.982151944577265*^9, 3.982151962551285*^9}, {
   3.9821617381212826`*^9, 3.9821617392975636`*^9}},
 CellLabel->
  "In[106]:=",ExpressionUUID->"be3bfecc-edad-2c49-af79-77368c675018"]
}, Open  ]],

