       RowBox[{
         SubscriptBox["\[CapitalOmega]", 
          RowBox[{
            StyleBox["D", "TI"], 
            StyleBox["M", "TI"]}]], "\[LongEqual]", 
         FractionBox["\[Rho]", 
          SubscriptBox["\[Rho]", 
           StyleBox["c", "TI"]]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\Omega_{DM} = \\frac{\\rho_{\\DM}}{\\rho_c}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b3adceff-91bd-de4c-881b-a97306745f76"],
