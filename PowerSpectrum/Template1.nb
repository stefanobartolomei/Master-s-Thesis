Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"g1", "[", "tau_", "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"0", "<", "tau", "<", 
         RowBox[{"1", "/", "beta"}]}]}], "}"}], "}"}], ",", "0"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"R", "[", "tau_", "]"}], " ", ":=", " ", 
   RowBox[{"v", "*", "tau"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"tau_", ",", "q_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"g1", "[", "tau", "]"}], "*", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"R", "[", "tau", "]"}], ")"}], 
     FractionBox["3", "2"]], " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", "tau", "]"}]}], "3"], ")"}], "2"]}], 
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", "tau", "]"}]}], "2"], ")"}], "2"], " ", "+", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", "tau", "]"}]}], "3"], ")"}], "6"]}]]]}]}], " ", 
  ";"}]}], "Input",
