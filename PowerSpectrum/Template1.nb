Cell["Varying velocity and PT time scale", "Chapter",
 CellChangeTimes->{{3.9821490881635494`*^9, 
  3.982149116324003*^9}},ExpressionUUID->"9c5047c8-165e-2e4b-bd63-\
acaeb1a10d3e"],

Cell[BoxData[
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}]], "Input",
 CellLabel->"In[18]:=",ExpressionUUID->"b40c45af-cccc-0848-98b6-29b60a135a5d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"g1", "[", 
    RowBox[{"tau_", ",", "beta_"}], "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"0", "<", "tau", "<", 
         RowBox[{"1", "/", "beta"}]}]}], "}"}], "}"}], ",", "0"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"R", "[", 
    RowBox[{"tau_", ",", "v_"}], "]"}], " ", ":=", " ", 
   RowBox[{"v", "*", "tau"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"tau_", ",", "q_", ",", "beta_", ",", "v_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"g1", "[", 
     RowBox[{"tau", ",", "beta"}], "]"}], "*", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"R", "[", 
       RowBox[{"tau", ",", "v"}], "]"}], ")"}], 
     FractionBox["3", "2"]], " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", 
            RowBox[{"tau", ",", "v"}], "]"}]}], "3"], ")"}], "2"]}], 
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", 
            RowBox[{"tau", ",", "v"}], "]"}]}], "2"], ")"}], "2"], " ", "+", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", 
            RowBox[{"tau", ",", "v"}], "]"}]}], "3"], ")"}], "6"]}]]]}]}], 
  " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fTdf", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}], ",", 
     RowBox[{"beta_", "?", "NumericQ"}], ",", 
     RowBox[{"v_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"tau", ",", "q", ",", "beta", ",", "v"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], "*", "q0", "*", "tau"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"tau", ",", "0", ",", 
       RowBox[{"1", "/", "beta"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fstarTdf", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}], ",", 
     RowBox[{"beta_", "?", "NumericQ"}], ",", 
     RowBox[{"v_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ComplexExpand", "[", 
       RowBox[{"f", "[", 
        RowBox[{"tau", ",", "q", ",", "beta", ",", "v"}], "]"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", "*", "q0", "*", "tau"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"tau", ",", "0", ",", 
       RowBox[{"1", "/", "beta"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DeltaS", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}], ",", 
     RowBox[{"beta_", "?", "NumericQ"}], ",", 
     RowBox[{"v_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{"fTdf", "[", 
     RowBox[{"q0", ",", "q", ",", "beta", ",", "v"}], "]"}], "*", 
    RowBox[{"fstarTdf", "[", 
     RowBox[{"q0", ",", "q", ",", "beta", ",", "v"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"spectrum", "[", 
    RowBox[{
