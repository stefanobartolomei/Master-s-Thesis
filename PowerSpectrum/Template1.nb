 RowBox[{
  RowBox[{
   RowBox[{"fTdf", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"tau", ",", "q"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], "*", "q0", "*", "tau"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"tau", ",", "0", ",", 
       RowBox[{"1", "/", "beta"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
