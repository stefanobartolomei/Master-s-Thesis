Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"g2", "[", "tau_", "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"4", "*", 
         SuperscriptBox["beta", "2"], " ", "tau", " ", "*", 
         RowBox[{"(", 
          RowBox[{
           FractionBox["1", "beta"], "-", "tau"}], ")"}]}], ",", 
        RowBox[{"0", "<", "tau", "<", 
         RowBox[{"1", "/", "beta"}]}]}], "}"}], "}"}], ",", "0"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"R", "[", "tau_", "]"}], " ", ":=", " ", 
   RowBox[{"v", "*", "tau"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"tau_", ",", "q_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"g2", "[", "tau", "]"}], "*", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"R", "[", "tau", "]"}], ")"}], 
     FractionBox["3", "2"]], " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
