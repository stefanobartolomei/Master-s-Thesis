         FractionBox[
          RowBox[{"3", 
            SubsuperscriptBox[
             StyleBox["H", "TI"], "0", "2"]}], 
          RowBox[{"8", "\[Pi]", 
            StyleBox["G", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\rho_c = \\frac{3H^2_0}{8\\pi G}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "629624e4-f3d4-a342-8618-7dfb1aea1f54"],
 ", ",
