       RowBox[{
         SubscriptBox["\[CapitalDelta]", 
          StyleBox["S", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["q", "TI"], ",", 
             SubscriptBox[
              StyleBox["q", "TI"], "0"]}], ")"}], "\[LongEqual]", 
         "\[Integral]", 
         StyleBox["d", "TI"], "\[Tau]", 
         StyleBox["d", "TI"], 
         SuperscriptBox["\[Tau]", "\[Prime]"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            StyleBox["i", "TI"], 
            SubscriptBox[
             StyleBox["q", "TI"], "0"], 
            RowBox[{"(", 
              RowBox[{"\[Tau]", "-", 
                SuperscriptBox["\[Tau]", "\[Prime]"]}], ")"}]}]], 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], 
