      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", "tau", "]"}]}], "2"], ")"}], "2"], " ", "+", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"R", "[", "tau", "]"}]}], "3"], ")"}], "6"]}]]]}]}], " ", 
