Cell[TextData[{
 "Fourier transform\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["q", "TI"], "0"], ",", 
             StyleBox["q", "TI"]}], ")"}], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", "0", 
          RowBox[{"1", "/", "\[Beta]"}]], 
         StyleBox["d", "TI"], "\[Tau]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            StyleBox["i", "TI"], 
            SubscriptBox[
             StyleBox["q", "TI"], "0"], "\[Tau]"}]], 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "f(q_0,q) = \\int _0^{1/\\beta}d\\tau e^{-iq_0\\tau} f(\\tau,q)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "318f81b8-05cf-dd45-855a-b2b5b6d257bd"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[CapitalDelta]", 
          StyleBox["h", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["q", "TI"], ",", 
             SubscriptBox[
              StyleBox["q", "TI"], "0"]}], ")"}], "\[LongEqual]", 
         "\[Integral]", 
         StyleBox["d", "TI"], "\[Tau]", 
         StyleBox["d", "TI"], 
         SuperscriptBox["\[Tau]", "\[Prime]"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            StyleBox["i", "TI"], 
            SubscriptBox[
             StyleBox["q", "TI"], "0"], 
            RowBox[{"(", 
              RowBox[{"\[Tau]", "-", 
                SuperscriptBox["\[Tau]", "\[Prime]"]}], ")"}]}]], 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], 
         SuperscriptBox[
          StyleBox["f", "TI"], "*"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox["\[Tau]", "\[Prime]"], ",", 
             StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\Delta_h(q,q_0) = \\int d\\tau d\\tau' e^{-iq_0(\\tau - \\tau')} \
f(\\tau,q) f^*(\\tau',q)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bf7c39ab-8e8a-e24e-ae6d-dee1cae2b29f"]
