Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"fTdf", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"tau", ",", "q"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], "*", "q0", "*", "tau"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"tau", ",", "0", ",", 
       RowBox[{"1", "/", "beta"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fstarTdf", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ComplexExpand", "[", 
       RowBox[{"f", "[", 
        RowBox[{"tau", ",", "q"}], "]"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", "*", "q0", "*", "tau"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"tau", ",", "0", ",", 
       RowBox[{"1", "/", "beta"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DeltaS", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{"fTdf", "[", 
     RowBox[{"q0", ",", "q"}], "]"}], "*", 
    RowBox[{"fstarTdf", "[", 
     RowBox[{"q0", ",", "q"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"spectrumFixedRatio", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
