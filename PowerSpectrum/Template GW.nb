  3.982930041504627*^9}},ExpressionUUID->"0a0c834e-9f0d-f74f-93cc-\
ea76c2bca40d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"funzioneprova", "[", "x_", "]"}], ":=", 
   RowBox[{"x", "^", "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xmin", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xmax", " ", "=", " ", 
   RowBox[{"10", "^", "3"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"deltax", " ", "=", " ", 
   RowBox[{"10", "^", "6"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xList", " ", "=", " ", 
   RowBox[{"10", "^", 
    RowBox[{"Subdivide", "[", 
     RowBox[{
      RowBox[{"Log10", "[", "xmin", "]"}], ",", 
      RowBox[{"Log10", "[", "xmax", "]"}], ",", "deltax"}], "]"}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.982932055103815*^9, 3.9829320856551933`*^9}, {
  3.9829321224011745`*^9, 3.982932160792074*^9}},
 CellLabel->
  "In[383]:=",ExpressionUUID->"7e797b80-5770-3844-9fb6-d4a2b312ca4a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"dataprovax", " ", "=", " ", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{"ParallelTable", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", "x", "}"}], ",", 
         RowBox[{"funzioneprova", "[", "x", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "xList"}], "}"}]}], "]"}], ",", "1"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"interprova", " ", "=", " ", 
   RowBox[{"Interpolation", "[", 
    RowBox[{"dataprovax", ",", 
     RowBox[{"InterpolationOrder", "->", "3"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.982932161997164*^9, 3.982932231154688*^9}},
