Notebook[{
Cell[BoxData[
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}]], "Input",
 CellLabel->
  "In[361]:=",ExpressionUUID->"fba0ff3c-3a73-0a41-badc-fc3befe5a987"],

Cell[CellGroupData[{

Cell[TextData[{
 "Template for Power Spectrum of GW from ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox["1", "st"], TraditionalForm], "errors" -> {}, "input" -> 
     "1^{\\text{st}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f2db6b19-4cf2-3c41-9b44-fe148b909bd0"],
 " order PT "
}], "Title",
 CellChangeTimes->{{3.9821483781011467`*^9, 3.982148403693825*^9}, {
  3.982152415301462*^9, 3.9821524228112583`*^9}, {3.9828550127682858`*^9, 
  3.9828550387462425`*^9}},ExpressionUUID->"afb58401-4e32-6544-8a9f-\
c8f288dfaa74"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["g", "TI"], 
          StyleBox["n", "TI"]], 
         RowBox[{"(", "\[Tau]", ")"}], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"[", 
            RowBox[{"4", 
              SuperscriptBox["\[Beta]", "2"], "\[Tau]", 
              RowBox[{"(", 
                RowBox[{
                  FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
            "]"}], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]], "\[Theta]", 
         RowBox[{"(", "\[Tau]", ")"}], "\[Theta]", 
         RowBox[{"(", 
           RowBox[{
             FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "g_n(\\tau) = \\Big[4\\beta^2 \\tau \\Big(\\frac{1}{\\beta} - \
\\tau\\Big)\\Big]^{n-1} \\theta(\\tau) \\theta(\\frac{1}{\\beta} - \\tau)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "eadbd653-bd98-6440-b707-ca1841e2cc48"],
 " \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["F", "TI"], 
         RowBox[{"(", 
           StyleBox["k", "TI"], ")"}], "\[LongEqual]", 
         SqrtBox[
          FractionBox[
           SuperscriptBox[
            StyleBox["R", "TI"], "3"], 
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
                RowBox[{
                  StyleBox["k", "TI"], 
                  StyleBox["R", "TI"]}], ")"}], "4"]}]]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "F(k) = \\sqrt{\\frac{R^3}{1 + (k R)^4}}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "781ab9ab-f1a3-5e4c-952b-222be374d1a0"]
}], "Subtitle",
 CellChangeTimes->{{3.982930042466116*^9, 
  3.9829300705945606`*^9}},ExpressionUUID->"db46176f-d5fc-e145-ac4e-\
95379aff3bea"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"gn", "[", 
    RowBox[{"tau_", ",", "beta_", ",", "n_"}], "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"4", "*", 
           SuperscriptBox["beta", "2"], " ", "tau", " ", "*", 
           RowBox[{"(", 
            RowBox[{
             FractionBox["1", "beta"], "-", "tau"}], ")"}]}], ")"}], 
         RowBox[{"n", "-", "1"}]], ",", 
        RowBox[{"0", "<", "tau", "<", 
         RowBox[{"1", "/", "beta"}]}]}], "}"}], "}"}], ",", "0"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"R", "[", 
    RowBox[{"v_", ",", "beta_"}], "]"}], ":=", 
   FractionBox["v", "beta"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Fmodulo", "[", 
     RowBox[{"k_", ",", "v_", ",", "beta_"}], "]"}], " ", ":=", 
    FractionBox[
     RowBox[{
      RowBox[{"R", "[", 
       RowBox[{"v", ",", "beta"}], "]"}], "^", "3"}], 
     RowBox[{"1", " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"k", "*", 
         RowBox[{"R", "[", 
          RowBox[{"v", ",", "beta"}], "]"}]}], ")"}], "^", "4"}]}]]}], ";"}], 
  " "}]}], "Input",
 CellChangeTimes->{{3.9829301513074055`*^9, 3.9829303275755367`*^9}, {
  3.9829305174875584`*^9, 3.9829305222887707`*^9}},
 CellLabel->
  "In[362]:=",ExpressionUUID->"8657eeb7-a2dc-4a4b-b511-78870250528d"],

