Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"gFourier", "[", 
    RowBox[{
     RowBox[{"k_", "?", "NumericQ"}], ",", 
     RowBox[{"beta_", "?", "NumericQ"}], ",", "n_"}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{"gn", "[", 
        RowBox[{"tau", ",", "beta", ",", "n"}], "]"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", "*", "k", "*", "tau"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"tau", ",", 
       RowBox[{"-", "\[Infinity]"}], ",", 
       RowBox[{"+", "\[Infinity]"}]}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.982930379121006*^9, 3.982930497692974*^9}, {
  3.9829305587820377`*^9, 3.982930624832569*^9}},
 CellLabel->
  "In[365]:=",ExpressionUUID->"6a291cbc-b54d-774d-94d0-803518405886"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Ps", "[", 
    RowBox[{
     RowBox[{"k_", "?", "NumericQ"}], ",", 
     RowBox[{"beta_", "?", "NumericQ"}], ",", 
     RowBox[{"v_", "?", "NumericQ"}], ",", "n_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Fmodulo", "[", 
     RowBox[{"k", ",", "v", ",", "beta"}], "]"}], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{"gFourier", "[", 
        RowBox[{"k", ",", "beta", ",", "n"}], "]"}], "]"}], "^", "2"}], 
     ")"}]}]}], ";"}]], "Input",
