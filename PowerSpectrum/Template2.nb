Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["g", "TI"], 
          StyleBox["n", "TI"]], 
         RowBox[{"(", "\[Tau]", ")"}], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"[", 
            RowBox[{"4", 
              SuperscriptBox["\[Beta]", "2"], "\[Tau]", 
              RowBox[{"(", 
                RowBox[{
                  FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
            "]"}], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]], "\[Theta]", 
         RowBox[{"(", "\[Tau]", ")"}], "\[Theta]", 
         RowBox[{"(", 
           RowBox[{
             FractionBox["1", "\[Beta]"], "-", "\[Tau]"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "g_n(\\tau) = \\Big[4\\beta^2 \\tau \\Big(\\frac{1}{\\beta} - \
\\tau\\Big)\\Big]^{n-1} \\theta(\\tau) \\theta(\\frac{1}{\\beta} - \\tau)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "40c6c858-8ead-984e-836d-5f138b607f18"],
 " ,\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["L", "TI"], 
         RowBox[{"(", "\[Tau]", ")"}], "\[LongEqual]", 
         FractionBox[
          StyleBox["v", "TI"], "\[Beta]"], 
         StyleBox["g", "TI"], 
         RowBox[{"(", "\[Tau]", ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "L(\\tau) = \\frac{v}{\\beta}g(\\tau)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "21586c3d-73bc-7e4d-a31c-523107dd7fca"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], "\[LongEqual]", 
         StyleBox["L", "TI"], 
         RowBox[{"(", "\[Tau]", ")"}], 
         SqrtBox[
          FractionBox[
           StyleBox["v", "TI"], "\[Beta]"]], 
         SqrtBox[
          FractionBox[
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["L", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "3"], ")"}], "2"]}], 
           RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["L", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "2"], ")"}], "2"], "+", 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   StyleBox["q", "TI"], 
                   StyleBox["L", "TI"], 
                   RowBox[{"(", "\[Tau]", ")"}]}], "3"], ")"}], "6"]}]]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "f(\\tau,q) = L(\\tau) \\sqrt{\\frac{v}{\\beta}}\\sqrt{\\frac{1 + \\qty(\
\\frac{q L(\\tau)}{3})^2}{1 + \\qty(\\frac{q L(\\tau)}{2})^2 + \\qty(\\frac{q \
L(\\tau)}{3})^6}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1b13b8ee-7eb9-0149-aad9-eba26ba30ffc"],
