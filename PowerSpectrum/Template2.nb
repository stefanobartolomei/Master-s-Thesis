Cell[CellGroupData[{

Cell["Varying velocity and PT time scale", "Chapter",
 CellChangeTimes->{{3.9821490881635494`*^9, 
  3.982149116324003*^9}},ExpressionUUID->"9c5047c8-165e-2e4b-bd63-\
acaeb1a10d3e"],

Cell[BoxData[
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}]], "Input",
 CellLabel->
  "In[129]:=",ExpressionUUID->"b40c45af-cccc-0848-98b6-29b60a135a5d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"g1", "[", 
    RowBox[{"tau_", ",", "beta_"}], "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"0", "<", "tau", "<", 
         RowBox[{"1", "/", "beta"}]}]}], "}"}], "}"}], ",", "0"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"L", "[", 
    RowBox[{"tau_", ",", "beta_", ",", "v_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    FractionBox["v", "beta"], "*", 
    RowBox[{"g1", "[", 
     RowBox[{"tau", ",", "beta"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"tau_", ",", "q_", ",", "beta_", ",", "v_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"L", "[", 
     RowBox[{"tau", ",", "beta", ",", "v"}], "]"}], "*", 
    SqrtBox[
     FractionBox["v", "beta"]], " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"L", "[", 
            RowBox[{"tau", ",", "beta", ",", "v"}], "]"}]}], "3"], ")"}], 
        "2"]}], 
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"L", "[", 
            RowBox[{"tau", ",", "beta", ",", "v"}], "]"}]}], "2"], ")"}], 
        "2"], " ", "+", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"q", "*", 
           RowBox[{"L", "[", 
            RowBox[{"tau", ",", "beta", ",", "v"}], "]"}]}], "3"], ")"}], 
        "6"]}]]]}]}], " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fTdf", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}], ",", 
     RowBox[{"beta_", "?", "NumericQ"}], ",", 
     RowBox[{"v_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"tau", ",", "q", ",", "beta", ",", "v"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], "*", "q0", "*", "tau"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"tau", ",", "0", ",", 
       RowBox[{"1", "/", "beta"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fstarTdf", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}], ",", 
     RowBox[{"beta_", "?", "NumericQ"}], ",", 
     RowBox[{"v_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ComplexExpand", "[", 
       RowBox[{"f", "[", 
        RowBox[{"tau", ",", "q", ",", "beta", ",", "v"}], "]"}], "]"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", "*", "q0", "*", "tau"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"tau", ",", "0", ",", 
       RowBox[{"1", "/", "beta"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DeltaS", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"q_", "?", "NumericQ"}], ",", 
     RowBox[{"beta_", "?", "NumericQ"}], ",", 
     RowBox[{"v_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{"fTdf", "[", 
     RowBox[{"q0", ",", "q", ",", "beta", ",", "v"}], "]"}], "*", 
    RowBox[{"fstarTdf", "[", 
     RowBox[{"q0", ",", "q", ",", "beta", ",", "v"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"spectrum", "[", 
    RowBox[{
     RowBox[{"q0_", "?", "NumericQ"}], ",", 
     RowBox[{"r_", "?", "NumericQ"}], ",", 
     RowBox[{"beta_", "?", "NumericQ"}], ",", 
     RowBox[{"v_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{"q0", "^", "3"}], " ", 
    RowBox[{"DeltaS", "[", 
     RowBox[{"q0", ",", 
      RowBox[{"q0", "/", "r"}], ",", "beta", ",", "v"}], "]"}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.98214914512698*^9, 3.9821494010735016`*^9}, {
   3.9821495545873337`*^9, 3.9821495605698776`*^9}, 3.982149591188259*^9, {
   3.9821497594394913`*^9, 3.9821497763907967`*^9}, {3.9821500228642216`*^9, 
   3.982150092840908*^9}, {3.982152640983013*^9, 3.982152707463873*^9}, {
   3.9821618962780323`*^9, 3.9821618973250904`*^9}},
 CellLabel->
  "In[130]:=",ExpressionUUID->"753e45df-0923-7b4b-ae77-2ae93da99f1d"]
}, Open  ]],

