Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"g1", "[", "tau_", "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"0", "<", "tau", "<", 
         RowBox[{"1", "/", "beta"}]}]}], "}"}], "}"}], ",", "0"}], "]"}]}], 
