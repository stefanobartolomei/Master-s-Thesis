Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubscriptBox[
         StyleBox["f", "TI"], 
         StyleBox["h", "TI"]], 
        RowBox[{"(", 
          RowBox[{
            SubscriptBox[
             StyleBox["q", "TI"], "0"], ",", 
            StyleBox["q", "TI"]}], ")"}], "\[LongEqual]", 
        FractionBox[
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              SubsuperscriptBox[
               StyleBox["q", "TI"], "0", "2"], "-", 
              SuperscriptBox[
               StyleBox["q", "TI"], "2"]}], ")"}], "2"], "2"]}], 
