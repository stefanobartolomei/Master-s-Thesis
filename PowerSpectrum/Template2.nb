Cell[TextData[{
 "Fourier transform\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["q", "TI"], "0"], ",", 
             StyleBox["q", "TI"]}], ")"}], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", "0", 
          RowBox[{"1", "/", "\[Beta]"}]], 
         StyleBox["d", "TI"], "\[Tau]", 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            StyleBox["i", "TI"], 
            SubscriptBox[
             StyleBox["q", "TI"], "0"], "\[Tau]"}]], 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "f(q_0,q) = \\int _0^{1/\\beta}d\\tau e^{-iq_0\\tau} f(\\tau,q)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fdeeae23-dd2b-6b4e-91a1-a48f050128bd"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[CapitalDelta]", 
          StyleBox["S", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["q", "TI"], ",", 
             SubscriptBox[
              StyleBox["q", "TI"], "0"]}], ")"}], "\[LongEqual]", 
         "\[Integral]", 
         StyleBox["d", "TI"], "\[Tau]", 
         StyleBox["d", "TI"], 
         SuperscriptBox["\[Tau]", "\[Prime]"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            StyleBox["i", "TI"], 
            SubscriptBox[
             StyleBox["q", "TI"], "0"], 
            RowBox[{"(", 
              RowBox[{"\[Tau]", "-", 
                SuperscriptBox["\[Tau]", "\[Prime]"]}], ")"}]}]], 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           RowBox[{"\[Tau]", ",", 
             StyleBox["q", "TI"]}], ")"}], 
         SuperscriptBox[
          StyleBox["f", "TI"], "*"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox["\[Tau]", "\[Prime]"], ",", 
             StyleBox["q", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\Delta_S(q,q_0) = \\int d\\tau d\\tau' e^{-iq_0(\\tau - \\tau')} \
f(\\tau,q) f^*(\\tau',q)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c74cda9f-fcfe-914e-872f-68f019250487"]
