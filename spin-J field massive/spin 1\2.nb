           StyleBox["q", "TI"], "\[RightVector]"], "|", 
          OverscriptBox[
           StyleBox["z", "TI"], "^"]}], TraditionalForm], "errors" -> {}, 
      "input" -> "\\vec{q} = |\\vec{q}|\\hat{z}", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Epsilon]zPlus", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}], "*", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "I", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"I", ",", 
          RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]zMinus", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}], "*", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"-", "I"}], ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "I"}], ",", 
          RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]qPlus", " ", "=", " ", 
     RowBox[{"R", ".", "\[Epsilon]zPlus", ".", 
      RowBox[{"Transpose", "[", "R", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
