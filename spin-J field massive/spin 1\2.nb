Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubscriptBox[
         StyleBox["B", "TI"], 
         RowBox[{"1", "/", "2"}]], "\[LongEqual]", 
        SubscriptBox["\[Delta]", "\[Mu]\[Nu]"], 
        FractionBox["1", "2"], 
        SubscriptBox[
         OverscriptBox[
          StyleBox["u", "TI"], "_"], "\[UpArrow]"], 
        RowBox[{"(", 
          StyleBox["k", "TI"], ")"}], 
        RowBox[{"[", 
          RowBox[{"-", 
            SuperscriptBox["\[Gamma]", "\[Nu]"], 
            SuperscriptBox["\[Omega]", "\[Mu]"], "+", 
            RowBox[{"(", 
              RowBox[{
                SuperscriptBox["\[Gamma]", "\[Mu]"], 
                SuperscriptBox[
                 StyleBox["q", "TI"], "\[Nu]"], "-", 
                SuperscriptBox["\[Gamma]", "\[Mu]"], 
                SuperscriptBox["\[Gamma]", "\[Nu]"], 
                SubscriptBox["\[Gamma]", 
                 StyleBox["a", "TI"]], 
                SuperscriptBox[
                 StyleBox["q", "TI"], 
                 StyleBox["a", "TI"]]}], ")"}]}], "]"}], 
        SubscriptBox[
         StyleBox["v", "TI"], "\[DownArrow]"], 
        RowBox[{"(", "\[Omega]", ")"}]}], TraditionalForm], "errors" -> {}, 
    "input" -> 
