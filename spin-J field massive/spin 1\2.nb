       RowBox[{"(", 
        RowBox[{"k", "-", "q"}], ")"}], "2"], "-", 
      SuperscriptBox["\[CapitalOmega]", "2"]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"3", " ", 
       SuperscriptBox["k", "2"]}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["q", "2"]}], "+", 
      RowBox[{"q", " ", "\[CapitalOmega]"}], "-", 
      SuperscriptBox["\[CapitalOmega]", "2"], "+", 
      RowBox[{"k", " ", 
       RowBox[{"(", 
