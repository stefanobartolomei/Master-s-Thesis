Cell[BoxData[
 RowBox[{
  RowBox[{"ufunz", "[", 
   RowBox[{"Pmu_", ",", "P_", ",", "M_", ",", "assumps_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "\[Gamma]PM", ",", "solP", ",", "u1", ",", "u2", ",", "helicityOp", ",", 
      "helicityu1", ",", " ", "helicityu2", ",", "uPlus", ",", "uMinus"}], 
     "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Gamma]PM", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"eta", ".", "Pmu"}], ")"}], ".", "\[Gamma]Matricies"}], " ", 
       "-", " ", 
       RowBox[{"M", " ", "*", 
        RowBox[{"IdentityMatrix", "[", "4", "]"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"solP", "=", " ", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{"NullSpace", "[", "\[Gamma]PM", "]"}], ",", " ", 
        RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"u1", "=", " ", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{
         SqrtBox[
          RowBox[{"2", " ", 
           RowBox[{"Pmu", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}]], 
         RowBox[{"Normalize", "[", 
          RowBox[{"solP", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ",", 
        RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"u2", " ", "=", " ", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{
         SqrtBox[
          RowBox[{"2", " ", 
           RowBox[{"Pmu", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}]], 
         RowBox[{"Normalize", "[", 
          RowBox[{"solP", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ",", 
        RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"helicityOp", " ", "=", " ", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Gamma]5", ".", "\[Gamma]0", ".", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[Gamma]1", "*", 
             RowBox[{"P", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], " ", "+", " ", 
            RowBox[{"\[Gamma]2", "*", 
             RowBox[{"P", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], " ", "+", " ", 
            RowBox[{"\[Gamma]3", "*", 
             RowBox[{"P", "[", 
              RowBox[{"[", "3", "]"}], "]"}]}]}], ")"}]}], "/", 
         RowBox[{"Norm", "[", "P", "]"}]}], ",", " ", 
        RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"helicityu1", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"Conjugate", "[", "u1", "]"}], ".", "helicityOp", ".", "u1"}],
        "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Conjugate", "[", "u1", "]"}], ".", "u1"}], ")"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"helicityu2", "=", " ", 
      RowBox[{
       RowBox[{
