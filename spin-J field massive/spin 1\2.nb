Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox[
         StyleBox["C", "TI"], 
         RowBox[{"1", "/", "2"}], "\[PlusMinus]"], "\[LongEqual]", 
        FractionBox["1", "2"], 
        SubscriptBox[
         OverscriptBox[
          StyleBox["u", "TI"], "_"], "\[UpArrow]"], 
        RowBox[{"(", 
          StyleBox["k", "TI"], ")"}], 
        RowBox[{"[", 
          RowBox[{"-", 
            SuperscriptBox["\[Omega]", 
             StyleBox["i", "TI"]], 
            SubsuperscriptBox["\[Epsilon]", 
             RowBox[{
               StyleBox["i", "TI"], 
               StyleBox["j", "TI"]}], "\[PlusMinus]"], 
            RowBox[{"(", 
              OverscriptBox[
               StyleBox["q", "TI"], "\[RightVector]"], ")"}], 
            SuperscriptBox["\[Gamma]", 
             StyleBox["j", "TI"]], "-", 
            SuperscriptBox["\[Gamma]", 
             StyleBox["i", "TI"]], 
            SubsuperscriptBox["\[Epsilon]", 
             RowBox[{
               StyleBox["i", "TI"], 
               StyleBox["j", "TI"]}], "\[PlusMinus]"], 
            RowBox[{"(", 
              OverscriptBox[
               StyleBox["q", "TI"], "\[RightVector]"], ")"}], 
            SuperscriptBox["\[Gamma]", 
             StyleBox["j", "TI"]], 
            SubscriptBox["\[Gamma]", 
             StyleBox["a", "TI"]], 
            SuperscriptBox[
             StyleBox["q", "TI"], 
             StyleBox["a", "TI"]]}], ")"}], "]", 
        SubscriptBox[
         StyleBox["v", "TI"], "\[DownArrow]"], 
        RowBox[{"(", "\[Omega]", ")"}]}], TraditionalForm], "errors" -> {}, 
    "input" -> 
    "C^\\pm_{1/2} = \\frac{1}{2} \\bar{u}_\\uparrow(k) \\Big[-\\omega^i \
\\epsilon^\\pm_{ij}(\\vec{q})\\gamma^j - \\gamma^i \
\\epsilon^\\pm_{ij}(\\vec{q})\\gamma^j \\gamma_a \
q^a\\Big)\\Big]v_\\downarrow(\\omega)", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"d7d0a09e-7a73-4f65-9399-c5c8317ec39a"]], \
