Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        RowBox[{"(", 
          RowBox[{
            SuperscriptBox["\[Gamma]", "\[Mu]"], 
            SubscriptBox[
             StyleBox["k", "TI"], "\[Mu]"], "-", 
            StyleBox["M", "TI"]}], ")"}], 
        StyleBox["u", "TI"], 
        RowBox[{"(", 
          StyleBox["k", "TI"], ")"}], "\[LongEqual]", "0"}], TraditionalForm],
