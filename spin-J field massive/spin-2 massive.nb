\"]\) \>\"", ",", "solAlpha"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<(Polar) \!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{\"\[Beta]\", \"\[LongEqual]\"}], TraditionalForm], \"errors\" -> {}, \
\"input\" -> \"\\\\beta =\", \"state\" -> \
\"Boxes\"|>,\"TeXAssistantTemplate\"]\) \>\"", ",", 
      RowBox[{"Simplify", "[", 
       RowBox[{"solBeta", " ", "/.", " ", 
        RowBox[{"omega", "->", "\[CapitalOmega]"}]}], "]"}]}], "]"}], 
    ";"}]}]}]], "Input",
