     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"ResultBP2P2", "/", 
         RowBox[{"-", 
          FractionBox[
           RowBox[{
            SuperscriptBox["\[ExponentialE]", 
             RowBox[{
              RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"k", "-", "q", "+", "\[CapitalOmega]"}], ")"}], "2"], 
            " ", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"k", "+", "q", "+", "\[CapitalOmega]"}], ")"}], "2"]}], 
           RowBox[{"4", " ", "k", " ", "\[CapitalOmega]"}]]}]}], " ", "/.", 
        RowBox[{"\[Phi]", "->", "0"}]}], ")"}], " ", "/.", " ", 
      RowBox[{"M", "->", "0"}]}], ",", " ", 
