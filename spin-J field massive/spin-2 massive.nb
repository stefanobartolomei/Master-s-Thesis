         RowBox[{"q", "^", "2"}], " ", "-", " ", 
         RowBox[{"2", " ", "k", " ", "q", " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "]"}]}]}], ",", " ", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"q", ">", "0"}], ",", 
        RowBox[{"k", ">", "0"}], ",", 
        RowBox[{"0", "<", "\[Theta]", "<", "\[Pi]"}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
