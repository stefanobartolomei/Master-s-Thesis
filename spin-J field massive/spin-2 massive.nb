              StyleBox["V", "TI"], "2", 
              RowBox[{"-", ",", "++"}]], 
             SuperscriptBox["|", "2"], "+", "|", 
             SubsuperscriptBox[
              StyleBox["V", "TI"], "2", 
              RowBox[{"-", ",", "+-"}]], 
