      RowBox[{"{", 
       RowBox[{
        RowBox[{"k", ">", "0"}], ",", 
        RowBox[{"\[CapitalOmega]", ">", "0"}], ",", 
        RowBox[{"q", ">", "0"}]}], "}"}]}]}], "]"}]}], 
  "]"}], "\[IndentingNewLine]", 
