Cell[BoxData[{
 RowBox[{
  RowBox[{"KhPlus", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"2", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Conjugate", "[", "ResultCPPlusPlus", "]"}], "*", 
          "ResultCPPlusPlus"}], " ", "+", " ", 
         RowBox[{
          RowBox[{"Conjugate", "[", "ResultCPPlusMinus", "]"}], "*", 
          "ResultCPPlusMinus"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", "k", " ", "omega"}], ")"}]}]}], ",", " ", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"k", ">", "0"}], ",", 
        RowBox[{"omega", ">", "0"}], ",", 
        RowBox[{"0", "<", "\[Theta]", "<", "\[Pi]"}], ",", 
        RowBox[{"0", "<", "\[Phi]", "<", 
         RowBox[{"2", "\[Pi]"}]}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
