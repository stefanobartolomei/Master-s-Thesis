  RowBox[{
   RowBox[{
    RowBox[{"solAlpha", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"ArcTan", "[", 
        RowBox[{
         RowBox[{"Q", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"Q", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ",", 
       RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox["\[Alpha]", "sol"], "\[LongEqual]", "arctan", 
          RowBox[{"(", 
            FractionBox[
             SubscriptBox[
              StyleBox["q", "TI"], "1"], 
             SubscriptBox[
              StyleBox["q", "TI"], "2"]], ")"}]}], TraditionalForm], 
      "errors" -> {}, "input" -> 
      "\\alpha_{\\text{sol}} = \\arctan\\qty(\\frac{q_1}{q_2})", "state" -> 
      "Boxes"|>,
     "TeXAssistantTemplate"], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"solBeta", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"ArcCos", "[", 
        RowBox[{
         RowBox[{"Q", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "/", 
         RowBox[{"Norm", "[", "Q", "]"}]}], "]"}], ",", 
       RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox["\[Beta]", "sol"], "\[LongEqual]", "arccos", 
          RowBox[{"(", 
            FractionBox[
             SubscriptBox[
              StyleBox["q", "TI"], "3"], 
             TemplateBox[{
               RowBox[{
                 OverscriptBox[
                  StyleBox["q", "TI"], "\[RightVector]"]}]}, "Abs"]], ")"}]}],
         TraditionalForm], "errors" -> {}, "input" -> 
      "\\beta_{\\text{sol}} = \\arccos\\qty(\\frac{q_3}{|\\vec{q}|})", 
      "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solRule", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Alpha]", "->", "solAlpha"}], ",", 
       RowBox[{"\[Beta]", "->", "solBeta"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", "Results", " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<(Azimuthal) \!\(\*TemplateBox[<|\"boxes\" -> FormBox[
