Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox[
         StyleBox["K", "TI"], "2", 
         SuperscriptBox[
          StyleBox["h", "TI"], "+"]], "\[LongEqual]", 
        FractionBox[
         RowBox[{"|", 
           SubsuperscriptBox[
            StyleBox["C", "TI"], "2", 
            RowBox[{"+", ",", "++"}]], 
           SuperscriptBox["|", "2"], "+", "|", 
           SubsuperscriptBox[
            StyleBox["C", "TI"], "2", 
            RowBox[{"+", ",", "--"}]], 
           SuperscriptBox["|", "2"], "+", "|", 
           SubsuperscriptBox[
            StyleBox["C", "TI"], "2", 
            RowBox[{"+", ",", "+-"}]], 
           SuperscriptBox["|", "2"], "+", "|", 
           SubsuperscriptBox[
            StyleBox["C", "TI"], "2", 
            RowBox[{"+", ",", "-+"}]], 
           SuperscriptBox["|", "2"]}], 
         RowBox[{"4|", 
           OverscriptBox[
            StyleBox["k", "TI"], "\[RightVector]"], "||", 
           OverscriptBox["\[Omega]", "\[RightVector]"], "|"}]], 
        "\[LongEqual]", 
        FractionBox[
         RowBox[{"2", "(", 
           RowBox[{"|", 
             SubsuperscriptBox[
              StyleBox["C", "TI"], "2", 
              RowBox[{"+", ",", "++"}]], 
             SuperscriptBox["|", "2"], "+", "|", 
             SubsuperscriptBox[
              StyleBox["C", "TI"], "2", 
              RowBox[{"+", ",", "+-"}]], 
             SuperscriptBox["|", "2"]}], ")"}], 
         RowBox[{"4|", 
           OverscriptBox[
            StyleBox["k", "TI"], "\[RightVector]"], "||", 
           OverscriptBox["\[Omega]", "\[RightVector]"], "|"}]], "    ", 
        ",    ", 
        SubsuperscriptBox[
         StyleBox["K", "TI"], "2", 
         SuperscriptBox[
          StyleBox["h", "TI"], "-"]], "\[LongEqual]", 
        FractionBox[
         RowBox[{"|", 
           SubsuperscriptBox[
            StyleBox["C", "TI"], "2", 
            RowBox[{"-", ",", "++"}]], 
           SuperscriptBox["|", "2"], "+", "|", 
           SubsuperscriptBox[
            StyleBox["C", "TI"], "2", 
            RowBox[{"-", ",", "--"}]], 
           SuperscriptBox["|", "2"], "+", "|", 
           SubsuperscriptBox[
            StyleBox["C", "TI"], "2", 
            RowBox[{"-", ",", "+-"}]], 
           SuperscriptBox["|", "2"], "+", "|", 
           SubsuperscriptBox[
            StyleBox["C", "TI"], "2", 
            RowBox[{"-", ",", "-+"}]], 
           SuperscriptBox["|", "2"]}], 
         RowBox[{"4|", 
           OverscriptBox[
            StyleBox["k", "TI"], "\[RightVector]"], "||", 
           OverscriptBox["\[Omega]", "\[RightVector]"], "|"}]], 
        "\[LongEqual]", 
        FractionBox[
         RowBox[{"2", "(", 
           RowBox[{"|", 
             SubsuperscriptBox[
              StyleBox["C", "TI"], "2", 
              RowBox[{"-", ",", "++"}]], 
             SuperscriptBox["|", "2"], "+", "|", 
             SubsuperscriptBox[
              StyleBox["C", "TI"], "2", 
              RowBox[{"-", ",", "+-"}]], 
             SuperscriptBox["|", "2"]}], ")"}], 
         RowBox[{"4|", 
           OverscriptBox[
            StyleBox["k", "TI"], "\[RightVector]"], "||", 
           OverscriptBox["\[Omega]", "\[RightVector]"], "|"}]]}], 
      TraditionalForm], "errors" -> {}, "input" -> 
    "K_2^{h^+} = \\frac{|C_2^{+,++}|^2 + |C_2^{+,--}|^2 + |C_2^{+,+-}|^2 + \
|C_2^{+,-+}|^2}{4|\\vec{k}||\\vec{\\omega}|} = \\frac{2\\qty(|C_2^{+,++}|^2 + \
|C_2^{+,+-}|^2)}{4|\\vec{k}||\\vec{\\omega}|} \\qquad , \\qquad K_2^{h^-} = \
\\frac{|C_2^{-,++}|^2 + |C_2^{-,--}|^2 + |C_2^{-,+-}|^2 + \
|C_2^{-,-+}|^2}{4|\\vec{k}||\\vec{\\omega}|} = \\frac{2\\qty(|C_2^{-,++}|^2 + \
|C_2^{-,+-}|^2)}{4|\\vec{k}||\\vec{\\omega}|}", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"4e7586bf-0c90-4555-8e7b-a61047eeb918"]], \
