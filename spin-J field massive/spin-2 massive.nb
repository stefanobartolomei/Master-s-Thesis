Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Vcoeff", "[", 
    RowBox[{"\[Epsilon]q_", ",", "\[Epsilon]\[Omega]_", ",", "\[Epsilon]K_"}],
     "]"}], ":=", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{"1", "/", "2"}], ")"}]}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Q", ".", "\[Omega]"}], ")"}], "*", 
         RowBox[{"(", 
          RowBox[{"\[Epsilon]q", ".", "K"}], ")"}]}], " ", "+", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Q", ".", "K"}], ")"}], "*", 
         RowBox[{"(", 
          RowBox[{"\[Epsilon]q", ".", "\[Omega]"}], ")"}]}]}], ")"}], "*", 
      RowBox[{"Tr", "[", 
       RowBox[{"\[Epsilon]\[Omega]", ".", "\[Epsilon]K"}], "]"}]}], ",", " ", 
     RowBox[{"Assumptions", "->", "assumps2"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ResultVcoeff", "[", 
    RowBox[{"C_", ",", "sub\[Theta]_"}], "]"}], ":=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"C", "/.", " ", "sub\[Theta]"}], ",", " ", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"q", ">", "0"}], ",", 
        RowBox[{"k", ">", "0"}], ",", 
