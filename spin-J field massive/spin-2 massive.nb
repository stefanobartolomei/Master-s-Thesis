Cell[BoxData[{
 RowBox[{"Print", "[", 
  RowBox[{"\"\<\\n (should be one) \!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{
FractionBox[
SubsuperscriptBox[
StyleBox[\"D\", \"TI\"], \"2\", 
RowBox[{\"\[PlusMinus]\", \"2\", \"\[PlusMinus]\", \"2\"}]], 
SubscriptBox[
RowBox[{\"(\", 
SubsuperscriptBox[
StyleBox[\"D\", \"TI\"], \"2\", 
RowBox[{\"\[PlusMinus]\", \"2\", \"\[PlusMinus]\", \"2\"}]], \")\"}], 
RowBox[{
StyleBox[\"M\", \"TI\"], \"\[LongEqual]\", \"0\"}]]], 
OverscriptBox[\"\[LongRightArrow]\", \"M;0\"]}], TraditionalForm], \"errors\" \
-> {}, \"input\" -> \
\"\\\\frac{D_2^{\\\\pm2\\\\pm2}}{\\\\qty(D_2^{\\\\pm2\\\\pm2})_{M=0}} \
\\\\xrightarrow{M\\\\to 0}\", \"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\
\"]\) \>\"", ",", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"ResultDP2P2", "/", 
         FractionBox[
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{
             RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"k", "-", "q", "+", "\[CapitalOmega]"}], ")"}], "3"], 
           " ", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"k", "+", "q", "+", "\[CapitalOmega]"}], ")"}], "3"]}], 
          RowBox[{"16", " ", 
           SuperscriptBox["k", "2"], " ", 
           SuperscriptBox["\[CapitalOmega]", "2"]}]]}], " ", "/.", 
        RowBox[{"\[Phi]", "->", "0"}]}], ")"}], " ", "/.", " ", 
      RowBox[{"M", "->", "0"}]}], ",", " ", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"k", ">", "0"}], ",", 
        RowBox[{"\[CapitalOmega]", ">", "0"}], ",", 
        RowBox[{"q", ">", "0"}]}], "}"}]}]}], "]"}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<\\n (should be one) \!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{
