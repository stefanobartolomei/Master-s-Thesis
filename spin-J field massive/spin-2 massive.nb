RowBox[{\"(\", 
RowBox[{\"\[Alpha]\", \",\", \"\[Beta]\"}], \")\"}], 
OverscriptBox[
StyleBox[\"z\", \"TI\"], \"^\"]}], \"]\"}], \"-\", 
RowBox[{\"[\", 
