Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox[
         StyleBox["V", "TI"], "2", 
         RowBox[{"+", ",", 
           SuperscriptBox["\[Lambda]\[Lambda]", "\[Prime]"]}]], 
        "\[LongEqual]", "-", 
        FractionBox["1", "2"], 
        RowBox[{"[", 
          RowBox[{
            RowBox[{"(", 
              RowBox[{
                OverscriptBox[
                 StyleBox["q", "TI"], "\[RightVector]"], "\[CenterDot]", 
                OverscriptBox["\[Omega]", "\[RightVector]"]}], ")"}], 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox[
                 OverscriptBox["\[Epsilon]", "\[RightVector]"], 
                 OverscriptBox[
                  StyleBox["q", "TI"], "\[RightVector]"], 
                 RowBox[{" ", "+"}]], "\[CenterDot]", 
                OverscriptBox[
                 StyleBox["k", "TI"], "\[RightVector]"]}], ")"}], "+", 
            RowBox[{"(", 
              RowBox[{
                OverscriptBox[
                 StyleBox["q", "TI"], "\[RightVector]"], "\[CenterDot]", 
                OverscriptBox[
                 StyleBox["k", "TI"], "\[RightVector]"]}], ")"}], 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox[
                 OverscriptBox["\[Epsilon]", "\[RightVector]"], 
                 OverscriptBox[
                  StyleBox["q", "TI"], "\[RightVector]"], 
                 RowBox[{" ", "+"}]], "\[CenterDot]", 
                OverscriptBox["\[Omega]", "\[RightVector]"]}], ")"}]}], "]"}],
         "Tr", 
        RowBox[{"[", 
          RowBox[{
            SubsuperscriptBox["\[Epsilon]", "1", "\[Lambda]"], 
            RowBox[{"(", "\[Omega]", ")"}], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", "2", 
             SuperscriptBox["\[Lambda]", "\[Prime]"]], 
            RowBox[{"(", 
              StyleBox["k", "TI"], ")"}]}], "]"}]}], TraditionalForm], 
    "errors" -> {}, "input" -> 
    "V^{+,\\lambda\\lambda'}_2 = -\\frac{1}{2}\\Big[\\qty(\\vec{q} \\cdot \
\\vec{\\omega})\\qty(\\vec{\\epsilon}^{\\ +}_{\\vec{q}}\\cdot \\vec{k}) + \
\\qty(\\vec{q} \\cdot \\vec{k})\\qty(\\vec{\\epsilon}^{\\ +}_{\\vec{q}}\\cdot \
\\vec{\\omega}) \\Big]\\text{Tr}\\Big[\\epsilon^{\\lambda}_1(\\omega) \\cdot \
\\epsilon^{\\lambda'}_2(k)\\Big]", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"141c7592-c8cd-4798-bcba-60b38a728dea"]], \
