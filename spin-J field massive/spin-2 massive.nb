  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         OverscriptBox[
          StyleBox["q", "TI"], "\[RightVector]"], "|", 
         StyleBox["R", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[Alpha]", "sol"], ",", 
             SubscriptBox["\[Beta]", "sol"]}], ")"}], 
         OverscriptBox[
          StyleBox["z", "TI"], "^"], "\[LongEqual]", 
         OverscriptBox["\[Omega]", "\[RightVector]"], "+", 
         OverscriptBox[
          StyleBox["k", "TI"], "\[RightVector]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "|\\vec{q}| R(\\alpha_{\\text{sol}}, \\beta_{\\text{sol}}) \\hat{z}  = \
\\vec{\\omega} + \\vec{k}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "af6efd65-d3d4-4da3-932a-7c7084a33263"],
