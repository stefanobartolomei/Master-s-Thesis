 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox["\[Epsilon]", 
           RowBox[{
             StyleBox["i", "TI"], 
