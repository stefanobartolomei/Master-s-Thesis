     RowBox[{
      RowBox[{"D", " ", "=", " ", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"eta", ".", "\[Omega]mu"}], ")"}], ".", "Kmu"}], 
              ")"}]}], " ", "+", " ", 
            RowBox[{"2", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"eta", ".", "\[Omega]mu"}], ")"}], ".", "Kmu"}], 
                ")"}], " ", "+", " ", 
               RowBox[{"M", "^", "2"}]}], ")"}]}]}], ")"}], "*", 
          RowBox[{"Tr", "[", 
           RowBox[{"\[Epsilon]\[Omega]", ".", "\[Epsilon]K"}], "]"}]}], ",", 
