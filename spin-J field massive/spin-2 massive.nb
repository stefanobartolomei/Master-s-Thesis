            StyleBox["V", "TI"], "2", 
            RowBox[{"+", ",", "-+"}]], 
           SuperscriptBox["|", "2"]}], 
         RowBox[{"4|", 
           OverscriptBox[
            StyleBox["k", "TI"], "\[RightVector]"], "||", 
           OverscriptBox["\[Omega]", "\[RightVector]"], "|"}]], 
        "\[LongEqual]", 
        FractionBox[
         RowBox[{"2", "(", 
           RowBox[{"|", 
             SubsuperscriptBox[
              StyleBox["V", "TI"], "2", 
              RowBox[{"+", ",", "++"}]], 
             SuperscriptBox["|", "2"], "+", "|", 
             SubsuperscriptBox[
              StyleBox["V", "TI"], "2", 
              RowBox[{"+", ",", "+-"}]], 
             SuperscriptBox["|", "2"]}], ")"}], 
         RowBox[{"4|", 
           OverscriptBox[
            StyleBox["k", "TI"], "\[RightVector]"], "||", 
           OverscriptBox["\[Omega]", "\[RightVector]"], "|"}]], "    ", 
        ",    ", 
        SubsuperscriptBox[
         StyleBox["K", "TI"], "2", 
         SuperscriptBox[
          StyleBox["W", "TI"], "-"]], "\[LongEqual]", 
        FractionBox[
         RowBox[{"|", 
           SubsuperscriptBox[
            StyleBox["V", "TI"], "2", 
            RowBox[{"-", ",", "++"}]], 
           SuperscriptBox["|", "2"], "+", "|", 
           SubsuperscriptBox[
            StyleBox["V", "TI"], "2", 
            RowBox[{"-", ",", "--"}]], 
           SuperscriptBox["|", "2"], "+", "|", 
           SubsuperscriptBox[
            StyleBox["V", "TI"], "2", 
            RowBox[{"-", ",", "+-"}]], 
           SuperscriptBox["|", "2"], "+", "|", 
           SubsuperscriptBox[
            StyleBox["V", "TI"], "2", 
            RowBox[{"-", ",", "-+"}]], 
           SuperscriptBox["|", "2"]}], 
         RowBox[{"4|", 
           OverscriptBox[
            StyleBox["k", "TI"], "\[RightVector]"], "||", 
           OverscriptBox["\[Omega]", "\[RightVector]"], "|"}]], 
        "\[LongEqual]", 
        FractionBox[
         RowBox[{"2", "(", 
