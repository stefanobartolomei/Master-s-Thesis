Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox[
         StyleBox["D", "TI"], "2", 
         SuperscriptBox["\[Lambda]\[Lambda]", "\[Prime]"]], "\[LongEqual]", 
        SubscriptBox["\[Eta]", "\[Mu]\[Nu]"], 
        RowBox[{"[", 
          RowBox[{"-", 
            SuperscriptBox["\[Omega]", "\[Mu]"], 
            SuperscriptBox[
             StyleBox["k", "TI"], "\[Nu]"], "+", 
            FractionBox["1", "2"], 
            SuperscriptBox["\[Eta]", "\[Mu]\[Nu]"], 
            RowBox[{"(", 
              RowBox[{
                RowBox[{"(", 
                  RowBox[{"\[Omega]", "\[CenterDot]", 
