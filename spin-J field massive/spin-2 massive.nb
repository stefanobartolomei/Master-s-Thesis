Cell[TextData[{
 "Check that for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox["\[Alpha]", "sol"], " ", ", ", 
          SubscriptBox["\[Beta]", "sol"]}], TraditionalForm], "errors" -> {}, 
      "input" -> "\\alpha_{\\text{sol}} \\ , \\ \\beta_{\\text{sol}}", 
      "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "7567894a-d94d-4760-9472-eaadb205908b"],
 " the Rotation matrix is such that: ",
