Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"vecsigma", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"PauliMatrix", "[", "1", "]"}], ",", 
      RowBox[{"PauliMatrix", "[", "2", "]"}], ",", 
      RowBox[{"PauliMatrix", "[", "3", "]"}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"HelicityBasis", "[", 
    RowBox[{"P_", ",", "helValue_", ",", "assumps_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"EigenEq", ",", "nullBasis", ",", "\[Xi]", ",", "norm\[Xi]"}], 
      "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"EigenEq", "=", " ", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             FractionBox[
              RowBox[{"P", "[", 
               RowBox[{"[", "i", "]"}], "]"}], 
              RowBox[{"Norm", "[", "P", "]"}]], "*", 
             RowBox[{"vecsigma", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}], " ", "-", " ", 
          RowBox[{"helValue", "*", 
           RowBox[{"IdentityMatrix", "[", "2", "]"}]}]}], ",", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nullBasis", "=", 
       RowBox[{"NullSpace", "[", 
        RowBox[{"EigenEq", ",", 
         RowBox[{"ZeroTest", "->", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"FullSimplify", "[", 
              RowBox[{"#", ",", 
               RowBox[{"Assumptions", "->", "assumps"}]}], "]"}], "==", "0"}],
             "&"}], ")"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Xi]", "=", 
       RowBox[{"nullBasis", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"norm\[Xi]", "=", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"ComplexExpand", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Xi]", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "*", 
            RowBox[{"Conjugate", "[", 
             RowBox[{"\[Xi]", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "+", 
           RowBox[{
            RowBox[{"\[Xi]", "[", 
             RowBox[{"[", "2", "]"}], "]"}], "*", 
            RowBox[{"Conjugate", "[", 
             RowBox[{"\[Xi]", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "]"}]}]}], "]"}], ",", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"\[Xi]", "/", 
         RowBox[{"Sqrt", "[", "norm\[Xi]", "]"}]}], ",", 
        RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9816298760029564`*^9, 3.9816299540122185`*^9}, {
  3.981629996539049*^9, 3.9816301812258606`*^9}, {3.9816303618180714`*^9, 
