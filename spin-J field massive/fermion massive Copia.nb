Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubscriptBox[
         StyleBox["D", "TI"], 
         RowBox[{"1", "/", "2"}]], "\[LongEqual]", 
        SubscriptBox["\[Eta]", "\[Mu]\[Nu]"], 
        FractionBox["1", "2"], 
        OverscriptBox[
         StyleBox["u", "TI"], "_"], 
        RowBox[{"(", 
          StyleBox["k", "TI"], ")"}], 
        RowBox[{"[", 
          RowBox[{"-", 
            SuperscriptBox["\[Gamma]", "\[Nu]"], 
            SuperscriptBox["\[Omega]", "\[Mu]"], "+", 
            FractionBox["1", "2"], 
            RowBox[{"(", 
              RowBox[{
                SuperscriptBox["\[Gamma]", "\[Nu]"], 
                SuperscriptBox[
                 StyleBox["q", "TI"], "\[Mu]"], "-", 
                SuperscriptBox["\[Gamma]", "\[Nu]"], 
                SuperscriptBox["\[Gamma]", "\[Mu]"], 
                SubscriptBox["\[Gamma]", 
                 StyleBox["a", "TI"]], 
                SuperscriptBox[
                 StyleBox["q", "TI"], 
                 StyleBox["a", "TI"]]}], ")"}]}], "]"}], 
        StyleBox["v", "TI"], 
        RowBox[{"(", "\[Omega]", ")"}]}], TraditionalForm], "errors" -> {}, 
