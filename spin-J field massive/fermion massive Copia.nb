Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"FastU", "[", 
     RowBox[{"Pmu_", ",", "NormP_", ",", "helValue_", ",", "\[Xi]_"}], "]"}], 
    ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"E", ",", "upper", ",", "lower"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"E", "=", 
        RowBox[{"Pmu", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"upper", "=", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{"E", "+", "M"}], "]"}], "*", "\[Xi]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"lower", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"helValue", "*", 
           RowBox[{"NormP", "/", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"E", "+", "M"}], "]"}]}]}], ")"}], "*", "\[Xi]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"Join", "[", 
        RowBox[{"upper", ",", "lower"}], "]"}]}]}], "\[IndentingNewLine]", 
     "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"FastV", "[", 
    RowBox[{"Pmu_", ",", "NormP_", ",", "helValue_", ",", "\[Xi]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"E", ",", "upper", ",", "lower"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"E", "=", 
       RowBox[{"Pmu", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"upper", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"helValue", "*", 
          RowBox[{"NormP", "/", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"E", "+", "M"}], "]"}]}]}], ")"}], "*", "\[Xi]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"lower", "=", 
       RowBox[{
        RowBox[{"Sqrt", "[", 
         RowBox[{"E", "+", "M"}], "]"}], "*", "\[Xi]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Join", "[", 
       RowBox[{"upper", ",", "lower"}], "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]}], "Input",
