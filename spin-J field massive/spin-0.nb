  RowBox[{
   RowBox[{"Ccoeff", "[", "\[Epsilon]q_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"C", ",", " ", "ResultC"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"C", " ", "=", " ", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{"\[Omega]", ".", "\[Epsilon]q", ".", "K"}], ")"}]}], ",", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ResultC", "=", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"C", " ", "/.", " ", "substitution\[Theta]"}], ",", " ", 
         RowBox[{"Assumptions", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"m", ">", "0"}], ",", 
            RowBox[{"k", ">", "0"}], ",", 
            RowBox[{"\[CapitalOmega]", ">", "0"}], ",", 
            RowBox[{"q", ">", "0"}], ",", 
            RowBox[{"0", "<", "\[Phi]", "<", 
             RowBox[{"2", "\[Pi]"}]}]}], "}"}]}]}], "]"}]}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
