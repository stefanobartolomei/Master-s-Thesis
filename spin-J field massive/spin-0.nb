                RowBox[{
                 RowBox[{"-", 
                  SuperscriptBox["q", "2"]}], "+", 
                 SuperscriptBox["q0", "2"]}], ")"}], " ", 
               RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "+", 
              RowBox[{"q0", " ", 
               SqrtBox[
                RowBox[{
                 RowBox[{"2", " ", 
                  SuperscriptBox["m", "2"], " ", 
                  RowBox[{"(", 
                   RowBox[{
                    SuperscriptBox["q", "2"], "-", 
                    RowBox[{"2", " ", 
                    SuperscriptBox["q0", "2"]}]}], ")"}]}], "+", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    SuperscriptBox["q", "2"], "-", 
                    SuperscriptBox["q0", "2"]}], ")"}], "2"], "+", 
                 RowBox[{"2", " ", 
                  SuperscriptBox["m", "2"], " ", 
                  SuperscriptBox["q", "2"], " ", 
                  RowBox[{"Cos", "[", 
                   RowBox[{"2", " ", "\[Theta]"}], "]"}]}]}]]}]}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", 
