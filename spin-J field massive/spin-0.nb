Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Definition", " ", "for", " ", "the", " ", "Matrix", " ", "operator", " ",
      "of", " ", "the", " ", "angular", " ", "momentum", " ", "in", " ", 
     "3"}], "-", 
    RowBox[{"dim", " ", "representation"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"J", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"(", GridBox[{
          {"0", "0", "0"},
          {"0", "0", 
           RowBox[{"-", "I"}]},
          {"0", "I", "0"}
         }], ")"}], ",", 
       RowBox[{"(", GridBox[{
          {"0", "0", "I"},
          {"0", "0", "0"},
          {
           RowBox[{"-", "I"}], "0", "0"}
         }], ")"}], ",", 
       RowBox[{"(", GridBox[{
          {"0", 
           RowBox[{"-", "I"}], "0"},
