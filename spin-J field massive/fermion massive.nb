         RowBox[{"(", 
          RowBox[{
           FractionBox["Ffermnew", 
            RowBox[{"8", " ", "\[Pi]", " "}]], " ", "/.", " ", "subs"}], 
          ")"}], " ", "//", "Simplify"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"result", " ", "=", " ", 
        RowBox[{"NIntegrate", "[", 
         RowBox[{"FtoInt", ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", 
            RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
          RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}], ",", 
          RowBox[{"MinRecursion", "->", "5"}], ",", 
          RowBox[{"AccuracyGoal", "->", "5"}]}], "]"}]}]}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
