Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Vcoeff", "[", 
    RowBox[{
    "\[Epsilon]q_", ",", "spinor\[Omega]_", ",", "spinorK_", ",", 
     "momentum_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "vec\[Gamma]", ",", "\[CapitalMu]", ",", "ConjspinK", ",", "V", ",", 
       "ResultV"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"vec\[Gamma]", "=", " ", 
       RowBox[{"{", 
        RowBox[{"\[Gamma]1", ",", "\[Gamma]2", ",", "\[Gamma]3"}], "}"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"\[CapitalMu]", " ", "=", " ", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"Q", ".", "momentum"}], ")"}]}], 
           RowBox[{"(", 
            RowBox[{"\[Epsilon]q", ".", "vec\[Gamma]"}], ")"}]}], " ", "-", 
          " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\[Epsilon]q", ".", "momentum"}], ")"}], 
           RowBox[{"(", 
            RowBox[{"Q", ".", "vec\[Gamma]"}], ")"}]}], " ", "+", " ", 
          RowBox[{
           FractionBox["1", "2"], 
           RowBox[{"(", 
            RowBox[{"\[Epsilon]q", ".", "vec\[Gamma]"}], ")"}], 
           RowBox[{"(", 
            RowBox[{"Q", ".", "Q"}], ")"}]}]}], ",", " ", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"ConjspinK", " ", "=", 
       RowBox[{"Simplify", "[", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Conjugate", "[", "spinorK", "]"}], ".", "\[Gamma]0"}], ",", 
         RowBox[{"Assumptions", "->", "assumpk"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"V", " ", "=", " ", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], 
          RowBox[{"ConjspinK", ".", "\[CapitalMu]", ".", "spinor\[Omega]"}]}],
          ",", " ", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ResultV", " ", "=", " ", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"V", "/.", " ", "substitution\[Theta]"}], ",", " ", 
         RowBox[{"Assumptions", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"k", ">", "0"}], ",", 
            RowBox[{"q", ">", "0"}], ",", 
            RowBox[{"\[CapitalOmega]", ">", "0"}], ",", 
            RowBox[{"M", ">", "0"}]}], "}"}]}]}], "]"}]}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
