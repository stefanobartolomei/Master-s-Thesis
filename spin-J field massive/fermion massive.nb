       "\[IndentingNewLine]", 
       RowBox[{"sub4\[Theta]", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"4", "\[Theta]"}], "]"}], "->", 
           RowBox[{
            RowBox[{"2", 
             RowBox[{
              RowBox[{"Cos", "[", 
               RowBox[{"2", "\[Theta]"}], "]"}], "^", "2"}]}], " ", "-", " ", 
            "1"}]}], ",", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"4", "\[Theta]"}], "]"}], "->", 
           RowBox[{"2", 
            RowBox[{"Sin", "[", 
             RowBox[{"2", "\[Theta]"}], "]"}], 
            RowBox[{"Cos", "[", 
             RowBox[{"2", "\[Theta]"}], "]"}]}]}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sub2\[Theta]", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"2", "\[Theta]"}], "]"}], "->", 
           RowBox[{
            RowBox[{"2", 
             RowBox[{
              RowBox[{"Cos", "[", "\[Theta]", "]"}], "^", "2"}]}], " ", "-", 
            " ", "1"}]}], ",", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"2", "\[Theta]"}], "]"}], "->", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", "+", " ", 
               RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ")"}], "^", "2"}], 
            " ", "-", " ", "1"}]}]}], "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"subx\[Theta]", " ", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", "\[Theta]", "]"}], "->", "x"}], " ", ",", " ", 
          RowBox[{
           RowBox[{"Sin", "[", "\[Theta]", "]"}], "->", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"1", " ", "-", " ", 
