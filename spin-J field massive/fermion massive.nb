Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Find", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        StyleBox["C", "TI"], TraditionalForm], "errors" -> {}, "input" -> "C",
       "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", 
    RowBox[{"matrix", ":", "  ", 
     TemplateBox[<|"boxes" -> FormBox[
         RowBox[{
           StyleBox["C", "TI"], 
           SubscriptBox["\[Gamma]", "\[Mu]"], 
           SuperscriptBox[
            StyleBox["C", "TI"], "-1"], "\[LongEqual]", "-", 
           SubsuperscriptBox["\[Gamma]", "\[Mu]", 
            StyleBox["T", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
       "C\\gamma_\\mu C^{-1} = -\\gamma_\\mu^T", "state" -> "Boxes"|>,
      "TeXAssistantTemplate"]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"CMatrix", "[", "gammas_List", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "cVars", ",", "eqns", ",", "sol", ",", "rawC", ",", "normalizedC"}], 
        "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"cVars", "=", 
         RowBox[{"Array", "[", 
          RowBox[{"c", ",", 
           RowBox[{"{", 
            RowBox[{"4", ",", "4"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"eqns", "=", 
         RowBox[{"Flatten", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"cVars", ".", 
               RowBox[{"gammas", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "+", 
              RowBox[{
               RowBox[{"Transpose", "[", 
                RowBox[{"gammas", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "]"}], ".", "cVars"}]}], "==",
              "0"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "4"}], "}"}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"sol", "=", 
         RowBox[{
          RowBox[{"Solve", "[", 
           RowBox[{"eqns", ",", 
            RowBox[{"Flatten", "[", "cVars", "]"}]}], "]"}], "//", 
          "Quiet"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"rawC", "=", 
         RowBox[{"cVars", "/.", " ", 
          RowBox[{"sol", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"rawC", "=", 
         RowBox[{"rawC", "/.", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"Variables", "[", "rawC", "]"}], "[", 
             RowBox[{"[", "1", "]"}], "]"}], "->", "1"}], "}"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"normalizedC", "=", 
         RowBox[{"rawC", "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"Tr", "[", 
             RowBox[{
              RowBox[{"ConjugateTranspose", "[", "rawC", "]"}], ".", "rawC"}],
              "]"}], "/", "4"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"FullSimplify", "[", "normalizedC", "]"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"CMat", "=", 
     RowBox[{"CMatrix", "[", "\[Gamma]Matricies", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"MatrixForm", "[", "CMat", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<\\n (should be all True): \>\"", ",", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"CMat", ".", 
          RowBox[{"\[Gamma]Matricies", "[", 
           RowBox[{"[", "i", "]"}], "]"}], ".", 
          RowBox[{"ConjugateTranspose", "[", "CMat", "]"}]}], "==", 
         RowBox[{"-", 
          RowBox[{"Transpose", "[", 
           RowBox[{"\[Gamma]Matricies", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "4"}], "}"}]}], "]"}]}], 
    "]"}]}]}]], "Input",
