    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "Fferm", ",", "sub4\[Theta]", ",", "sub2\[Theta]", ",", "subx\[Theta]",
         ",", "Ffermnew", ",", "FtoInt", ",", "result"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Fferm", " ", "=", " ", 
