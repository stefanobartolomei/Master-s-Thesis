Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubscriptBox[
         StyleBox["B", "TI"], 
         RowBox[{"1", "/", "2"}]], "\[LongEqual]", 
        SubscriptBox["\[Delta]", "\[Mu]\[Nu]"], 
        FractionBox["1", "2"], 
        OverscriptBox[
         StyleBox["u", "TI"], "_"], 
        RowBox[{"(", 
          StyleBox["k", "TI"], ")"}], 
        RowBox[{"[", 
          RowBox[{"-", 
            SuperscriptBox["\[Gamma]", "\[Nu]"], 
            SuperscriptBox["\[Omega]", "\[Mu]"], "+", 
            FractionBox["1", "2"], 
            RowBox[{"(", 
              RowBox[{
                SuperscriptBox["\[Gamma]", "\[Nu]"], 
                SuperscriptBox[
                 StyleBox["q", "TI"], "\[Mu]"], "-", 
                SuperscriptBox["\[Gamma]", "\[Nu]"], 
                SuperscriptBox["\[Gamma]", "\[Mu]"], 
                SubscriptBox["\[Gamma]", 
                 StyleBox["a", "TI"]], 
                SuperscriptBox[
                 StyleBox["q", "TI"], 
                 StyleBox["a", "TI"]]}], ")"}]}], "]"}], 
        StyleBox["v", "TI"], 
        RowBox[{"(", "\[Omega]", ")"}]}], TraditionalForm], "errors" -> {}, 
    "input" -> 
    "B_{1/2} =  \\delta_{\\mu \\nu} \\frac{1}{2} \\bar{u}(k) \
\\Big[-\\gamma^\\nu\\omega^\\mu + \\frac{1}{2}\\Big(\\gamma^\\nu q^\\mu - \
\\gamma^\\nu \\gamma^\\mu \\gamma_a q^a\\Big)\\Big]v(\\omega)", "state" -> 
    "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"28b6a12b-c9c5-472a-9f23-ebb12ec33c2b"]], \
"Chapter",
 CellChangeTimes->{{3.973055506430555*^9, 3.9730555137590146`*^9}, {
   3.973055544992835*^9, 3.9730555483077726`*^9}, 3.973055596027047*^9, 
   3.976353369808381*^9},ExpressionUUID->"5182ec10-7748-43c0-b6b1-\
2eb1c0b19ce1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Bcoeff", "[", 
    RowBox[{"spinor\[Omega]_", ",", "spinorK_", ",", "fourmomentum_"}], "]"}],
    ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "delta\[Gamma]\[Gamma]", ",", "\[CapitalMu]", ",", "ConjspinK", ",", 
       "B", ",", "ResultB"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"delta\[Gamma]\[Gamma]", " ", "=", " ", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Gamma]Matricies", "[", 
           RowBox[{"[", "i", "]"}], "]"}], ".", 
          RowBox[{"\[Gamma]Matricies", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "4"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"\[CapitalMu]", " ", "=", " ", 
       RowBox[{
        RowBox[{"-", " ", 
         RowBox[{"fourmomentum", ".", "\[Gamma]Matricies"}]}], " ", "+", 
        RowBox[{
         FractionBox["1", "2"], 
         RowBox[{"(", " ", 
          RowBox[{
           RowBox[{"Qmu", ".", "\[Gamma]Matricies"}], " ", "-", 
           RowBox[{"delta\[Gamma]\[Gamma]", ".", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"eta", ".", "Qmu"}], ")"}], ".", "\[Gamma]Matricies"}],
              ")"}]}]}], ")"}]}]}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"ConjspinK", " ", "=", 
       RowBox[{"Simplify", "[", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Conjugate", "[", "spinorK", "]"}], ".", "\[Gamma]0"}], ",", 
         RowBox[{"Assumptions", "->", "assumpk"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"B", " ", "=", " ", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], 
          RowBox[{"ConjspinK", ".", "\[CapitalMu]", ".", "spinor\[Omega]"}]}],
          ",", " ", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ResultB", " ", "=", " ", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{"B", " ", "/.", " ", "substitution\[Theta]"}], ",", " ", 
         RowBox[{"Assumptions", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"k", ">", "0"}], ",", 
