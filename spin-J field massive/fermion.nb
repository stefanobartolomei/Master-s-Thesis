Cell[CellGroupData[{

Cell["Work in the Helicity basis", "Subsection",
 CellChangeTimes->{{3.981628327453602*^9, 3.981628329782221*^9}, {
  3.9816303455339756`*^9, 
  3.981630354501009*^9}},ExpressionUUID->"35649df0-3442-d245-8b65-\
