Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"vfunz", "[", 
    RowBox[{"Pmu_", ",", "assumps_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "vGeneric", ",", "v1", ",", "v2", ",", "Pslash", ",", "DiracEq", ",", 
       "solv", ",", "vfinal"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"vGeneric", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{"v1", ",", "v2", ",", "v3", ",", "v4"}], "}"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Pslash", " ", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Pmu", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "*", "\[Gamma]0"}], " ", "-", " ", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
