Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ufunz", "[", 
    RowBox[{"Pmu_", ",", "assumps_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "uGeneric", ",", "u3", ",", "u4", ",", "Pslash", ",", "DiracEq", ",", 
       "solu", ",", "ufinal"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"uGeneric", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{"u1", ",", "u2", ",", "u3", ",", "u4"}], "}"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Pslash", " ", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Pmu", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "*", "\[Gamma]0"}], " ", "-", " ", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Pmu", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "*", 
           RowBox[{"\[Gamma]Matricies", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "2", ",", "4"}], "}"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"DiracEq", " ", "=", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Pslash", " ", "-", " ", 
          RowBox[{"M", "*", 
           RowBox[{"IdentityMatrix", "[", "4", "]"}]}]}], ")"}], ".", 
        "uGeneric"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"solu", " ", "=", " ", 
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"DiracEq", "[", 
             RowBox[{"[", "3", "]"}], "]"}], "==", "0"}], ",", 
           RowBox[{
            RowBox[{"DiracEq", "[", 
             RowBox[{"[", "4", "]"}], "]"}], "==", "0"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"u3", ",", "u4"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"u3", " ", "=", " ", 
       RowBox[{"u3", "/.", " ", 
        RowBox[{"solu", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"u4", " ", "=", " ", 
       RowBox[{"u4", "/.", 
        RowBox[{"solu", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"ufinal", " ", "=", " ", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"u1", ",", "u2", ",", "u3", ",", "u4"}], "}"}], ",", " ", 
         RowBox[{"Assumptions", "->", "assumps"}]}], "]"}]}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
