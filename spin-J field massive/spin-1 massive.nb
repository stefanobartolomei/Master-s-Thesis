Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox[
         StyleBox["V", "TI"], "1", 
         RowBox[{"\[PlusMinus]", ",", 
           SuperscriptBox["\[Lambda]\[Lambda]", "\[Prime]"]}]], 
        "\[LongEqual]", "-", 
        RowBox[{"(", 
          RowBox[{
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{"\[Lambda]", "*"}]], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{
               SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}], 
        RowBox[{"[", 
          RowBox[{
            RowBox[{"(", 
              RowBox[{
                OverscriptBox[
                 StyleBox["q", "TI"], "\[RightVector]"], "\[CenterDot]", 
                OverscriptBox["\[Omega]", "\[RightVector]"]}], ")"}], 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox[
                 OverscriptBox["\[Epsilon]", "\[RightVector]"], 
                 OverscriptBox[
                  StyleBox["q", "TI"], "\[RightVector]"], 
                 RowBox[{" ", "\[PlusMinus]"}]], "\[CenterDot]", 
                OverscriptBox[
                 StyleBox["k", "TI"], "\[RightVector]"]}], ")"}], "+", 
            RowBox[{"(", 
              RowBox[{
                OverscriptBox[
                 StyleBox["q", "TI"], "\[RightVector]"], "\[CenterDot]", 
                OverscriptBox[
                 StyleBox["k", "TI"], "\[RightVector]"]}], ")"}], 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox[
                 OverscriptBox["\[Epsilon]", "\[RightVector]"], 
                 OverscriptBox[
                  StyleBox["q", "TI"], "\[RightVector]"], 
                 RowBox[{" ", "\[PlusMinus]"}]], "\[CenterDot]", 
                OverscriptBox["\[Omega]", "\[RightVector]"]}], ")"}]}], "]"}],
         "+", "\n", "+", 
        RowBox[{"(", 
          RowBox[{
            StyleBox["k", "TI"], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{"\[Lambda]", "*"}]]}], ")"}], 
        RowBox[{"[", 
          RowBox[{
            RowBox[{"(", 
              RowBox[{
                OverscriptBox[
                 StyleBox["q", "TI"], "\[RightVector]"], "\[CenterDot]", 
                OverscriptBox["\[Omega]", "\[RightVector]"]}], ")"}], 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox[
                 OverscriptBox["\[Epsilon]", "\[RightVector]"], 
                 OverscriptBox[
                  StyleBox["q", "TI"], "\[RightVector]"], 
                 RowBox[{" ", "\[PlusMinus]"}]], "\[CenterDot]", 
                SubsuperscriptBox[
                 OverscriptBox["\[Epsilon]", "\[RightVector]"], 
                 OverscriptBox[
                  StyleBox["k", "TI"], "\[RightVector]"], 
                 RowBox[{" ", 
                   SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}], 
            "+", 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox[
                 OverscriptBox["\[Epsilon]", "\[RightVector]"], 
                 OverscriptBox[
                  StyleBox["q", "TI"], "\[RightVector]"], 
                 RowBox[{" ", "\[PlusMinus]"}]], "\[CenterDot]", 
                OverscriptBox["\[Omega]", "\[RightVector]"]}], ")"}], 
            RowBox[{"(", 
              RowBox[{
                OverscriptBox[
                 StyleBox["q", "TI"], "\[RightVector]"], "\[CenterDot]", 
                SubsuperscriptBox[
                 OverscriptBox["\[Epsilon]", "\[RightVector]"], 
                 OverscriptBox[
                  StyleBox["k", "TI"], "\[RightVector]"], 
                 RowBox[{" ", 
                   SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}]}],
           "]"}], "+", "\\[NewLine]", "+", 
        RowBox[{"(", 
          RowBox[{"\[Omega]", "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
