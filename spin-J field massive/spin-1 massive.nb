Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox[
         StyleBox["C", "TI"], "1", 
         RowBox[{"\[PlusMinus]", ",", 
           SuperscriptBox["\[Lambda]\[Lambda]", "\[Prime]"]}]], 
        "\[LongEqual]", "-", 
        RowBox[{"(", 
          RowBox[{
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{"\[Lambda]", "*"}]], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{
               SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}], 
        RowBox[{"(", 
          RowBox[{
            SuperscriptBox[
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             StyleBox["T", "TI"]], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["q", "TI"], "\[RightVector]"], "\[PlusMinus]"], 
            "\[CenterDot]", 
            OverscriptBox[
             StyleBox["k", "TI"], "\[RightVector]"]}], ")"}], "+", 
        RowBox[{"(", 
          RowBox[{
            StyleBox["k", "TI"], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{"\[Lambda]", "*"}]]}], ")"}], 
        RowBox[{"(", 
          RowBox[{
            SuperscriptBox[
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             StyleBox["T", "TI"]], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["q", "TI"], "\[RightVector]"], "\[PlusMinus]"], 
            "\[CenterDot]", 
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{" ", 
               SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}], "+", 
        RowBox[{"(", 
          RowBox[{"\[Omega]", "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{
               SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}], 
        RowBox[{"(", 
          RowBox[{
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{" ", "\[Lambda]", "*", 
               StyleBox["T", "TI"]}]], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["q", "TI"], "\[RightVector]"], "\[PlusMinus]"], 
            "\[CenterDot]", 
            OverscriptBox[
             StyleBox["k", "TI"], "\[RightVector]"]}], ")"}], "-", 
        RowBox[{"(", 
          RowBox[{"\[Omega]", "\[CenterDot]", 
            StyleBox["k", "TI"]}], ")"}], 
        RowBox[{"(", 
          RowBox[{
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{" ", "\[Lambda]", "*", 
               StyleBox["T", "TI"]}]], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["q", "TI"], "\[RightVector]"], "\[PlusMinus]"], 
            "\[CenterDot]", 
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{" ", 
               SuperscriptBox["\[Lambda]", "\[Prime]"], "*", 
               StyleBox["T", "TI"]}]]}], ")"}], "-", 
        SuperscriptBox[
         StyleBox["M", "TI"], "2"], 
        RowBox[{"(", 
          RowBox[{
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{" ", "\[Lambda]", "*", 
               StyleBox["T", "TI"]}]], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["q", "TI"], "\[RightVector]"], "\[PlusMinus]"], 
            "\[CenterDot]", 
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{" ", 
               SuperscriptBox["\[Lambda]", "\[Prime]"], "*", 
               StyleBox["T", "TI"]}]]}], ")"}]}], TraditionalForm], 
    "errors" -> {}, "input" -> 
    "C_1^{\\pm,\\lambda \\lambda'} = \
-\\qty(\\epsilon^{\\lambda*}_{\\vec{\\omega}} \\cdot \\epsilon^{\\lambda'*}_{\
