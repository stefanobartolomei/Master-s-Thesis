Cell[TextData[{
 "Polarization vectors for spin-1 particles ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"{", 
           RowBox[{
             SubsuperscriptBox["\[Epsilon]", 
              OverscriptBox["\[Omega]", "\[RightVector]"], "\[PlusMinus]"], 
             " ", ", ", 
             SubsuperscriptBox["\[Epsilon]", 
              OverscriptBox["\[Omega]", "\[RightVector]"], "0"]}], "}"}], " ",
          ",", 
         RowBox[{"{", 
           RowBox[{
             SubsuperscriptBox["\[Epsilon]", 
              OverscriptBox[
               StyleBox["k", "TI"], "\[RightVector]"], "\[PlusMinus]"], " ", 
             ", ", 
             SubsuperscriptBox["\[Epsilon]", 
              OverscriptBox[
               StyleBox["k", "TI"], "\[RightVector]"], "0"]}], "}"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\{\\epsilon^\\pm_{\\vec{\\omega}} \\ , \\  \
\\epsilon^0_{\\vec{\\omega}} \\} \\ , \\{\\epsilon^\\pm_{\\vec{k}} \\ , \\ \
\\epsilon^0_{\\vec{k}} \\}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "97859399-a20c-4ef0-a883-60a742a39a88"],
 " and for the vectorial perturbation ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox["\[Epsilon]", 
        OverscriptBox[
         StyleBox["q", "TI"], "\[RightVector]"], "\[PlusMinus]"], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\epsilon^\\pm_{\\vec{q}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8dda9170-e99b-41db-9f63-101a283efe6e"]
}], "Subtitle",
