Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["F", "TI"], 
          StyleBox["J", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["M", "TI"], ",", 
             StyleBox["q", "TI"], ",", 
             SubscriptBox[
              StyleBox["q", "TI"], "0"], ",", "\[Theta]"}], ")"}], 
         "\[Congruent]", 
         FractionBox[
          SuperscriptBox[
           OverscriptBox[
            StyleBox["k", "TI"], "~"], "2"], 
          RowBox[{
            SqrtBox[
             RowBox[{
               SuperscriptBox[
                StyleBox["M", "TI"], "2"], "+", 
               SuperscriptBox[
                OverscriptBox[
                 StyleBox["k", "TI"], "~"], "2"]}]], 
            SqrtBox[
             RowBox[{
               SuperscriptBox[
                StyleBox["M", "TI"], "2"], "+", 
               SuperscriptBox[
                StyleBox["q", "TI"], "2"], "+", 
               SuperscriptBox[
                OverscriptBox[
                 StyleBox["k", "TI"], "~"], "2"], "-", "2", 
               StyleBox["q", "TI"], 
               OverscriptBox[
                StyleBox["k", "TI"], "~"], "cos", "\[Theta]"}]]}]], 
         FractionBox[
          RowBox[{"|", 
            SubscriptBox[
             StyleBox["M", "TI"], 
             StyleBox["J", "TI"]], 
            RowBox[{"[", 
              RowBox[{
                StyleBox["M", "TI"], ",", 
                SubscriptBox[
                 StyleBox["q", "TI"], "0"], ",", 
                StyleBox["q", "TI"], ",", "\[Theta]"}], "]"}], 
            SuperscriptBox["|", "2"]}], 
          TemplateBox[{
            RowBox[{
              SuperscriptBox[
               StyleBox["f", "TI"], "\[Prime]"], 
              RowBox[{"(", 
                OverscriptBox[
                 StyleBox["k", "TI"], "~"], ")"}]}]}, "Abs"]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "F_J(M,q,q_0,\\theta) \\equiv \\frac{\\tilde{k}^2}{\\sqrt{M^2 + \
\\tilde{k}^2} \\sqrt{M^2 + q^2  + \\tilde{k}^2 -2q\\tilde{k}\\cos\\theta}} \
\\frac{\\qty|\\mathcal{M}_J \\qty[M,q_0,q,\\theta]|^2}{|f'(\\tilde{k})|}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d262b6a8-a250-9e4d-9218-8f573871736f"],
 "  "
}], "Subtitle",
