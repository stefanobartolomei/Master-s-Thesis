Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           StyleBox["k", "TI"], ")"}], "\[LongEqual]", 
         SqrtBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["M", "TI"], "2"], "+", 
            SuperscriptBox[
             StyleBox["k", "TI"], "2"]}]], "+", 
         SqrtBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["M", "TI"], "2"], "+", 
            SuperscriptBox[
             StyleBox["k", "TI"], "2"], "+", 
            SuperscriptBox[
             StyleBox["q", "TI"], "2"], "-", "2", 
            StyleBox["q", "TI"], 
            StyleBox["k", "TI"], "cos", "\[Theta]"}]], "-", 
         SubscriptBox[
          StyleBox["q", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "f(k) =\\sqrt{M^2 + k^2} + \\sqrt{M^2 + k^2 + q^2 -2qk\\cos\\theta} - \
q_0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "32ff7283-cf1e-764a-8eff-7ce3ba8d73ad"]
}], "Subsubsection",
