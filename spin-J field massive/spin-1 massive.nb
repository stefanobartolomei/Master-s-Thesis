Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Epsilon]Plus\[Omega]", " ", "=", " ", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"{", "0", "}"}], ",", "\[Epsilon]Plusz"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Epsilon]Minus\[Omega]", " ", "=", " ", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"{", "0", "}"}], ",", "\[Epsilon]Minusz"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Epsilon]Zero\[Omega]", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Norm", "[", "\[Omega]", "]"}], "/", "M"}], "}"}], ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{"M", "^", "2"}], " ", "+", " ", 
             RowBox[{
              RowBox[{"Norm", "[", "\[Omega]", "]"}], "^", "2"}]}], "]"}], "/",
            "M"}], ")"}], "\[Epsilon]Zeroz"}]}], "]"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"omega", ">", "0"}], ",", 
         RowBox[{"M", ">", "0"}]}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Epsilon]PlusK", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", "0", "}"}], ",", 
       RowBox[{"R", ".", "\[Epsilon]Plusz"}]}], "]"}], ",", " ", 
     RowBox[{"Assumptions", "->", "assump\[Theta]\[Phi]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Epsilon]MinusK", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", "0", "}"}], ",", 
       RowBox[{"R", ".", "\[Epsilon]Minusz"}]}], "]"}], ",", " ", 
     RowBox[{"Assumptions", "->", "assump\[Theta]\[Phi]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Epsilon]ZeroK", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Norm", "[", "K", "]"}], "/", "M"}], "}"}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"M", "^", "2"}], " ", "+", " ", 
            RowBox[{
             RowBox[{"Norm", "[", "K", "]"}], "^", "2"}]}], "]"}], "/", "M"}],
          ")"}], "*", 
        RowBox[{"R", ".", "\[Epsilon]Zeroz"}]}]}], "]"}], ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"0", "<", "\[Theta]", "<", "\[Pi]"}], ",", 
        RowBox[{"0", "<", "\[Phi]", "<", 
         RowBox[{"2", "\[Pi]"}]}], ",", 
        RowBox[{"M", ">", "0"}], ",", 
        RowBox[{"k", ">", "0"}]}], "}"}]}]}], "]"}]}], ";"}]}], "Input",
