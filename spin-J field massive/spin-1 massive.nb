Cell[CellGroupData[{

Cell[TextData[{
 "Polarization vectors for spin-1 particles ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"{", 
           RowBox[{
             SubsuperscriptBox["\[Epsilon]", 
              OverscriptBox["\[Omega]", "\[RightVector]"], "\[PlusMinus]"], 
             " ", ", ", 
             SubsuperscriptBox["\[Epsilon]", 
              OverscriptBox["\[Omega]", "\[RightVector]"], "0"]}], "}"}], " ",
          ",", 
         RowBox[{"{", 
           RowBox[{
             SubsuperscriptBox["\[Epsilon]", 
              OverscriptBox[
               StyleBox["k", "TI"], "\[RightVector]"], "\[PlusMinus]"], " ", 
             ", ", 
             SubsuperscriptBox["\[Epsilon]", 
              OverscriptBox[
               StyleBox["k", "TI"], "\[RightVector]"], "0"]}], "}"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\{\\epsilon^\\pm_{\\vec{\\omega}} \\ , \\  \
\\epsilon^0_{\\vec{\\omega}} \\} \\ , \\{\\epsilon^\\pm_{\\vec{k}} \\ , \\ \
\\epsilon^0_{\\vec{k}} \\}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "13452fab-9756-4c85-ba44-d5a4fcd717bb"]
}], "Subtitle",
