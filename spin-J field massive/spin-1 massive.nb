Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Funz", "[", "Amplitude_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"fk", ",", "ResultF"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"fk", " ", "=", 
       RowBox[{
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"M", "^", "2"}], " ", "+", " ", 
          RowBox[{"k", "^", "2"}]}], "]"}], " ", "+", " ", 
        RowBox[{"Sqrt", "[", 
