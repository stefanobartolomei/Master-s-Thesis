Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Ccoeff", "[", 
    RowBox[{"\[Epsilon]q_", ",", "\[Epsilon]\[Omega]_", ",", "\[Epsilon]K_"}],
     "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "vec\[Epsilon]\[Omega]", ",", "vec\[Epsilon]K", ",", "C", ",", 
       "ResultC"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"vec\[Epsilon]\[Omega]", " ", "=", 
