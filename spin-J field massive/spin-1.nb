           SuperscriptBox["\[Lambda]\[Lambda]", "\[Prime]"]}]], 
        "\[LongEqual]", "-", 
        RowBox[{"(", 
          RowBox[{
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{"\[Lambda]", "*"}]], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{
               SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}], 
        RowBox[{"(", 
          RowBox[{
            SuperscriptBox[
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             StyleBox["T", "TI"]], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["q", "TI"], "\[RightVector]"], "\[PlusMinus]"], 
            "\[CenterDot]", 
            OverscriptBox[
             StyleBox["k", "TI"], "\[RightVector]"]}], ")"}], "+", 
        RowBox[{"(", 
          RowBox[{
            StyleBox["k", "TI"], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{"\[Lambda]", "*"}]]}], ")"}], 
        RowBox[{"(", 
          RowBox[{
            SuperscriptBox[
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             StyleBox["T", "TI"]], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["q", "TI"], "\[RightVector]"], "\[PlusMinus]"], 
            "\[CenterDot]", 
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{" ", 
               SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}], "+", 
        RowBox[{"(", 
          RowBox[{"\[Omega]", "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{
               SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}], 
        RowBox[{"(", 
          RowBox[{
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{" ", "\[Lambda]", "*", 
               StyleBox["T", "TI"]}]], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["q", "TI"], "\[RightVector]"], "\[PlusMinus]"], 
            "\[CenterDot]", 
            OverscriptBox[
             StyleBox["k", "TI"], "\[RightVector]"]}], ")"}], "-", 
        RowBox[{"(", 
          RowBox[{"\[Omega]", "\[CenterDot]", 
            StyleBox["k", "TI"]}], ")"}], 
        RowBox[{"(", 
          RowBox[{
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{" ", "\[Lambda]", "*", 
               StyleBox["T", "TI"]}]], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["q", "TI"], "\[RightVector]"], "\[PlusMinus]"], 
            "\[CenterDot]", 
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{" ", 
               SuperscriptBox["\[Lambda]", "\[Prime]"], "*", 
               StyleBox["T", "TI"]}]]}], ")"}], "-", 
        SuperscriptBox[
         StyleBox["M", "TI"], "2"], 
        RowBox[{"(", 
          RowBox[{
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{" ", "\[Lambda]", "*", 
               StyleBox["T", "TI"]}]], "\[CenterDot]", 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["q", "TI"], "\[RightVector]"], "\[PlusMinus]"], 
            "\[CenterDot]", 
            SubsuperscriptBox[
             OverscriptBox["\[Epsilon]", "\[RightVector]"], 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{" ", 
               SuperscriptBox["\[Lambda]", "\[Prime]"], "*", 
               StyleBox["T", "TI"]}]]}], ")"}]}], TraditionalForm], 
    "errors" -> {}, "input" -> 
    "C_1^{\\pm,\\lambda \\lambda'} = \
-\\qty(\\epsilon^{\\lambda*}_{\\vec{\\omega}} \\cdot \\epsilon^{\\lambda'*}_{\
\\vec{k}}) \\qty(\\vec{\\omega}^T \\cdot \\epsilon^\\pm_{\\vec{q}} \\cdot \
\\vec{k})  + \\qty(k \\cdot \
\\epsilon^{\\lambda*}_{\\vec{\\omega}})\\qty(\\vec{\\omega}^T \\cdot \
\\epsilon^\\pm_{\\vec{q}} \\cdot \\vec{\\epsilon}^{\\ \\lambda'*}_{\\vec{k}}) \
+\\qty(\\omega \\cdot \\epsilon^{\\lambda'*}_{\\vec{k}}) \\qty( \
\\vec{\\epsilon}^{ \\ \\lambda * T}_{\\vec{\\omega}} \\cdot \
\\epsilon^\\pm_{\\vec{q}} \\cdot \\vec{k}) - \\qty(\\omega \\cdot \
k)\\qty(\\vec{\\epsilon}^{\\ \\lambda * T}_{\\vec{\\omega}} \\cdot \\epsilon^\
\\pm_{\\vec{q}} \\cdot \\vec{\\epsilon}^{ \\ \\lambda' *T }_{\\vec{k}}) - M^2 \
\\qty(\\vec{\\epsilon}^{\\ \\lambda * T}_{\\vec{\\omega}} \\cdot \
\\epsilon^\\pm_{\\vec{q}} \\cdot \\vec{\\epsilon}^{ \\ \\lambda' *T \
}_{\\vec{k}})", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"dec8bcd2-003b-4758-9f41-72160da7037b"]], \
