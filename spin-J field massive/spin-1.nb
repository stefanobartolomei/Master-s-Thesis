\\lambda'*}_{\\vec{k}}) + \\qty(\\vec{\\epsilon}^{\\ \\pm}_{\\vec{q}} \\cdot \
\\vec{\\epsilon}^{\\ \\lambda*}_{\\vec{\\omega}}) \\qty(\\vec{q} \\cdot \
\\vec{\\epsilon}^{\\ \\lambda'*}_{\\vec{k}})\\Big] +\\\\\n\t&& - M^2 \
