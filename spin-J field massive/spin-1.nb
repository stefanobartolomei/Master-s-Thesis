          RowBox[{"[", "4", "]"}], "]"}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"vec\[Epsilon]K", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Epsilon]K", "[", 
