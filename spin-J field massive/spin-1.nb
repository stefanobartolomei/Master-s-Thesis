Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubsuperscriptBox[
         StyleBox["B", "TI"], "1", 
         RowBox[{"\[Lambda]", ",", 
           SuperscriptBox["\[Lambda]", "\[Prime]"]}]], "\[LongEqual]", 
        SubscriptBox["\[Delta]", "\[Mu]\[Nu]"], 
        RowBox[{"[", 
          RowBox[{"-", 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox["\[Epsilon]", 
                 OverscriptBox["\[Omega]", "\[RightVector]"], 
                 RowBox[{"\[Lambda]", "*"}]], "\[CenterDot]", 
                SubsuperscriptBox["\[Epsilon]", 
                 OverscriptBox[
                  StyleBox["k", "TI"], "\[RightVector]"], 
                 RowBox[{
                   SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}], 
            SuperscriptBox["\[Omega]", "\[Mu]"], 
            SuperscriptBox[
             StyleBox["k", "TI"], "\[Nu]"], "+", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["k", "TI"], "\[CenterDot]", 
                SubsuperscriptBox["\[Epsilon]", 
                 OverscriptBox["\[Omega]", "\[RightVector]"], 
                 RowBox[{"\[Lambda]", "*"}]]}], ")"}], 
            SuperscriptBox["\[Omega]", "\[Mu]"], 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{
               SuperscriptBox["\[Lambda]", "\[Prime]"], "\[Nu]", "*"}]], "+", 
            RowBox[{"(", 
              RowBox[{"\[Omega]", "\[CenterDot]", 
                SubsuperscriptBox["\[Epsilon]", 
                 OverscriptBox[
                  StyleBox["k", "TI"], "\[RightVector]"], 
                 RowBox[{
                   SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}], 
            SuperscriptBox[
             StyleBox["k", "TI"], "\[Nu]"], 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{"\[Lambda]\[Mu]", "*"}]], "-", 
            RowBox[{"(", 
              RowBox[{"\[Omega]", "\[CenterDot]", 
                StyleBox["k", "TI"]}], ")"}], 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{"\[Lambda]\[Mu]", "*"}]], 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{
               SuperscriptBox["\[Lambda]", "\[Prime]"], "\[Nu]", "*"}]], "+", 
            "\n", "        ", "-", 
            FractionBox["1", "2"], 
            SuperscriptBox["\[Eta]", "\[Mu]\[Nu]"], 
            RowBox[{"(", 
              RowBox[{"\[Omega]", "\[CenterDot]", 
                SubsuperscriptBox["\[Epsilon]", 
                 OverscriptBox[
                  StyleBox["k", "TI"], "\[RightVector]"], 
                 RowBox[{
                   SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}], 
            RowBox[{"(", 
              RowBox[{
                StyleBox["k", "TI"], "\[CenterDot]", 
                SubsuperscriptBox["\[Epsilon]", 
                 OverscriptBox["\[Omega]", "\[RightVector]"], 
                 RowBox[{"\[Lambda]", "*"}]]}], ")"}], "+", 
            FractionBox["1", "2"], 
            SuperscriptBox["\[Eta]", "\[Mu]\[Nu]"], 
            RowBox[{"(", 
              RowBox[{"\[Omega]", "\[CenterDot]", 
                StyleBox["k", "TI"]}], ")"}], 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox["\[Epsilon]", 
                 OverscriptBox["\[Omega]", "\[RightVector]"], 
                 RowBox[{"\[Lambda]", "*"}]], "\[CenterDot]", 
                SubsuperscriptBox["\[Epsilon]", 
                 OverscriptBox[
                  StyleBox["k", "TI"], "\[RightVector]"], 
                 RowBox[{
                   SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}], 
            "-", 
            SuperscriptBox[
             StyleBox["M", "TI"], "2"], 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox["\[Omega]", "\[RightVector]"], 
             RowBox[{"\[Lambda]\[Mu]", "*"}]], 
            SubsuperscriptBox["\[Epsilon]", 
             OverscriptBox[
              StyleBox["k", "TI"], "\[RightVector]"], 
             RowBox[{
               SuperscriptBox["\[Lambda]", "\[Prime]"], "\[Nu]", "*"}]], "+", 
            FractionBox["1", "2"], 
            SuperscriptBox["\[Eta]", "\[Mu]\[Nu]"], 
            SuperscriptBox[
             StyleBox["M", "TI"], "2"], 
            RowBox[{"(", 
              RowBox[{
                SubsuperscriptBox["\[Epsilon]", 
                 OverscriptBox["\[Omega]", "\[RightVector]"], 
                 RowBox[{"\[Lambda]", "*"}]], "\[CenterDot]", 
                SubsuperscriptBox["\[Epsilon]", 
                 OverscriptBox[
                  StyleBox["k", "TI"], "\[RightVector]"], 
                 RowBox[{
                   SuperscriptBox["\[Lambda]", "\[Prime]"], "*"}]]}], ")"}]}],
           "]"}]}], TraditionalForm], "errors" -> {}, "input" -> 
    "B_1^{\\lambda, \\lambda'} =  \\delta_{\\mu \\nu}\\qty[-\\qty(\\epsilon^{\
\\lambda*}_{\\vec{\\omega}} \\cdot \\epsilon^{\\lambda'*}_{\\vec{k}}) \
\\omega^\\mu k^\\nu + \\qty(k \\cdot \\epsilon^{\\lambda*}_{\\vec{\\omega}}) \
\\omega^\\mu\\epsilon^{\\lambda' \\nu*}_{\\vec{k}} +\\qty(\\omega \\cdot \
\\epsilon^{\\lambda'*}_{\\vec{k}}) k^\\nu \\epsilon^{\\lambda \
\\mu*}_{\\vec{\\omega}} - \\qty(\\omega \\cdot k)\\epsilon^{\\lambda \\mu*}_{\
\\vec{\\omega}}\\epsilon^{\\lambda' \\nu*}_{\\vec{k}} +\\\\\n\t&& \\qquad \
