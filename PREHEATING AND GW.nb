Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"\[Kappa]", ">", 
    RowBox[{
    "12", " ", "Equivalent", " ", "to", " ", "vacuum", " ", "evolution"}]}], 
   " ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"fase", " ", "del", " ", "vuoto", " ", "dinamico", " ", 
    RowBox[{
     RowBox[{"\[Theta]", "'"}], "[", "z", "]"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eq\[Theta]", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Theta]", "'"}], "[", "z", "]"}], "==", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"\[Omega]2", "[", 
        RowBox[{"z", ",", "k"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bc\[Theta]", "=", 
     RowBox[{
      RowBox[{"\[Theta]", "[", "zIn", "]"}], "==", "0"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sol\[Theta]", "=", 
     RowBox[{"ParametricNDSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"eq\[Theta]", ",", "bc\[Theta]"}], "}"}], ",", "\[Theta]", ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "zIn", ",", "zMax"}], "}"}], ",", 
       RowBox[{"{", "k", "}"}], ",", 
       RowBox[{"MaxSteps", "->", "Infinity"}], ",", 
       RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Theta]sol", "[", 
      RowBox[{"k_", ",", "z_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"sol\[Theta]", "[", "k", "]"}], "[", "z", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Vacuum", " ", "mode", " ", "function"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Chi]vac", "[", 
      RowBox[{"k_", ",", "z_"}], "]"}], ":=", 
     FractionBox[
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], "*", 
        RowBox[{"\[Theta]sol", "[", 
         RowBox[{"k", ",", "z"}], "]"}]}], "]"}], 
      RowBox[{"Sqrt", "[", 
       RowBox[{"2", "*", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"\[Omega]2", "[", 
          RowBox[{"z", ",", "k"}], "]"}], "]"}]}], "]"}]]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"plotdiff\[Chi]vacuum", " ", "=", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"\[Chi]vac", "[", 
           RowBox[{"12", ",", "z"}], "]"}], "]"}], "^", "2"}], ",", 
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"\[Chi]sol", "[", 
           RowBox[{"12", ",", "z"}], "]"}], "]"}], "^", "2"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", "zIn", ",", "zMax"}], "}"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", 
         RowBox[{"AbsoluteThickness", "[", "1.2", "]"}]}], "]"}]}], ",", 
      RowBox[{"FrameTicksStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", 
         RowBox[{"FontFamily", "->", "\"\<Times\>\""}], ",", 
         RowBox[{"FontSize", "->", "14"}]}], "]"}]}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"Style", "[", 
              
              RowBox[{"\"\<z = \!\(\*SubscriptBox[\(m\), \(\[Phi]\)]\)t\>\"", 
               ",", "\"\<Times\>\""}], "]"}], "}"}], "]"}], ",", "15", 
           ",", "\"\<Times\>\""}], "]"}], ",", 
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"Style", "[", 
              
              RowBox[{"\"\<|\!\(\*SubscriptBox[\(\[Chi]\), \
\(k\)]\)(z)\!\(\*SuperscriptBox[\(|\), \(2\)]\)\>\"", ",", "\"\<Times\>\""}], 
              "]"}], "}"}], "]"}], ",", "15", ",", "\"\<Times\>\""}], "]"}]}],
         "}"}]}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Red", ",", "Thick"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Dashed", ",", 
           RowBox[{"Darker", "[", "Blue", "]"}]}], "}"}]}], "}"}]}]}], 
     "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"plotRe\[Chi]vacuum", " ", "=", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Re", "[", 
         RowBox[{"\[Chi]vac", "[", 
          RowBox[{"12", ",", "z"}], "]"}], "]"}], ",", 
        RowBox[{"Re", "[", 
         RowBox[{"\[Chi]sol", "[", 
          RowBox[{"12", ",", "z"}], "]"}], "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", "zIn", ",", "zMax"}], "}"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", 
         RowBox[{"AbsoluteThickness", "[", "1.2", "]"}]}], "]"}]}], ",", 
      RowBox[{"FrameTicksStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", 
         RowBox[{"FontFamily", "->", "\"\<Times\>\""}], ",", 
         RowBox[{"FontSize", "->", "14"}]}], "]"}]}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"Style", "[", 
              
              RowBox[{"\"\<z = \!\(\*SubscriptBox[\(m\), \(\[Phi]\)]\)t\>\"", 
