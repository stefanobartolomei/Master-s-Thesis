Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", "Funzioni", " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"qVec", "[", 
      RowBox[{"k_", ",", "p_", ",", "x_"}], "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"k", "^", "2"}], "+", 
       RowBox[{"p", "^", "2"}], "-", 
       RowBox[{"2", "*", "k", "*", "p", "*", "x"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"kCutoff", " ", "=", " ", 
     RowBox[{
      RowBox[{"Round", "[", 
       RowBox[{
        RowBox[{"qeff", "[", 
         RowBox[{"zIn", "-", "bpar"}], "]"}], "^", 
        RowBox[{"(", 
         RowBox[{"1", "/", "4"}], ")"}]}], "]"}], "+", "1"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"<", " ", "kMaxGrid"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"select\[Chi]grid", "[", 
      RowBox[{"k_", ",", "z_"}], "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"k", "<=", "kMinGrid"}], "||", 
        RowBox[{"k", ">=", "kCutoff"}]}], ",", "0.0", ",", 
       RowBox[{"\[Chi]grid", "[", 
        RowBox[{"k", ",", "z"}], "]"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"AbsIAdimSquared", "[", 
      RowBox[{
       RowBox[{"xq0_", "?", "NumericQ"}], ",", 
       RowBox[{"xq_", "?", "NumericQ"}], ",", 
       RowBox[{"xp_", "?", "NumericQ"}], ",", 
       RowBox[{"x_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "xqp", ",", "chiValsP", ",", "chiValsQp", ",", "productField", ",", 
         "fourierPhase", ",", "dotProduct"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"xqp", "=", 
         RowBox[{"qVec", "[", 
          RowBox[{"xq", ",", "xp", ",", "x"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"xp", ">=", "kCutoff"}], "||", 
             RowBox[{"xqp", ">=", "kCutoff"}]}], ",", 
            RowBox[{"Return", "[", "0.0", "]"}]}], "]"}], ";"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"xp", "<=", "kMinGrid"}], "||", 
           RowBox[{"xp", ">=", "kCutoff"}], "||", 
           RowBox[{"xqp", "<=", "kMinGrid"}], "||", 
           RowBox[{"xqp", ">=", "kCutoff"}]}], ",", 
          RowBox[{"Return", "[", "0", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"Quiet", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"chiValsP", "=", 
           RowBox[{"Map", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"select\[Chi]grid", "[", 
               RowBox[{"xp", ",", "#"}], "]"}], "&"}], ",", "zVals"}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"chiValsQp", "=", 
           RowBox[{"Map", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"select\[Chi]grid", "[", 
               RowBox[{"xqp", ",", "#"}], "]"}], "&"}], ",", "zVals"}], 
            "]"}]}], ";"}], "\[IndentingNewLine]", "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"productField", "=", 
         RowBox[{"chiValsP", "*", "chiValsQp"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"fourierPhase", "=", 
         RowBox[{"Exp", "[", 
          RowBox[{"I", "*", "xq0", "*", "zVals"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"dotProduct", "=", 
         RowBox[{
          RowBox[{"fourierPhase", ".", "productField"}], "*", "dz"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        SuperscriptBox[
         RowBox[{"Abs", "[", "dotProduct", "]"}], "2"]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"P\[CapitalPi]Adim", "[", 
      RowBox[{
       RowBox[{"xq0_", "?", "NumericQ"}], ",", 
       RowBox[{"xq_", "?", "NumericQ"}], ",", 
       RowBox[{"xpSteps_Integer", ":", "50"}], ",", 
       RowBox[{"xSteps_Integer", ":", "20"}]}], "]"}], ":=", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "xpMax", ",", "dxp", ",", "dx", ",", "xpGrid", ",", "xGrid", ",", 
         "sumVal"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"xpMax", "=", "kCutoff"}], ";", "\[IndentingNewLine]", 
        RowBox[{"dxp", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"xpMax", "-", "0.1"}], ")"}], "/", "xpSteps"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"dx", "=", 
         RowBox[{"2.0", "/", "xSteps"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"xpGrid", "=", 
         RowBox[{"Range", "[", 
          RowBox[{"0.1", ",", "xpMax", ",", "dxp"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"xGrid", "=", 
         RowBox[{"Range", "[", 
          RowBox[{
           RowBox[{"-", "1.0"}], ",", "1.0", ",", "dx"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"Quiet", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"sumVal", "=", 
           RowBox[{"ParallelSum", "[", 
            RowBox[{
             RowBox[{
              SuperscriptBox["xp", "6"], 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{"1", "-", 
                 SuperscriptBox["x", "2"]}], ")"}], "2"], "  ", 
              RowBox[{"AbsIAdimSquared", "[", 
               RowBox[{"xq0", ",", "xq", ",", "xp", ",", "x"}], "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"xp", ",", "xpGrid"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"x", ",", "xGrid"}], "}"}]}], "]"}]}], ";"}], 
         "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{
         FractionBox["1", 
          RowBox[{"4", " ", 
           SuperscriptBox["\[Pi]", "2"]}]], " ", "sumVal", "*", "dxp", "*", 
         "dx"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"P\[CapitalPi]toPlot", "[", 
      RowBox[{
       RowBox[{"xq0_", "?", "NumericQ"}], ",", 
       RowBox[{"xq_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{
      SuperscriptBox["xq", "3"], " ", 
      RowBox[{"P\[CapitalPi]Adim", "[", 
       RowBox[{"xq0", ",", "xq"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalDelta]hadim", "[", 
      RowBox[{
       RowBox[{"xq0_", "?", "NumericQ"}], ",", 
       RowBox[{"xq_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", "pAdimVal", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"pAdimVal", "=", 
         RowBox[{"P\[CapitalPi]Adim", "[", 
          RowBox[{"xq0", ",", "xq"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         FractionBox["2", 
          SuperscriptBox["\[Pi]", "2"]], 
         FractionBox[
          SuperscriptBox["xq", "3"], 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox["xq0", "2"], " ", "-", " ", 
             SuperscriptBox["xq", "2"]}], ")"}], "2"]], "pAdimVal"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}]}]}]], "Input",
