Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Campo", " ", "fisico"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PS\[Chi]phy", "[", 
      RowBox[{"k_", ",", "z_"}], "]"}], ":=", "  ", 
     RowBox[{
      FractionBox[
       SuperscriptBox["k", "3"], 
       RowBox[{"2", 
        SuperscriptBox["\[Pi]", "2"]}]], 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"Abs", "[", 
          RowBox[{"\[Chi]sol", "[", 
           RowBox[{"k", ",", "z"}], "]"}], "]"}], "2"], "  ", "-", " ", 
        FractionBox["1", 
         RowBox[{"2", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"\[Omega]2", "[", 
            RowBox[{"z", ",", "k"}], "]"}], "]"}]}]]}], " ", ")"}]}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Chi]phySpectrum", "[", 
      RowBox[{"kList_List", ",", "z_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "currentK", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Monitor", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"currentK", "=", "k"}], ";", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"PS\[Chi]phy", "[", 
               RowBox[{"k", ",", "z"}], "]"}]}], "}"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "kList"}], "}"}]}], "]"}], ",", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           RowBox[{"\"\<Computation \[Chi] for k = \>\"", ",", "currentK"}], 
           "}"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PS\[Chi]", "[", 
      RowBox[{"k_", ",", "z_"}], "]"}], ":=", 
     RowBox[{
      FractionBox[
       SuperscriptBox["k", "3"], 
       RowBox[{"2", 
        SuperscriptBox["\[Pi]", "2"]}]], "  ", 
      SuperscriptBox[
       RowBox[{"Abs", "[", 
        RowBox[{"\[Chi]sol", "[", 
         RowBox[{"k", ",", "z"}], "]"}], "]"}], "2"]}]}], " ", ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Chi]Spectrum", "[", 
      RowBox[{"kList_List", ",", "z_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "currentK", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Monitor", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"currentK", "=", "k"}], ";", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"PS\[Chi]", "[", 
               RowBox[{"k", ",", "z"}], "]"}]}], "}"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "kList"}], "}"}]}], "]"}], ",", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           RowBox[{"\"\<Computation \[Chi] for k = \>\"", ",", "currentK"}], 
           "}"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], 
    ";"}]}]}]], "Input",
