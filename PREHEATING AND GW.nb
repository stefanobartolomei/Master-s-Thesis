Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Hubble", " ", 
    RowBox[{"factor", ":", " ", 
     RowBox[{"matter", " ", "era"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"H", "[", "z_", "]"}], ":=", 
     FractionBox["2", 
      RowBox[{"3", "z"}]]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Solution", " ", "Inflaton"}], " ", "*)"}], " ", "\n", 
   RowBox[{
    RowBox[{"eq\[Phi]", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"\[Phi]", "''"}], "[", "z", "]"}], "+", 
       RowBox[{"3", "*", 
        RowBox[{"H", "[", "z", "]"}], "*", 
        RowBox[{
         RowBox[{"\[Phi]", "'"}], "[", "z", "]"}]}], "+", 
       RowBox[{"\[Phi]", "[", "z", "]"}]}], "==", "0"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"\[Phi]In", "=", "2.32"}], ";"}], "                         ", 
   RowBox[{"(*", " ", 
    RowBox[{
    "in", " ", "units", " ", "of", " ", "reduced", " ", "Planck", " ", 
     "mass"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"d\[Phi]In", "=", 
     RowBox[{"-", "0.78"}]}], ";"}], "                    ", 
   RowBox[{"(*", " ", 
    RowBox[{
    "in", " ", "units", " ", "of", " ", "reduced", " ", "Planck", " ", 
     "mass"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bc\[Phi]", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Phi]", "[", "zIn", "]"}], "==", "\[Phi]In"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Phi]", "'"}], "[", "zIn", "]"}], "==", "d\[Phi]In"}]}], 
      "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol\[Phi]", "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"eq\[Phi]", ",", "bc\[Phi]"}], "}"}], ",", "\[Phi]", ",", 
        "z"}], "]"}], "//", "FullSimplify"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", "Plots", " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"\[Phi]plot", " ", "=", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"sol\[Phi]", "[", "z", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", "zIn", ",", "zMax"}], "}"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", 
         RowBox[{"AbsoluteThickness", "[", "1.2", "]"}]}], "]"}]}], ",", 
      RowBox[{"FrameTicksStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", 
         RowBox[{"FontFamily", "->", "\"\<Times\>\""}], ",", 
         RowBox[{"FontSize", "->", "14"}]}], "]"}]}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"Style", "[", 
              
              RowBox[{"\"\<z = \!\(\*SubscriptBox[\(m\), \(\[Phi]\)]\)t\>\"", 
               ",", "\"\<Times\>\""}], "]"}], "}"}], "]"}], ",", "15", 
           ",", "\"\<Times\>\""}], "]"}], ",", 
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"Style", "[", 
              RowBox[{"\"\<\[Phi](z)\>\"", ",", "\"\<Times\>\""}], "]"}], 
             "}"}], "]"}], ",", "15", ",", "\"\<Times\>\""}], "]"}]}], 
        "}"}]}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"Blue", ",", "Thick"}], "}"}]}]}], "]"}]}]}]}]], "Input",
