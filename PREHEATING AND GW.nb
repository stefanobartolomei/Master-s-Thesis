  3.9909287965463657`*^9}},ExpressionUUID->"89c7de08-e78e-6d4b-8a11-\
146653105251"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"kMinGrid", "=", "0.01"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kMaxGrid", "=", 
     RowBox[{"2", "*", 
      RowBox[{"q", "^", 
       RowBox[{"(", 
        RowBox[{"1", "/", "4"}], ")"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dk", "=", "0.1"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", "Griglia", " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"nzpoints", "=", "500"}], ";"}], " ", "\n", 
   RowBox[{
    RowBox[{"dz", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"zMax", "-", "zIn"}], ")"}], "/", "nzpoints"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"zVals", "=", 
     RowBox[{"Range", "[", 
      RowBox[{"zIn", ",", "zMax", ",", "dz"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Chi]phys", "[", 
      RowBox[{"k_", ",", "z_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"\[Chi]sol", "[", 
       RowBox[{"k", ",", "z"}], "]"}], "-", 
      RowBox[{"\[Chi]vac", "[", 
       RowBox[{"k", ",", "z"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gridData", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"kV", ",", "zV"}], "}"}], ",", 
             RowBox[{"\[Chi]phys", "[", 
              RowBox[{"kV", ",", "zV"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"zV", ",", "zVals"}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"kV", ",", "kMinGrid", ",", "kMaxGrid", ",", "dk"}], 
          "}"}]}], "]"}], ",", "1"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"\[Chi]grid", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{"gridData", ",", 
       RowBox[{"InterpolationOrder", "->", "3"}]}], "]"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.990941158190777*^9, 3.990941330129837*^9}, {
   3.990941365827299*^9, 3.990941575791033*^9}, {3.990941692941105*^9, 
   3.990941744496149*^9}, {3.9909418450900764`*^9, 3.990941856735468*^9}, {
   3.990942053359453*^9, 3.9909421590667915`*^9}, {3.9909506409726048`*^9, 
   3.990950644732174*^9}, {3.9909510470932636`*^9, 3.990951052129116*^9}, {
   3.9909540961435738`*^9, 3.9909541636845703`*^9}, 3.9909544848040867`*^9, {
   3.9909563457929363`*^9, 3.990956354975609*^9}, {3.990957962978876*^9, 
   3.990957979728306*^9}, {3.990958502121805*^9, 3.990958515200302*^9}, {
   3.9909587925737343`*^9, 3.990958799369972*^9}, {3.990970262901737*^9, 
   3.990970288083788*^9}, 3.990970680570278*^9, {3.9910247999951324`*^9, 
   3.9910248060217743`*^9}, {3.991027859345148*^9, 3.9910278700919895`*^9}, {
   3.9910283209116344`*^9, 3.991028321709587*^9}, 3.991041398872965*^9, {
   3.9910454374819546`*^9, 3.991045457838665*^9}, {3.99104561999798*^9, 
   3.991045623184925*^9}, {3.9912822806036263`*^9, 3.991282292916893*^9}, 
   3.9912853717331963`*^9, {3.9916292069722004`*^9, 3.9916292259811535`*^9}, {
