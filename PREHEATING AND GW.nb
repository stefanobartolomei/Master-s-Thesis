Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "q", " ", "effective", " ", "in", " ", "expanding", " ", "universe"}], " ",
    "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"qeff", "[", "z_", "]"}], ":=", 
     RowBox[{
      RowBox[{"q", "*", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"a", "/", 
           RowBox[{"(", 
            RowBox[{"z", "+", "b"}], ")"}]}], "\[Phi]In"], ")"}], "2"]}], " ",
       "/.", " ", "fitParams"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bpar", " ", "=", " ", 
     RowBox[{"b", "/.", 
      RowBox[{"fitParams", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Plot", " ", "q", " ", "effective"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"qPlot", " ", "=", " ", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"qeff", "[", 
         RowBox[{"z", "-", "bpar"}], "]"}], ",", 
        RowBox[{"q", "*", 
         RowBox[{"(", 
          RowBox[{"z", "^", 
           RowBox[{"-", "2"}]}], ")"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", "zIn", ",", "zMax"}], "}"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"AxesLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<z = \!\(\*SubscriptBox[\(m\), \(\[Phi]\)]\)t [adim]\>\"",
          ",", "\"\<q(z)\>\""}], "}"}]}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Thick", ",", "Blue"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Dashed", ",", "Red"}], "}"}]}], "}"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Apar", "[", 
      RowBox[{"z_", ",", "k_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"k", "^", "2"}], " ", "+", " ", 
      RowBox[{"2", 
       RowBox[{"qeff", "[", "z", "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]Mathieu", "[", 
      RowBox[{"z_", ",", "k_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"Apar", "[", 
       RowBox[{"z", ",", "k"}], "]"}], "+", " ", 
      RowBox[{"2", 
       RowBox[{"qeff", "[", "z", "]"}], 
       RowBox[{"Cos", "[", 
        RowBox[{"2", "z"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]2", "[", 
      RowBox[{"z_", ",", "k_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"k", "^", "2"}], "+", 
      RowBox[{"4", "*", "q", "*", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"sol\[Phi]", "[", "z", "]"}], "\[Phi]In"], ")"}], 
        "2"]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Plot", " ", "equivalence"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Omega]Plot1", " ", "=", " ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"\[Omega]Mathieu", "[", 
        RowBox[{
         RowBox[{"z", "-", "bpar"}], ",", "5"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "zIn", ",", "zMax"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Dashed", ",", "Red"}], "}"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Omega]2Plot", " ", "=", " ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"\[Omega]2", "[", 
        RowBox[{"z", ",", "5"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "zIn", ",", "zMax"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", "Blue", "}"}]}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<z = \!\(\*SubscriptBox[\(m\), \(\[Phi]\)]\)t [adim]\>\"",
           ",", "\"\<\[Omega](\[Kappa],z)\>\""}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"Style", "[", 
         RowBox[{"StringForm", "[", 
          
          RowBox[{"\"\<Frequency \!\(\*SubscriptBox[\(\[Omega]\), \(k\)]\)(z) \
for k = ``\>\"", ",", "5"}], "]"}], "]"}]}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Blue", ",", "Thick"}], "}"}]}], ",", 
       RowBox[{"GridLines", "->", "Automatic"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{"{", 
     RowBox[{"\[Omega]2Plot", ",", "\[Omega]Plot1"}], "}"}], 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.990420627297159*^9, 3.9904206692795105`*^9}, {
