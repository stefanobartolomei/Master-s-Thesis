Cell[CellGroupData[{

Cell["Daughter dynamic", "Chapter",
 CellChangeTimes->{{3.98626417586549*^9, 
  3.986264204808403*^9}},ExpressionUUID->"1a671c83-a09a-3143-a514-\
a08ddf6813d6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Solution", " ", "Spectator"}], " ", "*)"}], " ", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"eq\[Chi]", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "''"}], "[", "z", "]"}], "+", 
       RowBox[{
        RowBox[{"\[Omega]2", "[", 
         RowBox[{"z", ",", "k"}], "]"}], "*", 
        RowBox[{"\[Chi]", "[", "z", "]"}]}]}], "==", "0"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bc\[Chi]", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Chi]", "[", "zIn", "]"}], "==", 
        FractionBox["1", 
         SqrtBox[
          RowBox[{"2", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"\[Omega]2", "[", 
             RowBox[{"zIn", ",", "k"}], "]"}], "]"}]}]]]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Chi]", "'"}], "[", "zIn", "]"}], "==", 
        RowBox[{
         RowBox[{"-", "I"}], 
         SqrtBox[
          FractionBox[
           RowBox[{"Sqrt", "[", 
            RowBox[{"\[Omega]2", "[", 
             RowBox[{"zIn", ",", "k"}], "]"}], "]"}], "2"]]}]}]}], "}"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol\[Chi]", "=", 
     RowBox[{"ParametricNDSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"eq\[Chi]", ",", 
         RowBox[{"bc\[Chi]", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"bc\[Chi]", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", "\[Chi]", ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "zIn", ",", "zMax"}], "}"}], ",", 
       RowBox[{"{", "k", "}"}], ",", 
       RowBox[{"MaxSteps", "->", "Infinity"}], ",", 
       RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Chi]sol", "[", 
      RowBox[{"k_", ",", "z_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"sol\[Chi]", "[", "k", "]"}], "[", "z", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Number", " ", "density", " ", "spectator"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"number\[Chi]", "[", 
      RowBox[{"k_", ",", "z_"}], "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "\[Chi]solK", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\[Chi]solK", " ", "=", " ", 
         RowBox[{"sol\[Chi]", "[", "k", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         FractionBox[
          SuperscriptBox[
           RowBox[{"Abs", "[", 
            RowBox[{
             RowBox[{"\[Chi]solK", "'"}], "[", "z", "]"}], "]"}], "2"], 
          RowBox[{"2", "*", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"\[Omega]2", "[", 
             RowBox[{"z", ",", "k"}], "]"}], "]"}]}]], "+", 
         RowBox[{
          FractionBox[
           RowBox[{"Sqrt", "[", 
            RowBox[{"\[Omega]2", "[", 
             RowBox[{"z", ",", "k"}], "]"}], "]"}], "2"], 
          SuperscriptBox[
           RowBox[{"Abs", "[", 
            RowBox[{"\[Chi]solK", "[", "z", "]"}], "]"}], "2"]}], "-", 
         FractionBox["1", "2"]}]}]}], "\[IndentingNewLine]", "]"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.990361792640465*^9, 3.990361799715828*^9}, {
   3.9903618328956966`*^9, 3.990362229897236*^9}, {3.990362263043434*^9, 
